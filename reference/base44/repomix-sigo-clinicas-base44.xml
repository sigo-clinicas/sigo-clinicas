<file path="src/pages/LandingPage.jsx">
import React, { useState, useEffect } from 'react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Card, CardContent } from '@/components/ui/card';
import { Dialog, DialogContent, DialogHeader, DialogTitle } from '@/components/ui/dialog';
import { ArrowRight, CheckCircle2, Users, Calendar, Zap, Heart, Smile, LogIn, Building2, Stethoscope } from 'lucide-react';
import { base44 } from '@/api/base44Client';
import { useNavigate } from 'react-router-dom';

export default function LandingPage() {
  const navigate = useNavigate();
  const [footerForm, setFooterForm] = useState({ nome: '', whatsapp: '' });
  const [cupomModal, setCupomModal] = useState({ open: false, nome: '', telefone: '' });
  const [salaVIPModal, setSalaVIPModal] = useState({ open: false, step: 1, nome: '', telefone: '', email: '', cidade: '', especialidade: '', sala_vip_id: '' });
  const [loading, setLoading] = useState(false);
  const [selectedCupom, setSelectedCupom] = useState(null);
  const [profissionais, setProfissionais] = useState([]);
  const [servicos, setServicos] = useState([]);
  const [clinicas, setClinicas] = useState([]);
  const [salas, setSalas] = useState([]);
  const [cidades, setCidades] = useState([]);
  const [especialidades, setEspecialidades] = useState([]);

  useEffect(() => {
    base44.entities.Profissional.list().then(setProfissionais).catch(console.error);
    base44.entities.Servico.list().then(setServicos).catch(console.error);
    base44.entities.Clinica.list().then(c => {
      setClinicas(c);
      const uniqueCities = [...new Set(c.map(cl => cl.cidade).filter(Boolean))];
      setCidades(uniqueCities.sort());
    }).catch(console.error);
    base44.entities.SalaVIP.list().then(data => {
      setSalas(data);
    }).catch(console.error);
  }, []);

  const handleFooterSubmit = async (e) => {
    e.preventDefault();
    setLoading(true);
    try {
      await base44.integrations.Core.SendEmail({
        to: 'contato@sigoclinicas.com',
        subject: 'Novo Lead - Lista VIP',
        html: `<p>Nome: ${footerForm.nome}</p><p>WhatsApp: ${footerForm.whatsapp}</p>`,
      });
      setFooterForm({ nome: '', whatsapp: '' });
    } catch (error) {
      console.error('Erro ao enviar:', error);
    } finally {
      setLoading(false);
    }
  };

  const handleCupomClick = (cupom) => {
    setSelectedCupom(cupom);
    setCupomModal({ open: true, nome: '', telefone: '' });
  };

  const handleSalaVIPClick = () => {
    setSalaVIPModal({ open: true, step: 1, nome: '', telefone: '', email: '', cidade: '', especialidade: '', sala_vip_id: '' });
  };

  const getSalasDisponiveis = () => {
    let filtradas = salas.filter(s => s.status === 'aprovada' && s.clinica_cidade === salaVIPModal.cidade);
    if (salaVIPModal.especialidade) {
      const clinicasEspecialidade = clinicas.filter(c => c.tipo === salaVIPModal.especialidade && c.cidade === salaVIPModal.cidade);
      const clinicaIds = clinicasEspecialidade.map(c => c.id);
      filtradas = filtradas.filter(s => clinicaIds.includes(s.clinica_id));
    }
    return filtradas;
  };

  const handleSalaVIPNext = () => {
    if (salaVIPModal.step === 1) {
      if (!salaVIPModal.nome || !salaVIPModal.telefone) {
        alert('Nome e telefone são obrigatórios');
        return;
      }
      setSalaVIPModal({ ...salaVIPModal, step: 2 });
    } else if (salaVIPModal.step === 2) {
      if (!salaVIPModal.cidade) {

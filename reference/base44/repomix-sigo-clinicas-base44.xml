import { useEffect, useState, useMemo } from 'react';
import { base44 } from '@/api/base44Client';
import { format, eachDayOfInterval, startOfMonth, endOfMonth, addMonths, subMonths, startOfWeek, endOfWeek, startOfDay, endOfDay, parseISO } from 'date-fns';
import { ptBR } from 'date-fns/locale';
import { Plus, TrendingUp, TrendingDown, DollarSign, ChevronLeft, ChevronRight, Search, CheckCircle2 } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { BarChart, Bar, XAxis, YAxis, Tooltip, ResponsiveContainer, Legend, CartesianGrid } from 'recharts';
import LancamentoModal from '@/components/financeiro/LancamentoModal';
import PagamentoRapidoModal from '@/components/financeiro/PagamentoRapidoModal';

const statusColor = {
  pendente: 'bg-yellow-100 text-yellow-700',
  pago_parcial: 'bg-orange-100 text-orange-700',
  pago: 'bg-green-100 text-green-700',
  cancelado: 'bg-gray-100 text-gray-600',
  atrasado: 'bg-red-100 text-red-600',
};

const statusLabel = {
  pendente: 'Pendente',
  pago_parcial: 'Parcial',
  pago: 'Pago',
  cancelado: 'Cancelado',
  atrasado: 'Atrasado',
};

const fmt = v => new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v || 0);

export default function FluxoCaixa() {
  const [lancamentos, setLancamentos] = useState([]);
  const [loading, setLoading] = useState(true);
  const [mesBase, setMesBase] = useState(new Date());
  const [abaLista, setAbaLista] = useState('todos'); // 'todos' | 'receita' | 'despesa'
  const [filtroStatus, setFiltroStatus] = useState('aberto');
  const [busca, setBusca] = useState('');
  const [filtroPeriodo, setFiltroPeriodo] = useState('mes_atual');
  const [dataInicio, setDataInicio] = useState(format(startOfMonth(new Date()), 'yyyy-MM-dd'));
  const [dataFim, setDataFim] = useState(format(endOfMonth(new Date()), 'yyyy-MM-dd'));
  const [modalOpen, setModalOpen] = useState(false);
  const [selecionado, setSelecionado] = useState(null);
  const [pagamentoRapido, setPagamentoRapido] = useState(null);

  useEffect(() => { load(); }, []);

  async function load() {
    const l = await base44.entities.LancamentoFinanceiro.list('-data_vencimento', 500);
    setLancamentos(l);
    setLoading(false);
  }

  // Dados do gráfico
  const dadosGrafico = useMemo(() => {
    const inicio = startOfMonth(mesBase);
    const fim = endOfMonth(mesBase);
    const dias = eachDayOfInterval({ start: inicio, end: fim });
    return dias.map(dia => {
      const diaStr = format(dia, 'yyyy-MM-dd');
      const recebido = lancamentos
        .filter(l => l.tipo === 'receita' && (l.status === 'pago' || l.status === 'pago_parcial') && l.data_vencimento?.slice(0, 10) === diaStr)
        .reduce((s, l) => s + (l.valor_pago || (l.status === 'pago' ? l.valor : 0) || 0), 0);
      const pago = lancamentos
        .filter(l => l.tipo === 'despesa' && (l.status === 'pago' || l.status === 'pago_parcial') && l.data_vencimento?.slice(0, 10) === diaStr)
        .reduce((s, l) => s + (l.valor_pago || (l.status === 'pago' ? l.valor : 0) || 0), 0);
      return { dia: format(dia, 'dd'), Receitas: recebido, Despesas: pago };
    }).filter(d => d.Receitas > 0 || d.Despesas > 0);
  }, [lancamentos, mesBase]);

  // KPIs
  const totalReceita = lancamentos.filter(l => l.tipo === 'receita' && (l.status === 'pago' || l.status === 'pago_parcial'))
    .reduce((s, l) => s + (l.valor_pago || (l.status === 'pago' ? l.valor : 0) || 0), 0);
  const totalDespesa = lancamentos.filter(l => l.tipo === 'despesa' && (l.status === 'pago' || l.status === 'pago_parcial'))
    .reduce((s, l) => s + (l.valor_pago || (l.status === 'pago' ? l.valor : 0) || 0), 0);
  const saldo = totalReceita - totalDespesa;
  const totalPendenteReceber = lancamentos
    .filter(l => l.tipo === 'receita' && (l.status === 'pendente' || l.status === 'pago_parcial' || l.status === 'atrasado'))
    .reduce((s, l) => s + (l.saldo_em_aberto ?? l.valor ?? 0), 0);
  const totalPendentePagar = lancamentos
    .filter(l => l.tipo === 'despesa' && (l.status === 'pendente' || l.status === 'pago_parcial' || l.status === 'atrasado'))
    .reduce((s, l) => s + (l.saldo_em_aberto ?? l.valor ?? 0), 0);

  // KPIs do mês p/ gráfico
  const mesStr = format(mesBase, 'yyyy-MM');
  const receitaMes = lancamentos.filter(l => l.tipo === 'receita' && l.status === 'pago' && l.data_vencimento?.slice(0, 7) === mesStr).reduce((s, l) => s + (l.valor || 0), 0);
  const despesaMes = lancamentos.filter(l => l.tipo === 'despesa' && l.status === 'pago' && l.data_vencimento?.slice(0, 7) === mesStr).reduce((s, l) => s + (l.valor || 0), 0);
  const pendentesMes = lancamentos.filter(l => l.status === 'pendente' && l.data_vencimento?.slice(0, 7) === mesStr).reduce((s, l) => s + (l.valor || 0), 0);

  // Intervalo do filtro de período
  const { periodoInicio, periodoFim } = useMemo(() => {
    const hoje = new Date();
    if (filtroPeriodo === 'hoje') return { periodoInicio: startOfDay(hoje), periodoFim: endOfDay(hoje) };
    if (filtroPeriodo === 'semana') return { periodoInicio: startOfWeek(hoje, { locale: ptBR }), periodoFim: endOfWeek(hoje, { locale: ptBR }) };
    if (filtroPeriodo === 'mes_atual') return { periodoInicio: startOfMonth(hoje), periodoFim: endOfMonth(hoje) };
    if (filtroPeriodo === 'mes_anterior') { const ant = subMonths(hoje, 1); return { periodoInicio: startOfMonth(ant), periodoFim: endOfMonth(ant) }; }
    if (filtroPeriodo === 'personalizado') return { periodoInicio: dataInicio ? parseISO(dataInicio) : null, periodoFim: dataFim ? parseISO(dataFim) : null };
    return { periodoInicio: null, periodoFim: null };
  }, [filtroPeriodo, dataInicio, dataFim]);

  // Lista filtrada
  const filtrados = lancamentos.filter(l => {
    const tipoOk = abaLista === 'todos' || l.tipo === abaLista;
    const statusOk = filtroStatus === 'todos' || (filtroStatus === 'aberto' ? ['pendente', 'pago_parcial', 'atrasado'].includes(l.status) : l.status === filtroStatus);
    const buscaOk = !busca || l.descricao?.toLowerCase().includes(busca.toLowerCase()) || l.paciente_nome?.toLowerCase().includes(busca.toLowerCase());
    let periodoOk = true;
    if (periodoInicio && periodoFim && l.data_vencimento) {
      const d = parseISO(l.data_vencimento.slice(0, 10));
      periodoOk = d >= periodoInicio && d <= periodoFim;
    }
    return tipoOk && statusOk && buscaOk && periodoOk;
  });

  // Pode mostrar botão rápido se há saldo em aberto
  function podePagarRapido(l) {
    if (l.status === 'pago' || l.status === 'cancelado') return false;
    const valorJaPago = l.valor_pago || 0;
    const saldo = l.saldo_em_aberto ?? Math.max(0, (l.valor || 0) - valorJaPago);
    return saldo > 0.01;
  }

  function handlePagamentoRapido(e, l) {
    e.stopPropagation();
    setPagamentoRapido(l);
  }

  return (
    <div className="p-6 space-y-5">
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-semibold">Fluxo de Caixa</h1>
          <p className="text-sm text-muted-foreground mt-0.5">Visão consolidada de receitas, despesas e saldo</p>
        </div>
        <Button onClick={() => { setSelecionado(null); setModalOpen(true); }} className="gap-1.5">
          <Plus className="w-4 h-4" /> Novo Lançamento
        </Button>
      </div>

      {/* KPIs */}
      <div className="grid grid-cols-2 lg:grid-cols-4 gap-3">
        <div className="bg-card rounded-xl border border-border p-4 flex gap-3 items-center">
          <div className="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center shrink-0"><TrendingUp className="w-4 h-4 text-green-700" /></div>
          <div>
            <p className="text-xs text-muted-foreground font-semibold">Recebido</p>
            <p className="text-lg font-bold text-green-600">{fmt(totalReceita)}</p>
          </div>
        </div>
        <div className="bg-card rounded-xl border border-border p-4 flex gap-3 items-center">
          <div className="w-8 h-8 bg-red-100 rounded-lg flex items-center justify-center shrink-0"><TrendingDown className="w-4 h-4 text-red-600" /></div>
          <div>
            <p className="text-xs text-muted-foreground font-semibold">Pago</p>
            <p className="text-lg font-bold text-red-600">{fmt(totalDespesa)}</p>
          </div>
        </div>
        <div className="bg-card rounded-xl border border-border p-4 flex gap-3 items-center">
          <div className={`w-8 h-8 rounded-lg flex items-center justify-center shrink-0 ${saldo >= 0 ? 'bg-blue-100' : 'bg-orange-100'}`}>
            <DollarSign className={`w-4 h-4 ${saldo >= 0 ? 'text-blue-700' : 'text-orange-600'}`} />
          </div>
          <div>
            <p className="text-xs text-muted-foreground font-semibold">Saldo</p>
            <p className={`text-lg font-bold ${saldo >= 0 ? 'text-blue-700' : 'text-orange-600'}`}>{fmt(saldo)}</p>
          </div>
        </div>
        <div className="bg-card rounded-xl border border-border p-4 flex gap-3 items-center">
          <div className="w-8 h-8 bg-yellow-100 rounded-lg flex items-center justify-center shrink-0">
            <DollarSign className="w-4 h-4 text-yellow-600" />
          </div>
          <div>
            <p className="text-xs text-muted-foreground font-semibold">A Receber</p>
            <p className="text-lg font-bold text-yellow-600">{fmt(totalPendenteReceber)}</p>
            <p className="text-xs text-muted-foreground">A Pagar: {fmt(totalPendentePagar)}</p>
          </div>
        </div>
      </div>

      {/* Abas */}
      <Tabs defaultValue="todos" className="space-y-4">
        <TabsList>
          <TabsTrigger value="todos">Todos os Lançamentos</TabsTrigger>
          <TabsTrigger value="grafico">Gráfico Mensal</TabsTrigger>
        </TabsList>

        {/* ABA TODOS */}
        <TabsContent value="todos" className="space-y-3">
          {/* Sub-abas: Todos / A Receber / A Pagar */}
          <div className="flex rounded-lg border border-border overflow-hidden w-fit">
            <button onClick={() => setAbaLista('todos')} className={`px-5 py-2 text-sm font-medium transition-colors ${abaLista === 'todos' ? 'bg-primary text-primary-foreground' : 'bg-card hover:bg-muted'}`}>Todos</button>
            <button onClick={() => setAbaLista('receita')} className={`px-5 py-2 text-sm font-medium transition-colors ${abaLista === 'receita' ? 'bg-primary text-primary-foreground' : 'bg-card hover:bg-muted'}`}>A Receber</button>
            <button onClick={() => setAbaLista('despesa')} className={`px-5 py-2 text-sm font-medium transition-colors ${abaLista === 'despesa' ? 'bg-primary text-primary-foreground' : 'bg-card hover:bg-muted'}`}>A Pagar</button>
          </div>

          {/* Filtro de período */}
          <div className="flex flex-wrap gap-2 items-center">
            {[
              { value: 'hoje', label: 'Hoje' },
              { value: 'semana', label: 'Esta Semana' },
              { value: 'mes_atual', label: 'Mês Atual' },
              { value: 'mes_anterior', label: 'Mês Anterior' },
              { value: 'personalizado', label: 'Personalizado' },
              { value: 'todos', label: 'Todos' },
            ].map(op => (
              <button
                key={op.value}
                onClick={() => setFiltroPeriodo(op.value)}
                className={`px-3 py-1.5 rounded-lg text-xs font-medium border transition-colors ${filtroPeriodo === op.value ? 'bg-primary text-primary-foreground border-primary' : 'bg-card border-border hover:bg-muted'}`}
              >
                {op.label}
              </button>
            ))}
            {filtroPeriodo === 'personalizado' && (
              <>
                <Input type="date" className="w-36 h-8 text-xs" value={dataInicio} onChange={e => setDataInicio(e.target.value)} />
                <span className="text-muted-foreground text-xs">até</span>
                <Input type="date" className="w-36 h-8 text-xs" value={dataFim} onChange={e => setDataFim(e.target.value)} />
              </>
            )}
          </div>

          <div className="flex flex-wrap gap-3">
            <div className="relative flex-1 min-w-[180px]">
              <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground" />
              <Input className="pl-9" placeholder="Buscar descrição ou paciente..." value={busca} onChange={e => setBusca(e.target.value)} />
            </div>
            <Select value={filtroStatus} onValueChange={setFiltroStatus}>
              <SelectTrigger className="w-44"><SelectValue /></SelectTrigger>
              <SelectContent>
                <SelectItem value="aberto">Em Aberto</SelectItem>
                <SelectItem value="pago">Pagos</SelectItem>
                <SelectItem value="todos">Todos</SelectItem>
              </SelectContent>
            </Select>
          </div>

          <div className="bg-card rounded-xl border border-border overflow-hidden">
            <table className="w-full text-sm">
              <thead className="bg-muted/50">
                <tr>
                  <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Descrição</th>
                  <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase hidden sm:table-cell">Tipo</th>
                  <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Valor</th>
                  <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase hidden md:table-cell">Em Aberto</th>
                  <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase hidden md:table-cell">Vencimento</th>
                  <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Status</th>
                  <th className="px-4 py-3 text-xs font-semibold text-muted-foreground uppercase text-right">Ação</th>
                </tr>
              </thead>
              <tbody>
                {loading ? (
                  <tr><td colSpan={7} className="text-center py-12 text-muted-foreground">Carregando...</td></tr>
                ) : filtrados.length === 0 ? (
                  <tr><td colSpan={7} className="text-center py-12 text-muted-foreground">Nenhum registro encontrado.</td></tr>
                ) : filtrados.map(l => {
                  const valorPago = l.valor_pago || (l.status === 'pago' ? l.valor : 0) || 0;
                  const saldoAberto = l.saldo_em_aberto ?? Math.max(0, (l.valor || 0) - valorPago);
                  const isReceita = l.tipo === 'receita';
                  return (
                    <tr key={l.id} className="border-t border-border hover:bg-muted/20 cursor-pointer" onClick={() => { setSelecionado(l); setModalOpen(true); }}>
                      <td className="px-4 py-3 font-medium">
                        <div>{l.descricao}</div>
                        {l.paciente_nome && <div className="text-xs text-muted-foreground">{l.paciente_nome}</div>}
                      </td>
                      <td className="px-4 py-3 hidden sm:table-cell">
                        <span className={`px-2 py-0.5 rounded-full text-xs font-medium ${isReceita ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-600'}`}>
                          {isReceita ? 'Receita' : 'Despesa'}
                        </span>
                      </td>
                      <td className={`px-4 py-3 font-semibold ${isReceita ? 'text-green-700' : 'text-red-600'}`}>{fmt(l.valor)}</td>
                      <td className="px-4 py-3 hidden md:table-cell">
                        {saldoAberto > 0.01 ? <span className="text-orange-600 font-semibold">{fmt(saldoAberto)}</span> : <span className="text-muted-foreground">—</span>}
                      </td>
                      <td className="px-4 py-3 text-muted-foreground hidden md:table-cell">{l.data_vencimento ? format(new Date(l.data_vencimento), 'dd/MM/yyyy') : '—'}</td>
                      <td className="px-4 py-3">
                        <span className={`px-2 py-0.5 rounded-full text-xs font-medium ${statusColor[l.status] || statusColor.pendente}`}>
                          {statusLabel[l.status] || l.status}
                        </span>
                      </td>
                      <td className="px-4 py-3 text-right">
                        {podePagarRapido(l) && (
                          <button
                            onClick={(e) => handlePagamentoRapido(e, l)}
                            title={isReceita ? 'Registrar recebimento' : 'Registrar pagamento'}
                            className={`inline-flex items-center gap-1 px-2.5 py-1 rounded-md text-xs font-semibold transition-colors ${isReceita ? 'bg-green-100 text-green-700 hover:bg-green-200' : 'bg-red-100 text-red-700 hover:bg-red-200'}`}
                          >
                            <CheckCircle2 className="w-3.5 h-3.5" />
                            {isReceita ? 'Receber' : 'Pagar'}
                          </button>
                        )}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </TabsContent>

        {/* ABA GRÁFICO */}
        <TabsContent value="grafico" className="space-y-4">
          <div className="bg-card rounded-xl border border-border p-5">
            <div className="flex items-center justify-between mb-4">
              <div>
                <h2 className="font-semibold">Fluxo por Dia</h2>
                <p className="text-xs text-muted-foreground mt-0.5 capitalize">
                  {format(mesBase, 'MMMM yyyy', { locale: ptBR })} · Receitas: {fmt(receitaMes)} · Despesas: {fmt(despesaMes)} · Pendentes: {fmt(pendentesMes)}
                </p>
              </div>
              <div className="flex items-center gap-1">
                <button onClick={() => setMesBase(m => subMonths(m, 1))} className="p-1.5 rounded hover:bg-muted text-muted-foreground"><ChevronLeft className="w-4 h-4" /></button>
                <span className="text-sm font-medium px-2 capitalize">{format(mesBase, 'MMM/yy', { locale: ptBR })}</span>
                <button onClick={() => setMesBase(m => addMonths(m, 1))} className="p-1.5 rounded hover:bg-muted text-muted-foreground"><ChevronRight className="w-4 h-4" /></button>
              </div>
            </div>
            {dadosGrafico.length === 0 ? (
              <div className="h-48 flex items-center justify-center text-muted-foreground text-sm">
                Nenhum lançamento pago neste mês.
              </div>
            ) : (
              <ResponsiveContainer width="100%" height={260}>
                <BarChart data={dadosGrafico} margin={{ top: 0, right: 0, left: 0, bottom: 0 }}>
                  <CartesianGrid strokeDasharray="3 3" vertical={false} stroke="hsl(var(--border))" />
                  <XAxis dataKey="dia" tick={{ fontSize: 11 }} axisLine={false} tickLine={false} />
                  <YAxis tick={{ fontSize: 11 }} axisLine={false} tickLine={false} tickFormatter={v => `R$${(v / 1000).toFixed(0)}k`} width={50} />
                  <Tooltip formatter={(v, name) => [fmt(v), name]} />
                  <Legend wrapperStyle={{ fontSize: 12 }} />
                  <Bar dataKey="Receitas" fill="#22c55e" radius={[4, 4, 0, 0]} />
                  <Bar dataKey="Despesas" fill="#ef4444" radius={[4, 4, 0, 0]} />
                </BarChart>
              </ResponsiveContainer>
            )}
          </div>
        </TabsContent>
      </Tabs>

      {modalOpen && (
        <LancamentoModal
          lancamento={selecionado}
          onClose={() => setModalOpen(false)}
          onSaved={() => { setModalOpen(false); load(); }}
        />
      )}

      {pagamentoRapido && (
        <PagamentoRapidoModal
          lancamento={pagamentoRapido}
          onClose={() => setPagamentoRapido(null)}
          onSaved={() => { setPagamentoRapido(null); load(); }}
        />
      )}
    </div>
  );
}

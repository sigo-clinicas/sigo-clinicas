import { useEffect, useState, useMemo } from 'react';
import { base44 } from '@/api/base44Client';
import { format, addDays, startOfWeek, isSameDay, parseISO, startOfMonth, endOfMonth, eachDayOfInterval, addMonths, getMonth } from 'date-fns';
import { ptBR } from 'date-fns/locale';
import { ChevronLeft, ChevronRight, Plus, Users, Search, X } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import ConsultaModal from '@/components/agenda/ConsultaModal';
import { useAuth } from '@/lib/AuthContext';

const HOURS = Array.from({ length: 13 }, (_, i) => i + 7); // 7h às 19h

const statusColors = {
  agendado: 'bg-blue-100 border-blue-400 text-blue-800',
  confirmado: 'bg-green-100 border-green-400 text-green-800',
  em_atendimento: 'bg-yellow-100 border-yellow-400 text-yellow-800',
  concluido: 'bg-gray-100 border-gray-400 text-gray-700',
  cancelado: 'bg-red-100 border-red-300 text-red-700 opacity-60',
  faltou: 'bg-orange-100 border-orange-400 text-orange-700',
  externo: 'bg-purple-100 border-purple-400 text-purple-800',
};

const statusLabel = {
  agendado: 'Agendado', confirmado: 'Confirmado', em_atendimento: 'Em Atend.',
  concluido: 'Concluído', cancelado: 'Cancelado', faltou: 'Faltou', externo: 'Online',
};

function profAtende(prof, dia, hora) {
  // Verifica se o profissional atende neste dia/hora
  const diaSemana = dia.getDay(); // 0=Dom, 6=Sáb
  const dias = prof.dias_atendimento || [1, 2, 3, 4, 5];
  if (!dias.includes(diaSemana)) return false;
  const ini = prof.horario_inicio || '07:00';
  const fim = prof.horario_fim || '19:00';
  const hStr = String(hora).padStart(2, '0') + ':00';
  return hStr >= ini && hStr < fim;
}

export default function Agenda() {
  const { currentUser } = useAuth();
  const userRole = currentUser?.role || 'user';
  const isProfissional = userRole === 'profissional';

  const [consultas, setConsultas] = useState([]);
  const [profissionais, setProfissionais] = useState([]);
  const [meuProfissional, setMeuProfissional] = useState(null);
  const [profsSelecionados, setProfsSelecionados] = useState([]);
  const [semanaAtual, setSemanaAtual] = useState(new Date());
  const [modoVisualizacao, setModoVisualizacao] = useState('semana'); // 'hoje' | 'semana' | 'dia' | 'mes'
  const [diaSelecionado, setDiaSelecionado] = useState(new Date());
  const [mesAtual, setMesAtual] = useState(new Date());
  const [modalOpen, setModalOpen] = useState(false);
  const [consultaSel, setConsultaSel] = useState(null);
  const [slotSel, setSlotSel] = useState(null);
  const [slotProfId, setSlotProfId] = useState(null);
  const [loading, setLoading] = useState(true);
  const [filtroPaciente, setFiltroPaciente] = useState('');

  const inicioSemana = startOfWeek(semanaAtual, { weekStartsOn: 1 });
  const diasSemana = Array.from({ length: 7 }, (_, i) => addDays(inicioSemana, i));

  // Dias do mês atual para view mensal
  const diasMes = eachDayOfInterval({ start: startOfMonth(mesAtual), end: endOfMonth(mesAtual) });
  // Padding de dias antes do 1º
  const padInicio = startOfMonth(mesAtual).getDay(); // 0=Dom

  useEffect(() => { load(); }, []);

  async function load() {
    setLoading(true);
    const [c, p] = await Promise.all([
      base44.entities.Consulta.list('-data_hora', 500),
      base44.entities.Profissional.list(),
    ]);
    setProfissionais(p.filter(x => x.ativo !== false));

    // Se é profissional, descobre qual profissional ele é
    if (isProfissional && currentUser?.id) {
      const meu = p.find(x => x.user_id === currentUser.id);
      setMeuProfissional(meu || null);
      if (meu) setProfsSelecionados([meu.id]);
    } else {
      // Default: todos ativos
      setProfsSelecionados(p.filter(x => x.ativo !== false).map(x => x.id));
    }

    setConsultas(c);
    setLoading(false);
  }

  // Profissionais exibidos na grade (filtrados pela seleção)
  const profsExibidos = useMemo(() => {
    if (isProfissional && meuProfissional) return [meuProfissional];
    if (profsSelecionados.length === 0) return profissionais;
    return profissionais.filter(p => profsSelecionados.includes(p.id));
  }, [profissionais, profsSelecionados, isProfissional, meuProfissional]);

  // Dias a exibir conforme modo
  const diasExibidos = (modoVisualizacao === 'dia' || modoVisualizacao === 'hoje')
    ? [modoVisualizacao === 'hoje' ? new Date() : diaSelecionado]
    : diasSemana;

  // Consultas filtradas por nome de paciente
  const consultasFiltradas = useMemo(() => {
    if (!filtroPaciente.trim()) return consultas;
    const termo = filtroPaciente.toLowerCase();
    return consultas.filter(c => c.paciente_nome?.toLowerCase().includes(termo));
  }, [consultas, filtroPaciente]);

  function getConsultasSlot(profId, dia, hora) {
    return consultasFiltradas.filter(c => {
      if (c.profissional_id !== profId) return false;
      const d = parseISO(c.data_hora);
      return isSameDay(d, dia) && d.getHours() === hora;
    });
  }

  function getConsultasDia(dia) {
    return consultasFiltradas.filter(c => isSameDay(parseISO(c.data_hora), dia));
  }

  function handleSlotClick(dia, hora, profId) {
    const dt = new Date(dia);
    dt.setHours(hora, 0, 0, 0);
    setSlotSel(dt);
    setSlotProfId(profId);
    setConsultaSel(null);
    setModalOpen(true);
  }

  function handleConsultaClick(e, c) {
    e.stopPropagation();
    setConsultaSel(c);
    setSlotSel(null);
    setSlotProfId(null);
    setModalOpen(true);
  }

  function toggleProf(id) {
    setProfsSelecionados(prev =>
      prev.includes(id) ? prev.filter(x => x !== id) : [...prev, id]
    );
  }

  const canEdit = ['admin', 'gestor', 'recepcionista', 'profissional', 'user'].includes(userRole);

  if (loading) return (
    <div className="flex items-center justify-center h-full">
      <div className="w-8 h-8 border-4 border-primary/30 border-t-primary rounded-full animate-spin" />
    </div>
  );

  return (
    <div className="flex flex-col h-full">
      {/* Header */}
      <div className="p-4 border-b border-border bg-card shrink-0">
        <div className="flex flex-wrap items-center gap-3">
          <div>
            <h1 className="text-xl font-semibold">Agenda</h1>
            <p className="text-xs text-muted-foreground">
              {modoVisualizacao === 'hoje' && format(new Date(), "EEEE, dd 'de' MMMM", { locale: ptBR })}
              {modoVisualizacao === 'semana' && `${format(inicioSemana, "dd/MM", { locale: ptBR })} — ${format(addDays(inicioSemana, 6), "dd/MM/yyyy", { locale: ptBR })}`}
              {modoVisualizacao === 'dia' && format(diaSelecionado, "EEEE, dd 'de' MMMM", { locale: ptBR })}
              {modoVisualizacao === 'mes' && format(mesAtual, "MMMM 'de' yyyy", { locale: ptBR })}
            </p>
          </div>

          {/* Navegação */}
          {modoVisualizacao !== 'hoje' && (
            <div className="flex items-center gap-1.5">
              <Button variant="outline" size="icon" onClick={() => {
                if (modoVisualizacao === 'semana') setSemanaAtual(addDays(semanaAtual, -7));
                else if (modoVisualizacao === 'dia') setDiaSelecionado(addDays(diaSelecionado, -1));
                else if (modoVisualizacao === 'mes') setMesAtual(addMonths(mesAtual, -1));
              }}><ChevronLeft className="w-4 h-4" /></Button>
              <Button variant="outline" size="sm" onClick={() => {
                setSemanaAtual(new Date()); setDiaSelecionado(new Date()); setMesAtual(new Date());
              }}>Hoje</Button>
              <Button variant="outline" size="icon" onClick={() => {
                if (modoVisualizacao === 'semana') setSemanaAtual(addDays(semanaAtual, 7));
                else if (modoVisualizacao === 'dia') setDiaSelecionado(addDays(diaSelecionado, 1));
                else if (modoVisualizacao === 'mes') setMesAtual(addMonths(mesAtual, 1));
              }}><ChevronRight className="w-4 h-4" /></Button>
            </div>
          )}

          {/* Modo visualização */}
          <div className="flex rounded-lg border border-border overflow-hidden text-xs">
            {['hoje', 'dia', 'semana', 'mes'].map(modo => (
              <button key={modo} onClick={() => setModoVisualizacao(modo)}
                className={`px-3 py-1.5 font-medium capitalize transition-colors ${modoVisualizacao === modo ? 'bg-primary text-primary-foreground' : 'hover:bg-muted'}`}>
                {modo === 'mes' ? 'Mês' : modo.charAt(0).toUpperCase() + modo.slice(1)}
              </button>
            ))}
          </div>

          {/* Filtro por paciente */}
          <div className="relative flex-1 max-w-xs">
            <Search className="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-muted-foreground" />
            <Input
              placeholder="Buscar paciente..."
              value={filtroPaciente}
              onChange={e => setFiltroPaciente(e.target.value)}
              className="pl-8 h-8 text-sm"
            />
            {filtroPaciente && (
              <button onClick={() => setFiltroPaciente('')} className="absolute right-2 top-1/2 -translate-y-1/2">
                <X className="w-3.5 h-3.5 text-muted-foreground hover:text-foreground" />
              </button>
            )}
          </div>

          {/* Filtro profissional — só para não-profissional */}
          {!isProfissional && (
            <div className="flex items-center gap-1 ml-auto flex-wrap">
              <span className="text-xs text-muted-foreground font-medium mr-1 flex items-center gap-1"><Users className="w-3.5 h-3.5" />Profissionais:</span>
              {profissionais.map(p => (
                <button
                  key={p.id}
                  onClick={() => toggleProf(p.id)}
                  className={`flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium transition-all border ${profsSelecionados.includes(p.id) ? 'text-white border-transparent' : 'border-border text-muted-foreground bg-card hover:border-primary/40'}`}
                  style={profsSelecionados.includes(p.id) ? { backgroundColor: p.cor || '#1E3A5F', borderColor: p.cor || '#1E3A5F' } : {}}
                >
                  <span className="w-2 h-2 rounded-full" style={{ backgroundColor: p.cor || '#1E3A5F' }} />
                  {p.nome}
                </button>
              ))}
            </div>
          )}

          {canEdit && (
            <Button onClick={() => { setConsultaSel(null); setSlotSel(new Date()); setSlotProfId(profsExibidos[0]?.id || null); setModalOpen(true); }} className="gap-1.5 ml-auto shrink-0" size="sm">
              <Plus className="w-4 h-4" /> Novo Agendamento
            </Button>
          )}
        </div>
      </div>

      {/* Calendar */}
      <div className="flex-1 overflow-auto">
        {/* Vista Mensal */}
        {modoVisualizacao === 'mes' ? (
          <div className="p-4">
            <div className="grid grid-cols-7 text-center text-xs font-semibold text-muted-foreground mb-2">
              {['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'].map(d => <div key={d} className="py-1">{d}</div>)}
            </div>
            <div className="grid grid-cols-7 gap-1">
              {Array.from({ length: padInicio }).map((_, i) => <div key={`pad-${i}`} />)}
              {diasMes.map(dia => {
                const cssDia = getConsultasDia(dia);
                const isHoje = isSameDay(dia, new Date());
                return (
                  <div
                    key={dia.toString()}
                    onClick={() => { setDiaSelecionado(dia); setModoVisualizacao('dia'); }}
                    className={`min-h-[80px] p-1.5 rounded-lg border border-border cursor-pointer hover:border-primary/40 transition-colors ${isHoje ? 'bg-primary/5 border-primary/30' : 'bg-card'}`}
                  >
                    <div className={`text-xs font-semibold mb-1 w-6 h-6 flex items-center justify-center rounded-full ${isHoje ? 'bg-primary text-primary-foreground' : ''}`}>
                      {format(dia, 'd')}
                    </div>
                    <div className="space-y-0.5">
                      {cssDia.slice(0, 3).map(c => (
                        <div
                          key={c.id}
                          onClick={e => { e.stopPropagation(); handleConsultaClick(e, c); }}
                          className={`text-[10px] px-1 py-0.5 rounded truncate cursor-pointer ${statusColors[c.status] || statusColors.agendado}`}
                        >
                          {format(parseISO(c.data_hora), 'HH:mm')} {c.paciente_nome}
                        </div>
                      ))}
                      {cssDia.length > 3 && <div className="text-[10px] text-muted-foreground">+{cssDia.length - 3} mais</div>}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        ) : profsExibidos.length === 0 ? (
          <div className="flex items-center justify-center h-full text-muted-foreground text-sm">
            <div className="text-center"><Users className="w-10 h-10 mx-auto mb-2 opacity-30" /><p>Nenhum profissional selecionado.</p></div>
          </div>
        ) : (
          <div style={{ minWidth: Math.max(700, 60 + profsExibidos.length * diasExibidos.length * 110) }}>
            {/* Header: dias × profissionais */}
            <div
              className="grid sticky top-0 z-10 bg-card border-b border-border"
              style={{ gridTemplateColumns: `60px repeat(${profsExibidos.length * diasExibidos.length}, minmax(110px, 1fr))` }}
            >
              <div className="border-r border-border" />
              {diasExibidos.map(dia => (
                profsExibidos.map(prof => (
                  <div
                    key={`${dia}-${prof.id}`}
                    className={`text-center py-2 border-r border-border ${isSameDay(dia, new Date()) ? 'bg-primary/5' : ''}`}
                  >
                    <div className="text-xs font-semibold uppercase text-muted-foreground">{format(dia, 'EEE dd', { locale: ptBR })}</div>
                    <div className="flex items-center justify-center gap-1 mt-0.5">
                      <span className="w-2 h-2 rounded-full" style={{ backgroundColor: prof.cor || '#1E3A5F' }} />
                      <span className="text-xs font-medium text-foreground truncate">{prof.nome.split(' ')[0]}</span>
                    </div>
                  </div>
                ))
              ))}
            </div>

            {/* Rows */}
            {HOURS.map(hora => (
              <div
                key={hora}
                className="grid"
                style={{ gridTemplateColumns: `60px repeat(${profsExibidos.length * diasExibidos.length}, minmax(110px, 1fr))` }}
              >
                <div className="border-r border-b border-border text-right pr-2 pt-1 shrink-0">
                  <span className="text-xs text-muted-foreground">{String(hora).padStart(2, '0')}:00</span>
                </div>
                {diasExibidos.map(dia =>
                  profsExibidos.map(prof => {
                    const ativo = profAtende(prof, dia, hora);
                    const cs = getConsultasSlot(prof.id, dia, hora);
                    return (
                      <div
                        key={`${dia}-${prof.id}`}
                        className={`border-r border-b border-border min-h-[56px] p-0.5 transition-colors relative ${ativo ? 'cursor-pointer hover:bg-muted/30' : 'bg-muted/10 cursor-not-allowed'}`}
                        onClick={() => ativo && canEdit && handleSlotClick(dia, hora, prof.id)}
                      >
                        {!ativo && cs.length === 0 && (
                          <div className="absolute inset-0 flex items-center justify-center opacity-20">
                            <div className="w-full h-px bg-gray-400 rotate-12" />
                          </div>
                        )}
                        {cs.map(c => (
                          <div
                            key={c.id}
                            onClick={e => handleConsultaClick(e, c)}
                            className={`rounded border-l-2 px-1 py-0.5 text-xs mb-0.5 cursor-pointer hover:opacity-80 transition-opacity ${statusColors[c.status] || statusColors.agendado}`}
                          >
                            <div className="font-semibold truncate">{format(parseISO(c.data_hora), 'HH:mm')} {c.paciente_nome}</div>
                            <div className="truncate opacity-70 text-[10px]">{statusLabel[c.status] || c.status}</div>
                          </div>
                        ))}
                      </div>
                    );
                  })
                )}
              </div>
            ))}
          </div>
        )}
      </div>

      {modalOpen && (
        <ConsultaModal
          consulta={consultaSel}
          dataHora={slotSel}
          profissionalPreSel={slotProfId}
          profissionais={profsExibidos.length > 0 ? profsExibidos : profissionais}
          onClose={() => setModalOpen(false)}
          onSaved={() => { setModalOpen(false); load(); }}
        />
      )}
    </div>
  );
}

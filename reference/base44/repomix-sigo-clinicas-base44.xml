import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { useAuth } from '@/lib/AuthContext';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Checkbox } from '@/components/ui/checkbox';
import { Plus, Trash2, Edit2, Send, Users } from 'lucide-react';
import { format } from 'date-fns';
import { ptBR } from 'date-fns/locale';

export default function Campanhas() {
  const { currentUser } = useAuth();
  const [campanhas, setCampanhas] = useState([]);
  const [loading, setLoading] = useState(true);
  const [showForm, setShowForm] = useState(false);
  const [editingId, setEditingId] = useState(null);
  const [form, setForm] = useState({
    nome: '',
    descricao: '',
    status: 'draft',
    filtros_demograficos: {
      idade_minima: '',
      idade_maxima: '',
      generos: [],
      localizacoes: []
    },
    filtros_procedimentos: {
      realizados: [],
      nao_realizados: []
    },
    filtros_status_paciente: {
      tipos: [],
      sem_visita_dias: ''
    },
    filtros_compra: {
      sem_compra: false,
      tipos_orcamento: []
    },
    filtros_temporais: {
      data_cadastro_inicio: '',
      data_cadastro_fim: '',
      aniversario_mes: '',
      sazonalidade: ''
    },
    canais_disparo: [],
    conteudo_email: {
      assunto: '',
      corpo: ''
    },
    conteudo_sms: {
      mensagem: ''
    },
    conteudo_whatsapp: {
      mensagem: ''
    },
    data_agendado: ''
  });
  const [saving, setSaving] = useState(false);

  useEffect(() => {
    loadData();
  }, []);

  async function loadData() {
    try {
      const data = await base44.entities.Campanha.list();
      setCampanhas(data);
    } catch (error) {
      console.error('Erro ao carregar campanhas:', error);
    }
    setLoading(false);
  }

  async function handleSave() {
    if (!form.nome.trim()) {
      alert('Nome da campanha é obrigatório');
      return;
    }

    setSaving(true);
    try {
      if (editingId) {
        await base44.entities.Campanha.update(editingId, form);
      } else {
        await base44.entities.Campanha.create(form);
      }
      resetForm();
      await loadData();
    } catch (error) {
      console.error('Erro ao salvar campanha:', error);
      alert('Erro ao salvar campanha');
    }
    setSaving(false);
  }

  async function handleDelete(id) {
    if (!confirm('Deseja deletar esta campanha?')) return;
    try {
      await base44.entities.Campanha.delete(id);
      await loadData();
    } catch (error) {
      console.error('Erro ao deletar:', error);
    }
  }

  function resetForm() {
    setForm({
      nome: '',
      descricao: '',
      status: 'draft',
      filtros_demograficos: { idade_minima: '', idade_maxima: '', generos: [], localizacoes: [] },
      filtros_procedimentos: { realizados: [], nao_realizados: [] },
      filtros_status_paciente: { tipos: [], sem_visita_dias: '' },
      filtros_compra: { sem_compra: false, tipos_orcamento: [] },
      filtros_temporais: { data_cadastro_inicio: '', data_cadastro_fim: '', aniversario_mes: '', sazonalidade: '' },
      canais_disparo: [],
      conteudo_email: { assunto: '', corpo: '' },
      conteudo_sms: { mensagem: '' },
      conteudo_whatsapp: { mensagem: '' },
      data_agendado: ''
    });
    setEditingId(null);
    setShowForm(false);
  }

  function handleEdit(campanha) {
    setForm(campanha);
    setEditingId(campanha.id);
    setShowForm(true);
  }

  if (loading) {
    return (
      <div className="flex items-center justify-center h-96">
        <div className="w-8 h-8 border-4 border-primary/20 border-t-primary rounded-full animate-spin" />
      </div>
    );
  }

  return (
    <div className="p-6 max-w-7xl mx-auto">
      <div className="flex justify-between items-center mb-6">
        <h1 className="text-3xl font-bold text-foreground">Campanhas de Marketing</h1>
        <Button onClick={() => { resetForm(); setShowForm(true); }}>
          <Plus className="w-4 h-4 mr-2" />
          Nova Campanha
        </Button>
      </div>

      {showForm && (
        <Card className="mb-6">
          <CardHeader>
            <CardTitle>{editingId ? 'Editar Campanha' : 'Criar Nova Campanha'}</CardTitle>
          </CardHeader>
          <CardContent>
            <Tabs defaultValue="geral" className="w-full">
              <TabsList className="grid w-full grid-cols-4 mb-4">
                <TabsTrigger value="geral">Geral</TabsTrigger>
                <TabsTrigger value="filtros">Filtros</TabsTrigger>
                <TabsTrigger value="conteudo">Conteúdo</TabsTrigger>
                <TabsTrigger value="agendamento">Agendamento</TabsTrigger>
              </TabsList>

              <TabsContent value="geral" className="space-y-4">
                <div className="space-y-2">
                  <Label>Nome da Campanha *</Label>
                  <Input
                    value={form.nome}
                    onChange={e => setForm({ ...form, nome: e.target.value })}
                    placeholder="Ex: Promoção Summer 2026"
                  />
                </div>
                <div className="space-y-2">
                  <Label>Descrição</Label>
                  <Input
                    value={form.descricao}
                    onChange={e => setForm({ ...form, descricao: e.target.value })}
                    placeholder="Objetivo da campanha"
                  />
                </div>
                <div className="space-y-2">
                  <Label>Status</Label>
                  <Select value={form.status} onValueChange={v => setForm({ ...form, status: v })}>
                    <SelectTrigger>
                      <SelectValue />
                    </SelectTrigger>
                    <SelectContent>
                      <SelectItem value="draft">Rascunho</SelectItem>
                      <SelectItem value="agendada">Agendada</SelectItem>
                      <SelectItem value="ativa">Ativa</SelectItem>
                      <SelectItem value="pausada">Pausada</SelectItem>
                      <SelectItem value="finalizada">Finalizada</SelectItem>
                    </SelectContent>
                  </Select>
                </div>
                <div className="space-y-2">
                  <Label>Canais de Disparo</Label>
                  <div className="flex gap-4">
                    {['email', 'sms', 'whatsapp'].map(canal => (
                      <div key={canal} className="flex items-center gap-2">
                        <Checkbox
                          id={canal}
                          checked={form.canais_disparo.includes(canal)}
                          onCheckedChange={checked => {
                            if (checked) {
                              setForm({ ...form, canais_disparo: [...form.canais_disparo, canal] });
                            } else {
                              setForm({ ...form, canais_disparo: form.canais_disparo.filter(c => c !== canal) });
                            }
                          }}
                        />
                        <Label htmlFor={canal} className="capitalize cursor-pointer">{canal}</Label>
                      </div>
                    ))}
                  </div>
                </div>
              </TabsContent>

              <TabsContent value="filtros" className="space-y-6">
                {/* Demográficos */}
                <div className="border-b pb-4">
                  <h3 className="font-semibold mb-3">Filtros Demográficos</h3>
                  <div className="grid grid-cols-2 gap-4">
                    <div className="space-y-2">
                      <Label>Idade Mínima</Label>
                      <Input
                        type="number"
                        value={form.filtros_demograficos.idade_minima}
                        onChange={e => setForm({
                          ...form,
                          filtros_demograficos: { ...form.filtros_demograficos, idade_minima: e.target.value }
                        })}
                      />
                    </div>
                    <div className="space-y-2">
                      <Label>Idade Máxima</Label>
                      <Input
                        type="number"
                        value={form.filtros_demograficos.idade_maxima}
                        onChange={e => setForm({
                          ...form,
                          filtros_demograficos: { ...form.filtros_demograficos, idade_maxima: e.target.value }
                        })}
                      />
                    </div>
                  </div>
                  <div className="mt-4 space-y-2">
                    <Label>Gêneros</Label>
                    <Input
                      placeholder="Separados por vírgula (ex: Masculino, Feminino)"
                      value={form.filtros_demograficos.generos.join(', ')}
                      onChange={e => setForm({
                        ...form,
                        filtros_demograficos: { ...form.filtros_demograficos, generos: e.target.value.split(',').map(g => g.trim()) }
                      })}
                    />
                  </div>
                  <div className="mt-4 space-y-2">
                    <Label>Localizações</Label>
                    <Input
                      placeholder="Separadas por vírgula (ex: São Paulo, Rio de Janeiro)"
                      value={form.filtros_demograficos.localizacoes.join(', ')}
                      onChange={e => setForm({
                        ...form,
                        filtros_demograficos: { ...form.filtros_demograficos, localizacoes: e.target.value.split(',').map(l => l.trim()) }
                      })}
                    />
                  </div>
                </div>

                {/* Status do Paciente */}
                <div className="border-b pb-4">
                  <h3 className="font-semibold mb-3">Status do Paciente</h3>
                  <div className="flex gap-4 mb-4">
                    {['novo', 'ativo', 'inativo'].map(tipo => (
                      <div key={tipo} className="flex items-center gap-2">
                        <Checkbox
                          id={`status-${tipo}`}
                          checked={form.filtros_status_paciente.tipos.includes(tipo)}
                          onCheckedChange={checked => {
                            if (checked) {
                              setForm({
                                ...form,
                                filtros_status_paciente: {
                                  ...form.filtros_status_paciente,
                                  tipos: [...form.filtros_status_paciente.tipos, tipo]
                                }
                              });
                            } else {
                              setForm({
                                ...form,
                                filtros_status_paciente: {
                                  ...form.filtros_status_paciente,
                                  tipos: form.filtros_status_paciente.tipos.filter(t => t !== tipo)
                                }
                              });

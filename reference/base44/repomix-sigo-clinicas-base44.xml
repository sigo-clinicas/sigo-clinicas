<file path="src/components/financeiro/LancamentoModal.jsx">
import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { X, Trash2, Plus, ChevronDown, ChevronUp } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { format } from 'date-fns';

const formasPg = ['dinheiro', 'cartao_debito', 'cartao_credito', 'pix', 'transferencia', 'boleto'];

const statusColor = {
  pendente: 'bg-yellow-100 text-yellow-700',
  pago_parcial: 'bg-orange-100 text-orange-700',
  pago: 'bg-green-100 text-green-700',
  cancelado: 'bg-gray-100 text-gray-600',
  atrasado: 'bg-red-100 text-red-600',
};

const fmt = v => new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v || 0);

export default function LancamentoModal({ lancamento, tipoFixo, onClose, onSaved }) {
  const tipoAtual = tipoFixo || lancamento?.tipo || 'receita';
  const [form, setForm] = useState({
    tipo: tipoAtual,
    descricao: lancamento?.descricao || '',
    valor: lancamento?.valor || '',
    data_vencimento: lancamento?.data_vencimento || '',
    data_pagamento: lancamento?.data_pagamento || '',
    status: lancamento?.status || 'pendente',
    categoria: lancamento?.categoria || '',
    forma_pagamento: lancamento?.forma_pagamento || 'pix',
    paciente_nome: lancamento?.paciente_nome || '',
    observacoes: lancamento?.observacoes || '',
    pagamentos_parciais: lancamento?.pagamentos_parciais || [],
  });
  const [categorias, setCategorias] = useState([]);

  useEffect(() => {
    base44.entities.CategoriaLancamento.filter({ tipo: form.tipo, ativo: true }, 'nome', 100)
      .then(lista => setCategorias(lista));
  }, [form.tipo]);

  // Estado do pagamento parcial
  const [showPagamento, setShowPagamento] = useState(false);
  const [pgParcial, setPgParcial] = useState({ valor: '', data: format(new Date(), 'yyyy-MM-dd'), forma_pagamento: 'pix', observacao: '' });
  const [saving, setSaving] = useState(false);

  function set(k, v) { setForm(f => ({ ...f, [k]: v })); }

  const valorTotal = Number(form.valor) || 0;
  const valorJaPago = (form.pagamentos_parciais || []).reduce((s, p) => s + (Number(p.valor) || 0), 0);
  const saldoEmAberto = Math.max(0, valorTotal - valorJaPago);

  function adicionarPagamento() {
    const val = Number(pgParcial.valor);
    if (!val || val <= 0) return alert('Informe um valor válido');
    if (val > saldoEmAberto) return alert(`Valor maior que o saldo em aberto (${fmt(saldoEmAberto)})`);

    const novoPagamento = { ...pgParcial, valor: val };
    const novaLista = [...(form.pagamentos_parciais || []), novoPagamento];
    const novoTotal = valorJaPago + val;
    const novoSaldo = valorTotal - novoTotal;
    const novoStatus = novoSaldo <= 0 ? 'pago' : 'pago_parcial';

    setForm(f => ({
      ...f,
      pagamentos_parciais: novaLista,
      valor_pago: novoTotal,
      saldo_em_aberto: novoSaldo,
      status: novoStatus,
      data_pagamento: novoSaldo <= 0 ? pgParcial.data : f.data_pagamento,
    }));
    setPgParcial({ valor: '', data: format(new Date(), 'yyyy-MM-dd'), forma_pagamento: 'pix', observacao: '' });
    setShowPagamento(false);
  }

  function removerPagamento(idx) {
    const novaLista = form.pagamentos_parciais.filter((_, i) => i !== idx);
    const novoTotal = novaLista.reduce((s, p) => s + (Number(p.valor) || 0), 0);
    const novoSaldo = valorTotal - novoTotal;
    const novoStatus = novoTotal === 0 ? 'pendente' : novoSaldo <= 0 ? 'pago' : 'pago_parcial';
    setForm(f => ({
      ...f,
      pagamentos_parciais: novaLista,
      valor_pago: novoTotal,
      saldo_em_aberto: novoSaldo,
      status: novoStatus,
    }));
  }

  async function handleSave() {
    if (!form.descricao.trim() || !form.valor) return alert('Descrição e valor são obrigatórios');
    setSaving(true);
    const data = {
      ...form,
      valor: Number(form.valor),
      valor_pago: valorJaPago,
      saldo_em_aberto: saldoEmAberto,
    };
    if (lancamento) await base44.entities.LancamentoFinanceiro.update(lancamento.id, data);
    else await base44.entities.LancamentoFinanceiro.create(data);
    setSaving(false);
    onSaved();
  }

  async function handleDelete() {
    if (!confirm('Excluir lançamento?')) return;
    await base44.entities.LancamentoFinanceiro.delete(lancamento.id);
    onSaved();
  }

  const isReceita = form.tipo === 'receita';
  const acaoLabel = isReceita ? 'Receber' : 'Pagar';

  return (
    <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
      <div className="bg-card rounded-xl shadow-xl w-full max-w-lg max-h-[92vh] overflow-y-auto">
        <div className="flex items-center justify-between p-5 border-b border-border">
          <h2 className="text-base font-semibold">{lancamento ? 'Editar Lançamento' : 'Novo Lançamento'}</h2>
          <button onClick={onClose} className="text-muted-foreground hover:text-foreground"><X className="w-5 h-5" /></button>
        </div>

        <div className="p-5 space-y-4">
          <div className="grid grid-cols-2 gap-3">
            {!tipoFixo && (
              <div className="col-span-2 space-y-1.5">
                <Label>Tipo</Label>
                <Select value={form.tipo} onValueChange={v => set('tipo', v)}>
                  <SelectTrigger><SelectValue /></SelectTrigger>
                  <SelectContent>
                    <SelectItem value="receita">Receita (a receber)</SelectItem>
                    <SelectItem value="despesa">Despesa (a pagar)</SelectItem>
                  </SelectContent>
                </Select>
              </div>
            )}
            <div className="col-span-2 space-y-1.5">
              <Label>Descrição *</Label>
              <Input value={form.descricao} onChange={e => set('descricao', e.target.value)} placeholder="Ex: Consulta Dr. João" />
            </div>
            <div className="space-y-1.5">
              <Label>Valor Total (R$) *</Label>
              <Input type="number" value={form.valor} onChange={e => set('valor', e.target.value)} placeholder="0,00" />
            </div>
            <div className="space-y-1.5">
              <Label>Vencimento</Label>
              <Input type="date" value={form.data_vencimento} onChange={e => set('data_vencimento', e.target.value)} />
            </div>
            <div className="space-y-1.5">
              <Label>Categoria</Label>
              <Select value={form.categoria} onValueChange={v => set('categoria', v)}>
                <SelectTrigger><SelectValue placeholder="Selecione..." /></SelectTrigger>
                <SelectContent>
                  {categorias.length === 0 && <SelectItem value="_nenhuma" disabled>Nenhuma categoria cadastrada</SelectItem>}
                  {categorias.map(c => <SelectItem key={c.id} value={c.nome}>{c.nome}</SelectItem>)}
                </SelectContent>
              </Select>
            </div>
            <div className="space-y-1.5">
              <Label>Status</Label>
              <Select value={form.status} onValueChange={v => set('status', v)}>
                <SelectTrigger><SelectValue /></SelectTrigger>
                <SelectContent>
                  <SelectItem value="pendente">Pendente</SelectItem>
                  <SelectItem value="pago_parcial">Pago Parcialmente</SelectItem>
                  <SelectItem value="pago">Pago</SelectItem>
                  <SelectItem value="atrasado">Atrasado</SelectItem>
                  <SelectItem value="cancelado">Cancelado</SelectItem>
                </SelectContent>
              </Select>
            </div>
            <div className="col-span-2 space-y-1.5">
              <Label>Paciente (opcional)</Label>
              <Input value={form.paciente_nome} onChange={e => set('paciente_nome', e.target.value)} placeholder="Nome do paciente" />
            </div>
          </div>

          {/* Seção de pagamentos */}
          {valorTotal > 0 && (
            <div className="border border-border rounded-lg overflow-hidden">
              <div className="bg-muted/40 px-4 py-3 flex items-center justify-between">
                <div>
                  <p className="text-sm font-semibold">Pagamentos / Recebimentos</p>
                  <div className="flex gap-4 mt-0.5">
                    <span className="text-xs text-green-700">Pago: {fmt(valorJaPago)}</span>
                    <span className={`text-xs font-semibold ${saldoEmAberto > 0 ? 'text-orange-600' : 'text-green-600'}`}>
                      Saldo em aberto: {fmt(saldoEmAberto)}
                    </span>
                  </div>
                </div>
                {saldoEmAberto > 0 && (
                  <Button size="sm" variant="outline" className="gap-1 text-xs" onClick={() => setShowPagamento(v => !v)}>
                    <Plus className="w-3 h-3" /> {acaoLabel} {showPagamento ? <ChevronUp className="w-3 h-3" /> : <ChevronDown className="w-3 h-3" />}
                  </Button>
                )}
              </div>

              {/* Formulário pagamento parcial */}
              {showPagamento && saldoEmAberto > 0 && (
                <div className="p-4 border-t border-border bg-muted/10 space-y-3">
                  <p className="text-xs text-muted-foreground font-medium uppercase">Registrar {acaoLabel}mento</p>
                  <div className="grid grid-cols-2 gap-3">
                    <div className="space-y-1">
                      <Label className="text-xs">Valor (máx. {fmt(saldoEmAberto)})</Label>
                      <Input
                        type="number"
                        placeholder={String(saldoEmAberto.toFixed(2))}
                        value={pgParcial.valor}
                        onChange={e => setPgParcial(p => ({ ...p, valor: e.target.value }))}
                      />
                    </div>
                    <div className="space-y-1">
                      <Label className="text-xs">Data</Label>
                      <Input type="date" value={pgParcial.data} onChange={e => setPgParcial(p => ({ ...p, data: e.target.value }))} />
                    </div>
                    <div className="space-y-1">
                      <Label className="text-xs">Forma de Pagamento</Label>
                      <Select value={pgParcial.forma_pagamento} onValueChange={v => setPgParcial(p => ({ ...p, forma_pagamento: v }))}>
                        <SelectTrigger className="h-8 text-xs"><SelectValue /></SelectTrigger>
                        <SelectContent>{formasPg.map(f => <SelectItem key={f} value={f} className="text-xs capitalize">{f.replace('_', ' ')}</SelectItem>)}</SelectContent>
                      </Select>
                    </div>
                    <div className="space-y-1">
                      <Label className="text-xs">Observação</Label>
                      <Input className="h-8 text-xs" placeholder="Opcional" value={pgParcial.observacao} onChange={e => setPgParcial(p => ({ ...p, observacao: e.target.value }))} />
                    </div>
                  </div>
                  <Button size="sm" className="w-full gap-1" onClick={adicionarPagamento}>
                    <Plus className="w-3 h-3" /> Confirmar {acaoLabel}mento
                  </Button>
                </div>
              )}

              {/* Histórico */}
              {form.pagamentos_parciais?.length > 0 && (
                <div className="divide-y divide-border">
                  {form.pagamentos_parciais.map((p, idx) => (
                    <div key={idx} className="px-4 py-2.5 flex items-center justify-between text-sm">
                      <div className="flex items-center gap-3">
                        <span className="text-green-700 font-semibold">{fmt(p.valor)}</span>
                        <span className="text-muted-foreground text-xs">{p.data ? format(new Date(p.data), 'dd/MM/yyyy') : ''}</span>
                        <span className="text-muted-foreground text-xs capitalize">{p.forma_pagamento?.replace('_', ' ')}</span>
                        {p.observacao && <span className="text-muted-foreground text-xs">· {p.observacao}</span>}
                      </div>
                      <button onClick={() => removerPagamento(idx)} className="text-muted-foreground hover:text-red-500 ml-2">
                        <X className="w-3.5 h-3.5" />
                      </button>
                    </div>
                  ))}
                </div>
              )}
            </div>
          )}
        </div>

        <div className="flex items-center gap-2 p-5 border-t border-border">
          {lancamento && <Button variant="destructive" size="sm" onClick={handleDelete}><Trash2 className="w-4 h-4" /></Button>}
          <div className="flex-1" />
          <Button variant="outline" onClick={onClose}>Cancelar</Button>
          <Button onClick={handleSave} disabled={saving}>{saving ? 'Salvando...' : 'Salvar'}</Button>
        </div>
      </div>
    </div>
  );
}

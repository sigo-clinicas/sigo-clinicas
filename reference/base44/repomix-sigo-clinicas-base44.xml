                      >
                        <Edit2 className="w-4 h-4" />
                      </Button>
                      <Button
                        size="sm"
                        variant="outline"
                        className="flex-1"
                        onClick={() => deletarPlano(plano.id)}
                      >
                        <Trash2 className="w-4 h-4" />
                      </Button>
                    </div>
                  </div>
                </CardContent>
              </Card>
            ))}
          </div>
        </TabsContent>

        <TabsContent value="assinaturas" className="space-y-6">
          <h1 className="text-3xl font-bold">Assinaturas Ativas</h1>
          
          <div className="space-y-4">
            {assinaturas.filter(a => a.status === 'ativa').length === 0 ? (
              <Card>
                <CardContent className="py-8 text-center text-muted-foreground">
                  Nenhuma assinatura ativa
                </CardContent>
              </Card>
            ) : (
              assinaturas
                .filter(a => a.status === 'ativa')
                .map(assinatura => (
                  <Card key={assinatura.id}>
                    <CardContent className="pt-6">
                      <div className="flex justify-between items-start">
                        <div>
                          <h3 className="font-semibold text-lg">{assinatura.clinica_nome}</h3>
                          <p className="text-sm text-muted-foreground">{assinatura.plano_nome}</p>
                          <div className="flex gap-2 mt-2">
                            <Badge className="bg-green-100 text-green-800">Ativa</Badge>
                            <span className="text-xs text-muted-foreground">
                              Próxima cobrança: {assinatura.proxima_cobranca}
                            </span>
                          </div>
                        </div>
                        <div className="text-right">
                          <div className="text-2xl font-bold">R$ {assinatura.preco_mensal?.toFixed(2)}</div>
                          <p className="text-xs text-muted-foreground">/mês</p>
                        </div>
                      </div>
                    </CardContent>
                  </Card>
                ))
            )}
          </div>
        </TabsContent>
      </Tabs>

      {/* Modal Plano */}
      <Dialog open={modalPlano.open} onOpenChange={(open) => setModalPlano({ ...modalPlano, open })}>
        <DialogContent className="max-w-2xl">
          <DialogHeader>
            <DialogTitle>{modalPlano.edit ? 'Editar Plano' : 'Novo Plano'}</DialogTitle>
          </DialogHeader>

          <div className="space-y-6">
            {/* Info Básica */}
            <div className="space-y-3">
              <div>
                <label className="block text-sm font-medium mb-2">Nome do Plano *</label>
                <Input
                  value={formPlano.nome}
                  onChange={(e) => setFormPlano({ ...formPlano, nome: e.target.value })}
                  placeholder="Ex: Básico, Profissional, Enterprise"
                />
              </div>
              <div>
                <label className="block text-sm font-medium mb-2">Descrição</label>
                <Input
                  value={formPlano.descricao}
                  onChange={(e) => setFormPlano({ ...formPlano, descricao: e.target.value })}
                  placeholder="Descreva o plano"
                />
              </div>
              <div>
                <label className="block text-sm font-medium mb-2">Preço Mensal (R$) *</label>
                <Input
                  type="number"
                  value={formPlano.preco_mensal}
                  onChange={(e) => setFormPlano({ ...formPlano, preco_mensal: parseFloat(e.target.value) || 0 })}
                  placeholder="0.00"
                  step="0.01"
                />
              </div>
            </div>

            {/* Limites */}
            <div className="space-y-3">
              <h3 className="font-semibold text-sm">Limites de Usuários</h3>
              <div className="grid grid-cols-2 gap-3">
                <div>
                  <label className="block text-xs text-muted-foreground mb-1">Administradores</label>
                  <Input
                    type="number"
                    value={formPlano.limite_admin}
                    onChange={(e) => setFormPlano({ ...formPlano, limite_admin: parseInt(e.target.value) || 0 })}
                    min="0"
                  />
                </div>
                <div>
                  <label className="block text-xs text-muted-foreground mb-1">Gestores</label>
                  <Input
                    type="number"
                    value={formPlano.limite_gestor}
                    onChange={(e) => setFormPlano({ ...formPlano, limite_gestor: parseInt(e.target.value) || 0 })}
                    min="0"
                  />
                </div>
                <div>
                  <label className="block text-xs text-muted-foreground mb-1">Recepcionistas</label>
                  <Input
                    type="number"
                    value={formPlano.limite_recepcionista}
                    onChange={(e) => setFormPlano({ ...formPlano, limite_recepcionista: parseInt(e.target.value) || 0 })}
                    min="0"
                  />
                </div>
                <div>
                  <label className="block text-xs text-muted-foreground mb-1">Profissionais</label>
                  <Input
                    type="number"
                    value={formPlano.limite_profissional}
                    onChange={(e) => setFormPlano({ ...formPlano, limite_profissional: parseInt(e.target.value) || 0 })}
                    min="0"
                  />
                </div>
              </div>
            </div>

            {/* Permissões */}
            <div className="space-y-3">
              <h3 className="font-semibold text-sm">Permissões Incluídas</h3>
              <div className="space-y-2">
                {PERMISSOES_DISPONIVEIS.map(perm => (
                  <label key={perm.key} className="flex items-start gap-3 p-2 rounded hover:bg-muted cursor-pointer">
                    <input
                      type="checkbox"
                      checked={formPlano.permissoes[perm.key] || false}
                      onChange={(e) => setFormPlano({
                        ...formPlano,
                        permissoes: { ...formPlano.permissoes, [perm.key]: e.target.checked }
                      })}
                      className="mt-1"
                    />
                    <div>
                      <p className="font-medium text-sm">{perm.label}</p>
                      <p className="text-xs text-muted-foreground">{perm.desc}</p>
                    </div>
                  </label>
                ))}

import { useEffect, useState } from 'react';
import { base44 } from '@/api/base44Client';
import { useClinica } from '@/lib/ClinicaContext';
import { Plus, Search, Edit2, Trash2 } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import PacienteModal from '@/components/pacientes/PacienteModal';
import { format } from 'date-fns';
import { useNavigate } from 'react-router-dom';

export default function Pacientes() {
  const [pacientes, setPacientes] = useState([]);
  const [convenios, setConvenios] = useState([]);
  const [busca, setBusca] = useState('');
  const [modalOpen, setModalOpen] = useState(false);
  const [selecionado, setSelecionado] = useState(null);
  const [loading, setLoading] = useState(true);
  const navigate = useNavigate();
  const { config } = useClinica();
  const origens = config.origens_pacientes || [];
  function getOrigemCor(origem) {
    const found = origens.find(o => o.nome === origem);
    return found?.cor || 'bg-gray-100 text-gray-600';
  }

  useEffect(() => { load(); }, []);

  async function load() {
    const [p, c] = await Promise.all([
      base44.entities.Paciente.list('-created_date', 300),
      base44.entities.Convenio.list(),
    ]);
    setPacientes(p);
    setConvenios(c);
    setLoading(false);
  }

  async function handleDelete(id) {
    if (!confirm('Excluir paciente?')) return;
    await base44.entities.Paciente.delete(id);
    load();
  }

  const filtrados = pacientes.filter(p =>
    p.nome?.toLowerCase().includes(busca.toLowerCase()) ||
    p.cpf?.includes(busca) ||
    p.telefone?.includes(busca)
  );

  const getConvenio = (id) => convenios.find(c => c.id === id)?.nome || 'Particular';

  return (
    <div className="p-6 space-y-5">
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-semibold">Pacientes</h1>
          <p className="text-sm text-muted-foreground mt-0.5">{pacientes.length} cadastrados</p>
        </div>
        <Button onClick={() => { setSelecionado(null); setModalOpen(true); }} className="gap-1.5">
          <Plus className="w-4 h-4" /> Novo Paciente
        </Button>
      </div>

      <div className="relative max-w-sm">
        <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground" />
        <Input className="pl-9" placeholder="Buscar por nome, CPF ou telefone..." value={busca} onChange={e => setBusca(e.target.value)} />
      </div>

      <div className="bg-card rounded-xl border border-border overflow-hidden">
        <table className="w-full text-sm">
          <thead className="bg-muted/50">
            <tr>
              <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Nome</th>
              <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase hidden md:table-cell">CPF</th>
              <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase hidden md:table-cell">Telefone</th>
              <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase hidden lg:table-cell">Convênio</th>
              <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase hidden lg:table-cell">Nascimento</th>
              <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Status</th>
              <th className="px-4 py-3" />
            </tr>
          </thead>
          <tbody>
            {loading ? (
              <tr><td colSpan={7} className="text-center py-12 text-muted-foreground">Carregando...</td></tr>
            ) : filtrados.length === 0 ? (
              <tr><td colSpan={7} className="text-center py-12 text-muted-foreground">Nenhum paciente encontrado.</td></tr>
            ) : filtrados.map(p => (
              <tr key={p.id} className="border-t border-border hover:bg-muted/20 transition-colors">
                <td className="px-4 py-3">
                  <button
                    onClick={() => navigate(`/pacientes/perfil?id=${p.id}`)}
                    className="flex items-center gap-2 hover:underline text-left"
                  >
                    <div className="w-7 h-7 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xs font-bold shrink-0">
                      {p.nome?.[0]?.toUpperCase()}
                    </div>
                    <span className="font-medium">{p.nome}</span>
                    {p.origem && (
                      <span className={`text-xs px-2 py-0.5 rounded-full font-medium ${getOrigemCor(p.origem)}`}>{p.origem}</span>
                    )}
                  </button>
                </td>
                <td className="px-4 py-3 text-muted-foreground hidden md:table-cell">{p.cpf || '—'}</td>
                <td className="px-4 py-3 text-muted-foreground hidden md:table-cell">{p.telefone || '—'}</td>
                <td className="px-4 py-3 hidden lg:table-cell">
                  <span className="px-2 py-0.5 rounded-full bg-secondary text-secondary-foreground text-xs font-medium">{getConvenio(p.convenio_id)}</span>
                </td>
                <td className="px-4 py-3 text-muted-foreground hidden lg:table-cell">
                  {p.data_nascimento ? format(new Date(p.data_nascimento), 'dd/MM/yyyy') : '—'}
                </td>
                <td className="px-4 py-3">
                  <span className={`px-2 py-0.5 rounded-full text-xs font-medium ${p.ativo !== false ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-600'}`}>
                    {p.ativo !== false ? 'Ativo' : 'Inativo'}
                  </span>
                </td>
                <td className="px-4 py-3">
                  <div className="flex items-center gap-1 justify-end">
                    <button onClick={() => { setSelecionado(p); setModalOpen(true); }} className="p-1.5 rounded hover:bg-muted text-muted-foreground hover:text-foreground transition-colors">
                      <Edit2 className="w-3.5 h-3.5" />
                    </button>
                    <button onClick={() => handleDelete(p.id)} className="p-1.5 rounded hover:bg-red-50 text-muted-foreground hover:text-red-600 transition-colors">
                      <Trash2 className="w-3.5 h-3.5" />
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      {modalOpen && (
        <PacienteModal
          paciente={selecionado}
          convenios={convenios}
          onClose={() => setModalOpen(false)}
          onSaved={() => { setModalOpen(false); load(); }}
        />
      )}


    </div>
  );
}
</file>

<file path="src/pages/PortalAgendamento.jsx">
import { useEffect, useState } from 'react';
import { base44 } from '@/api/base44Client';
import { format, addDays, startOfWeek, isSameDay, parseISO } from 'date-fns';
import { ptBR } from 'date-fns/locale';
import { ChevronLeft, ChevronRight, Building2, Calendar, Clock, User, Phone, Mail } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';

const HOURS = Array.from({ length: 13 }, (_, i) => i + 7);

function profAtende(prof, dia, hora) {
  const diaSemana = dia.getDay();
  const dias = prof.dias_atendimento || [1, 2, 3, 4, 5];
  if (!dias.includes(diaSemana)) return false;
  const ini = prof.horario_inicio || '07:00';
  const fim = prof.horario_fim || '19:00';
  const hStr = String(hora).padStart(2, '0') + ':00';
  return hStr >= ini && hStr < fim;
}

export default function PortalAgendamento() {
  const [profissionais, setProfissionais] = useState([]);
  const [consultas, setConsultas] = useState([]);
  const [profSel, setProfSel] = useState('');
  const [semana, setSemana] = useState(new Date());
  const [slotSel, setSlotSel] = useState(null); // { dia, hora }
  const [etapa, setEtapa] = useState('agenda'); // 'agenda' | 'form' | 'confirmado'
  const [form, setForm] = useState({ nome: '', telefone: '', email: '', cpf: '', observacoes: '' });
  const [saving, setSaving] = useState(false);
  const [loading, setLoading] = useState(true);

  const inicioSemana = startOfWeek(semana, { weekStartsOn: 1 });
  const diasSemana = Array.from({ length: 7 }, (_, i) => addDays(inicioSemana, i));
  const profAtual = profissionais.find(p => p.id === profSel);

  useEffect(() => { load(); }, []);

  async function load() {
    const [p, c] = await Promise.all([
      base44.entities.Profissional.list(),
      base44.entities.Consulta.list('-data_hora', 500),
    ]);
    const ativos = p.filter(x => x.ativo !== false);
    setProfissionais(ativos);
    if (ativos.length > 0) setProfSel(ativos[0].id);
    setConsultas(c);
    setLoading(false);
  }

  function slotOcupado(dia, hora) {
    return consultas.some(c => {
      if (c.profissional_id !== profSel) return false;
      if (['cancelado'].includes(c.status)) return false;
      const d = parseISO(c.data_hora);
      return isSameDay(d, dia) && d.getHours() === hora;
    });
  }

  function handleSlotClick(dia, hora) {
    if (!profAtual) return;
    if (!profAtende(profAtual, dia, hora)) return;
    if (slotOcupado(dia, hora)) return;
    if (dia < new Date().setHours(0, 0, 0, 0)) return; // não permite datas passadas
    setSlotSel({ dia, hora });
    setEtapa('form');
  }

  async function handleConfirmar() {
    if (!form.nome.trim() || !form.telefone.trim()) {
      alert('Nome e telefone são obrigatórios');
      return;
    }
    setSaving(true);
    const dt = new Date(slotSel.dia);
    dt.setHours(slotSel.hora, 0, 0, 0);

    // Cria ou encontra paciente pelo nome/telefone
    await base44.entities.Consulta.create({
      paciente_id: 'externo',
      paciente_nome: form.nome,
      profissional_id: profSel,
      profissional_nome: profAtual?.nome || '',
      data_hora: dt.toISOString(),
      duracao_minutos: 30,
      tipo: 'consulta',
      status: 'externo',
      observacoes: `AGENDAMENTO ONLINE\nTel: ${form.telefone}\nEmail: ${form.email}\nCPF: ${form.cpf}\n${form.observacoes}`,
    });
    setSaving(false);
    setEtapa('confirmado');
    load(); // recarrega para bloquear o slot
  }

  if (loading) return (
    <div className="min-h-screen flex items-center justify-center bg-background">
      <div className="w-8 h-8 border-4 border-primary/30 border-t-primary rounded-full animate-spin" />
    </div>
  );

  return (
    <div className="min-h-screen bg-gradient-to-br from-primary/5 via-background to-secondary/20">
      {/* Header */}
      <header className="bg-white border-b border-border shadow-sm sticky top-0 z-20">
        <div className="max-w-5xl mx-auto px-4 h-16 flex items-center gap-3">
          <div className="w-9 h-9 bg-primary rounded-lg flex items-center justify-center">
            <Building2 className="w-5 h-5 text-white" />
          </div>
          <div>
            <div className="font-bold text-primary text-sm">Sigo Clínicas</div>
            <div className="text-xs text-muted-foreground">Agendamento Online</div>
          </div>
        </div>
      </header>

      <div className="max-w-5xl mx-auto px-4 py-8">
        {etapa === 'confirmado' ? (
          <div className="max-w-md mx-auto text-center py-16">
            <div className="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
              <Calendar className="w-10 h-10 text-green-600" />
            </div>
            <h2 className="text-2xl font-bold text-foreground mb-2">Agendamento Confirmado!</h2>
            <p className="text-muted-foreground mb-2">Seu agendamento foi realizado com sucesso.</p>
            <div className="bg-card rounded-xl border border-border p-4 text-left mt-6 mb-6 space-y-2 text-sm">
              <div className="flex gap-2"><User className="w-4 h-4 text-muted-foreground shrink-0 mt-0.5" /><span><b>Profissional:</b> {profAtual?.nome}</span></div>
              <div className="flex gap-2"><Calendar className="w-4 h-4 text-muted-foreground shrink-0 mt-0.5" /><span><b>Data:</b> {slotSel && format(slotSel.dia, "EEEE, dd 'de' MMMM", { locale: ptBR })}</span></div>
              <div className="flex gap-2"><Clock className="w-4 h-4 text-muted-foreground shrink-0 mt-0.5" /><span><b>Horário:</b> {slotSel && String(slotSel.hora).padStart(2, '0')}:00</span></div>
            </div>
            <p className="text-xs text-muted-foreground mb-6">Em breve a clínica entrará em contato para confirmar.</p>
            <Button onClick={() => { setEtapa('agenda'); setSlotSel(null); setForm({ nome: '', telefone: '', email: '', cpf: '', observacoes: '' }); }} variant="outline">
              Fazer novo agendamento
            </Button>
          </div>
        ) : etapa === 'form' ? (
          <div className="max-w-md mx-auto">
            <button onClick={() => setEtapa('agenda')} className="text-sm text-muted-foreground hover:text-foreground flex items-center gap-1 mb-6">
              <ChevronLeft className="w-4 h-4" /> Voltar
            </button>
            <h2 className="text-xl font-bold mb-1">Seus dados</h2>
            <p className="text-sm text-muted-foreground mb-6">
              <b>{profAtual?.nome}</b> · {slotSel && format(slotSel.dia, "EEE, dd/MM", { locale: ptBR })} às {slotSel && String(slotSel.hora).padStart(2, '0')}:00
            </p>
            <div className="bg-card rounded-xl border border-border p-5 space-y-4">
              <div className="space-y-1.5">
                <Label>Nome completo *</Label>
                <Input value={form.nome} onChange={e => setForm(f => ({ ...f, nome: e.target.value }))} placeholder="Seu nome completo" />
              </div>
              <div className="space-y-1.5">
                <Label>Telefone / WhatsApp *</Label>
                <Input value={form.telefone} onChange={e => setForm(f => ({ ...f, telefone: e.target.value }))} placeholder="(00) 00000-0000" />
              </div>
              <div className="space-y-1.5">
                <Label>Email</Label>
                <Input type="email" value={form.email} onChange={e => setForm(f => ({ ...f, email: e.target.value }))} placeholder="seu@email.com" />
              </div>
              <div className="space-y-1.5">
                <Label>CPF</Label>
                <Input value={form.cpf} onChange={e => setForm(f => ({ ...f, cpf: e.target.value }))} placeholder="000.000.000-00" />
              </div>
              <div className="space-y-1.5">
                <Label>Observações (opcional)</Label>
                <Input value={form.observacoes} onChange={e => setForm(f => ({ ...f, observacoes: e.target.value }))} placeholder="Ex: primeira consulta, plano de saúde..." />
              </div>
              <Button onClick={handleConfirmar} disabled={saving} className="w-full mt-2">
                {saving ? 'Confirmando...' : 'Confirmar Agendamento'}
              </Button>
            </div>
          </div>
        ) : (
          <>
            <div className="mb-6">
              <h1 className="text-2xl font-bold text-foreground mb-1">Agendar Consulta</h1>
              <p className="text-muted-foreground text-sm">Escolha o profissional, selecione um horário disponível e confirme seus dados.</p>
            </div>

            {/* Filtro profissional */}
            <div className="bg-card rounded-xl border border-border p-4 mb-5">
              <Label className="text-xs font-semibold uppercase tracking-wide text-muted-foreground mb-2 block">Profissional</Label>
              <div className="flex flex-wrap gap-2">
                {profissionais.map(p => (
                  <button
                    key={p.id}
                    onClick={() => setProfSel(p.id)}
                    className={`flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium border transition-all ${profSel === p.id ? 'text-white border-transparent shadow' : 'border-border text-foreground hover:border-primary/50 bg-background'}`}
                    style={profSel === p.id ? { backgroundColor: p.cor || '#1E3A5F' } : {}}
                  >
                    <span className="w-2 h-2 rounded-full" style={{ backgroundColor: p.cor || '#1E3A5F' }} />
                    <span>{p.nome}</span>
                    {p.especialidade && <span className="text-xs opacity-70">· {p.especialidade}</span>}
                  </button>
                ))}
              </div>
              {profAtual && (
                <p className="text-xs text-muted-foreground mt-2">
                  Horário: {profAtual.horario_inicio || '07:00'} — {profAtual.horario_fim || '19:00'}
                </p>
              )}
            </div>

            {/* Navegação de semana */}
            <div className="flex items-center gap-2 mb-4">
              <Button variant="outline" size="icon" onClick={() => setSemana(addDays(semana, -7))}><ChevronLeft className="w-4 h-4" /></Button>
              <span className="text-sm font-medium flex-1 text-center">
                {format(inicioSemana, "dd/MM", { locale: ptBR })} — {format(addDays(inicioSemana, 6), "dd/MM/yyyy", { locale: ptBR })}
              </span>
              <Button variant="outline" size="icon" onClick={() => setSemana(addDays(semana, 7))}><ChevronRight className="w-4 h-4" /></Button>
            </div>

            {/* Grade de horários */}
            <div className="bg-card rounded-xl border border-border overflow-hidden">
              <div className="overflow-x-auto">
                <div style={{ minWidth: 520 }}>
                  {/* Dias header */}
                  <div className="grid grid-cols-8 border-b border-border bg-muted/30">
                    <div className="py-3 px-2 text-xs font-semibold text-muted-foreground text-center border-r border-border">Hora</div>
                    {diasSemana.map(dia => (
                      <div key={dia.toString()} className={`py-3 text-center border-r border-border ${isSameDay(dia, new Date()) ? 'bg-primary/10' : ''}`}>
                        <div className="text-xs font-semibold uppercase text-muted-foreground">{format(dia, 'EEE', { locale: ptBR })}</div>
                        <div className={`text-sm font-bold mt-0.5 ${isSameDay(dia, new Date()) ? 'text-primary' : 'text-foreground'}`}>{format(dia, 'd')}</div>
                      </div>
                    ))}
                  </div>

                  {/* Slots */}
                  {HOURS.map(hora => (
                    <div key={hora} className="grid grid-cols-8 border-b border-border">
                      <div className="py-2 px-2 text-xs text-muted-foreground text-center border-r border-border font-mono">{String(hora).padStart(2, '0')}:00</div>
                      {diasSemana.map(dia => {
                        const passado = new Date(dia).setHours(hora, 0, 0, 0) < Date.now();
                        const ativo = profAtual ? profAtende(profAtual, dia, hora) : false;
                        const ocupado = slotOcupado(dia, hora);
                        const disponivel = ativo && !ocupado && !passado;

                        return (
                          <div
                            key={dia.toString()}
                            className={`border-r border-border py-1 px-1 flex items-center justify-center min-h-[44px] ${disponivel ? 'cursor-pointer hover:bg-primary/10 transition-colors' : ''}`}
                            onClick={() => disponivel && handleSlotClick(dia, hora)}
                          >
                            {disponivel && (
                              <span className="text-xs text-primary font-medium bg-primary/10 hover:bg-primary hover:text-white rounded px-1.5 py-0.5 transition-colors">
                                Livre
                              </span>
                            )}
                            {ocupado && ativo && !passado && (
                              <span className="text-xs text-muted-foreground bg-muted rounded px-1.5 py-0.5">Ocupado</span>
                            )}
                            {!ativo && <span className="text-muted-foreground/30 text-lg">—</span>}
                            {ativo && passado && !ocupado && <span className="text-muted-foreground/30 text-xs">—</span>}
                          </div>
                        );
                      })}
                    </div>
                  ))}
                </div>
              </div>
            </div>

            <p className="text-xs text-muted-foreground text-center mt-4">Clique em um horário "Livre" para agendar sua consulta.</p>
          </>
        )}
      </div>
    </div>
  );
}
</file>

<file path="src/pages/Profissionais.jsx">
import { useEffect, useState } from 'react';
import { base44 } from '@/api/base44Client';
import { Plus, Edit2, Trash2, Stethoscope } from 'lucide-react';
import { Button } from '@/components/ui/button';
import ProfissionalModal from '@/components/profissionais/ProfissionalModal';

const DIAS = ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'];

export default function Profissionais() {
  const [profissionais, setProfissionais] = useState([]);
  const [convenios, setConvenios] = useState([]);
  const [modalOpen, setModalOpen] = useState(false);
  const [selecionado, setSelecionado] = useState(null);
  const [loading, setLoading] = useState(true);

  useEffect(() => { load(); }, []);

  async function load() {
    const [p, c] = await Promise.all([
      base44.entities.Profissional.list(),
      base44.entities.Convenio.list(),
    ]);
    setProfissionais(p);
    setConvenios(c);
    setLoading(false);
  }

  async function handleDelete(id) {
    if (!confirm('Excluir profissional?')) return;
    await base44.entities.Profissional.delete(id);
    load();
  }

  return (
    <div className="p-6 space-y-5">
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-semibold">Profissionais</h1>
          <p className="text-sm text-muted-foreground mt-0.5">{profissionais.length} cadastrados</p>
        </div>
        <Button onClick={() => { setSelecionado(null); setModalOpen(true); }} className="gap-1.5">
          <Plus className="w-4 h-4" /> Novo Profissional
        </Button>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {loading ? (
          <p className="text-muted-foreground col-span-3 text-center py-12">Carregando...</p>
        ) : profissionais.length === 0 ? (
          <div className="col-span-3 text-center py-16 text-muted-foreground">
            <Stethoscope className="w-12 h-12 mx-auto mb-3 opacity-30" />
            <p>Nenhum profissional cadastrado.</p>
          </div>
        ) : profissionais.map(p => (
          <div key={p.id} className="bg-card rounded-xl border border-border p-5">
            <div className="flex items-start justify-between mb-3">
              <div className="flex items-center gap-3">
                <div className="w-10 h-10 rounded-full flex items-center justify-center text-white text-sm font-bold" style={{ backgroundColor: p.cor || '#1E3A5F' }}>
                  {p.nome?.[0]?.toUpperCase()}
                </div>
                <div>
                  <div className="font-semibold text-sm">{p.nome}</div>
                  <div className="text-xs text-muted-foreground">{p.especialidade || '—'}</div>
                </div>
              </div>
              <div className="flex gap-1">
                <button onClick={() => { setSelecionado(p); setModalOpen(true); }} className="p-1.5 rounded hover:bg-muted text-muted-foreground">
                  <Edit2 className="w-3.5 h-3.5" />
                </button>
                <button onClick={() => handleDelete(p.id)} className="p-1.5 rounded hover:bg-red-50 text-muted-foreground hover:text-red-600">
                  <Trash2 className="w-3.5 h-3.5" />
                </button>
              </div>
            </div>
            <div className="space-y-1.5 text-xs text-muted-foreground">
              {p.crm && <div>CRM: <span className="text-foreground font-medium">{p.crm}</span></div>}
              {p.telefone && <div>Tel: <span className="text-foreground">{p.telefone}</span></div>}
              {p.horario_inicio && <div>Horário: <span className="text-foreground">{p.horario_inicio} — {p.horario_fim}</span></div>}
              {p.dias_atendimento?.length > 0 && (
                <div className="flex flex-wrap gap-1 mt-2">
                  {p.dias_atendimento.map(d => (
                    <span key={d} className="px-1.5 py-0.5 bg-secondary rounded text-xs font-medium">{DIAS[d]}</span>
                  ))}
                </div>
              )}
            </div>
            <div className={`mt-3 text-xs font-medium ${p.ativo !== false ? 'text-green-600' : 'text-red-500'}`}>
              {p.ativo !== false ? '● Ativo' : '● Inativo'}
            </div>
          </div>
        ))}
      </div>

      {modalOpen && (
        <ProfissionalModal
          profissional={selecionado}
          convenios={convenios}
          onClose={() => setModalOpen(false)}
          onSaved={() => { setModalOpen(false); load(); }}
        />
      )}
    </div>
  );
}
</file>

<file path="src/pages/Prontuarios.jsx">
import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { Search, BookOpenCheck, ChevronRight, User } from 'lucide-react';
import { Input } from '@/components/ui/input';
import { format, differenceInYears } from 'date-fns';
import { useNavigate } from 'react-router-dom';

export default function Prontuarios() {
  const [pacientes, setPacientes] = useState([]);
  const [loading, setLoading] = useState(true);
  const [busca, setBusca] = useState('');
  const navigate = useNavigate();

  useEffect(() => {
    base44.entities.Paciente.filter({ ativo: true }, 'nome').then(data => {
      setPacientes(data);
      setLoading(false);
    });
  }, []);

  const filtrados = pacientes.filter(p =>
    p.nome.toLowerCase().includes(busca.toLowerCase()) ||
    (p.cpf && p.cpf.includes(busca)) ||
    (p.telefone && p.telefone.includes(busca))
  );

  return (
    <div className="p-6 max-w-3xl mx-auto space-y-5">
      <div className="flex items-center gap-3">
        <div className="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center">
          <BookOpenCheck className="w-5 h-5 text-primary" />
        </div>
        <div>
          <h1 className="text-xl font-semibold">Prontuários</h1>
          <p className="text-sm text-muted-foreground">Selecione um paciente para acessar o prontuário</p>
        </div>
      </div>

      <div className="relative">
        <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground" />
        <Input
          className="pl-9"
          placeholder="Buscar por nome, CPF ou telefone..."
          value={busca}
          onChange={e => setBusca(e.target.value)}
        />
      </div>

      {loading ? (
        <p className="text-sm text-muted-foreground py-8 text-center">Carregando...</p>
      ) : filtrados.length === 0 ? (
        <div className="text-center py-12 text-muted-foreground border border-dashed border-border rounded-xl">
          <BookOpenCheck className="w-8 h-8 mx-auto mb-2 opacity-30" />
          <p className="text-sm">Nenhum paciente encontrado.</p>
        </div>
      ) : (
        <div className="space-y-2">
          {filtrados.map(p => {
            const idade = p.data_nascimento ? differenceInYears(new Date(), new Date(p.data_nascimento)) : null;
            return (
              <button
                key={p.id}
                onClick={() => navigate(`/pacientes/perfil?id=${p.id}`)}
                className="w-full bg-card border border-border rounded-xl p-4 flex items-center gap-3 hover:shadow-sm hover:border-primary/30 transition-all text-left"
              >
                <div className="w-9 h-9 rounded-full bg-primary/10 flex items-center justify-center text-primary font-semibold text-sm shrink-0">
                  {p.nome[0]?.toUpperCase()}
                </div>
                <div className="flex-1 min-w-0">
                  <div className="font-medium text-sm">{p.nome}</div>
                  <div className="text-xs text-muted-foreground mt-0.5">
                    {[
                      p.cpf,
                      idade ? `${idade} anos` : null,
                      p.telefone,
                    ].filter(Boolean).join(' · ')}
                  </div>
                </div>
                <ChevronRight className="w-4 h-4 text-muted-foreground shrink-0" />
              </button>
            );
          })}
        </div>
      )}
    </div>
  );
}
</file>

<file path="src/pages/Relatorios.jsx">
import { useEffect, useState } from 'react';
import { base44 } from '@/api/base44Client';
import { format, startOfMonth, endOfMonth, parseISO, startOfWeek, endOfWeek, eachDayOfInterval } from 'date-fns';
import { ptBR } from 'date-fns/locale';
import { FileText, TrendingUp, Users, Calendar, LineChart as LineChartIcon, BarChart3 } from 'lucide-react';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { PieChart, Pie, Cell, BarChart, Bar, XAxis, YAxis, Tooltip, CartesianGrid, ResponsiveContainer, Legend, LineChart, Line } from 'recharts';

const COLORS = ['#1E4D7B', '#2563EB', '#059669', '#D97706', '#DC2626', '#7C3AED'];

export default function Relatorios() {
  const [consultas, setConsultas] = useState([]);
  const [lancamentos, setLancamentos] = useState([]);
  const [profissionais, setProfissionais] = useState([]);
  const [evolucoes, setEvolucoes] = useState([]);
  const [convenios, setConvenios] = useState([]);
  const [loading, setLoading] = useState(true);
  const [dataInicio, setDataInicio] = useState(format(startOfMonth(new Date()), 'yyyy-MM-dd'));
  const [dataFim, setDataFim] = useState(format(endOfMonth(new Date()), 'yyyy-MM-dd'));
  const [filtroProfissional, setFiltroProfissional] = useState('todos');

  useEffect(() => {
    async function load() {
      const [c, l, p, e, cv] = await Promise.all([
        base44.entities.Consulta.list('-data_hora', 500),
        base44.entities.LancamentoFinanceiro.list('-data_vencimento', 500),
        base44.entities.Profissional.list(),
        base44.entities.EvolucaoSessao.list('-data_hora', 500),
        base44.entities.Convenio.list(),
      ]);
      setConsultas(c); setLancamentos(l); setProfissionais(p); setEvolucoes(e); setConvenios(cv);
      setLoading(false);
    }
    load();
  }, []);

  const consultasFiltradas = consultas.filter(c => {
    const d = c.data_hora ? new Date(c.data_hora) : null;
    if (!d) return false;
    const ini = new Date(dataInicio); ini.setHours(0, 0, 0, 0);
    const fim = new Date(dataFim); fim.setHours(23, 59, 59, 999);
    const dentroRange = d >= ini && d <= fim;
    const profOk = filtroProfissional === 'todos' || c.profissional_id === filtroProfissional;
    return dentroRange && profOk;
  });

  const fmt = v => new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v);

  // Por status
  const porStatus = ['agendado', 'confirmado', 'concluido', 'cancelado', 'faltou'].map(s => ({
    name: s.replace('_', ' '), value: consultasFiltradas.filter(c => c.status === s).length
  })).filter(x => x.value > 0);

  // Por convênio
  const porConvenio = convenios.map(cv => ({
    name: cv.nome,
    value: consultasFiltradas.filter(c => c.convenio_id === cv.id).length
  })).filter(x => x.value > 0);
  const particular = consultasFiltradas.filter(c => !c.convenio_id).length;
  if (particular > 0) porConvenio.push({ name: 'Particular', value: particular });

  // Por profissional
  const porProfissional = profissionais.map(p => ({
    name: p.nome,
    consultas: consultasFiltradas.filter(c => c.profissional_id === p.id).length,
    receita: lancamentos.filter(l => l.tipo === 'receita' && l.status === 'pago' && l.profissional_id === p.id).reduce((s, l) => s + (l.valor || 0), 0)
  })).filter(x => x.consultas > 0);

  const totalReceita = lancamentos.filter(l => l.tipo === 'receita' && l.status === 'pago').reduce((s, l) => s + (l.valor || 0), 0);
  const totalDespesa = lancamentos.filter(l => l.tipo === 'despesa' && l.status === 'pago').reduce((s, l) => s + (l.valor || 0), 0);

  // Evolução por profissional
  const evolucoesPorProf = profissionais.map(p => ({
    nome: p.nome,
    anotacoes: evolucoes.filter(e => e.profissional_id === p.id && new Date(e.data_hora) >= new Date(dataInicio) && new Date(e.data_hora) <= new Date(dataFim)).length
  })).filter(x => x.anotacoes > 0);

  // Pacientes atendidos por profissional
  const pacientesAtendidos = profissionais.map(p => ({
    nome: p.nome,
    pacientes: new Set(consultasFiltradas.filter(c => c.profissional_id === p.id).map(c => c.paciente_id)).size
  })).filter(x => x.pacientes > 0);

  // DRE (Demonstração de Resultados do Exercício)
  const lucroLiquido = totalReceita - totalDespesa;

  // Gráfico agenda da semana por status
  const dataAtual = new Date();
  const inicioSemana = startOfWeek(dataAtual, { weekStartsOn: 1 });
  const fimSemana = endOfWeek(dataAtual, { weekStartsOn: 1 });
  const diasSemana = eachDayOfInterval({ start: inicioSemana, end: fimSemana });
  
  const agendaSemana = diasSemana.map(dia => {
    const diaStr = format(dia, 'yyyy-MM-dd');
    const consulta = {
      dia: format(dia, 'EEE', { locale: ptBR }).toUpperCase(),
      agendado: consultas.filter(c => format(new Date(c.data_hora), 'yyyy-MM-dd') === diaStr && c.status === 'agendado').length,
      confirmado: consultas.filter(c => format(new Date(c.data_hora), 'yyyy-MM-dd') === diaStr && c.status === 'confirmado').length,
      concluido: consultas.filter(c => format(new Date(c.data_hora), 'yyyy-MM-dd') === diaStr && c.status === 'concluido').length,
      cancelado: consultas.filter(c => format(new Date(c.data_hora), 'yyyy-MM-dd') === diaStr && c.status === 'cancelado').length
    };
    return consulta;
  });

  if (loading) return <div className="flex items-center justify-center h-full"><div className="w-8 h-8 border-4 border-primary/30 border-t-primary rounded-full animate-spin" /></div>;

  return (
    <div className="p-6 space-y-6">
      <div>
        <h1 className="text-2xl font-semibold">Relatórios</h1>
        <p className="text-sm text-muted-foreground mt-0.5">Análise gerencial da clínica</p>
      </div>

      {/* Filtros */}
      <div className="bg-card rounded-xl border border-border p-4 flex flex-wrap gap-4">
        <div className="space-y-1.5">
          <Label className="text-xs">Data Início</Label>
          <Input type="date" value={dataInicio} onChange={e => setDataInicio(e.target.value)} className="w-40" />
        </div>
        <div className="space-y-1.5">
          <Label className="text-xs">Data Fim</Label>
          <Input type="date" value={dataFim} onChange={e => setDataFim(e.target.value)} className="w-40" />
        </div>
        <div className="space-y-1.5">
          <Label className="text-xs">Profissional</Label>
          <Select value={filtroProfissional} onValueChange={setFiltroProfissional}>
            <SelectTrigger className="w-48"><SelectValue /></SelectTrigger>
            <SelectContent>
              <SelectItem value="todos">Todos</SelectItem>

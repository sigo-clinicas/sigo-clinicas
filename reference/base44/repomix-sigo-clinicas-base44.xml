export default function Depoimentos() {
  const [depoimentos, setDepoimentos] = useState([]);
  const [clinicas, setClinicas] = useState([]);
  const [profissionais, setProfissionais] = useState([]);
  const [servicos, setServicos] = useState([]);
  const [loading, setLoading] = useState(true);
  const [modalAberto, setModalAberto] = useState(false);
  const [solicitarAberto, setSolicitarAberto] = useState(false);
  const [editando, setEditando] = useState(null);

  useEffect(() => { fetchData(); }, []);

  const fetchData = async () => {
    setLoading(true);
    try {
      const [deps, cls, profs, servs] = await Promise.all([
        base44.entities.Depoimento.list('-created_date'),
        base44.entities.Clinica.list(),
        base44.entities.Profissional.list(),
        base44.entities.Servico.list(),
      ]);
      setDepoimentos(deps);
      setClinicas(cls);
      setProfissionais(profs);
      setServicos(servs);
    } finally {
      setLoading(false);
    }
  };

  const handleAprovar = async (dep) => {
    await base44.entities.Depoimento.update(dep.id, { status: 'aprovado' });
    fetchData();
  };
  const handleRecusar = async (dep) => {
    await base44.entities.Depoimento.update(dep.id, { status: 'recusado' });
    fetchData();
  };
  const handleTogglePublicar = async (dep) => {
    await base44.entities.Depoimento.update(dep.id, {
      publicar_no_site: !dep.publicar_no_site,
      destaque: !dep.publicar_no_site ? dep.destaque : false,
    });
    fetchData();
  };
  const handleDelete = async (id) => {
    await base44.entities.Depoimento.delete(id);
    fetchData();
  };
  const handleEdit = (dep) => { setEditando(dep); setModalAberto(true); };

  const pendentes = depoimentos.filter(d => d.status === 'pendente');
  const aprovados = depoimentos.filter(d => d.status === 'aprovado');
  const recusados = depoimentos.filter(d => d.status === 'recusado');
  const noSite = depoimentos.filter(d => d.publicar_no_site);

  if (loading) return <div className="p-8 text-center text-muted-foreground">Carregando...</div>;

  return (
    <div className="p-6 max-w-7xl mx-auto">
      {/* Header */}
      <div className="flex items-center justify-between mb-6">
        <div>
          <h1 className="text-2xl font-bold flex items-center gap-2">
            <MessageSquareQuote className="w-6 h-6 text-primary" /> Depoimentos
          </h1>
          <p className="text-sm text-muted-foreground mt-1">Gerencie avaliações de pacientes e o que aparece na Landing Page</p>
        </div>
        <div className="flex gap-2">
          <Button variant="outline" onClick={() => setSolicitarAberto(true)} className="gap-2">
            <Send className="w-4 h-4" /> Solicitar Avaliação
          </Button>
          <Button onClick={() => { setEditando(null); setModalAberto(true); }} className="gap-2">
            <Plus className="w-4 h-4" /> Novo Depoimento
          </Button>
        </div>
      </div>

      {/* KPIs */}
      <div className="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        {[
          { label: 'Total', value: depoimentos.length, color: 'text-foreground' },
          { label: 'Pendentes', value: pendentes.length, color: 'text-yellow-600' },
          { label: 'Aprovados', value: aprovados.length, color: 'text-green-600' },
          { label: 'No site', value: noSite.length, color: 'text-primary' },
        ].map(k => (
          <Card key={k.label}>
            <CardContent className="pt-4 pb-4 text-center">
              <p className={`text-2xl font-bold ${k.color}`}>{k.value}</p>
              <p className="text-xs text-muted-foreground mt-0.5">{k.label}</p>
            </CardContent>
          </Card>
        ))}
      </div>

      {/* Abas */}
      <Tabs defaultValue="pendentes">
        <TabsList>
          <TabsTrigger value="pendentes">Pendentes ({pendentes.length})</TabsTrigger>
          <TabsTrigger value="aprovados">Aprovados ({aprovados.length})</TabsTrigger>
          <TabsTrigger value="no-site">No Site ({noSite.length})</TabsTrigger>
          <TabsTrigger value="recusados">Recusados ({recusados.length})</TabsTrigger>
        </TabsList>

        {[
          { key: 'pendentes', lista: pendentes },
          { key: 'aprovados', lista: aprovados },
          { key: 'no-site', lista: noSite },
          { key: 'recusados', lista: recusados },
        ].map(({ key, lista }) => (
          <TabsContent key={key} value={key} className="mt-4">
            {lista.length === 0 ? (
              <div className="text-center py-16 text-muted-foreground">
                <MessageSquareQuote className="w-10 h-10 mx-auto mb-3 opacity-30" />
                <p>Nenhum depoimento aqui ainda</p>
              </div>
            ) : (
              <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
                {lista.map(dep => (
                  <DepoimentoCard
                    key={dep.id}
                    dep={dep}
                    onEdit={handleEdit}
                    onDelete={handleDelete}
                    onAprovar={handleAprovar}
                    onRecusar={handleRecusar}
                    onTogglePublicar={handleTogglePublicar}
                  />
                ))}
              </div>
            )}
          </TabsContent>
        ))}
      </Tabs>

      <DepoimentoModal
        open={modalAberto}
        onClose={() => { setModalAberto(false); setEditando(null); }}
        onSaved={fetchData}
        depoimento={editando}
        clinicas={clinicas}
        profissionais={profissionais}
        servicos={servicos}
      />

      <SolicitarModal
        open={solicitarAberto}
        onClose={() => setSolicitarAberto(false)}
        clinicas={clinicas}
        profissionais={profissionais}
      />
    </div>
  );
}

<file path="src/components/servicos/TabelaPrecoModal.jsx">
import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { X, Trash2, Plus, Check } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';

const tipoValorLabel = { fixo: 'Valor fixo', a_partir_de: 'A partir de', gratuito: 'Gratuito' };

export default function TabelaPrecoModal({ tabela, servicos, convenios, onClose, onSaved }) {
  const [form, setForm] = useState({
    nome: tabela?.nome || '',
    convenio_id: tabela?.convenio_id || '',
    convenio_nome: tabela?.convenio_nome || '',
    descricao: tabela?.descricao || '',
    ativo: tabela?.ativo !== false,
  });
  const [itens, setItens] = useState([]);
  const [saving, setSaving] = useState(false);
  const [loadingItens, setLoadingItens] = useState(false);

  useEffect(() => {
    if (tabela?.id) {
      setLoadingItens(true);
      base44.entities.ItemTabelaPreco.filter({ tabela_id: tabela.id })
        .then(res => { setItens(res); setLoadingItens(false); });
    }
  }, [tabela]);

  function setF(k, v) { setForm(f => ({ ...f, [k]: v })); }

  function addItem() {
    setItens(i => [...i, { _key: Date.now(), servico_id: '', servico_nome: '', tipo_valor: 'fixo', valor: '', ativo: true, _novo: true }]);
  }

  function updateItem(idx, k, v) {
    setItens(arr => arr.map((it, i) => i === idx ? { ...it, [k]: v } : it));
  }

  function removeItem(idx) {
    setItens(arr => arr.filter((_, i) => i !== idx));
  }

  async function handleSave() {
    if (!form.nome) return alert('Informe o nome da tabela');
    setSaving(true);

    // Salva ou atualiza a tabela
    let tabelaId = tabela?.id;
    const tabelaData = { ...form };
    if (tabelaId) await base44.entities.TabelaPreco.update(tabelaId, tabelaData);
    else {
      const nova = await base44.entities.TabelaPreco.create(tabelaData);
      tabelaId = nova.id;
    }

    // Salva os itens
    for (const item of itens) {
      if (!item.servico_id || !item.tipo_valor) continue;
      const itemData = {
        tabela_id: tabelaId,
        tabela_nome: form.nome,
        servico_id: item.servico_id,
        servico_nome: item.servico_nome,
        tipo_valor: item.tipo_valor,
        valor: item.tipo_valor !== 'gratuito' ? Number(item.valor) || 0 : 0,
        ativo: item.ativo !== false,
      };
      if (item.id) await base44.entities.ItemTabelaPreco.update(item.id, itemData);
      else await base44.entities.ItemTabelaPreco.create(itemData);
    }

    setSaving(false);
    onSaved();
  }

  async function handleDelete() {
    if (!confirm('Excluir esta tabela e todos os seus itens?')) return;
    // Remove itens primeiro
    for (const item of itens) {
      if (item.id) await base44.entities.ItemTabelaPreco.delete(item.id);
    }
    await base44.entities.TabelaPreco.delete(tabela.id);
    onSaved();
  }

  async function handleRemoveItem(item, idx) {
    if (item.id) {
      if (!confirm('Remover este serviço da tabela?')) return;
      await base44.entities.ItemTabelaPreco.delete(item.id);
    }
    removeItem(idx);
  }

  return (
    <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
      <div className="bg-card rounded-xl shadow-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto">
        <div className="flex items-center justify-between p-5 border-b border-border">
          <h2 className="text-base font-semibold">{tabela ? 'Editar Tabela' : 'Nova Tabela de Preços'}</h2>
          <button onClick={onClose} className="text-muted-foreground hover:text-foreground"><X className="w-5 h-5" /></button>
        </div>

        <div className="p-5 space-y-5">
          {/* Dados da tabela */}
          <div className="space-y-3">
            <div className="grid grid-cols-2 gap-3">
              <div className="space-y-1.5">
                <Label>Nome da Tabela *</Label>
                <Input value={form.nome} onChange={e => setF('nome', e.target.value)} placeholder="Ex: Tabela Particular 2024" />
              </div>
              <div className="space-y-1.5">
                <Label>Convênio (vazio = Particular)</Label>
                <Select value={form.convenio_id || 'particular'} onValueChange={v => {
                  if (v === 'particular') { setF('convenio_id', ''); setF('convenio_nome', ''); }
                  else { const c = convenios.find(x => x.id === v); setF('convenio_id', v); setF('convenio_nome', c?.nome || ''); }
                }}>
                  <SelectTrigger><SelectValue placeholder="Particular" /></SelectTrigger>
                  <SelectContent>
                    <SelectItem value="particular">Particular</SelectItem>
                    {convenios.map(c => <SelectItem key={c.id} value={c.id}>{c.nome}</SelectItem>)}
                  </SelectContent>
                </Select>
              </div>
            </div>
            <div className="space-y-1.5">
              <Label>Descrição</Label>
              <Input value={form.descricao} onChange={e => setF('descricao', e.target.value)} placeholder="Opcional" />
            </div>
            <label className="flex items-center gap-2 text-sm cursor-pointer">
              <input type="checkbox" checked={form.ativo} onChange={e => setF('ativo', e.target.checked)} className="rounded" />
              Tabela ativa
            </label>
          </div>

          {/* Itens */}
          <div>
            <div className="flex items-center justify-between mb-3">
              <h3 className="font-medium text-sm">Serviços desta tabela</h3>
              <Button size="sm" variant="outline" onClick={addItem} className="gap-1.5">
                <Plus className="w-3.5 h-3.5" /> Adicionar Serviço
              </Button>
            </div>

            {loadingItens ? (
              <p className="text-sm text-muted-foreground text-center py-4">Carregando...</p>
            ) : itens.length === 0 ? (
              <div className="border border-dashed border-border rounded-lg p-6 text-center text-sm text-muted-foreground">
                Nenhum serviço adicionado. Clique em "Adicionar Serviço".
              </div>
            ) : (
              <div className="space-y-2">
                {itens.map((item, idx) => (
                  <div key={item.id || item._key || idx} className="flex items-center gap-2 bg-muted/40 rounded-lg p-3">
                    <div className="flex-1 min-w-0">
                      <Select value={item.servico_id || 'none'} onValueChange={v => {
                        if (v === 'none') { updateItem(idx, 'servico_id', ''); updateItem(idx, 'servico_nome', ''); }
                        else { const s = servicos.find(x => x.id === v); updateItem(idx, 'servico_id', v); updateItem(idx, 'servico_nome', s?.nome || ''); }
                      }}>
                        <SelectTrigger className="h-8 text-xs"><SelectValue placeholder="Selecionar serviço" /></SelectTrigger>
                        <SelectContent>{servicos.map(s => <SelectItem key={s.id} value={s.id}>{s.nome}</SelectItem>)}</SelectContent>
                      </Select>
                    </div>
                    <Select value={item.tipo_valor} onValueChange={v => updateItem(idx, 'tipo_valor', v)}>
                      <SelectTrigger className="h-8 text-xs w-36"><SelectValue /></SelectTrigger>
                      <SelectContent>
                        <SelectItem value="fixo">Valor fixo</SelectItem>
                        <SelectItem value="a_partir_de">A partir de</SelectItem>
                        <SelectItem value="gratuito">Gratuito</SelectItem>
                      </SelectContent>
                    </Select>
                    {item.tipo_valor !== 'gratuito' && (
                      <div className="relative w-28">
                        <span className="absolute left-2.5 top-1/2 -translate-y-1/2 text-xs text-muted-foreground">R$</span>
                        <Input
                          type="number"
                          value={item.valor}
                          onChange={e => updateItem(idx, 'valor', e.target.value)}
                          className="h-8 text-xs pl-8"
                          placeholder="0,00"
                          min={0}
                          step={0.01}
                        />
                      </div>
                    )}
                    {item.tipo_valor === 'gratuito' && (
                      <div className="w-28 h-8 flex items-center justify-center">
                        <span className="text-xs text-green-600 font-medium flex items-center gap-1"><Check className="w-3 h-3" /> Gratuito</span>
                      </div>
                    )}
                    <button onClick={() => handleRemoveItem(item, idx)} className="p-1.5 rounded hover:bg-red-100 text-muted-foreground hover:text-red-600 shrink-0">
                      <Trash2 className="w-3.5 h-3.5" />
                    </button>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>

        <div className="flex items-center gap-2 p-5 border-t border-border">
          {tabela && (
            <Button variant="destructive" size="sm" onClick={handleDelete}><Trash2 className="w-4 h-4" /></Button>
          )}
          <div className="flex-1" />
          <Button variant="outline" onClick={onClose}>Cancelar</Button>
          <Button onClick={handleSave} disabled={saving}>{saving ? 'Salvando...' : 'Salvar'}</Button>
        </div>
      </div>
    </div>
  );
}
</file>


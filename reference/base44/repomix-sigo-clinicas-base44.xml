<file path="src/pages/anamnese/PreencherAnamnese.jsx">
import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { CheckCircle2, ClipboardList, AlertCircle } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';

export default function PreencherAnamnese() {
  const token = window.location.pathname.split('/anamnese/')[1];
  const [resposta, setResposta] = useState(null);
  const [formulario, setFormulario] = useState(null);
  const [respostas, setRespostas] = useState({});
  const [loading, setLoading] = useState(true);
  const [enviando, setEnviando] = useState(false);
  const [concluido, setConcluido] = useState(false);
  const [erro, setErro] = useState('');

  useEffect(() => {
    async function load() {
      if (!token) {
        setErro('Link inválido.');
        setLoading(false);
        return;
      }
      const res = await base44.functions.invoke('anamnesePublica', { action: 'get', token });
      const data = res.data;
      if (data.error === 'not_found') {
        setErro('Formulário não encontrado ou link inválido.');
        setLoading(false);
        return;
      }
      if (data.resposta?.status === 'preenchido') {
        setConcluido(true);
        setLoading(false);
        return;
      }
      setResposta(data.resposta);
      setFormulario(data.formulario);
      setLoading(false);
    }
    load();
  }, [token]);

  async function handleSubmit() {
    const perguntas = formulario?.perguntas || [];
    for (const p of perguntas) {
      if (p.obrigatoria && !respostas[p.id]?.trim()) {
        alert(`A pergunta "${p.texto}" é obrigatória.`);
        return;
      }
    }
    setEnviando(true);
    const respostasArray = perguntas.map(p => ({
      pergunta_id: p.id,
      pergunta_texto: p.texto,
      resposta: respostas[p.id] || '',
    }));
    await base44.functions.invoke('anamnesePublica', { action: 'submit', token, respostas: respostasArray });
    setEnviando(false);
    setConcluido(true);
  }

  if (loading) return (
    <div className="min-h-screen flex items-center justify-center bg-background">
      <p className="text-muted-foreground">Carregando...</p>
    </div>
  );

  if (erro) return (
    <div className="min-h-screen flex items-center justify-center bg-background p-6">
      <div className="text-center space-y-3">
        <AlertCircle className="w-12 h-12 text-destructive mx-auto" />
        <h2 className="text-lg font-semibold">Formulário não encontrado</h2>
        <p className="text-muted-foreground text-sm">{erro}</p>
      </div>
    </div>
  );

  if (concluido) return (
    <div className="min-h-screen flex items-center justify-center bg-background p-6">
      <div className="text-center space-y-3 max-w-sm">
        <CheckCircle2 className="w-14 h-14 text-green-500 mx-auto" />
        <h2 className="text-xl font-semibold">Obrigado!</h2>
        <p className="text-muted-foreground">Sua ficha de anamnese foi preenchida com sucesso. A clínica já pode visualizá-la.</p>
      </div>
    </div>
  );

  const perguntas = formulario?.perguntas || [];

  return (
    <div className="min-h-screen bg-background py-10 px-4">
      <div className="max-w-xl mx-auto space-y-6">
        {/* Header */}
        <div className="text-center space-y-2">
          <div className="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mx-auto">
            <ClipboardList className="w-6 h-6 text-primary" />
          </div>
          <h1 className="text-2xl font-bold">{formulario?.nome || 'Anamnese'}</h1>
          {formulario?.descricao && (
            <p className="text-muted-foreground text-sm">{formulario.descricao}</p>
          )}
          <p className="text-sm text-muted-foreground">Paciente: <strong>{resposta?.paciente_nome}</strong></p>
        </div>

        {/* Perguntas */}
        <div className="bg-card border border-border rounded-xl p-6 space-y-5">
          {perguntas.length === 0 && (
            <p className="text-muted-foreground text-sm text-center">Este formulário não possui perguntas.</p>
          )}
          {perguntas.map((p, idx) => (
            <div key={p.id} className="space-y-2">
              <Label className="text-sm font-medium">
                {idx + 1}. {p.texto}
                {p.obrigatoria && <span className="text-destructive ml-1">*</span>}
              </Label>

              {(p.tipo === 'texto' || p.tipo === 'numero') && (
                <Input
                  type={p.tipo === 'numero' ? 'number' : 'text'}
                  value={respostas[p.id] || ''}
                  onChange={e => setRespostas(r => ({ ...r, [p.id]: e.target.value }))}
                  placeholder="Sua resposta..."
                />
              )}

              {p.tipo === 'texto_longo' && (
                <textarea
                  className="w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring min-h-[100px] resize-y"
                  value={respostas[p.id] || ''}
                  onChange={e => setRespostas(r => ({ ...r, [p.id]: e.target.value }))}
                  placeholder="Sua resposta..."
                />
              )}

              {p.tipo === 'sim_nao' && (
                <div className="flex gap-3">
                  {['Sim', 'Não'].map(op => (
                    <button
                      key={op}
                      onClick={() => setRespostas(r => ({ ...r, [p.id]: op }))}
                      className={`flex-1 py-2.5 rounded-lg border text-sm font-medium transition-all ${
                        respostas[p.id] === op
                          ? 'bg-primary text-primary-foreground border-primary'
                          : 'border-border hover:bg-muted'
                      }`}
                    >
                      {op}
                    </button>
                  ))}
                </div>
              )}

              {p.tipo === 'multipla_escolha' && (
                <div className="space-y-2">
                  {(p.opcoes || []).map(op => (
                    <label key={op} className="flex items-center gap-2 cursor-pointer">
                      <input
                        type="radio"
                        name={p.id}
                        value={op}
                        checked={respostas[p.id] === op}
                        onChange={() => setRespostas(r => ({ ...r, [p.id]: op }))}
                        className="accent-primary"
                      />
                      <span className="text-sm">{op}</span>
                    </label>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>

        <Button className="w-full h-11" onClick={handleSubmit} disabled={enviando}>
          {enviando ? 'Enviando...' : 'Enviar formulário'}
        </Button>
        <p className="text-xs text-center text-muted-foreground">Suas informações são confidenciais e seguras.</p>
      </div>
    </div>
  );
}
</file>

<file path="src/pages/financeiro/Cobrancas.jsx">
import { useEffect, useState } from 'react';
import { base44 } from '@/api/base44Client';
import { format } from 'date-fns';
import { Plus, Search, FileText, Download } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { Dialog, DialogContent, DialogHeader, DialogTitle } from '@/components/ui/dialog';
import { Checkbox } from '@/components/ui/checkbox';
import LancamentoModal from '@/components/financeiro/LancamentoModal';

const statusColor = {
  pendente: 'bg-yellow-100 text-yellow-700',
  pago: 'bg-green-100 text-green-700',
  cancelado: 'bg-gray-100 text-gray-600',
  atrasado: 'bg-red-100 text-red-600',
};

export default function Cobrancas() {
  const [lancamentos, setLancamentos] = useState([]);
  const [filtroStatus, setFiltroStatus] = useState('todos');
  const [busca, setBusca] = useState('');
  const [modalOpen, setModalOpen] = useState(false);
  const [selecionado, setSelecionado] = useState(null);
  const [loading, setLoading] = useState(true);
  const [faturamentoModal, setFaturamentoModal] = useState({ open: false, tipo: 'nfs', selecionados: [] });
  const [vendas, setVendas] = useState([]);

  useEffect(() => { load(); }, []);

  async function load() {
    const l = await base44.entities.LancamentoFinanceiro.filter({ tipo: 'receita' }, '-data_vencimento', 300);
    const v = await base44.entities.Orcamento.filter({ status: 'aprovado' }, '-venda_data', 300);
    setLancamentos(l);
    setVendas(v.filter(o => o.venda_data));
    setLoading(false);
  }

  const filtrados = lancamentos.filter(l => {
    const statusOk = filtroStatus === 'todos' || l.status === filtroStatus;
    const buscaOk = !busca || l.descricao?.toLowerCase().includes(busca.toLowerCase()) || l.paciente_nome?.toLowerCase().includes(busca.toLowerCase());
    return statusOk && buscaOk;
  });

  const totalPendente = filtrados.filter(l => l.status === 'pendente' || l.status === 'atrasado').reduce((s, l) => s + (l.valor || 0), 0);
  const totalRecebido = filtrados.filter(l => l.status === 'pago').reduce((s, l) => s + (l.valor || 0), 0);
  const fmt = v => new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v);

  const handleGerarNFS = (vendaId) => {
    alert(`NFS gerada para venda ${vendaId} - Integração com sistema de NFS`);
  };

  const handleGerarLote = () => {
    if (faturamentoModal.selecionados.length === 0) {
      alert('Selecione pelo menos uma venda');
      return;
    }
    alert(`${faturamentoModal.selecionados.length} ${faturamentoModal.tipo.toUpperCase()}(s) geradas - Integração com sistema de faturamento`);
    setFaturamentoModal({ open: false, tipo: 'nfs', selecionados: [] });
  };

  return (
    <div className="p-6 space-y-5">
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-semibold">Cobranças</h1>
          <p className="text-sm text-muted-foreground mt-0.5">Receitas, cobranças e faturamento</p>
        </div>
        <Button onClick={() => { setSelecionado(null); setModalOpen(true); }} className="gap-1.5">
          <Plus className="w-4 h-4" /> Nova Cobrança
        </Button>
      </div>

      <Tabs defaultValue="cobrancas" className="w-full">
        <TabsList className="grid w-full grid-cols-2">
          <TabsTrigger value="cobrancas">Cobranças</TabsTrigger>
          <TabsTrigger value="faturamento">Faturamento</TabsTrigger>
        </TabsList>

        <TabsContent value="cobrancas" className="space-y-5">
          <div className="grid grid-cols-2 gap-4">
            <div className="bg-card rounded-xl border border-border p-4">
              <p className="text-xs text-muted-foreground uppercase font-semibold">A Receber</p>
              <p className="text-2xl font-bold text-orange-600 mt-1">{fmt(totalPendente)}</p>
            </div>
            <div className="bg-card rounded-xl border border-border p-4">
              <p className="text-xs text-muted-foreground uppercase font-semibold">Recebido</p>
              <p className="text-2xl font-bold text-green-600 mt-1">{fmt(totalRecebido)}</p>
            </div>
          </div>

          <div className="flex flex-wrap gap-3">
            <div className="relative flex-1 min-w-[200px]">
              <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground" />
              <Input className="pl-9" placeholder="Buscar..." value={busca} onChange={e => setBusca(e.target.value)} />
            </div>
            <Select value={filtroStatus} onValueChange={setFiltroStatus}>
              <SelectTrigger className="w-40"><SelectValue /></SelectTrigger>
              <SelectContent>
                <SelectItem value="todos">Todos</SelectItem>
                <SelectItem value="pendente">Pendente</SelectItem>
                <SelectItem value="pago">Pago</SelectItem>
                <SelectItem value="atrasado">Atrasado</SelectItem>
                <SelectItem value="cancelado">Cancelado</SelectItem>
              </SelectContent>
            </Select>
          </div>

          <div className="bg-card rounded-xl border border-border overflow-hidden">
            <table className="w-full text-sm">
              <thead className="bg-muted/50">
                <tr>
                  <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Descrição</th>
                  <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase hidden md:table-cell">Paciente</th>
                  <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Valor</th>
                  <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase hidden md:table-cell">Vencimento</th>
                  <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Status</th>
                  <th className="px-4 py-3" />
                </tr>
              </thead>
              <tbody>
                {loading ? (
                  <tr><td colSpan={6} className="text-center py-12 text-muted-foreground">Carregando...</td></tr>
                ) : filtrados.length === 0 ? (
                  <tr><td colSpan={6} className="text-center py-12 text-muted-foreground">Nenhum registro encontrado.</td></tr>
                ) : filtrados.map(l => (
                  <tr key={l.id} className="border-t border-border hover:bg-muted/20 transition-colors cursor-pointer" onClick={() => { setSelecionado(l); setModalOpen(true); }}>
                    <td className="px-4 py-3 font-medium">{l.descricao}</td>
                    <td className="px-4 py-3 text-muted-foreground hidden md:table-cell">{l.paciente_nome || '—'}</td>
                    <td className="px-4 py-3 font-semibold text-green-700">{fmt(l.valor)}</td>
                    <td className="px-4 py-3 text-muted-foreground hidden md:table-cell">
                      {l.data_vencimento ? format(new Date(l.data_vencimento), 'dd/MM/yyyy') : '—'}
                    </td>
                    <td className="px-4 py-3">
                      <span className={`px-2 py-0.5 rounded-full text-xs font-medium ${statusColor[l.status] || statusColor.pendente}`}>
                        {l.status?.charAt(0).toUpperCase() + l.status?.slice(1) || 'Pendente'}
                      </span>
                    </td>
                    <td className="px-4 py-3" />
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </TabsContent>

        <TabsContent value="faturamento" className="space-y-5">
          <div className="flex gap-3">
            <Button onClick={() => setFaturamentoModal({ ...faturamentoModal, open: true, tipo: 'nfs' })} variant="outline" className="gap-2">
              <FileText className="w-4 h-4" />
              Gerar NFS
            </Button>
            <Button onClick={() => setFaturamentoModal({ ...faturamentoModal, open: true, tipo: 'nfe' })} variant="outline" className="gap-2">
              <FileText className="w-4 h-4" />
              Gerar NFe
            </Button>
          </div>

          <div className="bg-card rounded-xl border border-border overflow-hidden">
            <table className="w-full text-sm">
              <thead className="bg-muted/50">
                <tr>
                  <th className="px-4 py-3 w-8">
                    <Checkbox
                      checked={faturamentoModal.selecionados.length === vendas.length && vendas.length > 0}
                      onCheckedChange={(checked) => {
                        if (checked) setFaturamentoModal({ ...faturamentoModal, selecionados: vendas.map(v => v.id) });
                        else setFaturamentoModal({ ...faturamentoModal, selecionados: [] });
                      }}
                    />
                  </th>
                  <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Cliente</th>
                  <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase hidden md:table-cell">Valor</th>
                  <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase hidden md:table-cell">Data Venda</th>
                  <th className="px-4 py-3" />
                </tr>
              </thead>
              <tbody>
                {loading ? (
                  <tr><td colSpan={5} className="text-center py-12 text-muted-foreground">Carregando...</td></tr>
                ) : vendas.length === 0 ? (
                  <tr><td colSpan={5} className="text-center py-12 text-muted-foreground">Nenhuma venda para faturar.</td></tr>
                ) : vendas.map(v => (
                  <tr key={v.id} className="border-t border-border hover:bg-muted/20 transition-colors">
                    <td className="px-4 py-3">
                      <Checkbox
                        checked={faturamentoModal.selecionados.includes(v.id)}
                        onCheckedChange={(checked) => {
                          const selecionados = checked
                            ? [...faturamentoModal.selecionados, v.id]
                            : faturamentoModal.selecionados.filter(id => id !== v.id);
                          setFaturamentoModal({ ...faturamentoModal, selecionados });
                        }}
                      />
                    </td>
                    <td className="px-4 py-3 font-medium">{v.cliente_nome}</td>
                    <td className="px-4 py-3 text-muted-foreground hidden md:table-cell">{fmt(v.valor_final)}</td>
                    <td className="px-4 py-3 text-muted-foreground hidden md:table-cell">
                      {v.venda_data ? format(new Date(v.venda_data), 'dd/MM/yyyy') : '—'}
                    </td>
                    <td className="px-4 py-3 text-right">
                      <Button size="sm" variant="ghost" onClick={() => handleGerarNFS(v.id)} className="gap-1">
                        <Download className="w-3 h-3" />
                        Gerar
                      </Button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          {faturamentoModal.selecionados.length > 0 && (
            <Button onClick={() => handleGerarLote()} className="w-full gap-2">
              <FileText className="w-4 h-4" />
              Gerar {faturamentoModal.selecionados.length} {faturamentoModal.tipo.toUpperCase()}(s) em Lote
            </Button>
          )}
        </TabsContent>
      </Tabs>

      {modalOpen && (
        <LancamentoModal
          lancamento={selecionado}
          tipoFixo="receita"
          onClose={() => setModalOpen(false)}
          onSaved={() => { setModalOpen(false); load(); }}
        />
      )}

      {/* Modal Gerar NFS/NFe */}
      <Dialog open={faturamentoModal.open} onOpenChange={(open) => setFaturamentoModal({ ...faturamentoModal, open })}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>Gerar {faturamentoModal.tipo.toUpperCase()}</DialogTitle>
          </DialogHeader>
          <div className="space-y-4">
            <div>
              <label className="block text-sm font-medium mb-3">Tipo de Documento</label>
              <div className="flex gap-3">
                <label className="flex items-center gap-2 cursor-pointer">
                  <input
                    type="radio"
                    value="nfs"
                    checked={faturamentoModal.tipo === 'nfs'}
                    onChange={(e) => setFaturamentoModal({ ...faturamentoModal, tipo: e.target.value })}
                    className="w-4 h-4"
                  />
                  <span>NFS-e (Serviços)</span>
                </label>
                <label className="flex items-center gap-2 cursor-pointer">
                  <input
                    type="radio"
                    value="nfe"
                    checked={faturamentoModal.tipo === 'nfe'}
                    onChange={(e) => setFaturamentoModal({ ...faturamentoModal, tipo: e.target.value })}
                    className="w-4 h-4"
                  />
                  <span>NFe (Mercadorias)</span>
                </label>
              </div>
            </div>
            <div className="p-3 bg-muted rounded text-sm text-muted-foreground">
              {faturamentoModal.selecionados.length > 0
                ? `${faturamentoModal.selecionados.length} venda(s) selecionada(s) para gerar em lote`
                : 'Selecione as vendas na tabela acima para gerar em lote'}
            </div>
            <div className="flex gap-3">
              <Button variant="outline" className="flex-1" onClick={() => setFaturamentoModal({ ...faturamentoModal, open: false })}>
                Cancelar
              </Button>
              <Button className="flex-1" onClick={() => handleGerarLote()} disabled={faturamentoModal.selecionados.length === 0}>
                Gerar {faturamentoModal.selecionados.length > 0 ? 'em Lote' : ''}
              </Button>
            </div>
          </div>
        </DialogContent>
      </Dialog>
    </div>
  );
}

import React, { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Input } from '@/components/ui/input';
import { Dialog, DialogContent, DialogHeader, DialogTitle } from '@/components/ui/dialog';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Trash2, Send } from 'lucide-react';
import { format } from 'date-fns';
import { ptBR } from 'date-fns/locale';

export default function Leads() {
  const [leads, setLeads] = useState([]);
  const [clinicas, setClinicas] = useState([]);
  const [publishModal, setPublishModal] = useState({ open: false, leadId: null, clinicaId: '' });
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    fetchData();
  }, []);

  const fetchData = async () => {
    try {
      const leadsData = await base44.entities.Lead.list('-created_date');
      const clinicasData = await base44.entities.Clinica.list();
      setLeads(leadsData);
      setClinicas(clinicasData);
    } catch (error) {
      console.error('Erro ao carregar leads:', error);
    } finally {
      setLoading(false);
    }
  };

  const leadsComLogin = leads.filter(l => l.tem_login === true);
  const leadsSemLogin = leads.filter(l => l.tem_login === false);

  const handlePublish = async () => {
    if (!publishModal.clinicaId) return;
    try {
      const clinica = clinicas.find(c => c.id === publishModal.clinicaId);
      await base44.entities.Lead.update(publishModal.leadId, {
        status: 'publicado',
        clinica_id: publishModal.clinicaId,
        clinica_nome: clinica?.nome,
      });
      setPublishModal({ open: false, leadId: null, clinicaId: '' });
      fetchData();
    } catch (error) {
      console.error('Erro ao publicar:', error);
    }
  };

  const handleDelete = async (id) => {
    try {
      await base44.entities.Lead.delete(id);
      fetchData();
    } catch (error) {
      console.error('Erro ao deletar:', error);
    }
  };

  if (loading) {
    return <div className="p-8 text-center">Carregando...</div>;
  }

  const LeadCard = ({ lead }) => (
    <Card>
      <CardContent className="pt-6">
        <div className="space-y-3">
          <div>
            <p className="text-sm text-muted-foreground">Nome</p>
            <p className="font-semibold">{lead.nome}</p>
          </div>
          <div>
            <p className="text-sm text-muted-foreground">Telefone</p>
            <p className="font-semibold">{lead.telefone}</p>
          </div>
          <div>
            <p className="text-sm text-muted-foreground">Interesse</p>
            <p className="font-semibold">{lead.cupom_interesse || lead.origem}</p>
          </div>
          {lead.clinica_nome && (
            <div>
              <p className="text-sm text-muted-foreground">Publicado para</p>
              <p className="font-semibold text-green-600">{lead.clinica_nome}</p>
            </div>
          )}
          <p className="text-xs text-muted-foreground">
            {format(new Date(lead.created_date), 'dd/MM/yyyy HH:mm', { locale: ptBR })}
          </p>
          <div className="flex gap-2 pt-2">
            {lead.status === 'novo' && (
              <Button
                size="sm"
                onClick={() => setPublishModal({ open: true, leadId: lead.id, clinicaId: '' })}
                className="flex-1 gap-2"
              >
                <Send className="w-4 h-4" />
                Publicar
              </Button>
            )}
            <Button
              size="sm"
              variant="ghost"
              onClick={() => handleDelete(lead.id)}
              className="text-destructive"
            >
              <Trash2 className="w-4 h-4" />
            </Button>
          </div>
        </div>
      </CardContent>
    </Card>
  );

  return (
    <div className="p-8">
      <h1 className="text-3xl font-bold mb-8">Gerenciar Leads</h1>

      <Tabs defaultValue="sem-login" className="w-full">
        <TabsList>
          <TabsTrigger value="sem-login">
            Sem Login ({leadsSemLogin.length})
          </TabsTrigger>
          <TabsTrigger value="com-login">
            Com Login ({leadsComLogin.length})
          </TabsTrigger>
        </TabsList>

        <TabsContent value="sem-login" className="space-y-4">
          <div className="grid md:grid-cols-3 gap-6">
            {leadsSemLogin.map(lead => (
              <LeadCard key={lead.id} lead={lead} />
            ))}
          </div>
          {leadsSemLogin.length === 0 && (
            <p className="text-muted-foreground text-center py-8">Nenhum lead sem login</p>
          )}
        </TabsContent>

        <TabsContent value="com-login" className="space-y-4">
          <div className="grid md:grid-cols-3 gap-6">
            {leadsComLogin.map(lead => (
              <LeadCard key={lead.id} lead={lead} />
            ))}
          </div>
          {leadsComLogin.length === 0 && (
            <p className="text-muted-foreground text-center py-8">Nenhum lead com login</p>
          )}
        </TabsContent>
      </Tabs>

      {/* Modal Publicar */}
      <Dialog open={publishModal.open} onOpenChange={(open) => setPublishModal({ ...publishModal, open })}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>Publicar Lead para Clínica</DialogTitle>
          </DialogHeader>
          <div className="space-y-4">
            <Select value={publishModal.clinicaId} onValueChange={(value) => setPublishModal({ ...publishModal, clinicaId: value })}>
              <SelectTrigger>
                <SelectValue placeholder="Selecione uma clínica" />
              </SelectTrigger>
              <SelectContent>
                {clinicas.map(clinica => (
                  <SelectItem key={clinica.id} value={clinica.id}>
                    {clinica.nome}
                  </SelectItem>
                ))}
              </SelectContent>
            </Select>
            <div className="flex gap-3">
              <Button
                variant="outline"
                className="flex-1"
                onClick={() => setPublishModal({ open: false, leadId: null, clinicaId: '' })}
              >
                Cancelar
              </Button>
              <Button className="flex-1" onClick={handlePublish}>
                Publicar
              </Button>
            </div>
          </div>
        </DialogContent>
      </Dialog>
    </div>
  );
}
</file>


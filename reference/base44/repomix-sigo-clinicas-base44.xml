import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { format } from 'date-fns';
import { X, Trash2, ShoppingBag, ChevronDown, ChevronUp, Plus, Receipt, ShoppingCart } from 'lucide-react';
import ProdutoVendaModal from '@/components/agenda/ProdutoVendaModal';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';

const statusOpts = ['agendado', 'confirmado', 'em_atendimento', 'concluido', 'cancelado', 'faltou'];
const tipoOpts = ['consulta', 'retorno', 'exame', 'procedimento'];
const pgOpts = ['dinheiro', 'cartao_debito', 'cartao_credito', 'pix', 'convenio', 'pendente'];

function formatCurrency(v) {
  if (!v && v !== 0) return '—';
  return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v);
}

function normalizarServicos(consulta) {
  if (!consulta) return [];
  if (consulta.servicos?.length > 0) return consulta.servicos;
  if (consulta.servico_id) return [{
    servico_id: consulta.servico_id,
    servico_nome: consulta.servico_nome || '',
    orcamento_id: consulta.orcamento_id || '',
    orcamento_item_idx: consulta.orcamento_item_idx ?? null,
  }];
  return [];
}

export default function ConsultaModal({ consulta, dataHora, profissionalPreSel, profissionais, onClose, onSaved }) {
  const [pacientes, setPacientes] = useState([]);
  const [convenios, setConvenios] = useState([]);
  const [todosServicos, setTodosServicos] = useState([]);
  const [tabelasPreco, setTabelasPreco] = useState([]);
  const [itensTabela, setItensTabela] = useState([]);
  const [vendasPaciente, setVendasPaciente] = useState([]);
  const [contasBancarias, setContasBancarias] = useState([]);
  const [showVendas, setShowVendas] = useState(false);
  const [gerarVenda, setGerarVenda] = useState(false);
  const [produtoVendaOpen, setProdutoVendaOpen] = useState(false);
  const [tipoVenda, setTipoVenda] = useState('contas_receber'); // 'avista' | 'contas_receber'
  const [contaBancariaId, setContaBancariaId] = useState('');
  const [saving, setSaving] = useState(false);
  const [consultas, setConsultas] = useState([]);

  const [form, setForm] = useState({
    paciente_id: consulta?.paciente_id || '',
    paciente_nome: consulta?.paciente_nome || '',
    profissional_id: consulta?.profissional_id || profissionalPreSel || '',
    profissional_nome: consulta?.profissional_nome || '',
    convenio_id: consulta?.convenio_id || '',
    convenio_nome: consulta?.convenio_nome || '',
    data_hora: consulta?.data_hora ? format(new Date(consulta.data_hora), "yyyy-MM-dd'T'HH:mm") : (dataHora ? format(dataHora, "yyyy-MM-dd'T'HH:mm") : ''),
    duracao_minutos: consulta?.duracao_minutos || 30,
    tipo: consulta?.tipo || 'consulta',
    status: consulta?.status || 'agendado',
    forma_pagamento: consulta?.forma_pagamento || 'pendente',
    valor: consulta?.valor || '',
    observacoes: consulta?.observacoes || '',
    servicos: normalizarServicos(consulta),
  });

  useEffect(() => {
    Promise.all([
      base44.entities.Paciente.list(),
      base44.entities.Convenio.list(),
      base44.entities.Servico.list(),
      base44.entities.TabelaPreco.list(),
      base44.entities.ItemTabelaPreco.list(),
      base44.entities.Consulta.list(),
      base44.entities.ContaBancaria.list(),
    ]).then(([p, c, s, tb, it, cs, cbs]) => {
      setPacientes(p);
      setConvenios(c);
      setTodosServicos(s.filter(x => x.ativo !== false));
      setTabelasPreco(tb.filter(x => x.ativo !== false));
      setItensTabela(it.filter(x => x.ativo !== false));
      setConsultas(cs);
      setContasBancarias(cbs.filter(x => x.ativo !== false));
      if (profissionalPreSel && !consulta) {
        const prof = profissionais.find(x => x.id === profissionalPreSel);
        if (prof) setForm(f => ({ ...f, profissional_nome: prof.nome }));
      }
    });
  }, []);

  useEffect(() => {
    if (!form.paciente_id) { setVendasPaciente([]); return; }
    base44.entities.Orcamento.filter({ cliente_id: form.paciente_id }).then(orcamentos => {
      setVendasPaciente(orcamentos.filter(o => o.venda_data));
    });
  }, [form.paciente_id]);

  const profSelecionado = profissionais.find(p => p.id === form.profissional_id);
  const servicosFiltrados = profSelecionado?.servicos_comissao?.length > 0
    ? todosServicos.filter(s => profSelecionado.servicos_comissao.find(sc => sc.servico_id === s.id))
    : todosServicos;

  function setF(k, v) { setForm(f => ({ ...f, [k]: v })); }

  function buscarPrecoTabela(servicoId, convenioId) {
    const tabela = tabelasPreco.find(tb => convenioId ? tb.convenio_id === convenioId : !tb.convenio_id)
      || tabelasPreco.find(tb => !tb.convenio_id);
    if (!tabela) return null;
    const item = itensTabela.find(it => it.servico_id === servicoId && it.tabela_id === tabela.id);
    if (!item || item.tipo_valor === 'gratuito') return null;
    return item.valor || null;
  }

  // Soma valor total dos serviços adicionados
  function recalcularValor(servicosAtuais, novoServico, valorNovoServico) {
    // Apenas recalcula se o campo valor ainda não foi editado manualmente
    // Retorna o total somado de todos os serviços
    let total = 0;
    for (const sv of servicosAtuais) {
      const orc = vendasPaciente.find(o => o.id === sv.orcamento_id);
      if (orc && sv.orcamento_item_idx !== null) {
        total += orc.itens?.[sv.orcamento_item_idx]?.valor_unitario || 0;
      } else {
        total += buscarPrecoTabela(sv.servico_id, form.convenio_id) || 0;
      }
    }
    if (novoServico !== undefined) total += valorNovoServico || 0;
    return total > 0 ? total : '';
  }

  // Itens de venda disponíveis (sessões pendentes) - filtra serviços já usados em consultas "concluido"
  const servicesUsedInCompletedConsultations = consultas
    .filter(c => c.status === 'concluido' && c.paciente_id === form.paciente_id)
    .flatMap(c => c.servicos || [])
    .map(s => ({ orcId: s.orcamento_id, itemIdx: s.orcamento_item_idx }));

  const itensVendaDisponiveis = vendasPaciente.flatMap(orc =>
    (orc.itens || []).map((item, idx) => ({
      orcamentoId: orc.id,
      itemIdx: idx,
      servicoNome: item.servico_nome,
      servicoId: item.servico_id,
      valorUnitario: item.valor_unitario || 0,
      sessoesPendentes: (item.quantidade || 1) - (item.sessoes_realizadas || 0),
    }))
      .filter(x => x.sessoesPendentes > 0)
      .filter(x => !servicesUsedInCompletedConsultations.some(s => s.orcId === x.orcamentoId && s.itemIdx === x.itemIdx))
  );

  function itemVendaJaSelecionado(item) {
    return form.servicos.some(s => s.orcamento_id === item.orcamentoId && s.orcamento_item_idx === item.itemIdx);
  }

  function adicionarItemVenda(item) {
    if (itemVendaJaSelecionado(item)) return;
    const novoServico = {
      servico_id: item.servicoId,
      servico_nome: item.servicoNome,
      orcamento_id: item.orcamentoId,
      orcamento_item_idx: item.itemIdx,
    };
    const novosServicos = [...form.servicos, novoServico];
    const novoValor = recalcularValor(form.servicos, novoServico, item.valorUnitario);
    setForm(f => ({
      ...f,
      servicos: novosServicos,
      valor: novoValor,
      duracao_minutos: f.servicos.length === 0 ? (todosServicos.find(x => x.id === item.servicoId)?.duracao_minutos || f.duracao_minutos) : f.duracao_minutos,
    }));
    setShowVendas(false);
  }

  function adicionarServicoAvulso(servicoId) {
    if (!servicoId || servicoId === 'nenhum') return;
    const s = todosServicos.find(x => x.id === servicoId);
    if (!s) return;
    if (form.servicos.some(sv => sv.servico_id === servicoId && !sv.orcamento_id)) return;
    const novoServico = { servico_id: servicoId, servico_nome: s.nome, orcamento_id: '', orcamento_item_idx: null };
    const precoTabela = buscarPrecoTabela(servicoId, form.convenio_id) || 0;
    const novosServicos = [...form.servicos, novoServico];
    const novoValor = recalcularValor(form.servicos, novoServico, precoTabela);
    setForm(f => ({
      ...f,
      servicos: novosServicos,
      valor: novoValor,
      duracao_minutos: f.servicos.length === 0 ? (s.duracao_minutos || f.duracao_minutos) : f.duracao_minutos,
    }));
  }

  function removerServico(idx) {
    const novosServicos = form.servicos.filter((_, i) => i !== idx);
    const novoValor = recalcularValor(novosServicos);
    setForm(f => ({ ...f, servicos: novosServicos, valor: novoValor }));
  }

  // Verifica se TODOS os serviços são de orçamento (pré-pago)
  const todosServicosDeOrcamento = form.servicos.length > 0 && form.servicos.every(sv => sv.orcamento_id);
  // Tem algum serviço avulso (sem orçamento)?
  const temServicoAvulso = form.servicos.some(sv => !sv.orcamento_id);
  // Tem algum serviço de venda vinculado?
  const temVendaVinculada = form.servicos.some(sv => sv.orcamento_id);
  // Valor somente dos serviços avulsos
  const valorAvulso = form.servicos
    .filter(sv => !sv.orcamento_id)
    .reduce((acc, sv) => acc + (buscarPrecoTabela(sv.servico_id, form.convenio_id) || 0), 0);

  // Forma de pagamento da venda vinculada (do orçamento)
  const formaPagamentoVenda = temVendaVinculada
    ? vendasPaciente.find(o => form.servicos.some(sv => sv.orcamento_id === o.id))?.venda_forma_pagamento
    : null;

  async function handleSave() {
    setSaving(true);
    const data = { ...form, valor: form.valor ? Number(form.valor) : undefined };

    // Baixa sessões realizadas nas vendas
    if (data.status === 'concluido') {
      for (const sv of data.servicos) {
        if (!sv.orcamento_id || sv.orcamento_item_idx === null) continue;
        const orc = vendasPaciente.find(o => o.id === sv.orcamento_id);
        if (!orc) continue;
        const itens = (orc.itens || []).map((item, idx) =>
          idx === sv.orcamento_item_idx
            ? { ...item, sessoes_realizadas: (item.sessoes_realizadas || 0) + 1 }
            : item
        );
        await base44.entities.Orcamento.update(sv.orcamento_id, { itens });
      }
    }

    // Gera lançamento financeiro para serviços avulsos (sem orçamento)
    if (gerarVenda && temServicoAvulso) {
      const valor = Number(form.valor) > 0 ? Number(form.valor) : valorAvulso;
      const descricao = `${form.paciente_nome || 'Paciente'} — ${form.servicos.filter(s => !s.orcamento_id).map(s => s.servico_nome).join(', ') || 'Consulta'}`;
      const dataVencimento = format(new Date(data.data_hora || new Date()), 'yyyy-MM-dd');

      if (tipoVenda === 'avista' && contaBancariaId) {
        // Lança como pago diretamente na conta
        const conta = contasBancarias.find(c => c.id === contaBancariaId);
        const lancamento = await base44.entities.LancamentoFinanceiro.create({
          tipo: 'receita', descricao, valor,
          data_vencimento: dataVencimento, data_pagamento: dataVencimento,
          status: 'pago', categoria: 'consulta',
          forma_pagamento: form.forma_pagamento !== 'pendente' ? form.forma_pagamento : 'dinheiro',
          valor_pago: valor, saldo_em_aberto: 0,
          paciente_nome: form.paciente_nome, profissional_id: form.profissional_id,
        });
        // Movimenta a conta bancária
        await base44.entities.MovimentacaoConta.create({
          conta_id: contaBancariaId, conta_nome: conta?.nome || '',
          lancamento_financeiro_id: lancamento.id,
          tipo: 'entrada', descricao, valor, data: dataVencimento,
        });
        // Atualiza saldo da conta
        await base44.entities.ContaBancaria.update(contaBancariaId, {
          saldo_atual: (conta?.saldo_atual || 0) + valor,
        });
      } else {
        // Lança em contas a receber (pendente)
        await base44.entities.LancamentoFinanceiro.create({
          tipo: 'receita', descricao, valor,
          data_vencimento: dataVencimento, status: 'pendente',
          categoria: 'consulta', saldo_em_aberto: valor,
          paciente_nome: form.paciente_nome, profissional_id: form.profissional_id,
          consulta_id: consulta?.id || undefined,
        });
      }
    }

    if (consulta) await base44.entities.Consulta.update(consulta.id, data);
    else await base44.entities.Consulta.create(data);
    setSaving(false);
    onSaved();
  }

  async function handleDelete() {
    if (!confirm('Excluir esta consulta?')) return;
    await base44.entities.Consulta.delete(consulta.id);
    onSaved();
  }

  return (
    <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
      <div className="bg-card rounded-xl shadow-xl w-full max-w-lg max-h-[90vh] overflow-y-auto">
        <div className="flex items-center justify-between p-5 border-b border-border">
          <h2 className="text-base font-semibold">{consulta ? 'Editar Consulta' : 'Nova Consulta'}</h2>
          <button onClick={onClose} className="text-muted-foreground hover:text-foreground"><X className="w-5 h-5" /></button>
        </div>

        <div className="p-5 space-y-4">
          {/* Paciente */}
          <div className="space-y-1.5">
            <Label>Paciente</Label>
            <Select value={form.paciente_id} onValueChange={v => {
              const p = pacientes.find(x => x.id === v);
              setF('paciente_id', v);
              setF('paciente_nome', p?.nome || '');
              setF('servicos', []);
              setF('valor', '');
            }}>
              <SelectTrigger><SelectValue placeholder="Selecionar paciente" /></SelectTrigger>
              <SelectContent>{pacientes.map(p => <SelectItem key={p.id} value={p.id}>{p.nome}</SelectItem>)}</SelectContent>
            </Select>
          </div>

          {/* Serviços de venda pendentes */}
          {itensVendaDisponiveis.length > 0 && (
            <div>
              <button
                onClick={() => setShowVendas(!showVendas)}
                className="w-full flex items-center gap-2 px-3 py-2 rounded-lg border border-amber-200 bg-amber-50 text-amber-800 text-sm hover:bg-amber-100 transition-colors"
              >
                <ShoppingBag className="w-4 h-4" />
                <span className="flex-1 text-left font-medium">{itensVendaDisponiveis.length} serviço(s) de venda pendentes</span>
                {showVendas ? <ChevronUp className="w-4 h-4" /> : <ChevronDown className="w-4 h-4" />}
              </button>
              {showVendas && (
                <div className="mt-2 border border-border rounded-lg overflow-hidden divide-y divide-border">
                  {itensVendaDisponiveis.map((item, i) => {
                    const jaSel = itemVendaJaSelecionado(item);
                    return (
                      <button
                        key={i}
                        onClick={() => adicionarItemVenda(item)}
                        disabled={jaSel}
                        className={`w-full flex items-center justify-between px-3 py-2.5 transition-colors text-left ${jaSel ? 'bg-green-50 opacity-60 cursor-default' : 'hover:bg-muted/50'}`}
                      >
                        <div>
                          <p className="text-sm font-medium">{item.servicoNome}</p>
                          <p className="text-xs text-muted-foreground">{item.sessoesPendentes} sessão(ões) pendente(s)</p>
                        </div>
                        <div className="flex items-center gap-2">
                          {item.valorUnitario > 0 && <span className="text-sm font-semibold text-primary">{formatCurrency(item.valorUnitario)}</span>}
                          {jaSel
                            ? <span className="text-xs text-green-600 font-medium">✓</span>
                            : <Plus className="w-4 h-4 text-primary" />
                          }
                        </div>
                      </button>
                    );
                  })}
                </div>
              )}
            </div>
          )}

          {/* Profissional */}
          <div className="space-y-1.5">
            <Label>Profissional</Label>
            <Select value={form.profissional_id} onValueChange={v => {
              const p = profissionais.find(x => x.id === v);
              setF('profissional_id', v);
              setF('profissional_nome', p?.nome || '');
            }}>
              <SelectTrigger><SelectValue placeholder="Selecionar profissional" /></SelectTrigger>
              <SelectContent>{profissionais.map(p => <SelectItem key={p.id} value={p.id}>{p.nome}</SelectItem>)}</SelectContent>
            </Select>
          </div>

          {/* Serviços */}
          <div className="space-y-1.5">
            <Label>
              Serviços{profSelecionado?.servicos_comissao?.length > 0 && <span className="text-xs text-muted-foreground font-normal ml-1">(filtrado por profissional)</span>}
            </Label>

            {form.servicos.length > 0 && (
              <div className="space-y-1 mb-2">
                {form.servicos.map((sv, idx) => (
                  <div key={idx} className="flex items-center justify-between bg-muted/40 border border-border rounded-lg px-3 py-1.5">
                    <div className="flex items-center gap-2">
                      <span className="text-sm font-medium">{sv.servico_nome}</span>
                      {sv.orcamento_id && (
                        <span className="text-xs bg-amber-100 text-amber-700 rounded px-1.5 py-0.5">venda</span>
                      )}
                    </div>
                    <button onClick={() => removerServico(idx)} className="text-muted-foreground hover:text-destructive ml-2">
                      <X className="w-3.5 h-3.5" />
                    </button>
                  </div>
                ))}
              </div>
            )}

            <Select value="nenhum" onValueChange={adicionarServicoAvulso}>
              <SelectTrigger>
                <SelectValue placeholder="+ Adicionar serviço..." />
              </SelectTrigger>
              <SelectContent>
                <SelectItem value="nenhum">— Selecionar serviço —</SelectItem>
                {servicosFiltrados.map(s => (
                  <SelectItem key={s.id} value={s.id}>{s.nome} ({s.duracao_minutos} min)</SelectItem>
                ))}
              </SelectContent>
            </Select>
          </div>

          {/* Demais campos */}
          <div className="grid grid-cols-2 gap-3">
            <div className="space-y-1.5">
              <Label>Data e Hora</Label>
              <Input type="datetime-local" value={form.data_hora} onChange={e => setF('data_hora', e.target.value)} />
            </div>
            <div className="space-y-1.5">
              <Label>Duração (min)</Label>
              <Input type="number" value={form.duracao_minutos} onChange={e => setF('duracao_minutos', e.target.value)} />
            </div>
            <div className="space-y-1.5">
              <Label>Tipo</Label>
              <Select value={form.tipo} onValueChange={v => setF('tipo', v)}>
                <SelectTrigger><SelectValue /></SelectTrigger>
                <SelectContent>{tipoOpts.map(o => <SelectItem key={o} value={o} className="capitalize">{o}</SelectItem>)}</SelectContent>
              </Select>
            </div>
            <div className="space-y-1.5">
              <Label>Status</Label>
              <Select value={form.status} onValueChange={v => setF('status', v)}>
                <SelectTrigger><SelectValue /></SelectTrigger>
                <SelectContent>{statusOpts.map(o => <SelectItem key={o} value={o} className="capitalize">{o.replace('_', ' ')}</SelectItem>)}</SelectContent>
              </Select>
            </div>
            <div className="space-y-1.5">
              <Label>Convênio</Label>
              <Select value={form.convenio_id || 'nenhum'} onValueChange={v => {
                if (v === 'nenhum') { setF('convenio_id', ''); setF('convenio_nome', ''); }
                else { const c = convenios.find(x => x.id === v); setF('convenio_id', v); setF('convenio_nome', c?.nome || ''); }
              }}>
                <SelectTrigger><SelectValue placeholder="Particular" /></SelectTrigger>
                <SelectContent>
                  <SelectItem value="nenhum">Particular</SelectItem>
                  {convenios.map(c => <SelectItem key={c.id} value={c.id}>{c.nome}</SelectItem>)}
                </SelectContent>
              </Select>
            </div>
            {/* Valor e forma de pagamento: só mostra se tem serviço avulso */}
            {temServicoAvulso && (
              <div className="space-y-1.5">
                <Label>Valor (R$)</Label>
                <Input type="number" value={form.valor} onChange={e => setF('valor', e.target.value)} placeholder="0,00" />
              </div>
            )}
            {todosServicosDeOrcamento && (
              <div className="col-span-2">
                <div className="flex items-center gap-2 px-3 py-2 rounded-lg bg-amber-50 border border-amber-200 text-amber-800 text-sm">
                  <ShoppingBag className="w-4 h-4 shrink-0" />
                  <span>Serviços pré-pagos via orçamento — sem cobrança adicional.</span>
                </div>
              </div>
            )}
            {temServicoAvulso && (
              <div className="col-span-2 space-y-1.5">
                <Label>Forma de Pagamento</Label>
                <Select value={form.forma_pagamento} onValueChange={v => setF('forma_pagamento', v)}>
                  <SelectTrigger><SelectValue /></SelectTrigger>
                  <SelectContent>{pgOpts.map(o => <SelectItem key={o} value={o} className="capitalize">{o.replace('_', ' ')}</SelectItem>)}</SelectContent>
                </Select>
              </div>
            )}
            {temVendaVinculada && !temServicoAvulso && formaPagamentoVenda && (
              <div className="col-span-2 space-y-1.5">
                <Label>Forma de Pagamento</Label>
                <div className="flex h-9 items-center px-3 rounded-md border border-input bg-muted/40 text-sm text-muted-foreground capitalize">
                  {formaPagamentoVenda.replace('_', ' ')} <span className="ml-2 text-xs bg-amber-100 text-amber-700 rounded px-1.5 py-0.5">venda</span>
                </div>
              </div>
            )}
            <div className="col-span-2 space-y-1.5">
              <Label>Observações</Label>
              <Input value={form.observacoes} onChange={e => setF('observacoes', e.target.value)} placeholder="Opcional" />
            </div>
          </div>

          {/* Gerar Venda — só para serviços avulsos (sem orçamento) */}
          {temServicoAvulso && (
            <div className="space-y-3">
              <button
                onClick={() => setGerarVenda(!gerarVenda)}
                className={`w-full flex items-center gap-3 px-4 py-3 rounded-xl border-2 transition-all text-left ${gerarVenda ? 'border-primary bg-primary/5' : 'border-border hover:border-primary/40 bg-card'}`}
              >
                <div className={`w-5 h-5 rounded border-2 flex items-center justify-center shrink-0 transition-colors ${gerarVenda ? 'bg-primary border-primary' : 'border-muted-foreground'}`}>
                  {gerarVenda && <span className="text-primary-foreground text-xs font-bold">✓</span>}
                </div>
                <div>
                  <div className="flex items-center gap-2 text-sm font-medium">
                    <Receipt className="w-4 h-4 text-primary" />
                    Gerar Venda {(form.valor && Number(form.valor) > 0) ? `— ${formatCurrency(Number(form.valor))}` : ''}
                  </div>
                  <p className="text-xs text-muted-foreground mt-0.5">Registrar o recebimento desta consulta</p>
                </div>
              </button>

              {gerarVenda && (
                <div className="ml-2 pl-4 border-l-2 border-primary/30 space-y-3">
                  <div className="grid grid-cols-2 gap-2">
                    <button
                      onClick={() => setTipoVenda('avista')}
                      className={`px-3 py-2.5 rounded-lg border-2 text-sm font-medium text-left transition-all ${tipoVenda === 'avista' ? 'border-primary bg-primary/5 text-primary' : 'border-border hover:border-primary/30'}`}
                    >
                      💰 À Vista
                      <p className="text-xs font-normal text-muted-foreground mt-0.5">Entra na conta bancária</p>
                    </button>
                    <button
                      onClick={() => setTipoVenda('contas_receber')}
                      className={`px-3 py-2.5 rounded-lg border-2 text-sm font-medium text-left transition-all ${tipoVenda === 'contas_receber' ? 'border-primary bg-primary/5 text-primary' : 'border-border hover:border-primary/30'}`}
                    >
                      📋 Contas a Receber
                      <p className="text-xs font-normal text-muted-foreground mt-0.5">Fica em aberto</p>
                    </button>
                  </div>

                  {tipoVenda === 'avista' && (
                    <div className="space-y-1.5">
                      <Label>Conta Bancária</Label>
                      <Select value={contaBancariaId} onValueChange={setContaBancariaId}>
                        <SelectTrigger><SelectValue placeholder="Selecionar conta..." /></SelectTrigger>
                        <SelectContent>
                          {contasBancarias.map(c => (
                            <SelectItem key={c.id} value={c.id}>{c.nome}</SelectItem>
                          ))}
                        </SelectContent>
                      </Select>
                    </div>
                  )}
                </div>
              )}
            </div>
          )}
        </div>

        <div className="flex items-center gap-2 p-5 border-t border-border">
          {consulta && (
            <Button variant="destructive" size="sm" onClick={handleDelete}>
              <Trash2 className="w-4 h-4" />
            </Button>
          )}
          <Button
            variant="outline"
            size="sm"
            className="gap-1.5 text-emerald-700 border-emerald-300 hover:bg-emerald-50"
            onClick={() => setProdutoVendaOpen(true)}
          >
            <ShoppingCart className="w-4 h-4" /> Produtos
          </Button>
          <div className="flex-1" />
          <Button variant="outline" onClick={onClose}>Cancelar</Button>
          <Button onClick={handleSave} disabled={saving}>{saving ? 'Salvando...' : 'Salvar'}</Button>
        </div>
      </div>

      {produtoVendaOpen && (
        <ProdutoVendaModal
          dataHora={form.data_hora ? new Date(form.data_hora) : new Date()}
          onClose={() => setProdutoVendaOpen(false)}
          onSaved={() => setProdutoVendaOpen(false)}
        />
      )}
    </div>
  );
}

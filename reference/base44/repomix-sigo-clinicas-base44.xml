<file path="src/pages/financeiro/ContaDetalhe.jsx">
import { useEffect, useState, useMemo, useRef } from 'react';
import { base44 } from '@/api/base44Client';
import { format, parseISO } from 'date-fns';
import { ptBR } from 'date-fns/locale';
import {
  ArrowLeft, Search, Upload, CheckCircle2, XCircle, AlertCircle, Link2, Unlink,
  TrendingUp, TrendingDown, DollarSign, FileText, Info
} from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Badge } from '@/components/ui/badge';
import LancamentoModal from '@/components/financeiro/LancamentoModal';

const fmt = v => new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v || 0);

const statusColor = {
  pendente: 'bg-yellow-100 text-yellow-700',
  pago_parcial: 'bg-orange-100 text-orange-700',
  pago: 'bg-green-100 text-green-700',
  cancelado: 'bg-gray-100 text-gray-600',
  atrasado: 'bg-red-100 text-red-600',
};
const statusLabel = { pendente: 'Pendente', pago_parcial: 'Parcial', pago: 'Pago', cancelado: 'Cancelado', atrasado: 'Atrasado' };

// Parse de extrato CSV simples: data;descrição;valor (positivo=crédito, negativo=débito)
function parseExtratoCSV(text) {
  const lines = text.trim().split('\n').filter(Boolean);
  const result = [];
  for (const line of lines) {
    const cols = line.split(/[;,\t]/).map(c => c.trim().replace(/^"|"$/g, ''));
    if (cols.length < 3) continue;
    const [dataRaw, descricao, valorRaw] = cols;
    const valor = parseFloat(valorRaw.replace(',', '.'));
    if (isNaN(valor)) continue;
    // Tenta parsear data nos formatos dd/MM/yyyy ou yyyy-MM-dd
    let data = null;
    if (dataRaw.includes('/')) {
      const [d, m, y] = dataRaw.split('/');
      data = `${y}-${m.padStart(2,'0')}-${d.padStart(2,'0')}`;
    } else {
      data = dataRaw.slice(0, 10);
    }
    result.push({ data, descricao, valor, tipo: valor >= 0 ? 'entrada' : 'saida', conciliado: false });
  }
  return result;
}

export default function ContaDetalhe({ conta, onBack, onReload }) {
  const [lancamentos, setLancamentos] = useState([]);
  const [loading, setLoading] = useState(true);
  const [aba, setAba] = useState('lancamentos'); // 'lancamentos' | 'conciliacao'
  const [busca, setBusca] = useState('');
  const [modalLanc, setModalLanc] = useState(null);
  const [modalOpen, setModalOpen] = useState(false);

  // Conciliação
  const [extratoLinhas, setExtratoLinhas] = useState([]);
  const [extratoNome, setExtratoNome] = useState('');
  const [matchMap, setMatchMap] = useState({}); // extratoIdx -> lancamentoId
  const [conciliacoes, setConciliacoes] = useState({}); // lancamentoId -> { conciliado, data_conciliacao }
  const fileRef = useRef();

  useEffect(() => { load(); }, [conta.id]);

  async function load() {
    setLoading(true);
    const lancs = await base44.entities.LancamentoFinanceiro.list('-data_vencimento', 500);
    // Filtra lançamentos que têm conta_id ou foram vinculados via MovimentacaoConta
    const movs = await base44.entities.MovimentacaoConta.filter({ conta_id: conta.id }, '-data', 500);
    const lancIds = new Set(movs.map(m => m.lancamento_financeiro_id).filter(Boolean));
    const filtered = lancs.filter(l => lancIds.has(l.id));
    setLancamentos(filtered);

    // Carrega estado de conciliação salvo (reutilizamos campo observacoes pra não criar entidade nova)
    const concMap = {};
    filtered.forEach(l => {
      if (l._conciliado) concMap[l.id] = { conciliado: true, data_conciliacao: l._data_conciliacao };
    });
    setConciliacoes(concMap);
    setLoading(false);
  }

  const filtrados = useMemo(() => {
    return lancamentos.filter(l =>
      !busca || l.descricao?.toLowerCase().includes(busca.toLowerCase()) || l.paciente_nome?.toLowerCase().includes(busca.toLowerCase())
    );
  }, [lancamentos, busca]);

  // KPIs
  const totalRecebido = lancamentos.filter(l => l.tipo === 'receita' && (l.status === 'pago' || l.status === 'pago_parcial')).reduce((s, l) => s + (l.valor_pago || l.valor || 0), 0);
  const totalPago = lancamentos.filter(l => l.tipo === 'despesa' && (l.status === 'pago' || l.status === 'pago_parcial')).reduce((s, l) => s + (l.valor_pago || l.valor || 0), 0);
  const totalPendente = lancamentos.filter(l => ['pendente', 'pago_parcial', 'atrasado'].includes(l.status)).reduce((s, l) => s + (l.saldo_em_aberto ?? l.valor ?? 0), 0);
  const totalConciliados = Object.values(conciliacoes).filter(c => c.conciliado).length;

  // É de venda? lançamentos com consulta_id ou que tenham descrição típica de venda
  function isDeVenda(lanc) {
    return !!(lanc.consulta_id || lanc._origem_venda);
  }

  // Upload extrato
  function handleUpload(e) {
    const file = e.target.files[0];
    if (!file) return;
    setExtratoNome(file.name);
    const reader = new FileReader();
    reader.onload = ev => {
      const linhas = parseExtratoCSV(ev.target.result);
      setExtratoLinhas(linhas);
      setMatchMap({});
    };
    reader.readAsText(file, 'UTF-8');
    e.target.value = '';
  }

  // Auto-matching por valor e data aproximada (±3 dias)
  function autoMatch() {
    const newMap = {};
    extratoLinhas.forEach((el, idx) => {
      const match = lancamentos.find(l => {
        const valOk = Math.abs((el.tipo === 'entrada' ? l.valor : -l.valor) - el.valor) < 0.02;
        if (!valOk) return false;
        if (!l.data_vencimento) return false;
        const diff = Math.abs(new Date(el.data) - new Date(l.data_vencimento)) / 86400000;
        return diff <= 3;
      });
      if (match && !Object.values(newMap).includes(match.id)) {
        newMap[idx] = match.id;
      }
    });
    setMatchMap(newMap);
  }

  async function confirmarConciliacao(extratoIdx) {
    const lancId = matchMap[extratoIdx];
    if (!lancId) return;
    const hoje = format(new Date(), 'yyyy-MM-dd');
    const newConc = { ...conciliacoes, [lancId]: { conciliado: true, data_conciliacao: hoje } };
    setConciliacoes(newConc);
    // Salva no lançamento financeiro via campo observacoes (append)
    const lanc = lancamentos.find(l => l.id === lancId);
    if (lanc) {
      await base44.entities.LancamentoFinanceiro.update(lancId, {
        _conciliado: true,
        _data_conciliacao: hoje,
      });
    }
    setExtratoLinhas(el => el.map((l, i) => i === extratoIdx ? { ...l, conciliado: true } : l));
  }

  async function desconciliar(lancId) {
    const newConc = { ...conciliacoes };
    delete newConc[lancId];
    setConciliacoes(newConc);
    await base44.entities.LancamentoFinanceiro.update(lancId, { _conciliado: false, _data_conciliacao: null });
  }

  return (
    <div className="p-6 space-y-5">
      {/* Header */}
      <div className="flex items-center gap-3">
        <button onClick={onBack} className="p-2 rounded-lg hover:bg-muted text-muted-foreground hover:text-foreground transition-colors">
          <ArrowLeft className="w-5 h-5" />
        </button>
        <div>
          <h1 className="text-xl font-semibold">{conta.nome}</h1>
          <p className="text-xs text-muted-foreground">{conta.banco ? `${conta.banco} • Ag: ${conta.agencia} • Cc: ${conta.numero_conta}` : 'Conta sem banco vinculado'}</p>
        </div>
        <div className="ml-auto flex items-center gap-2">
          <div className="text-right">
            <p className="text-xs text-muted-foreground">Saldo Atual</p>
            <p className={`text-lg font-bold ${(conta.saldo_atual || 0) >= 0 ? 'text-green-600' : 'text-red-600'}`}>{fmt(conta.saldo_atual || 0)}</p>
          </div>
        </div>
      </div>

      {/* KPIs */}
      <div className="grid grid-cols-2 lg:grid-cols-4 gap-3">
        {[
          { label: 'Recebido', value: totalRecebido, color: 'text-green-600', bg: 'bg-green-50', icon: TrendingUp },
          { label: 'Pago', value: totalPago, color: 'text-red-600', bg: 'bg-red-50', icon: TrendingDown },
          { label: 'Pendente', value: totalPendente, color: 'text-yellow-600', bg: 'bg-yellow-50', icon: DollarSign },
          { label: 'Conciliados', value: null, color: 'text-blue-600', bg: 'bg-blue-50', icon: CheckCircle2, extra: `${totalConciliados} de ${lancamentos.length}` },
        ].map((k, i) => (
          <div key={i} className={`${k.bg} border border-border rounded-xl p-4 flex items-center gap-3`}>
            <k.icon className={`w-5 h-5 ${k.color} shrink-0`} />
            <div>
              <p className="text-xs text-muted-foreground font-medium">{k.label}</p>
              <p className={`text-base font-bold ${k.color}`}>{k.extra || fmt(k.value)}</p>
            </div>
          </div>
        ))}
      </div>

      {/* Abas */}
      <div className="flex rounded-lg border border-border overflow-hidden w-fit text-sm">
        <button onClick={() => setAba('lancamentos')} className={`px-5 py-2 font-medium transition-colors ${aba === 'lancamentos' ? 'bg-primary text-primary-foreground' : 'bg-card hover:bg-muted'}`}>
          Lançamentos
        </button>
        <button onClick={() => setAba('conciliacao')} className={`px-5 py-2 font-medium transition-colors flex items-center gap-1.5 ${aba === 'conciliacao' ? 'bg-primary text-primary-foreground' : 'bg-card hover:bg-muted'}`}>
          <Link2 className="w-4 h-4" /> Conciliação
        </button>
      </div>

      {/* ABA LANÇAMENTOS */}
      {aba === 'lancamentos' && (
        <div className="space-y-3">
          <div className="relative">
            <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground" />
            <Input className="pl-9" placeholder="Buscar lançamento..." value={busca} onChange={e => setBusca(e.target.value)} />
          </div>

          <div className="bg-card rounded-xl border border-border overflow-hidden">
            <table className="w-full text-sm">
              <thead className="bg-muted/50">
                <tr>
                  <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Descrição</th>
                  <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase hidden sm:table-cell">Tipo</th>
                  <th className="text-right px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Valor</th>
                  <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase hidden md:table-cell">Vencimento</th>
                  <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Status</th>
                  <th className="text-center px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Conciliado</th>
                  <th className="text-center px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Ações</th>
                </tr>
              </thead>
              <tbody>
                {loading ? (
                  <tr><td colSpan={7} className="text-center py-12 text-muted-foreground">Carregando...</td></tr>
                ) : filtrados.length === 0 ? (
                  <tr><td colSpan={7} className="text-center py-12 text-muted-foreground">Nenhum lançamento encontrado</td></tr>
                ) : filtrados.map(l => {
                  const conc = conciliacoes[l.id];
                  const deVenda = isDeVenda(l);
                  return (
                    <tr key={l.id} className="border-t border-border hover:bg-muted/20">
                      <td className="px-4 py-3">
                        <div className="font-medium">{l.descricao}</div>
                        {l.paciente_nome && <div className="text-xs text-muted-foreground">{l.paciente_nome}</div>}
                        {deVenda && (
                          <span className="inline-flex items-center gap-1 text-xs text-blue-600 bg-blue-50 px-1.5 py-0.5 rounded mt-0.5">
                            <FileText className="w-3 h-3" /> Gerado por venda
                          </span>
                        )}
                      </td>
                      <td className="px-4 py-3 hidden sm:table-cell">
                        <span className={`px-2 py-0.5 rounded-full text-xs font-medium ${l.tipo === 'receita' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-600'}`}>
                          {l.tipo === 'receita' ? 'Receita' : 'Despesa'}
                        </span>
                      </td>
                      <td className={`px-4 py-3 text-right font-semibold ${l.tipo === 'receita' ? 'text-green-700' : 'text-red-600'}`}>{fmt(l.valor)}</td>
                      <td className="px-4 py-3 text-muted-foreground hidden md:table-cell">{l.data_vencimento ? format(parseISO(l.data_vencimento), 'dd/MM/yyyy') : '—'}</td>
                      <td className="px-4 py-3">
                        <span className={`px-2 py-0.5 rounded-full text-xs font-medium ${statusColor[l.status] || statusColor.pendente}`}>
                          {statusLabel[l.status] || l.status}
                        </span>
                      </td>
                      <td className="px-4 py-3 text-center">
                        {conc?.conciliado ? (
                          <div className="flex flex-col items-center gap-0.5">
                            <CheckCircle2 className="w-4 h-4 text-green-600" />
                            <span className="text-xs text-muted-foreground">{conc.data_conciliacao ? format(parseISO(conc.data_conciliacao), 'dd/MM/yy') : ''}</span>
                          </div>
                        ) : (
                          <XCircle className="w-4 h-4 text-muted-foreground mx-auto" />
                        )}
                      </td>
                      <td className="px-4 py-3 text-center">
                        <div className="flex items-center justify-center gap-1.5">
                          {deVenda ? (
                            <span className="text-xs text-muted-foreground italic" title="Gerado por venda — edite pela venda">
                              <Info className="w-4 h-4" />
                            </span>
                          ) : (
                            <button
                              onClick={() => { setModalLanc(l); setModalOpen(true); }}
                              className="text-xs text-muted-foreground hover:text-foreground px-2 py-1 rounded hover:bg-muted transition-colors"
                            >
                              ✏️
                            </button>
                          )}
                          {conc?.conciliado && (
                            <button
                              onClick={() => desconciliar(l.id)}
                              className="text-xs text-orange-600 hover:text-orange-700 px-2 py-1 rounded hover:bg-orange-50 transition-colors flex items-center gap-0.5"
                              title="Desconciliar"
                            >
                              <Unlink className="w-3.5 h-3.5" />
                            </button>
                          )}
                        </div>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </div>
      )}

      {/* ABA CONCILIAÇÃO */}
      {aba === 'conciliacao' && (
        <div className="space-y-4">
          {/* Upload extrato */}
          <div className="bg-card border border-border rounded-xl p-5 space-y-3">
            <div className="flex items-center justify-between">
              <div>
                <h3 className="font-semibold text-sm">Extrato Bancário</h3>
                <p className="text-xs text-muted-foreground mt-0.5">Carregue um arquivo CSV com colunas: Data;Descrição;Valor (positivo=crédito, negativo=débito)</p>
              </div>
              <Button size="sm" variant="outline" className="gap-1.5" onClick={() => fileRef.current?.click()}>
                <Upload className="w-4 h-4" /> Carregar Extrato
              </Button>
              <input ref={fileRef} type="file" accept=".csv,.txt" className="hidden" onChange={handleUpload} />
            </div>
            {extratoNome && (
              <div className="flex items-center gap-2 text-xs text-muted-foreground">
                <FileText className="w-4 h-4" /> {extratoNome} · {extratoLinhas.length} linha(s)
                {extratoLinhas.length > 0 && (
                  <button onClick={autoMatch} className="ml-2 px-2 py-1 bg-blue-50 text-blue-700 rounded hover:bg-blue-100 text-xs font-medium">
                    ⚡ Auto-matching
                  </button>
                )}
              </div>
            )}
          </div>

          {extratoLinhas.length > 0 && (
            <div className="bg-card border border-border rounded-xl overflow-hidden">
              <div className="bg-muted/40 px-4 py-3 border-b border-border">
                <p className="text-sm font-semibold">Linhas do Extrato × Lançamentos</p>
              </div>
              <div className="divide-y divide-border">
                {extratoLinhas.map((el, idx) => {
                  const lancId = matchMap[idx];
                  const lanc = lancamentos.find(l => l.id === lancId);
                  const jaConciliado = lancId && conciliacoes[lancId]?.conciliado;
                  return (
                    <div key={idx} className={`px-4 py-3 flex items-start gap-4 ${el.conciliado || jaConciliado ? 'bg-green-50/40' : ''}`}>
                      {/* Extrato */}
                      <div className="flex-1 min-w-0">
                        <div className="flex items-center gap-2">
                          <span className={`text-xs font-bold ${el.valor >= 0 ? 'text-green-700' : 'text-red-600'}`}>{fmt(el.valor)}</span>
                          <span className="text-xs text-muted-foreground">{el.data ? format(parseISO(el.data), 'dd/MM/yyyy', { locale: ptBR }) : '—'}</span>
                        </div>
                        <p className="text-sm font-medium truncate">{el.descricao}</p>
                      </div>

                      {/* Seta */}
                      <div className="text-muted-foreground shrink-0 pt-1">
                        <Link2 className={`w-4 h-4 ${lancId ? 'text-blue-500' : ''}`} />
                      </div>

                      {/* Match */}
                      <div className="flex-1 min-w-0">
                        <select
                          className="w-full text-xs border border-border rounded px-2 py-1.5 bg-background"
                          value={lancId || ''}
                          onChange={e => setMatchMap(m => ({ ...m, [idx]: e.target.value || undefined }))}
                          disabled={el.conciliado || jaConciliado}
                        >
                          <option value="">— Selecionar lançamento —</option>
                          {lancamentos
                            .filter(l => !Object.entries(matchMap).some(([i, id]) => id === l.id && Number(i) !== idx))
                            .map(l => (
                              <option key={l.id} value={l.id}>
                                {format(l.data_vencimento ? parseISO(l.data_vencimento) : new Date(), 'dd/MM')} · {l.descricao.slice(0, 30)} · {fmt(l.valor)}
                              </option>
                            ))}
                        </select>
                        {lanc && (
                          <div className="flex items-center gap-1 mt-1">
                            <span className={`text-xs px-1.5 py-0.5 rounded ${statusColor[lanc.status]}`}>{statusLabel[lanc.status]}</span>
                            {conciliacoes[lanc.id]?.conciliado && <span className="text-xs text-green-600 font-medium flex items-center gap-0.5"><CheckCircle2 className="w-3 h-3" /> Conciliado</span>}
                          </div>
                        )}
                      </div>

                      {/* Ação */}
                      <div className="shrink-0 pt-1">
                        {el.conciliado || jaConciliado ? (
                          <CheckCircle2 className="w-5 h-5 text-green-600" />
                        ) : (
                          <button
                            onClick={() => confirmarConciliacao(idx)}
                            disabled={!lancId}
                            className="px-2.5 py-1 rounded text-xs font-semibold bg-blue-600 text-white hover:bg-blue-700 disabled:opacity-40 disabled:cursor-not-allowed"
                          >
                            Confirmar
                          </button>
                        )}
                      </div>
                    </div>
                  );
                })}
              </div>

              {/* Resumo */}
              <div className="bg-muted/30 px-4 py-3 border-t border-border flex gap-4 text-xs text-muted-foreground">
                <span className="text-green-600 font-medium">{extratoLinhas.filter(l => l.conciliado).length} conciliado(s)</span>
                <span>{extratoLinhas.filter(l => !l.conciliado).length} pendente(s)</span>
                <span>Total extrato: {fmt(extratoLinhas.reduce((s, l) => s + l.valor, 0))}</span>
              </div>
            </div>
          )}

          {extratoLinhas.length === 0 && (
            <div className="text-center py-16 text-muted-foreground border border-dashed border-border rounded-xl">
              <Upload className="w-10 h-10 mx-auto mb-3 opacity-30" />
              <p className="font-medium">Nenhum extrato carregado</p>
              <p className="text-xs mt-1">Carregue um arquivo CSV para iniciar a conciliação</p>
            </div>
          )}
        </div>
      )}

      {modalOpen && (
        <LancamentoModal
          lancamento={modalLanc}
          onClose={() => setModalOpen(false)}
          onSaved={() => { setModalOpen(false); load(); onReload?.(); }}
        />
      )}
    </div>
  );
}
</file>


export default function VendasFaturamento({ orcamentos, onEdit, onRefresh }) {
  const [expandido, setExpandido] = useState(null);

  const vendidos = orcamentos.filter(o => o.venda_data);

  const totalFaturado = vendidos.reduce((s, o) => s + (o.valor_final ?? o.valor_total ?? 0), 0);
  const totalRecebido = vendidos.reduce((s, o) => {
    const pagas = (o.venda_parcelas || []).filter(p => p.pago).reduce((acc, p) => acc + (p.valor || 0), 0);
    return s + pagas;
  }, 0);
  const totalPendente = totalFaturado - totalRecebido;

  async function marcarParcela(orc, parcIdx, pago) {
    const parcelas = (orc.venda_parcelas || []).map((p, i) =>
      i === parcIdx ? { ...p, pago, data_pagamento: pago ? format(new Date(), 'yyyy-MM-dd') : null } : p
    );
    await base44.entities.Orcamento.update(orc.id, { venda_parcelas: parcelas });
    onRefresh();
  }

  if (vendidos.length === 0) {
    return (
      <div className="text-center py-20 text-muted-foreground">
        <DollarSign className="w-12 h-12 mx-auto mb-3 opacity-20" />
        <p className="font-medium">Nenhuma venda registrada ainda.</p>
        <p className="text-sm mt-1">Mova um orçamento para "Aprovado" e clique em "Vender".</p>
      </div>
    );
  }

  return (
    <div className="space-y-5">
      {/* KPIs */}
      <div className="grid grid-cols-3 gap-4">
        {[
          { label: 'Total Faturado', value: totalFaturado, color: 'text-primary' },
          { label: 'Recebido', value: totalRecebido, color: 'text-green-600' },
          { label: 'Pendente', value: totalPendente, color: 'text-amber-600' },
        ].map(kpi => (
          <div key={kpi.label} className="bg-card border border-border rounded-xl p-4 space-y-1">
            <p className="text-xs text-muted-foreground">{kpi.label}</p>
            <p className={`text-xl font-bold ${kpi.color}`}>{formatCurrency(kpi.value)}</p>
          </div>
        ))}
      </div>

      {/* Lista */}
      <div className="space-y-3">
        {vendidos.map(orc => {
          const parcelas = orc.venda_parcelas || [];
          const totalParc = parcelas.length;
          const pagas = parcelas.filter(p => p.pago).length;
          const isOpen = expandido === orc.id;

          return (
            <div key={orc.id} className="bg-card border border-border rounded-xl overflow-hidden">
              <div
                className="flex items-center gap-4 p-4 cursor-pointer hover:bg-muted/20 transition-colors"
                onClick={() => setExpandido(isOpen ? null : orc.id)}
              >
                <div className="flex-1 min-w-0">
                  <div className="flex items-center gap-2 flex-wrap">
                    <span className="font-semibold">{orc.cliente_nome}</span>
                    <span className="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full font-medium">Vendido</span>
                  </div>
                  <div className="text-xs text-muted-foreground mt-0.5">
                    {orc.venda_data && `Venda em ${format(new Date(orc.venda_data), "dd/MM/yyyy", { locale: ptBR })}`}
                    {orc.profissional_nome && ` · ${orc.profissional_nome}`}
                    {totalParc > 0 && ` · ${pagas}/${totalParc} parcelas pagas`}
                  </div>
                </div>
                <div className="text-right shrink-0">
                  <div className="font-bold text-primary">{formatCurrency(orc.valor_final ?? orc.valor_total)}</div>
                  {orc.venda_forma_pagamento && (
                    <div className="text-xs text-muted-foreground capitalize">{orc.venda_forma_pagamento.replace('_', ' ')}</div>
                  )}
                </div>
                <div className="text-muted-foreground">
                  {isOpen ? <ChevronUp className="w-4 h-4" /> : <ChevronDown className="w-4 h-4" />}
                </div>
              </div>

              {isOpen && (
                <div className="border-t border-border bg-muted/10 p-4 space-y-3">
                  {/* Serviços */}
                  <div>
                    <p className="text-xs font-semibold text-muted-foreground uppercase mb-2">Serviços</p>
                    <div className="space-y-1">
                      {(orc.itens || []).map((item, i) => (
                        <div key={i} className="flex items-center justify-between text-sm">
                          <span>{item.servico_nome} {item.quantidade > 1 ? `×${item.quantidade}` : ''}</span>
                          <span className="font-medium">{item.tipo_valor === 'gratuito' ? 'Grátis' : formatCurrency(item.valor_total)}</span>
                        </div>
                      ))}
                    </div>
                  </div>

                  {/* Parcelas */}
                  {parcelas.length > 0 && (
                    <div>
                      <p className="text-xs font-semibold text-muted-foreground uppercase mb-2">Parcelas</p>
                      <div className="space-y-1.5">
                        {parcelas.map((p, i) => (
                          <div key={i} className="flex items-center gap-3 bg-card rounded-lg px-3 py-2 border border-border">
                            <button
                              onClick={() => marcarParcela(orc, i, !p.pago)}
                              className={`w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 transition-colors ${p.pago ? 'bg-green-500 border-green-500' : 'border-border hover:border-green-400'}`}
                            >
                              {p.pago && <CheckCircle2 className="w-3.5 h-3.5 text-white" />}
                            </button>
                            <span className="text-xs text-muted-foreground flex-1">
                              Parcela {p.numero} · {p.vencimento?.split('-').reverse().join('/')}
                              {p.data_pagamento && ` · Pago em ${p.data_pagamento.split('-').reverse().join('/')}`}
                            </span>
                            <span className={`text-sm font-medium ${p.pago ? 'text-green-600 line-through opacity-60' : ''}`}>
                              {formatCurrency(p.valor)}
                            </span>
                            {!p.pago && (
                              <Clock className="w-3.5 h-3.5 text-amber-500 shrink-0" />
                            )}
                          </div>
                        ))}
                      </div>
                    </div>
                  )}

                  <div className="flex justify-end">
                    <button onClick={() => onEdit(orc)} className="flex items-center gap-1.5 text-xs text-primary hover:underline">
                      <Edit2 className="w-3.5 h-3.5" /> Editar orçamento
                    </button>
                  </div>
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>
  );
}
</file>

<file path="src/components/pacientes/AbaAnamnesePaciente.jsx">
import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { CheckCircle2, Clock, ClipboardList, Eye, ChevronDown, ChevronUp } from 'lucide-react';
import { format } from 'date-fns';
import { ptBR } from 'date-fns/locale';

export default function AbaAnamnesePaciente({ paciente }) {
  const [respostas, setRespostas] = useState([]);
  const [loading, setLoading] = useState(true);
  const [expandido, setExpandido] = useState(null);

  useEffect(() => { load(); }, [paciente.id]);

  async function load() {
    const r = await base44.entities.RespostaAnamnese.filter({ paciente_id: paciente.id }, '-created_date');
    setRespostas(r);
    setLoading(false);
  }

  if (loading) return <p className="text-sm text-muted-foreground py-4">Carregando...</p>;

  if (respostas.length === 0) {
    return (
      <div className="text-center py-10 text-muted-foreground border border-dashed border-border rounded-xl">
        <ClipboardList className="w-8 h-8 mx-auto mb-2 opacity-30" />
        <p className="text-sm">Nenhuma ficha de anamnese enviada ainda.</p>
        <p className="text-xs mt-1">Envie um formulário pela seção de Anamnese.</p>
      </div>
    );
  }

  return (
    <div className="space-y-3">
      {respostas.map(r => (
        <div key={r.id} className="border border-border rounded-xl overflow-hidden">
          <div className="flex items-center gap-3 p-4">
            <div className={`w-8 h-8 rounded-full flex items-center justify-center shrink-0 ${
              r.status === 'preenchido' ? 'bg-green-100' : 'bg-amber-100'
            }`}>
              {r.status === 'preenchido'
                ? <CheckCircle2 className="w-4 h-4 text-green-600" />
                : <Clock className="w-4 h-4 text-amber-600" />
              }
            </div>
            <div className="flex-1 min-w-0">
              <p className="font-medium text-sm truncate">{r.formulario_nome}</p>
              <p className="text-xs text-muted-foreground">
                {r.status === 'preenchido'
                  ? `Preenchido em ${r.data_preenchimento ? format(new Date(r.data_preenchimento), "dd/MM/yyyy 'às' HH:mm", { locale: ptBR }) : '—'}`
                  : 'Aguardando preenchimento'
                }
              </p>
            </div>
            {r.status === 'preenchido' && (
              <button
                onClick={() => setExpandido(expandido === r.id ? null : r.id)}
                className="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg border border-border text-xs hover:bg-muted transition-colors shrink-0"
              >
                <Eye className="w-3.5 h-3.5" />
                Ver respostas
                {expandido === r.id ? <ChevronUp className="w-3 h-3" /> : <ChevronDown className="w-3 h-3" />}
              </button>
            )}
          </div>

          {expandido === r.id && r.respostas?.length > 0 && (
            <div className="border-t border-border bg-muted/20 p-4 space-y-3">
              {r.respostas.map((resp, i) => (
                <div key={i} className="space-y-0.5">
                  <p className="text-xs font-medium text-muted-foreground">{resp.pergunta_texto}</p>
                  <p className="text-sm">{resp.resposta || <span className="text-muted-foreground italic">Não respondida</span>}</p>
                </div>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  );
}

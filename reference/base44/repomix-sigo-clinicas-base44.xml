import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { X, Trash2, Package } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import AbaComposicao from './AbaComposicao';

export default function ServicoModal({ servico, onClose, onSaved }) {
  const [form, setForm] = useState({
    nome: '',
    codigo: '',
    duracao_minutos: 30,
    especialidade: '',
    requer_validade: false,
    observacoes: '',
    ativo: true,
  });
  const [saving, setSaving] = useState(false);
  const [tab, setTab] = useState('dados');

  useEffect(() => {
    if (servico) setForm({
      nome: servico.nome || '',
      codigo: servico.codigo || '',
      duracao_minutos: servico.duracao_minutos || 30,
      especialidade: servico.especialidade || '',
      requer_validade: servico.requer_validade || false,
      observacoes: servico.observacoes || '',
      ativo: servico.ativo !== false,
    });
  }, [servico]);

  function set(k, v) { setForm(f => ({ ...f, [k]: v })); }

  async function handleSave() {
    if (!form.nome) return alert('Informe o nome do serviço');
    setSaving(true);
    const data = { ...form, duracao_minutos: Number(form.duracao_minutos) };
    if (servico) await base44.entities.Servico.update(servico.id, data);
    else await base44.entities.Servico.create(data);
    setSaving(false);
    onSaved();
  }

  async function handleDelete() {
    if (!confirm('Excluir este serviço?')) return;
    await base44.entities.Servico.delete(servico.id);
    onSaved();
  }

  return (
    <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">

import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { Plus, Activity, Pencil, Trash2, ChevronDown, ChevronUp, Camera, X, AlertTriangle, Printer } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { format } from 'date-fns';
import { ptBR } from 'date-fns/locale';

export default function AbaEvolucao({ paciente }) {
  const [lista, setLista] = useState([]);
  const [loading, setLoading] = useState(true);
  const [editando, setEditando] = useState(null);
  const [expandido, setExpandido] = useState(null);
  const [agendamentos, setAgendamentos] = useState([]);

  useEffect(() => { load(); }, [paciente.id]);

  async function load() {
    setLoading(true);
    const [evol, agend] = await Promise.all([
      base44.entities.EvolucaoSessao.filter({ paciente_id: paciente.id }, '-data_hora'),
      base44.entities.Consulta.filter({ paciente_id: paciente.id, status: 'concluido' }, '-data_hora'),
    ]);
    setLista(evol);
    setAgendamentos(agend);
    setLoading(false);
  }

  async function excluir(id) {
    if (!confirm('Excluir este registro de evolução?')) return;
    await base44.entities.EvolucaoSessao.delete(id);
    load();
  }

  function imprimirEvolucao(ev) {
    const win = window.open('', '_blank');
    win.document.write(`
      <html>
        <head>
          <title>Evolução - ${paciente.nome}</title>
          <style>
            body { font-family: Arial, sans-serif; font-size: 12px; color: #111; margin: 40px; }
            .header { border-bottom: 2px solid #333; padding-bottom: 12px; margin-bottom: 20px; }
            h1 { font-size: 16px; margin: 0 0 4px; }
            .info { font-size: 11px; color: #555; margin: 2px 0; }
            h2 { font-size: 12px; font-weight: bold; margin: 16px 0 6px; border-bottom: 1px solid #ddd; padding-bottom: 2px; }
            .content { white-space: pre-wrap; font-size: 11px; line-height: 1.5; }
            .section { margin: 10px 0; }
            @media print { body { margin: 20px; } }
          </style>
        </head>
        <body>
          <div class="header">
            <h1>Registro de Evolução Clínica</h1>
            <div class="info"><b>Paciente:</b> ${paciente.nome}</div>
            <div class="info"><b>Data:</b> ${new Date(ev.data_hora).toLocaleDateString('pt-BR', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' })}</div>
            ${ev.numero_sessao ? `<div class="info"><b>Sessão:</b> ${ev.numero_sessao}</div>` : ''}
            ${ev.profissional_nome ? `<div class="info"><b>Profissional:</b> ${ev.profissional_nome}</div>` : ''}
          </div>
          ${ev.descricao_atendimento ? `<div class="section"><h2>Descrição do Atendimento</h2><div class="content">${ev.descricao_atendimento}</div></div>` : ''}
          ${ev.reacao_paciente ? `<div class="section"><h2>Reação do Paciente</h2><div class="content">${ev.reacao_paciente}</div></div>` : ''}
          ${ev.intercorrencias ? `<div class="section"><h2>⚠ Intercorrências</h2><div class="content">${ev.intercorrencias}</div></div>` : ''}
          ${ev.insumos_utilizados?.length > 0 ? `<div class="section"><h2>Rastreabilidade de Insumos</h2>${ev.insumos_utilizados.map(ins => `<div style="font-size:10px;margin:4px 0"><b>${ins.produto_nome}</b> ${ins.fabricante ? '· ' + ins.fabricante : ''} ${ins.lote ? '· Lote: ' + ins.lote : ''} ${ins.validade ? '· Val: ' + ins.validade : ''}</div>`).join('')}</div>` : ''}
          ${ev.orientacoes_pos ? `<div class="section"><h2>Orientações Pós-Procedimento</h2><div class="content">${ev.orientacoes_pos}</div></div>` : ''}
          ${ev.prescricao ? `<div class="section"><h2>Prescrição</h2><div class="content">${ev.prescricao}</div></div>` : ''}
        </body>
      </html>
    `);
    win.document.close();
    win.focus();
    win.print();
    win.close();
  }

  if (editando !== null) {
    return (
      <FormEvolucao
        evolucao={editando === 'novo' ? null : editando}
        paciente={paciente}
        agendamentos={agendamentos}
        numeroSessao={lista.length + 1}
        onSaved={() => { setEditando(null); load(); }}
        onCancel={() => setEditando(null)}
      />
    );
  }

  if (loading) return <p className="text-sm text-muted-foreground py-4">Carregando...</p>;

  return (
    <div className="space-y-4">
      <div className="flex items-center justify-between">
        <p className="text-sm text-muted-foreground">{lista.length} registro(s) de evolução</p>
        <Button size="sm" onClick={() => setEditando('novo')} className="gap-1.5">
          <Plus className="w-3.5 h-3.5" /> Nova Evolução
        </Button>
      </div>

      {lista.length === 0 ? (
        <div className="text-center py-10 text-muted-foreground border border-dashed border-border rounded-xl">
          <Activity className="w-8 h-8 mx-auto mb-2 opacity-30" />
          <p className="text-sm">Nenhuma evolução registrada.</p>
        </div>
      ) : (
        <div className="space-y-2">
          {lista.map((ev, idx) => (
            <div key={ev.id} className="bg-card border border-border rounded-xl overflow-hidden">
              <div
                className="p-4 flex items-center gap-3 cursor-pointer hover:bg-muted/30 transition-colors"
                onClick={() => setExpandido(expandido === ev.id ? null : ev.id)}
              >
                <div className="flex items-center justify-center w-8 h-8 rounded-full bg-primary/10 text-primary text-xs font-bold shrink-0">
                  {lista.length - idx}
                </div>
                <div className="flex-1 min-w-0">
                  <div className="font-medium text-sm">{format(new Date(ev.data_hora), "dd/MM/yyyy 'às' HH:mm", { locale: ptBR })}</div>
                  <div className="text-xs text-muted-foreground mt-0.5 truncate">
                    {ev.profissional_nome && `${ev.profissional_nome} · `}
                    {ev.descricao_atendimento?.substring(0, 60)}{ev.descricao_atendimento?.length > 60 ? '...' : ''}
                  </div>
                  {ev.intercorrencias && (
                    <div className="flex items-center gap-1 text-xs text-destructive mt-0.5">
                      <AlertTriangle className="w-3 h-3" /> Intercorrência registrada
                    </div>
                  )}
                </div>
                <div className="flex items-center gap-2 shrink-0">
                  <button onClick={e => { e.stopPropagation(); imprimirEvolucao(ev); }} className="text-muted-foreground hover:text-primary p-1" title="Imprimir evolução">
                    <Printer className="w-3.5 h-3.5" />
                  </button>
                  <button onClick={e => { e.stopPropagation(); setEditando(ev); }} className="text-muted-foreground hover:text-foreground p-1">
                    <Pencil className="w-3.5 h-3.5" />
                  </button>
                  <button onClick={e => { e.stopPropagation(); excluir(ev.id); }} className="text-muted-foreground hover:text-destructive p-1">
                    <Trash2 className="w-3.5 h-3.5" />
                  </button>
                  {expandido === ev.id ? <ChevronUp className="w-4 h-4 text-muted-foreground" /> : <ChevronDown className="w-4 h-4 text-muted-foreground" />}
                </div>
              </div>

              {expandido === ev.id && (
                <div className="border-t border-border p-4 space-y-3 bg-muted/10">
                  {ev.descricao_atendimento && <Info label="Descrição do Atendimento" value={ev.descricao_atendimento} />}
                  {ev.reacao_paciente && <Info label="Reação do Paciente" value={ev.reacao_paciente} />}
                  {ev.intercorrencias && (
                    <div className="space-y-0.5">
                      <p className="text-xs text-muted-foreground font-medium uppercase tracking-wide flex items-center gap-1">
                        <AlertTriangle className="w-3 h-3 text-destructive" /> Intercorrências
                      </p>
                      <p className="text-sm text-destructive bg-destructive/5 rounded-lg p-2">{ev.intercorrencias}</p>
                    </div>
                  )}
                  {ev.insumos_utilizados?.length > 0 && (
                    <div className="space-y-1">
                      <p className="text-xs text-muted-foreground font-medium uppercase tracking-wide">Rastreabilidade de Insumos</p>
                      <div className="space-y-1.5">
                        {ev.insumos_utilizados.map((ins, i) => (
                          <div key={i} className="text-xs bg-background border border-border rounded-lg px-3 py-2">
                            <span className="font-medium">{ins.produto_nome}</span>
                            {ins.fabricante && ` · ${ins.fabricante}`}
                            {ins.lote && <span className="text-muted-foreground"> · Lote: {ins.lote}</span>}
                            {ins.validade && <span className="text-muted-foreground"> · Val: {ins.validade}</span>}
                            {ins.quantidade && <span className="text-muted-foreground"> · Qtd: {ins.quantidade}</span>}
                          </div>
                        ))}
                      </div>
                    </div>
                  )}
                  {ev.orientacoes_pos && <Info label="Orientações Pós-Procedimento" value={ev.orientacoes_pos} />}
                  {ev.prescricao && <Info label="Prescrição" value={ev.prescricao} />}
                  {ev.proxima_sessao_sugerida && <Info label="Próxima Sessão Sugerida" value={format(new Date(ev.proxima_sessao_sugerida), 'dd/MM/yyyy')} />}
                  {ev.fotos_urls?.length > 0 && (
                    <div>
                      <p className="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Fotos</p>
                      <div className="flex gap-2 flex-wrap">
                        {ev.fotos_urls.map((f, i) => (
                          <a key={i} href={f.url} target="_blank" rel="noopener noreferrer">
                            <img src={f.url} alt={f.descricao || `Foto ${i+1}`} className="w-20 h-20 object-cover rounded-lg border border-border hover:opacity-80 transition-opacity" />
                          </a>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              )}
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

function Info({ label, value }) {
  return (
    <div className="space-y-0.5">
      <p className="text-xs text-muted-foreground font-medium uppercase tracking-wide">{label}</p>
      <p className="text-sm whitespace-pre-wrap">{value}</p>
    </div>
  );
}

function FormEvolucao({ evolucao, paciente, agendamentos, numeroSessao, onSaved, onCancel }) {
  const [profissionais, setProfissionais] = useState([]);
  const [saving, setSaving] = useState(false);
  const [uploadingFoto, setUploadingFoto] = useState(false);
  const [consultaSelecionada, setConsultaSelecionada] = useState(evolucao?.consulta_id || '');
  const now = new Date();
  const nowLocal = new Date(now.getTime() - now.getTimezoneOffset() * 60000).toISOString().slice(0, 16);

  const [form, setForm] = useState({
    paciente_id: paciente.id,
    paciente_nome: paciente.nome,
    profissional_id: evolucao?.profissional_id || '',
    profissional_nome: evolucao?.profissional_nome || '',
    data_hora: evolucao?.data_hora ? new Date(evolucao.data_hora).toISOString().slice(0, 16) : nowLocal,
    consulta_id: evolucao?.consulta_id || '',
    descricao_atendimento: evolucao?.descricao_atendimento || '',
    reacao_paciente: evolucao?.reacao_paciente || '',
    intercorrencias: evolucao?.intercorrencias || '',
    insumos_utilizados: evolucao?.insumos_utilizados || [],
    orientacoes_pos: evolucao?.orientacoes_pos || '',
    prescricao: evolucao?.prescricao || '',
    proxima_sessao_sugerida: evolucao?.proxima_sessao_sugerida || '',
    fotos_urls: evolucao?.fotos_urls || [],
    numero_sessao: evolucao?.numero_sessao || numeroSessao,
  });

  useEffect(() => {
    base44.entities.Profissional.list().then(p => setProfissionais(p.filter(x => x.ativo !== false)));
  }, []);

  function set(k, v) { setForm(f => ({ ...f, [k]: v })); }

  function addInsumo() {
    setForm(f => ({ ...f, insumos_utilizados: [...f.insumos_utilizados, { produto_nome: '', fabricante: '', lote: '', validade: '', quantidade: '' }] }));
  }

  function updateInsumo(idx, campo, valor) {
    setForm(f => {
      const ins = [...f.insumos_utilizados];
      ins[idx] = { ...ins[idx], [campo]: valor };
      return { ...f, insumos_utilizados: ins };
    });
  }

  function removeInsumo(idx) {
    setForm(f => ({ ...f, insumos_utilizados: f.insumos_utilizados.filter((_, i) => i !== idx) }));
  }

  async function handleFoto(e) {
    const file = e.target.files[0];
    if (!file) return;
    setUploadingFoto(true);
    const { file_url } = await base44.integrations.Core.UploadFile({ file });
    setForm(f => ({ ...f, fotos_urls: [...f.fotos_urls, { url: file_url, descricao: '' }] }));
    setUploadingFoto(false);
  }

  function removerFoto(idx) {
    setForm(f => ({ ...f, fotos_urls: f.fotos_urls.filter((_, i) => i !== idx) }));
  }

  async function salvar() {
    if (!form.data_hora) return alert('Data e hora são obrigatórias.');
    if (!form.consulta_id) return alert('Selecione um agendamento para vincular a evolução.');
    setSaving(true);
    const payload = { ...form, data_hora: new Date(form.data_hora).toISOString() };
    
    // Gera agendamento automático para próxima sessão sugerida
    if (form.proxima_sessao_sugerida && !evolucao) {
      const consultaSel = agendamentos.find(c => c.id === form.consulta_id);
      if (consultaSel) {
        await base44.entities.Consulta.create({
          paciente_id: form.paciente_id,
          paciente_nome: form.paciente_nome,
          profissional_id: consultaSel.profissional_id,
          profissional_nome: consultaSel.profissional_nome,
          data_hora: form.proxima_sessao_sugerida + 'T09:00',
          duracao_minutos: consultaSel.duracao_minutos || 30,
          tipo: 'retorno',
          status: 'agendado',
          forma_pagamento: 'pendente',
          observacoes: 'Próxima sessão sugerida automaticamente',
        });
      }
    }
    
    if (evolucao) await base44.entities.EvolucaoSessao.update(evolucao.id, payload);
    else await base44.entities.EvolucaoSessao.create(payload);
    setSaving(false);
    onSaved();
  }

  return (
    <div className="space-y-5">
      <button onClick={onCancel} className="text-xs text-muted-foreground hover:text-foreground">← Voltar</button>

      <div className="grid grid-cols-2 gap-3">
        <div className="space-y-1">
          <Label className="text-xs">Agendamento *</Label>
          <select
            className="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm"
            value={form.consulta_id}
            onChange={e => {
              const cons = agendamentos.find(x => x.id === e.target.value);
              set('consulta_id', e.target.value);
              if (cons) {
                set('data_hora', new Date(cons.data_hora).toISOString().slice(0, 16));
                set('profissional_id', cons.profissional_id);
                set('profissional_nome', cons.profissional_nome || '');
              }
            }}
          >
            <option value="">— Selecionar agendamento —</option>
            {agendamentos.map(c => (
              <option key={c.id} value={c.id}>
                {format(new Date(c.data_hora), "dd/MM/yyyy HH:mm", { locale: ptBR })} — {c.paciente_nome}
              </option>
            ))}
          </select>
        </div>
        <div className="space-y-1">
          <Label className="text-xs">Profissional</Label>
          <div className="flex h-9 items-center px-3 rounded-md border border-input bg-muted/30 text-sm text-muted-foreground">
            {form.profissional_nome || 'Será preenchido automaticamente'}
          </div>
        </div>
      </div>

      {/* Registro da Sessão */}
      <Secao titulo="Registro da Sessão">
        <TextArea label="Descrição do Atendimento *" value={form.descricao_atendimento} onChange={v => set('descricao_atendimento', v)} placeholder="O que foi realizado nesta sessão..." rows={4} />
        <TextArea label="Reação do Paciente" value={form.reacao_paciente} onChange={v => set('reacao_paciente', v)} placeholder="Como o paciente reagiu durante e após o procedimento..." />
        <TextArea label="Intercorrências" value={form.intercorrencias} onChange={v => set('intercorrencias', v)} placeholder="Reações inesperadas, complicações (deixe em branco se não houver)..." />
      </Secao>

      {/* Rastreabilidade */}
      <Secao titulo="Rastreabilidade de Insumos">
        <div className="space-y-2">
          {form.insumos_utilizados.map((ins, i) => (
            <div key={i} className="grid grid-cols-2 gap-2 p-3 bg-muted/30 rounded-lg border border-border">
              <div className="col-span-2 flex items-center justify-between">
                <span className="text-xs font-medium text-muted-foreground">Insumo {i + 1}</span>
                <button onClick={() => removeInsumo(i)} className="text-muted-foreground hover:text-destructive">
                  <X className="w-3.5 h-3.5" />
                </button>
              </div>
              <div className="col-span-2 space-y-1">
                <Label className="text-xs">Produto / Medicamento</Label>
                <Input value={ins.produto_nome} onChange={e => updateInsumo(i, 'produto_nome', e.target.value)} placeholder="Ex: Toxina Botulínica, Ácido Hialurônico..." />
              </div>
              <div className="space-y-1">
                <Label className="text-xs">Fabricante</Label>
                <Input value={ins.fabricante} onChange={e => updateInsumo(i, 'fabricante', e.target.value)} placeholder="Ex: Allergan" />
              </div>
              <div className="space-y-1">
                <Label className="text-xs">Quantidade</Label>
                <Input value={ins.quantidade} onChange={e => updateInsumo(i, 'quantidade', e.target.value)} placeholder="Ex: 50 UI, 1ml..." />
              </div>
              <div className="space-y-1">
                <Label className="text-xs">Lote</Label>
                <Input value={ins.lote} onChange={e => updateInsumo(i, 'lote', e.target.value)} placeholder="Número do lote" />
              </div>
              <div className="space-y-1">
                <Label className="text-xs">Validade</Label>
                <Input type="date" value={ins.validade} onChange={e => updateInsumo(i, 'validade', e.target.value)} />
              </div>
            </div>
          ))}
          <Button variant="outline" size="sm" onClick={addInsumo} className="gap-1.5 w-full">
            <Plus className="w-3.5 h-3.5" /> Adicionar Insumo
          </Button>
        </div>
      </Secao>

      {/* Pós-Procedimento */}
      <Secao titulo="Orientações e Prescrição">
        <TextArea label="Orientações Pós-Procedimento" value={form.orientacoes_pos} onChange={v => set('orientacoes_pos', v)} placeholder="Não tomar sol, repouso, cuidados específicos..." />
        <TextArea label="Prescrição (Receituário)" value={form.prescricao} onChange={v => set('prescricao', v)} placeholder="Medicamentos, doses e instruções de uso..." />
        <div className="space-y-1">
          <Label className="text-xs">Próxima Sessão Sugerida</Label>
          <Input type="date" value={form.proxima_sessao_sugerida} onChange={e => set('proxima_sessao_sugerida', e.target.value)} />
        </div>
      </Secao>

      {/* Fotos */}
      <Secao titulo="Fotos da Evolução">
        <div className="flex flex-wrap gap-2">
          {form.fotos_urls.map((f, i) => (
            <div key={i} className="relative">
              <img src={f.url} alt={f.descricao || `Foto ${i+1}`} className="w-20 h-20 object-cover rounded-lg border border-border" />
              <button onClick={() => removerFoto(i)} className="absolute -top-1.5 -right-1.5 bg-destructive text-destructive-foreground rounded-full p-0.5">
                <X className="w-3 h-3" />
              </button>
            </div>
          ))}
          <label className="w-20 h-20 flex flex-col items-center justify-center border-2 border-dashed border-border rounded-lg cursor-pointer hover:bg-muted/30 transition-colors text-muted-foreground">
            {uploadingFoto ? <span className="text-xs">...</span> : <><Camera className="w-5 h-5 mb-1" /><span className="text-xs">Foto</span></>}
            <input type="file" accept="image/*" className="hidden" onChange={handleFoto} disabled={uploadingFoto} />
          </label>
        </div>
      </Secao>

      <div className="flex justify-end gap-2 pt-2">
        <Button variant="outline" size="sm" onClick={onCancel}>Cancelar</Button>
        <Button size="sm" onClick={salvar} disabled={saving}>{saving ? 'Salvando...' : 'Salvar Evolução'}</Button>
      </div>
    </div>
  );
}

function Secao({ titulo, children }) {
  return (
    <div className="border border-border rounded-xl p-4 space-y-3">
      <h3 className="text-sm font-semibold">{titulo}</h3>
      {children}
    </div>
  );
}

function TextArea({ label, value, onChange, placeholder, rows = 3 }) {
  return (
    <div className="space-y-1">
      <Label className="text-xs">{label}</Label>
      <textarea
        className="w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm resize-none focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
        style={{ minHeight: `${rows * 1.75}rem` }}
        value={value}
        onChange={e => onChange(e.target.value)}
        placeholder={placeholder}
      />
    </div>
  );
}

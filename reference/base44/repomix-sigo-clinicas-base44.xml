import { useState, useMemo } from 'react';
import { format, startOfMonth, endOfMonth, parseISO, isWithinInterval, subMonths, isBefore, addDays } from 'date-fns';
import { ptBR } from 'date-fns/locale';
import { Download, BarChart3, Table2, AlertTriangle } from 'lucide-react';
import RastreabilidadeLotes from './RastreabilidadeLotes';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Label } from '@/components/ui/label';

const categoriaLabel = {
  material_consumo: 'Material',
  medicamento: 'Medicamento',
  equipamento: 'Equipamento',
  limpeza: 'Limpeza',
  descartavel: 'Descartável',
  produto_venda: 'Produto para Venda',
  outros: 'Outros',
};

function fmt(v) {
  if (!v && v !== 0) return '—';
  return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v);
}

// Gera meses dos últimos 13 meses
function getMeses() {
  const result = [];
  for (let i = 0; i < 13; i++) {
    const d = subMonths(new Date(), i);
    result.push({
      value: format(d, 'yyyy-MM'),
      label: format(d, 'MMMM yyyy', { locale: ptBR }),
    });
  }
  return result;
}

// ---- Mapa de Calor ----
function HeatmapCell({ value, max, label }) {
  const intensity = max > 0 ? value / max : 0;
  const bg = intensity === 0
    ? 'bg-gray-100 text-gray-400'
    : intensity < 0.25
    ? 'bg-blue-100 text-blue-800'
    : intensity < 0.5
    ? 'bg-blue-300 text-blue-900'
    : intensity < 0.75
    ? 'bg-blue-500 text-white'
    : 'bg-blue-700 text-white';

  return (
    <div className={`rounded p-2 text-center text-xs font-semibold ${bg}`} title={label}>
      <div className="truncate text-[10px] font-normal opacity-80">{label}</div>
      <div className="text-sm font-bold">{value}</div>
    </div>
  );
}

export default function RelatorioEstoque({ itens, movimentacoes }) {
  const meses = getMeses();
  const [tipoFiltro, setTipoFiltro] = useState('mes'); // 'mes' | 'personalizado'
  const [mesSelecionado, setMesSelecionado] = useState(meses[0].value);
  const [dataInicio, setDataInicio] = useState(format(startOfMonth(new Date()), 'yyyy-MM-dd'));
  const [dataFim, setDataFim] = useState(format(endOfMonth(new Date()), 'yyyy-MM-dd'));
  const [filtroClassificacao, setFiltroClassificacao] = useState('todos');
  const [filtroCategoria, setFiltroCategoria] = useState('');
  const [filtroEstoqueMin, setFiltroEstoqueMin] = useState('todos'); // 'todos' | 'abaixo' | 'acima' | 'dentro'
  const [vizHeatmap, setVizHeatmap] = useState('quantidade'); // 'quantidade' | 'valor'
  const [heatmapMetrica, setHeatmapMetrica] = useState('entrada'); // 'entrada' | 'saida' | 'saldo'
  const [view, setView] = useState('tabela'); // 'tabela' | 'heatmap' | 'rastreabilidade'

  // Intervalo do período selecionado
  const { inicio, fim } = useMemo(() => {
    if (tipoFiltro === 'mes') {
      const d = parseISO(mesSelecionado + '-01');
      return { inicio: startOfMonth(d), fim: endOfMonth(d) };
    }
    return { inicio: parseISO(dataInicio), fim: parseISO(dataFim) };
  }, [tipoFiltro, mesSelecionado, dataInicio, dataFim]);

  // Período ANTERIOR (mesmo tamanho)
  const { inicioAnterior, fimAnterior } = useMemo(() => {
    const diff = fim - inicio;
    return { inicioAnterior: new Date(inicio - diff - 1), fimAnterior: new Date(inicio - 1) };
  }, [inicio, fim]);

  // Movimentações no período e anterior
  const movsNoPeriodo = useMemo(() =>
    movimentacoes.filter(m => {
      if (!m.data) return false;
      const d = parseISO(m.data);
      return isWithinInterval(d, { start: inicio, end: fim });
    }), [movimentacoes, inicio, fim]);

  const movsAnteriores = useMemo(() =>
    movimentacoes.filter(m => {
      if (!m.data) return false;
      const d = parseISO(m.data);
      return isWithinInterval(d, { start: inicioAnterior, end: fimAnterior });
    }), [movimentacoes, inicioAnterior, fimAnterior]);

  // Categorias livres únicas dos itens
  const categoriasLivres = useMemo(() => {
    const cats = itens.map(it => it.categoria).filter(Boolean);
    return [...new Set(cats)].sort();
  }, [itens]);

  // Itens filtrados por classificação, categoria e estoque mínimo
  const itensFiltrados = useMemo(() => {
    return itens.filter(it => {
      const classOk = filtroClassificacao === 'todos' || it.classificacao === filtroClassificacao || it.categoria === filtroClassificacao;
      const catOk = !filtroCategoria || (it.categoria || '').toLowerCase().includes(filtroCategoria.toLowerCase());
      let minOk = true;
      if (filtroEstoqueMin === 'abaixo') minOk = it.estoque_minimo > 0 && (it.saldo_atual || 0) < it.estoque_minimo;
      else if (filtroEstoqueMin === 'acima') minOk = it.estoque_minimo > 0 && (it.saldo_atual || 0) > it.estoque_minimo;
      else if (filtroEstoqueMin === 'dentro') minOk = it.estoque_minimo > 0 && (it.saldo_atual || 0) >= it.estoque_minimo;
      return classOk && catOk && minOk;
    });
  }, [itens, filtroClassificacao, filtroCategoria, filtroEstoqueMin]);

  // Calcula linha por item para tabela
  const linhas = useMemo(() => {
    return itensFiltrados.map(it => {
      const movsItem = movsNoPeriodo.filter(m => m.item_id === it.id);
      const movsItemAnt = movsAnteriores.filter(m => m.item_id === it.id);

      const entQte = movsItem.filter(m => m.tipo === 'entrada' || m.tipo === 'saldo_inicial').reduce((s, m) => s + (m.quantidade || 0), 0);
      const entVal = movsItem.filter(m => m.tipo === 'entrada' || m.tipo === 'saldo_inicial').reduce((s, m) => s + (m.valor_total || 0), 0);
      const saiQte = movsItem.filter(m => m.tipo === 'saida').reduce((s, m) => s + (m.quantidade || 0), 0);
      const saiVal = movsItem.filter(m => m.tipo === 'saida').reduce((s, m) => s + (m.valor_total || 0), 0);

      // Saldo anterior = saldo calculado antes do período
      const entAntQte = movsItemAnt.filter(m => m.tipo === 'entrada' || m.tipo === 'saldo_inicial').reduce((s, m) => s + (m.quantidade || 0), 0);
      const saiAntQte = movsItemAnt.filter(m => m.tipo === 'saida').reduce((s, m) => s + (m.quantidade || 0), 0);
      // Usamos as movimentacoes até o inicio do período para calcular saldo real anterior
      const movsAteInicio = movimentacoes.filter(m => {
        if (!m.data || m.item_id !== it.id) return false;
        return parseISO(m.data) < inicio;
      });
      const saldoAntQte = movsAteInicio.reduce((s, m) => {
        if (m.tipo === 'saida') return s - (m.quantidade || 0);
        return s + (m.quantidade || 0);
      }, 0);
      const saldoAntVal = movsAteInicio.reduce((s, m) => {
        if (m.tipo === 'saida') return s - (m.valor_total || 0);
        return s + (m.valor_total || 0);
      }, 0);

      const saldoQte = saldoAntQte + entQte - saiQte;
      const saldoVal = saldoAntVal + entVal - saiVal;

      return {
        ...it,
        entQte, entVal, saiQte, saiVal,
        saldoAntQte, saldoAntVal,
        saldoQte, saldoVal,
        abaixoMin: it.estoque_minimo > 0 && (it.saldo_atual || 0) < it.estoque_minimo,
      };
    }).filter(l => l.entQte > 0 || l.saiQte > 0 || filtroEstoqueMin !== 'todos');
  }, [itensFiltrados, movsNoPeriodo, movimentacoes, inicio]);

  // Totais
  const totais = useMemo(() => linhas.reduce((acc, l) => ({
    entQte: acc.entQte + l.entQte,
    entVal: acc.entVal + l.entVal,
    saiQte: acc.saiQte + l.saiQte,
    saiVal: acc.saiVal + l.saiVal,
    saldoQte: acc.saldoQte + l.saldoQte,
    saldoVal: acc.saldoVal + l.saldoVal,
  }), { entQte: 0, entVal: 0, saiQte: 0, saiVal: 0, saldoQte: 0, saldoVal: 0 }), [linhas]);

  // Heatmap data
  const heatmapData = useMemo(() => {
    return itensFiltrados.map(it => {
      const movsItem = movsNoPeriodo.filter(m => m.item_id === it.id);
      const entQte = movsItem.filter(m => m.tipo === 'entrada').reduce((s, m) => s + (m.quantidade || 0), 0);
      const entVal = movsItem.filter(m => m.tipo === 'entrada').reduce((s, m) => s + (m.valor_total || 0), 0);
      const saiQte = movsItem.filter(m => m.tipo === 'saida').reduce((s, m) => s + (m.quantidade || 0), 0);
      const saiVal = movsItem.filter(m => m.tipo === 'saida').reduce((s, m) => s + (m.valor_total || 0), 0);
      const saldoQte = entQte - saiQte;
      const saldoVal = entVal - saiVal;
      const value = heatmapMetrica === 'entrada'
        ? (vizHeatmap === 'quantidade' ? entQte : entVal)
        : heatmapMetrica === 'saida'
        ? (vizHeatmap === 'quantidade' ? saiQte : saiVal)
        : (vizHeatmap === 'quantidade' ? Math.abs(saldoQte) : Math.abs(saldoVal));
      return { ...it, value };
    }).filter(x => x.value > 0).sort((a, b) => b.value - a.value);
  }, [itensFiltrados, movsNoPeriodo, heatmapMetrica, vizHeatmap]);

  const maxHeatmap = useMemo(() => Math.max(...heatmapData.map(x => x.value), 1), [heatmapData]);

  // Exportar CSV
  function exportarCSV() {
    const header = ['Código', 'Descrição', 'Categoria', 'Unidade', 'Saldo Ant. (Qtd)', 'Saldo Ant. (Valor)', 'Entradas (Qtd)', 'Entradas (Valor)', 'Saídas (Qtd)', 'Saídas (Valor)', 'Saldo Final (Qtd)', 'Saldo Final (Valor)', 'Estoque Mín.', 'Status'];
    const rows = linhas.map(l => [
      l.codigo || '', l.descricao, categoriaLabel[l.categoria] || l.categoria || '',
      l.unidade || 'un',
      l.saldoAntQte, l.saldoAntVal.toFixed(2),
      l.entQte, l.entVal.toFixed(2),
      l.saiQte, l.saiVal.toFixed(2),
      l.saldoQte, l.saldoVal.toFixed(2),
      l.estoque_minimo || 0,
      l.abaixoMin ? 'Abaixo do mínimo' : 'OK',
    ]);
    const csv = [header, ...rows].map(r => r.join(';')).join('\n');
    const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `relatorio_estoque_${format(inicio, 'yyyy-MM-dd')}_${format(fim, 'yyyy-MM-dd')}.csv`;
    a.click();
    URL.revokeObjectURL(url);
  }

  // Exportar Heatmap como PNG via canvas
  function exportarHeatmap() {
    const canvas = document.createElement('canvas');
    const cols = Math.min(heatmapData.length, 8);
    const rows = Math.ceil(heatmapData.length / cols);
    const cellW = 120, cellH = 60, padding = 12;
    canvas.width = cols * cellW + padding * 2;
    canvas.height = rows * cellH + padding * 2 + 40;
    const ctx = canvas.getContext('2d');
    ctx.fillStyle = '#f8fafc';
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    // Título
    ctx.fillStyle = '#1e293b';
    ctx.font = 'bold 14px sans-serif';
    const metricaLabel = heatmapMetrica === 'entrada' ? 'Entradas' : heatmapMetrica === 'saida' ? 'Saídas' : 'Saldo';
    ctx.fillText(`Mapa de Calor — ${metricaLabel} (${vizHeatmap === 'quantidade' ? 'Qtd' : 'Valor'}) — ${format(inicio, 'dd/MM/yyyy')} a ${format(fim, 'dd/MM/yyyy')}`, padding, 24);

    heatmapData.forEach((item, idx) => {
      const col = idx % cols;
      const row = Math.floor(idx / cols);
      const x = padding + col * cellW;
      const y = 40 + row * cellH;
      const intensity = maxHeatmap > 0 ? item.value / maxHeatmap : 0;

      // Fundo
      const r = Math.round(59 + (219 - 59) * (1 - intensity));
      const g = Math.round(130 + (234 - 130) * (1 - intensity));
      const b = Math.round(246 + (254 - 246) * (1 - intensity));
      ctx.fillStyle = intensity > 0.5 ? `rgba(29,78,216,${0.4 + intensity * 0.6})` : `rgba(219,234,254,${0.3 + intensity})`;
      ctx.fillRect(x + 2, y + 2, cellW - 4, cellH - 4);

      // Texto
      ctx.fillStyle = intensity > 0.5 ? '#ffffff' : '#1e3a5f';
      ctx.font = '9px sans-serif';
      const maxLen = 14;
      const name = item.descricao.length > maxLen ? item.descricao.slice(0, maxLen) + '…' : item.descricao;
      ctx.fillText(name, x + 6, y + 18);
      ctx.font = 'bold 13px sans-serif';
      const val = vizHeatmap === 'valor'
        ? new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL', maximumFractionDigits: 0 }).format(item.value)
        : String(item.value);
      ctx.fillText(val, x + 6, y + 38);
    });

    canvas.toBlob(blob => {
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `heatmap_estoque_${heatmapMetrica}_${format(inicio, 'yyyy-MM-dd')}.png`;
      a.click();
      URL.revokeObjectURL(url);
    });
  }

  return (
    <div className="space-y-5">
      {/* Filtros */}
      <div className="bg-card border border-border rounded-xl p-4 space-y-3">
        <h3 className="font-semibold text-sm">Filtros do Relatório</h3>
        <div className="flex flex-wrap gap-3 items-end">
          {/* Tipo de período */}
          <div className="space-y-1">
            <Label className="text-xs">Período</Label>
            <Select value={tipoFiltro} onValueChange={setTipoFiltro}>
              <SelectTrigger className="w-36"><SelectValue /></SelectTrigger>
              <SelectContent>
                <SelectItem value="mes">Por mês</SelectItem>
                <SelectItem value="personalizado">Personalizado</SelectItem>
              </SelectContent>
            </Select>
          </div>

          {tipoFiltro === 'mes' ? (
            <div className="space-y-1">
              <Label className="text-xs">Mês</Label>
              <Select value={mesSelecionado} onValueChange={setMesSelecionado}>
                <SelectTrigger className="w-48"><SelectValue /></SelectTrigger>
                <SelectContent>
                  {meses.map(m => <SelectItem key={m.value} value={m.value}>{m.label}</SelectItem>)}
                </SelectContent>
              </Select>
            </div>
          ) : (
            <>
              <div className="space-y-1">
                <Label className="text-xs">Data Início</Label>
                <Input type="date" className="w-40" value={dataInicio} onChange={e => setDataInicio(e.target.value)} />
              </div>
              <div className="space-y-1">
                <Label className="text-xs">Data Fim</Label>
                <Input type="date" className="w-40" value={dataFim} onChange={e => setDataFim(e.target.value)} />
              </div>
            </>
          )}

          {/* Classificação */}
          <div className="space-y-1">
            <Label className="text-xs">Classificação</Label>
            <Select value={filtroClassificacao} onValueChange={setFiltroClassificacao}>
              <SelectTrigger className="w-44"><SelectValue /></SelectTrigger>
              <SelectContent>
                <SelectItem value="todos">Todas</SelectItem>
                {Object.entries(categoriaLabel).map(([v, l]) => <SelectItem key={v} value={v}>{l}</SelectItem>)}
              </SelectContent>
            </Select>
          </div>

          {/* Categoria livre */}
          <div className="space-y-1">
            <Label className="text-xs">Categoria</Label>
            <Input
              className="w-40 h-9 text-sm"
              placeholder="Filtrar categoria..."
              value={filtroCategoria}
              onChange={e => setFiltroCategoria(e.target.value)}
            />
          </div>

          {/* Estoque mínimo */}
          <div className="space-y-1">
            <Label className="text-xs">Estoque Mínimo</Label>
            <Select value={filtroEstoqueMin} onValueChange={setFiltroEstoqueMin}>
              <SelectTrigger className="w-44"><SelectValue /></SelectTrigger>
              <SelectContent>
                <SelectItem value="todos">Todos</SelectItem>
                <SelectItem value="abaixo">Abaixo do mínimo</SelectItem>
                <SelectItem value="dentro">No mínimo ou acima</SelectItem>
                <SelectItem value="acima">Acima do mínimo</SelectItem>
              </SelectContent>
            </Select>
          </div>
        </div>
      </div>

      {/* KPIs */}
      <div className="grid grid-cols-2 md:grid-cols-3 gap-3">
        {[
          { label: 'Total Entradas', qte: totais.entQte, val: totais.entVal, color: 'text-green-700', bg: 'bg-green-50 border-green-200' },
          { label: 'Total Saídas', qte: totais.saiQte, val: totais.saiVal, color: 'text-red-600', bg: 'bg-red-50 border-red-200' },
          { label: 'Saldo do Período', qte: totais.saldoQte, val: totais.saldoVal, color: 'text-blue-700', bg: 'bg-blue-50 border-blue-200' },
        ].map((kpi, i) => (
          <div key={i} className={`rounded-xl border p-4 ${kpi.bg}`}>
            <p className="text-xs font-semibold text-muted-foreground uppercase mb-2">{kpi.label}</p>
            <p className={`text-xl font-bold ${kpi.color}`}>{kpi.qte} <span className="text-sm font-normal">unid.</span></p>
            <p className={`text-sm font-semibold ${kpi.color}`}>{fmt(kpi.val)}</p>
          </div>
        ))}
      </div>

      {/* Toggle Tabela / Heatmap / Rastreabilidade */}
      <div className="flex items-center justify-between flex-wrap gap-3">
        <div className="flex rounded-lg border border-border overflow-hidden text-sm">
          <button onClick={() => setView('tabela')} className={`px-4 py-2 font-medium flex items-center gap-1.5 transition-colors ${view === 'tabela' ? 'bg-primary text-primary-foreground' : 'hover:bg-muted'}`}>
            <Table2 className="w-4 h-4" /> Tabela
          </button>
          <button onClick={() => setView('heatmap')} className={`px-4 py-2 font-medium flex items-center gap-1.5 transition-colors ${view === 'heatmap' ? 'bg-primary text-primary-foreground' : 'hover:bg-muted'}`}>
            <BarChart3 className="w-4 h-4" /> Mapa de Calor
          </button>
          <button onClick={() => setView('rastreabilidade')} className={`px-4 py-2 font-medium flex items-center gap-1.5 transition-colors ${view === 'rastreabilidade' ? 'bg-primary text-primary-foreground' : 'hover:bg-muted'}`}>
            <AlertTriangle className="w-4 h-4" /> Lotes / Validade
          </button>
        </div>
        {view === 'tabela' ? (
          <Button size="sm" variant="outline" className="gap-1.5" onClick={exportarCSV}>
            <Download className="w-4 h-4" /> Exportar CSV
          </Button>
        ) : (
          <Button size="sm" variant="outline" className="gap-1.5" onClick={exportarHeatmap}>
            <Download className="w-4 h-4" /> Exportar PNG
          </Button>
        )}
      </div>

      {/* VIEW TABELA */}
      {view === 'tabela' && (
        <div className="border border-border rounded-xl overflow-x-auto">
          <table className="w-full text-sm min-w-[900px]">
            <thead className="bg-muted/40 border-b border-border">
              <tr>
                <th className="text-left px-3 py-3 font-medium text-muted-foreground">Item</th>
                <th className="text-left px-3 py-3 font-medium text-muted-foreground">Cat.</th>
                <th className="text-right px-3 py-3 font-medium text-muted-foreground border-l border-border" colSpan={2}>Saldo Anterior</th>
                <th className="text-right px-3 py-3 font-medium text-muted-foreground border-l border-green-200 bg-green-50/50" colSpan={2}>Entradas</th>
                <th className="text-right px-3 py-3 font-medium text-muted-foreground border-l border-red-200 bg-red-50/50" colSpan={2}>Saídas</th>
                <th className="text-right px-3 py-3 font-medium text-muted-foreground border-l border-blue-200 bg-blue-50/50" colSpan={2}>Saldo Final</th>
                <th className="text-center px-3 py-3 font-medium text-muted-foreground">Status</th>
              </tr>
              <tr className="text-xs bg-muted/20">
                <th className="px-3 pb-2"></th>
                <th className="px-3 pb-2"></th>
                <th className="px-3 pb-2 text-right border-l border-border">Qtd</th>
                <th className="px-3 pb-2 text-right">Valor</th>
                <th className="px-3 pb-2 text-right border-l border-green-200 bg-green-50/30">Qtd</th>
                <th className="px-3 pb-2 text-right bg-green-50/30">Valor</th>
                <th className="px-3 pb-2 text-right border-l border-red-200 bg-red-50/30">Qtd</th>
                <th className="px-3 pb-2 text-right bg-red-50/30">Valor</th>
                <th className="px-3 pb-2 text-right border-l border-blue-200 bg-blue-50/30">Qtd</th>
                <th className="px-3 pb-2 text-right bg-blue-50/30">Valor</th>
                <th className="px-3 pb-2"></th>
              </tr>
            </thead>
            <tbody className="divide-y divide-border">
              {linhas.length === 0 ? (
                <tr><td colSpan={11} className="text-center py-10 text-muted-foreground">Nenhuma movimentação no período</td></tr>
              ) : linhas.map(l => (
                <tr key={l.id} className={`hover:bg-muted/20 ${l.abaixoMin ? 'bg-orange-50/30' : ''}`}>
                  <td className="px-3 py-2.5">
                    <div className="font-medium text-sm">{l.descricao}</div>
                    <div className="text-xs text-muted-foreground">{l.codigo || ''} {l.unidade ? `• ${l.unidade}` : ''}</div>
                  </td>
                  <td className="px-3 py-2.5">
                    <div className="text-xs px-1.5 py-0.5 rounded bg-secondary text-secondary-foreground inline-block">
                      {categoriaLabel[l.classificacao || l.categoria] || '—'}
                    </div>
                    {l.categoria && <div className="text-xs text-muted-foreground mt-0.5">{l.categoria}</div>}
                  </td>
                  <td className="px-3 py-2.5 text-right border-l border-border text-muted-foreground">{l.saldoAntQte}</td>
                  <td className="px-3 py-2.5 text-right text-muted-foreground">{l.saldoAntVal > 0 ? fmt(l.saldoAntVal) : '—'}</td>
                  <td className="px-3 py-2.5 text-right border-l border-green-100 text-green-700 font-semibold bg-green-50/20">{l.entQte > 0 ? `+${l.entQte}` : '—'}</td>
                  <td className="px-3 py-2.5 text-right text-green-700 bg-green-50/20">{l.entVal > 0 ? fmt(l.entVal) : '—'}</td>
                  <td className="px-3 py-2.5 text-right border-l border-red-100 text-red-600 font-semibold bg-red-50/20">{l.saiQte > 0 ? `-${l.saiQte}` : '—'}</td>
                  <td className="px-3 py-2.5 text-right text-red-600 bg-red-50/20">{l.saiVal > 0 ? fmt(l.saiVal) : '—'}</td>
                  <td className="px-3 py-2.5 text-right border-l border-blue-100 font-bold text-blue-800 bg-blue-50/20">{l.saldoQte}</td>
                  <td className="px-3 py-2.5 text-right font-semibold text-blue-700 bg-blue-50/20">{fmt(l.saldoVal)}</td>
                  <td className="px-3 py-2.5 text-center">
                    {l.abaixoMin
                      ? <span className="text-xs px-1.5 py-0.5 rounded bg-orange-100 text-orange-700">⚠ Abaixo</span>
                      : l.estoque_minimo > 0
                      ? <span className="text-xs px-1.5 py-0.5 rounded bg-green-100 text-green-700">OK</span>
                      : <span className="text-xs text-muted-foreground">—</span>}
                  </td>
                </tr>
              ))}
            </tbody>
            {linhas.length > 0 && (
              <tfoot className="bg-muted/40 border-t-2 border-border font-semibold text-sm">
                <tr>
                  <td className="px-3 py-3" colSpan={2}>Totais ({linhas.length} itens)</td>
                  <td className="px-3 py-3 text-right border-l border-border">—</td>
                  <td className="px-3 py-3 text-right">—</td>
                  <td className="px-3 py-3 text-right border-l border-green-200 text-green-700 bg-green-50/30">+{totais.entQte}</td>
                  <td className="px-3 py-3 text-right text-green-700 bg-green-50/30">{fmt(totais.entVal)}</td>
                  <td className="px-3 py-3 text-right border-l border-red-200 text-red-600 bg-red-50/30">-{totais.saiQte}</td>
                  <td className="px-3 py-3 text-right text-red-600 bg-red-50/30">{fmt(totais.saiVal)}</td>
                  <td className="px-3 py-3 text-right border-l border-blue-200 text-blue-800 bg-blue-50/30">{totais.saldoQte}</td>
                  <td className="px-3 py-3 text-right text-blue-700 bg-blue-50/30">{fmt(totais.saldoVal)}</td>
                  <td></td>
                </tr>
              </tfoot>
            )}
          </table>
        </div>
      )}

      {/* VIEW RASTREABILIDADE */}
      {view === 'rastreabilidade' && (
        <RastreabilidadeLotes movimentacoes={movimentacoes} itens={itens} />
      )}

      {/* VIEW HEATMAP */}
      {view === 'heatmap' && (
        <div className="space-y-3">
          <div className="flex flex-wrap gap-3 items-end">
            <div className="space-y-1">
              <Label className="text-xs">Métrica</Label>
              <Select value={heatmapMetrica} onValueChange={setHeatmapMetrica}>
                <SelectTrigger className="w-32"><SelectValue /></SelectTrigger>
                <SelectContent>
                  <SelectItem value="entrada">Entradas</SelectItem>
                  <SelectItem value="saida">Saídas</SelectItem>
                  <SelectItem value="saldo">Saldo</SelectItem>
                </SelectContent>
              </Select>
            </div>
            <div className="space-y-1">
              <Label className="text-xs">Visualizar por</Label>
              <Select value={vizHeatmap} onValueChange={setVizHeatmap}>
                <SelectTrigger className="w-32"><SelectValue /></SelectTrigger>
                <SelectContent>
                  <SelectItem value="quantidade">Quantidade</SelectItem>
                  <SelectItem value="valor">Valor (R$)</SelectItem>
                </SelectContent>
              </Select>
            </div>
            <div className="flex items-end gap-2 text-xs text-muted-foreground pb-2">
              <span className="inline-flex gap-1 items-center">
                <span className="w-3 h-3 rounded bg-blue-100 border border-blue-200 inline-block"></span> Baixo
              </span>
              <span className="inline-flex gap-1 items-center">
                <span className="w-3 h-3 rounded bg-blue-400 inline-block"></span> Médio
              </span>
              <span className="inline-flex gap-1 items-center">
                <span className="w-3 h-3 rounded bg-blue-700 inline-block"></span> Alto
              </span>
            </div>
          </div>

          {heatmapData.length === 0 ? (
            <div className="text-center py-16 text-muted-foreground border border-border rounded-xl">
              Nenhuma movimentação encontrada para o período e filtros selecionados
            </div>
          ) : (
            <div id="heatmap-grid" className="grid gap-2" style={{ gridTemplateColumns: 'repeat(auto-fill, minmax(120px, 1fr))' }}>
              {heatmapData.map(item => (
                <HeatmapCell
                  key={item.id}
                  value={vizHeatmap === 'valor'
                    ? new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL', maximumFractionDigits: 0 }).format(item.value)
                    : item.value}
                  max={maxHeatmap}
                  label={item.descricao}
                />
              ))}
            </div>
          )}
        </div>
      )}
    </div>
  );
}

<file path="src/pages/Dashboard.jsx">
import { useEffect, useState } from 'react';
import { base44 } from '@/api/base44Client';
import { format, startOfMonth, endOfMonth, isToday } from 'date-fns';
import { ptBR } from 'date-fns/locale';
import { Calendar, Users, DollarSign, TrendingUp, Clock, CheckCircle, XCircle, AlertCircle } from 'lucide-react';
import { AreaChart, Area, BarChart, Bar, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer } from 'recharts';
import KpiCard from '@/components/dashboard/KpiCard';
import ConsultasHoje from '@/components/dashboard/ConsultasHoje';

export default function Dashboard() {
  const [consultas, setConsultas] = useState([]);
  const [lancamentos, setLancamentos] = useState([]);
  const [profissionais, setProfissionais] = useState([]);
  const [pacientes, setPacientes] = useState([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    async function load() {
      const [c, l, p, pa] = await Promise.all([
        base44.entities.Consulta.list('-data_hora', 200),
        base44.entities.LancamentoFinanceiro.list('-created_date', 200),
        base44.entities.Profissional.list(),
        base44.entities.Paciente.list(),
      ]);
      setConsultas(c);
      setLancamentos(l);
      setProfissionais(p);
      setPacientes(pa);
      setLoading(false);
    }
    load();
  }, []);

  const hoje = new Date();
  const consultasHoje = consultas.filter(c => {
    const d = new Date(c.data_hora);
    return isToday(d);
  });

  const mesAtual = consultas.filter(c => {
    const d = new Date(c.data_hora);
    return d >= startOfMonth(hoje) && d <= endOfMonth(hoje);
  });

  const receitaMes = lancamentos
    .filter(l => l.tipo === 'receita' && l.status === 'pago' && new Date(l.data_pagamento) >= startOfMonth(hoje))
    .reduce((s, l) => s + (l.valor || 0), 0);

  const despesasMes = lancamentos
    .filter(l => l.tipo === 'despesa' && l.status === 'pago' && new Date(l.data_pagamento) >= startOfMonth(hoje))
    .reduce((s, l) => s + (l.valor || 0), 0);

  const pendentes = lancamentos.filter(l => l.status === 'pendente' || l.status === 'atrasado');
  const totalPendente = pendentes.reduce((s, l) => s + (l.valor || 0), 0);

  // Profissional com mais consultas
  const profissionalTop = profissionais.map(p => ({
    nome: p.nome,
    consultas: consultas.filter(c => c.profissional_id === p.id).length
  })).sort((a, b) => b.consultas - a.consultas)[0];

  // Taxa de confirmação
  const totalAgendadas = consultasHoje.length;
  const totalConfirmadas = consultasHoje.filter(c => c.status === 'confirmado' || c.status === 'concluido').length;
  const taxaConfirmacao = totalAgendadas > 0 ? ((totalConfirmadas / totalAgendadas) * 100).toFixed(0) : 0;

  // Gráfico de consultas por dia (últimos 7 dias)
  const chartConsultas = Array.from({ length: 7 }, (_, i) => {
    const d = new Date();
    d.setDate(d.getDate() - (6 - i));
    const label = format(d, 'dd/MM');
    const count = consultas.filter(c => {
      const cd = new Date(c.data_hora);
      return format(cd, 'dd/MM/yyyy') === format(d, 'dd/MM/yyyy');
    }).length;
    return { dia: label, consultas: count };
  });

  // Gráfico financeiro mensal
  const chartFinanceiro = Array.from({ length: 6 }, (_, i) => {
    const d = new Date();
    d.setMonth(d.getMonth() - (5 - i));
    const label = format(d, 'MMM', { locale: ptBR });
    const receita = lancamentos.filter(l => l.tipo === 'receita' && l.status === 'pago' && new Date(l.data_pagamento)?.getMonth() === d.getMonth() && new Date(l.data_pagamento)?.getFullYear() === d.getFullYear()).reduce((s, l) => s + (l.valor || 0), 0);
    const despesa = lancamentos.filter(l => l.tipo === 'despesa' && l.status === 'pago' && new Date(l.data_pagamento)?.getMonth() === d.getMonth() && new Date(l.data_pagamento)?.getFullYear() === d.getFullYear()).reduce((s, l) => s + (l.valor || 0), 0);
    return { mes: label, receita, despesa };
  });

  const fmt = (v) => new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v);

  if (loading) return (
    <div className="flex items-center justify-center h-full">
      <div className="w-8 h-8 border-4 border-primary/30 border-t-primary rounded-full animate-spin" />
    </div>
  );

  return (
    <div className="p-6 space-y-6">
      <div>
        <h1 className="text-2xl font-semibold text-foreground">Dashboard</h1>
        <p className="text-muted-foreground text-sm mt-1">{format(hoje, "EEEE, dd 'de' MMMM 'de' yyyy", { locale: ptBR })}</p>
      </div>

      {/* KPIs */}
      <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <KpiCard title="Consultas Hoje" value={consultasHoje.length} icon={Calendar} color="blue" sub={`${totalConfirmadas} confirmadas (${taxaConfirmacao}%)`} />
        <KpiCard title="Consultas no Mês" value={mesAtual.length} icon={Users} color="green" sub={`${mesAtual.filter(c => c.status === 'concluido').length} concluídas`} />
        <KpiCard title="Receita do Mês" value={fmt(receitaMes)} icon={DollarSign} color="emerald" sub={`Lucro: ${fmt(receitaMes - despesasMes)}`} />
        <KpiCard title="A Receber" value={fmt(totalPendente)} icon={AlertCircle} color="orange" sub={`${pendentes.length} pendentes`} />
      </div>

      {/* Informações Complementares */}
      <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div className="bg-card rounded-xl border border-border p-4">
          <div className="flex items-center gap-2 mb-2">
            <Users className="w-4 h-4 text-blue-600" />
            <p className="text-xs text-muted-foreground uppercase font-semibold">Pacientes Totais</p>
          </div>
          <p className="text-2xl font-bold">{pacientes.length}</p>
        </div>
        <div className="bg-card rounded-xl border border-border p-4">
          <div className="flex items-center gap-2 mb-2">
            <CheckCircle className="w-4 h-4 text-green-600" />
            <p className="text-xs text-muted-foreground uppercase font-semibold">Taxa Confirmação</p>
          </div>
          <p className="text-2xl font-bold">{taxaConfirmacao}%</p>
        </div>
        <div className="bg-card rounded-xl border border-border p-4">
          <div className="flex items-center gap-2 mb-2">
            <TrendingUp className="w-4 h-4 text-emerald-600" />
            <p className="text-xs text-muted-foreground uppercase font-semibold">Top Profissional</p>
          </div>
          <p className="text-xl font-bold">{profissionalTop?.nome || '-'}</p>
          <p className="text-xs text-muted-foreground mt-1">{profissionalTop?.consultas || 0} consultas</p>
        </div>
      </div>

      {/* Charts */}
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <div className="bg-card rounded-xl border border-border p-5">
          <h3 className="text-sm font-semibold text-foreground mb-4">Consultas — Últimos 7 Dias</h3>
          <ResponsiveContainer width="100%" height={200}>
            <AreaChart data={chartConsultas}>
              <defs>
                <linearGradient id="cg" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="5%" stopColor="hsl(213,60%,35%)" stopOpacity={0.3} />
                  <stop offset="95%" stopColor="hsl(213,60%,35%)" stopOpacity={0} />
                </linearGradient>
              </defs>
              <CartesianGrid strokeDasharray="3 3" stroke="hsl(213,20%,92%)" />
              <XAxis dataKey="dia" tick={{ fontSize: 11 }} />
              <YAxis tick={{ fontSize: 11 }} />
              <Tooltip />
              <Area type="monotone" dataKey="consultas" stroke="hsl(213,60%,35%)" fill="url(#cg)" strokeWidth={2} />
            </AreaChart>
          </ResponsiveContainer>
        </div>

        <div className="bg-card rounded-xl border border-border p-5">
          <h3 className="text-sm font-semibold text-foreground mb-4">Financeiro — Últimos 6 Meses</h3>
          <ResponsiveContainer width="100%" height={200}>
            <BarChart data={chartFinanceiro}>
              <CartesianGrid strokeDasharray="3 3" stroke="hsl(213,20%,92%)" />
              <XAxis dataKey="mes" tick={{ fontSize: 11 }} />
              <YAxis tick={{ fontSize: 11 }} tickFormatter={v => `R$${(v/1000).toFixed(0)}k`} />
              <Tooltip formatter={v => fmt(v)} />
              <Bar dataKey="receita" fill="hsl(142,60%,45%)" radius={[3, 3, 0, 0]} name="Receita" />
              <Bar dataKey="despesa" fill="hsl(0,65%,55%)" radius={[3, 3, 0, 0]} name="Despesa" />
            </BarChart>
          </ResponsiveContainer>
        </div>
      </div>

      {/* Consultas de hoje */}
      <ConsultasHoje consultas={consultasHoje} />
    </div>
  );
}
</file>

<file path="src/pages/Estoque.jsx">
import { useState, useEffect, useMemo } from 'react';
import { base44 } from '@/api/base44Client';
import { Plus, Search, Package, ArrowDownCircle, ArrowUpCircle, AlertTriangle, History, BarChart3 } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Label } from '@/components/ui/label';
import { format, parseISO } from 'date-fns';
import { ptBR } from 'date-fns/locale';
import ItemEstoqueModal from '@/components/estoque/ItemEstoqueModal';
import EntradaEstoqueModal from '@/components/estoque/EntradaEstoqueModal';
import SaidaEstoqueModal from '@/components/estoque/SaidaEstoqueModal';
import MovimentacaoModal from '@/components/estoque/MovimentacaoModal';
import RelatorioEstoque from '@/components/estoque/RelatorioEstoque';

const categoriaLabel = {
  material_consumo: 'Material',
  medicamento: 'Medicamento',
  equipamento: 'Equipamento',
  limpeza: 'Limpeza',
  descartavel: 'Descartável',
  produto_venda: 'Produto para Venda',
  outros: 'Outros',
};

const tipoMovLabel = { saldo_inicial: 'Saldo Inicial', entrada: 'Entrada', saida: 'Saída' };
const tipoMovColor = {
  saldo_inicial: 'text-blue-600 bg-blue-50',
  entrada: 'text-green-700 bg-green-50',
  saida: 'text-red-600 bg-red-50',
};

function formatCurrency(v) {
  if (!v && v !== 0) return '—';
  return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v);
}

export default function Estoque() {
  const [itens, setItens] = useState([]);
  const [movimentacoes, setMovimentacoes] = useState([]);
  const [loading, setLoading] = useState(true);
  const [busca, setBusca] = useState('');
  const [filtroCategoria, setFiltroCategoria] = useState('todos');
  const [abaAtiva, setAbaAtiva] = useState('itens'); // 'itens' | 'ficha'
  const [itemModal, setItemModal] = useState(null); // null | 'novo' | item
  const [entradaOpen, setEntradaOpen] = useState(false);
  const [saidaOpen, setSaidaOpen] = useState(false);
  const [itemFicha, setItemFicha] = useState(null); // item selecionado para ver ficha
  const [movimentacaoEditar, setMovimentacaoEditar] = useState(null); // movimentação para editar

  useEffect(() => { load(); }, []);

  async function load() {
    setLoading(true);
    const [it, mv] = await Promise.all([
      base44.entities.ItemEstoque.list(),
      base44.entities.MovimentacaoEstoque.list('-data', 500),
    ]);
    setItens(it.filter(x => x.ativo !== false));
    setMovimentacoes(mv);
    setLoading(false);
  }

  const itensFiltrados = useMemo(() => {
    return itens.filter(it => {
      const buscaOk = !busca || it.descricao?.toLowerCase().includes(busca.toLowerCase()) || it.codigo?.toLowerCase().includes(busca.toLowerCase());
      const catOk = filtroCategoria === 'todos' || it.categoria === filtroCategoria || (filtroCategoria === 'produto_venda' && it.para_venda);
      return buscaOk && catOk;
    });
  }, [itens, busca, filtroCategoria]);

  // Ficha do item selecionado
  const movsFicha = useMemo(() => {
    if (!itemFicha) return [];
    return movimentacoes.filter(m => m.item_id === itemFicha.id).sort((a, b) => a.data?.localeCompare(b.data));
  }, [movimentacoes, itemFicha]);

  // Calcula saldo progressivo na ficha
  const fichaComSaldo = useMemo(() => {
    let saldo = 0;
    return movsFicha.map(m => {
      if (m.tipo === 'saida') saldo -= m.quantidade;
      else saldo += m.quantidade;
      return { ...m, saldo_acum: saldo };
    });
  }, [movsFicha]);

  const itensAbaixoMinimo = itens.filter(it => it.estoque_minimo > 0 && (it.saldo_atual || 0) < it.estoque_minimo);

  if (loading) return (
    <div className="flex items-center justify-center h-full">
      <div className="w-8 h-8 border-4 border-primary/30 border-t-primary rounded-full animate-spin" />
    </div>
  );

  return (
    <div className="p-6 space-y-5 max-w-6xl mx-auto">
      {/* Header */}
      <div className="flex items-center justify-between flex-wrap gap-3">
        <div>
          <h1 className="text-xl font-semibold flex items-center gap-2"><Package className="w-5 h-5" />Estoque</h1>
          <p className="text-sm text-muted-foreground">{itens.length} itens cadastrados</p>
        </div>
        <div className="flex items-center gap-2">
          {itensAbaixoMinimo.length > 0 && (
            <div className="flex items-center gap-1.5 px-3 py-1.5 bg-orange-50 border border-orange-200 rounded-lg text-orange-700 text-sm">
              <AlertTriangle className="w-4 h-4" />
              {itensAbaixoMinimo.length} item(s) abaixo do mínimo
            </div>
          )}
          <Button size="sm" variant="outline" className="gap-1.5 text-red-600 border-red-200 hover:bg-red-50" onClick={() => setSaidaOpen(true)}>
            <ArrowUpCircle className="w-4 h-4" /> Saída
          </Button>
          <Button size="sm" variant="outline" className="gap-1.5 text-green-700 border-green-200 hover:bg-green-50" onClick={() => setEntradaOpen(true)}>
            <ArrowDownCircle className="w-4 h-4" /> Entrada
          </Button>
          <Button onClick={() => setItemModal('novo')} size="sm" className="gap-1.5">
            <Plus className="w-4 h-4" /> Novo Item
          </Button>
        </div>
      </div>

      {/* Abas */}
      <div className="flex rounded-lg border border-border overflow-hidden text-sm w-fit">
        <button onClick={() => setAbaAtiva('itens')} className={`px-4 py-2 font-medium transition-colors ${abaAtiva === 'itens' ? 'bg-primary text-primary-foreground' : 'hover:bg-muted'}`}>
          Itens
        </button>
        <button onClick={() => setAbaAtiva('ficha')} className={`px-4 py-2 font-medium transition-colors flex items-center gap-1.5 ${abaAtiva === 'ficha' ? 'bg-primary text-primary-foreground' : 'hover:bg-muted'}`}>
          <History className="w-4 h-4" /> Ficha de Controle
        </button>
        <button onClick={() => setAbaAtiva('relatorio')} className={`px-4 py-2 font-medium transition-colors flex items-center gap-1.5 ${abaAtiva === 'relatorio' ? 'bg-primary text-primary-foreground' : 'hover:bg-muted'}`}>
          <BarChart3 className="w-4 h-4" /> Relatórios
        </button>
      </div>

      {/* Aba Itens */}
      {abaAtiva === 'itens' && (
        <>
          {/* Filtros */}
          <div className="flex gap-3 flex-wrap">
            <div className="relative flex-1 min-w-48">
              <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground" />
              <Input className="pl-9" placeholder="Buscar por descrição ou código..." value={busca} onChange={e => setBusca(e.target.value)} />
            </div>
            <Select value={filtroCategoria} onValueChange={setFiltroCategoria}>
              <SelectTrigger className="w-44"><SelectValue /></SelectTrigger>
              <SelectContent>
                <SelectItem value="todos">Todas categorias</SelectItem>
                {Object.entries(categoriaLabel).map(([v, l]) => <SelectItem key={v} value={v}>{l}</SelectItem>)}
              </SelectContent>
            </Select>
          </div>

          {/* Tabela */}
          <div className="border border-border rounded-xl overflow-hidden">
            <table className="w-full text-sm">
              <thead className="bg-muted/40 border-b border-border">
                <tr>
                  <th className="text-left px-4 py-3 font-medium text-muted-foreground">Código</th>
                  <th className="text-left px-4 py-3 font-medium text-muted-foreground">Descrição</th>
                  <th className="text-left px-4 py-3 font-medium text-muted-foreground">Categoria</th>
                  <th className="text-right px-4 py-3 font-medium text-muted-foreground">Custo</th>
                  <th className="text-right px-4 py-3 font-medium text-muted-foreground">Saldo</th>
                  <th className="text-center px-4 py-3 font-medium text-muted-foreground">Ações</th>
                </tr>
              </thead>
              <tbody className="divide-y divide-border">
                {itensFiltrados.length === 0 ? (
                  <tr><td colSpan={6} className="text-center py-10 text-muted-foreground">Nenhum item encontrado</td></tr>
                ) : itensFiltrados.map(it => {
                  const abaixoMin = it.estoque_minimo > 0 && (it.saldo_atual || 0) < it.estoque_minimo;
                  return (
                    <tr key={it.id} className="hover:bg-muted/20 transition-colors">
                      <td className="px-4 py-3 text-muted-foreground font-mono text-xs">{it.codigo || '—'}</td>
                      <td className="px-4 py-3">
                        <div className="font-medium">{it.descricao}</div>
                        {it.fornecedor && <div className="text-xs text-muted-foreground">{it.fornecedor}</div>}
                      </td>
                      <td className="px-4 py-3">
                        <span className="text-xs px-2 py-0.5 rounded-full bg-secondary text-secondary-foreground">
                          {categoriaLabel[it.categoria] || it.categoria}
                        </span>
                      </td>
                      <td className="px-4 py-3 text-right">{it.preco_custo ? formatCurrency(it.preco_custo) : '—'}</td>
                      <td className="px-4 py-3 text-right">
                        <span className={`font-semibold ${abaixoMin ? 'text-orange-600' : ''}`}>
                          {it.saldo_atual || 0} {it.unidade || 'un'}
                        </span>
                        {abaixoMin && <AlertTriangle className="w-3.5 h-3.5 text-orange-500 inline ml-1" />}
                      </td>
                      <td className="px-4 py-3">
                        <div className="flex items-center justify-center gap-1">
                          <button
                            onClick={() => { setItemFicha(it); setAbaAtiva('ficha'); }}
                            className="p-1.5 rounded hover:bg-muted text-muted-foreground hover:text-foreground transition-colors"
                            title="Ver ficha"
                          >
                            <History className="w-4 h-4" />
                          </button>
                          <button
                            onClick={() => { setEntradaOpen(true); }}
                            className="p-1.5 rounded hover:bg-green-50 text-green-600 hover:text-green-700 transition-colors"
                            title="Entrada"
                          >
                            <ArrowDownCircle className="w-4 h-4" />
                          </button>
                          <button
                            onClick={() => { setSaidaOpen(true); }}
                            className="p-1.5 rounded hover:bg-red-50 text-red-500 hover:text-red-600 transition-colors"
                            title="Saída"
                          >
                            <ArrowUpCircle className="w-4 h-4" />
                          </button>
                          <button
                            onClick={() => setItemModal(it)}
                            className="p-1.5 rounded hover:bg-muted text-muted-foreground hover:text-foreground transition-colors text-xs font-medium"
                            title="Editar"
                          >
                            ✏️
                          </button>
                        </div>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </>
      )}

      {/* Aba Ficha de Controle */}
      {abaAtiva === 'ficha' && (
        <div className="space-y-4">
          {/* Seletor de item */}
          <div className="flex items-center gap-3">

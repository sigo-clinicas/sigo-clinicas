<file path="src/pages/GerenciamentoUsuarios.jsx">
import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { useAuth } from '@/lib/AuthContext';
import { useClinica } from '@/lib/ClinicaContext';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Card, CardContent } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { Dialog, DialogContent, DialogHeader, DialogTitle } from '@/components/ui/dialog';
import { Trash2, Plus, Mail, Edit2 } from 'lucide-react';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';

const PAPEIS = [
  { role: 'admin', label: 'Administrador', desc: 'Acesso total ao sistema — configurações, usuários, financeiro, relatórios, pacientes e agenda.' },
  { role: 'gestor', label: 'Gestor', desc: 'Acesso a relatórios gerenciais, financeiro e visão geral. Sem configurações do sistema.' },
  { role: 'recepcionista', label: 'Recepcionista', desc: 'Agenda, cadastro de pacientes e cobranças. Sem acesso a relatórios financeiros gerenciais.' },
  { role: 'profissional', label: 'Profissional de Saúde', desc: 'Sua agenda pessoal e seus pacientes. Sem acesso ao financeiro.' },
];

export default function GerenciamentoUsuarios() {
  const { currentUser } = useAuth();
  const { config, setConfig } = useClinica();
  const [usuarios, setUsuarios] = useState([]);
  const [loading, setLoading] = useState(true);
  const [planoAtivo, setPlanoAtivo] = useState(null);
  const [assinatura, setAssinatura] = useState(null);
  const [modalInvite, setModalInvite] = useState({ open: false, email: '', role: 'recepcionista' });
  const [saved, setSaved] = useState(false);

  useEffect(() => {
    loadData();
  }, []);

  async function loadData() {
    try {
      const [users, assinaturas] = await Promise.all([
        base44.entities.User.list(),
        base44.entities.AssinaturaClinica.filter({ status: 'ativa' })
      ]);
      
      setUsuarios(users);
      
      if (assinaturas.length > 0) {
        const assinatura = assinaturas[0];
        setAssinatura(assinatura);
        
        const planos = await base44.entities.PlanoAssinatura.list();
        const plano = planos.find(p => p.id === assinatura.plano_id);
        setPlanoAtivo(plano);
      }
    } catch (error) {
      console.error('Erro ao carregar dados:', error);
    }
    setLoading(false);
  }

  async function handleInvite() {
    if (!modalInvite.email.trim()) {
      alert('Email é obrigatório');
      return;
    }

    if (!planoAtivo) {
      alert('Clínica sem plano ativo. Configure uma assinatura primeiro.');
      return;
    }
    
    const usuariosDoTipo = usuarios.filter(u => u.role === modalInvite.role).length;
    const limiteRole = {
      admin: planoAtivo.limite_admin,
      gestor: planoAtivo.limite_gestor,
      recepcionista: planoAtivo.limite_recepcionista,
      profissional: planoAtivo.limite_profissional,
    }[modalInvite.role];

    if (usuariosDoTipo >= limiteRole) {
      alert(`Limite de ${limiteRole} ${PAPEIS.find(p => p.role === modalInvite.role)?.label}s atingido no plano ${planoAtivo.nome}`);
      return;
    }

    try {
      await base44.users.inviteUser(modalInvite.email, modalInvite.role);
      setModalInvite({ open: false, email: '', role: 'recepcionista' });
      alert('Convite enviado com sucesso!');
      loadData();
    } catch (error) {
      console.error('Erro ao enviar convite:', error);
      alert('Erro ao enviar convite');
    }
  }

  if (loading) {
    return (
      <div className="flex items-center justify-center h-96">
        <div className="w-8 h-8 border-4 border-primary/20 border-t-primary rounded-full animate-spin" />
      </div>
    );
  }

  const getRoleLabel = (role) => {
    const roles = {
      admin: 'Administrador',
      gestor: 'Gestor',
      recepcionista: 'Recepcionista',
      profissional: 'Profissional'
    };
    return roles[role] || role;
  };

  const getRoleColor = (role) => {
    const colors = {
      admin: 'bg-red-100 text-red-800',
      gestor: 'bg-orange-100 text-orange-800',
      recepcionista: 'bg-blue-100 text-blue-800',
      profissional: 'bg-green-100 text-green-800'
    };
    return colors[role] || 'bg-gray-100 text-gray-800';
  };

  return (
    <div className="p-6 max-w-6xl mx-auto">
      <Tabs defaultValue="planos" className="w-full">
        <TabsList className="mb-6">
          <TabsTrigger value="planos">Planos</TabsTrigger>
          <TabsTrigger value="usuarios">Usuários</TabsTrigger>
        </TabsList>

        <TabsContent value="usuarios">
          <div className="flex justify-between items-center mb-6">
            <h1 className="text-3xl font-bold text-foreground">Gerenciamento de Usuários</h1>
            <Button onClick={() => setModalInvite({ ...modalInvite, open: true })} className="gap-2">
              <Plus className="w-4 h-4" />
              Convidar Usuário
            </Button>
          </div>

          <div className="grid gap-4">
            {usuarios.length === 0 ? (
              <Card>
                <CardContent className="py-8 text-center text-muted-foreground">
                  Nenhum usuário cadastrado.
                </CardContent>
              </Card>
            ) : (
              usuarios.map(user => {
                const contagem = usuarios.filter(u => u.role === user.role).length;
                const limiteRole = planoAtivo ? {
                  admin: planoAtivo.limite_admin,
                  gestor: planoAtivo.limite_gestor,
                  recepcionista: planoAtivo.limite_recepcionista,
                  profissional: planoAtivo.limite_profissional,
                }[user.role] : 0;
                return (
                  <Card key={user.id}>
                    <CardContent className="pt-6">
                      <div className="flex justify-between items-start">
                        <div className="flex-1">
                          <h3 className="font-semibold text-lg">{user.full_name}</h3>
                          <p className="text-sm text-muted-foreground">{user.email}</p>
                          <div className="flex items-center gap-2 mt-2">
                            <Badge className={`${getRoleColor(user.role)}`}>
                              {getRoleLabel(user.role)}
                            </Badge>
                            {planoAtivo && <span className="text-xs text-muted-foreground">({contagem}/{limiteRole})</span>}
                          </div>
                        </div>
                        <div className="flex gap-2">
                          <Button size="sm" variant="outline">
                            <Edit2 className="w-4 h-4" />
                          </Button>
                          <Button size="sm" variant="outline">
                            <Trash2 className="w-4 h-4" />
                          </Button>
                        </div>
                      </div>
                    </CardContent>
                  </Card>
                );
              })
            )}
          </div>
        </TabsContent>

        <TabsContent value="planos" className="space-y-6">
          <div>
            <h2 className="text-2xl font-bold">Limite de Usuários por Papel</h2>
            <p className="text-sm text-muted-foreground mt-1">Definidos pelo plano de assinatura da clínica</p>
          </div>

          {!planoAtivo ? (
            <Card>
              <CardContent className="py-8 text-center">
                <p className="text-muted-foreground mb-4">Nenhum plano ativo. Configure uma assinatura para definir os limites.</p>
                <a href="/admin/planos" className="text-primary underline">Ir para Planos</a>
              </CardContent>
            </Card>
          ) : (
            <>
              <Card>
                <CardContent className="pt-6">
                  <div className="flex justify-between items-center mb-4">
                    <div>
                      <h3 className="font-semibold text-lg">{planoAtivo.nome}</h3>
                      <p className="text-sm text-muted-foreground">{planoAtivo.descricao}</p>
                    </div>
                    <div className="text-right">
                      <div className="text-2xl font-bold text-primary">R$ {planoAtivo.preco_mensal?.toFixed(2)}</div>
                      <p className="text-xs text-muted-foreground">/mês</p>
                    </div>
                  </div>
                </CardContent>
              </Card>

              <div className="space-y-4">
                {PAPEIS.map(papel => {
                  const contagem = usuarios.filter(u => u.role === papel.role).length;
                  const limiteRole = {
                    admin: planoAtivo.limite_admin,
                    gestor: planoAtivo.limite_gestor,
                    recepcionista: planoAtivo.limite_recepcionista,
                    profissional: planoAtivo.limite_profissional,
                  }[papel.role];
                  const porcentagem = Math.round((contagem / limiteRole) * 100);
                  return (
                    <Card key={papel.role}>
                      <CardContent className="pt-6">
                        <div className="flex items-center justify-between mb-3">
                          <div>
                            <p className="font-semibold">{papel.label}</p>
                            <p className="text-xs text-muted-foreground mt-0.5">{contagem} de {limiteRole} usuários</p>
                          </div>
                          <Badge variant={porcentagem > 80 ? 'destructive' : 'secondary'}>
                            {porcentagem}%
                          </Badge>
                        </div>
                        <div className="w-full bg-muted h-2 rounded-full overflow-hidden">
                          <div 
                            className={`h-full transition-all ${porcentagem > 80 ? 'bg-red-500' : porcentagem > 50 ? 'bg-yellow-500' : 'bg-green-500'}`}
                            style={{ width: `${Math.min(porcentagem, 100)}%` }}
                          />
                        </div>
                      </CardContent>
                    </Card>
                  );
                })}
              </div>

              {assinatura && (
                <Card>
                  <CardContent className="pt-6">
                    <p className="text-sm text-muted-foreground">
                      Próxima cobrança: <span className="font-semibold">{assinatura.proxima_cobranca}</span>
                    </p>
                  </CardContent>
                </Card>
              )}
            </>
          )}
        </TabsContent>
      </Tabs>

      {/* Modal Convidar Usuário */}
      <Dialog open={modalInvite.open} onOpenChange={(open) => setModalInvite({ ...modalInvite, open })}>
        <DialogContent className="max-w-lg">
          <DialogHeader>
            <DialogTitle>Convidar Novo Usuário</DialogTitle>
          </DialogHeader>
          <div className="space-y-4">
            <div>
              <label className="block text-sm font-medium mb-2">Email *</label>
              <Input
                type="email"
                placeholder="usuario@example.com"
                value={modalInvite.email}
                onChange={(e) => setModalInvite({ ...modalInvite, email: e.target.value })}
              />
            </div>

            <div>
              <label className="block text-sm font-medium mb-3">Selecione o Papel *</label>
              <div className="space-y-2">
                {PAPEIS.map(papel => (
                  <button
                    key={papel.role}
                    onClick={() => setModalInvite({ ...modalInvite, role: papel.role })}
                    className={`w-full text-left p-3 rounded-lg border-2 transition-all ${
                      modalInvite.role === papel.role
                        ? 'border-primary bg-primary/5'
                        : 'border-border hover:border-primary/40'
                    }`}
                  >
                    <div className="flex items-center justify-between">
                      <div>
                        <p className="font-semibold text-sm">{papel.label}</p>
                        <p className="text-xs text-muted-foreground mt-0.5">{papel.desc}</p>
                      </div>
                      {modalInvite.role === papel.role && (
                        <div className="w-5 h-5 rounded-full bg-primary flex items-center justify-center">
                          <div className="w-2.5 h-2.5 rounded-full bg-white" />
                        </div>
                      )}
                    </div>
                  </button>
                ))}
              </div>
            </div>

            <div className="flex gap-2 pt-4">
              <Button
                variant="outline"
                className="flex-1"
                onClick={() => setModalInvite({ open: false, email: '', role: 'recepcionista' })}
              >
                Cancelar
              </Button>
              <Button className="flex-1" onClick={handleInvite}>
                <Mail className="w-4 h-4 mr-2" />
                Enviar Convite
              </Button>
            </div>
          </div>
        </DialogContent>
      </Dialog>
    </div>
  );
}

<file path="src/components/agenda/ProdutoVendaModal.jsx">
import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { format } from 'date-fns';
import { X, ShoppingCart, Plus, Minus, Trash2, Receipt } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Input } from '@/components/ui/input';

function formatCurrency(v) {
  if (!v && v !== 0) return '—';
  return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v);
}

export default function ProdutoVendaModal({ dataHora, onClose, onSaved }) {
  const [pacientes, setPacientes] = useState([]);
  const [produtosVenda, setProdutosVenda] = useState([]);
  const [contasBancarias, setContasBancarias] = useState([]);
  const [itens, setItens] = useState([]); // [{ produto, quantidade }]
  const [pacienteId, setPacienteId] = useState('');
  const [pacienteNome, setPacienteNome] = useState('');
  const [tipoVenda, setTipoVenda] = useState('contas_receber');
  const [contaBancariaId, setContaBancariaId] = useState('');
  const [formaPagamento, setFormaPagamento] = useState('dinheiro');
  const [saving, setSaving] = useState(false);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    Promise.all([
      base44.entities.Paciente.list(),
      base44.entities.ItemEstoque.list(),
      base44.entities.ContaBancaria.list(),
    ]).then(([p, it, cb]) => {
      setPacientes(p.filter(x => x.ativo !== false));
      setProdutosVenda(it.filter(x => x.ativo !== false && x.para_venda === true && (x.saldo_atual || 0) > 0));
      setContasBancarias(cb.filter(x => x.ativo !== false));
      setLoading(false);
    });
  }, []);

  const total = itens.reduce((acc, i) => acc + (i.produto.preco_venda || 0) * i.quantidade, 0);

  function adicionarProduto(produtoId) {
    if (!produtoId || produtoId === 'nenhum') return;
    const produto = produtosVenda.find(p => p.id === produtoId);
    if (!produto) return;
    const existe = itens.find(i => i.produto.id === produtoId);
    if (existe) {
      setItens(prev => prev.map(i => i.produto.id === produtoId ? { ...i, quantidade: i.quantidade + 1 } : i));
    } else {
      setItens(prev => [...prev, { produto, quantidade: 1 }]);
    }
  }

  function alterarQtd(produtoId, delta) {
    setItens(prev => prev
      .map(i => i.produto.id === produtoId ? { ...i, quantidade: Math.max(0, i.quantidade + delta) } : i)
      .filter(i => i.quantidade > 0)
    );
  }

  function removerItem(produtoId) {
    setItens(prev => prev.filter(i => i.produto.id !== produtoId));
  }

  async function handleSave() {
    if (itens.length === 0) return;
    setSaving(true);
    const dataVencimento = format(dataHora || new Date(), 'yyyy-MM-dd');
    const descricao = `Venda de produtos — ${pacienteNome || 'Cliente'} — ${itens.map(i => `${i.quantidade}x ${i.produto.descricao}`).join(', ')}`;

    // 1. Registra saída no estoque para cada produto
    for (const item of itens) {
      const novoSaldo = (item.produto.saldo_atual || 0) - item.quantidade;
      await base44.entities.MovimentacaoEstoque.create({
        item_id: item.produto.id,
        item_descricao: item.produto.descricao,
        tipo: 'saida',
        quantidade: item.quantidade,
        data: dataVencimento,
        observacao: `Venda — ${pacienteNome || 'Cliente'}`,
        valor_total: (item.produto.preco_venda || 0) * item.quantidade,
      });
      await base44.entities.ItemEstoque.update(item.produto.id, {
        saldo_atual: Math.max(0, novoSaldo),
      });
    }

    // 2. Gera lançamento financeiro
    if (tipoVenda === 'avista' && contaBancariaId) {
      const conta = contasBancarias.find(c => c.id === contaBancariaId);
      const lancamento = await base44.entities.LancamentoFinanceiro.create({
        tipo: 'receita', descricao, valor: total,
        data_vencimento: dataVencimento, data_pagamento: dataVencimento,
        status: 'pago', categoria: 'outros',
        forma_pagamento: formaPagamento,
        valor_pago: total, saldo_em_aberto: 0,
        paciente_nome: pacienteNome,
      });
      await base44.entities.MovimentacaoConta.create({
        conta_id: contaBancariaId, conta_nome: conta?.nome || '',
        lancamento_financeiro_id: lancamento.id,
        tipo: 'entrada', descricao, valor: total, data: dataVencimento,
      });
      await base44.entities.ContaBancaria.update(contaBancariaId, {
        saldo_atual: (conta?.saldo_atual || 0) + total,
      });
    } else {
      await base44.entities.LancamentoFinanceiro.create({
        tipo: 'receita', descricao, valor: total,
        data_vencimento: dataVencimento, status: 'pendente',
        categoria: 'outros', saldo_em_aberto: total,
        paciente_nome: pacienteNome,
      });
    }

    setSaving(false);
    onSaved();
  }

  const pgOpts = ['dinheiro', 'cartao_debito', 'cartao_credito', 'pix'];

  return (
    <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
      <div className="bg-card rounded-xl shadow-xl w-full max-w-lg max-h-[90vh] overflow-y-auto">
        <div className="flex items-center justify-between p-5 border-b border-border">
          <div className="flex items-center gap-2">
            <ShoppingCart className="w-5 h-5 text-emerald-600" />
            <h2 className="text-base font-semibold">Venda de Produtos</h2>
          </div>
          <button onClick={onClose} className="text-muted-foreground hover:text-foreground"><X className="w-5 h-5" /></button>
        </div>

        {loading ? (
          <div className="p-10 flex items-center justify-center">
            <div className="w-6 h-6 border-4 border-primary/30 border-t-primary rounded-full animate-spin" />
          </div>
        ) : (
          <div className="p-5 space-y-4">
            {/* Paciente */}
            <div className="space-y-1.5">
              <Label>Paciente / Cliente</Label>
              <Select value={pacienteId} onValueChange={v => {
                setPacienteId(v);
                setPacienteNome(pacientes.find(p => p.id === v)?.nome || '');
              }}>
                <SelectTrigger><SelectValue placeholder="Selecionar paciente (opcional)" /></SelectTrigger>
                <SelectContent>
                  <SelectItem value="avulso">— Venda avulsa (sem cadastro) —</SelectItem>
                  {pacientes.map(p => <SelectItem key={p.id} value={p.id}>{p.nome}</SelectItem>)}
                </SelectContent>
              </Select>
            </div>

            {/* Produtos disponíveis */}
            <div className="space-y-1.5">
              <Label>Adicionar Produto</Label>
              {produtosVenda.length === 0 ? (
                <div className="text-sm text-muted-foreground px-3 py-2 border border-border rounded-lg">
                  Nenhum produto marcado para venda com estoque disponível.
                </div>
              ) : (
                <Select value="nenhum" onValueChange={adicionarProduto}>
                  <SelectTrigger><SelectValue placeholder="+ Selecionar produto..." /></SelectTrigger>
                  <SelectContent>
                    <SelectItem value="nenhum">— Selecionar produto —</SelectItem>
                    {produtosVenda.map(p => (
                      <SelectItem key={p.id} value={p.id}>
                        {p.descricao} — {formatCurrency(p.preco_venda)} (estoque: {p.saldo_atual})
                      </SelectItem>
                    ))}
                  </SelectContent>
                </Select>
              )}
            </div>

            {/* Lista de itens selecionados */}
            {itens.length > 0 && (
              <div className="border border-border rounded-xl overflow-hidden divide-y divide-border">
                {itens.map(item => (
                  <div key={item.produto.id} className="flex items-center gap-3 px-3 py-2.5">
                    <div className="flex-1">
                      <p className="text-sm font-medium">{item.produto.descricao}</p>
                      <p className="text-xs text-muted-foreground">{formatCurrency(item.produto.preco_venda)} / un</p>
                    </div>
                    <div className="flex items-center gap-1.5">
                      <button onClick={() => alterarQtd(item.produto.id, -1)} className="w-6 h-6 rounded border border-border flex items-center justify-center hover:bg-muted">
                        <Minus className="w-3 h-3" />
                      </button>
                      <span className="w-8 text-center text-sm font-semibold">{item.quantidade}</span>
                      <button
                        onClick={() => alterarQtd(item.produto.id, 1)}
                        disabled={item.quantidade >= item.produto.saldo_atual}
                        className="w-6 h-6 rounded border border-border flex items-center justify-center hover:bg-muted disabled:opacity-40"
                      >
                        <Plus className="w-3 h-3" />
                      </button>
                    </div>
                    <span className="w-20 text-right text-sm font-semibold text-primary">
                      {formatCurrency((item.produto.preco_venda || 0) * item.quantidade)}
                    </span>
                    <button onClick={() => removerItem(item.produto.id)} className="text-muted-foreground hover:text-destructive">
                      <Trash2 className="w-4 h-4" />
                    </button>
                  </div>
                ))}
                <div className="flex items-center justify-between px-4 py-3 bg-muted/30">
                  <span className="text-sm font-semibold">Total</span>
                  <span className="text-lg font-bold text-primary">{formatCurrency(total)}</span>
                </div>
              </div>
            )}

            {/* Forma de Pagamento / Lançamento */}
            {itens.length > 0 && (
              <div className="space-y-3">
                <div className="grid grid-cols-2 gap-2">
                  <button
                    onClick={() => setTipoVenda('avista')}
                    className={`px-3 py-2.5 rounded-lg border-2 text-sm font-medium text-left transition-all ${tipoVenda === 'avista' ? 'border-emerald-500 bg-emerald-50 text-emerald-700' : 'border-border hover:border-emerald-300'}`}
                  >
                    💰 À Vista
                    <p className="text-xs font-normal text-muted-foreground mt-0.5">Entra na conta bancária</p>
                  </button>
                  <button
                    onClick={() => setTipoVenda('contas_receber')}
                    className={`px-3 py-2.5 rounded-lg border-2 text-sm font-medium text-left transition-all ${tipoVenda === 'contas_receber' ? 'border-emerald-500 bg-emerald-50 text-emerald-700' : 'border-border hover:border-emerald-300'}`}
                  >
                    📋 Contas a Receber
                    <p className="text-xs font-normal text-muted-foreground mt-0.5">Fica em aberto</p>
                  </button>
                </div>

                {tipoVenda === 'avista' && (
                  <div className="grid grid-cols-2 gap-3">
                    <div className="space-y-1.5">
                      <Label>Conta Bancária</Label>
                      <Select value={contaBancariaId} onValueChange={setContaBancariaId}>
                        <SelectTrigger><SelectValue placeholder="Selecionar conta..." /></SelectTrigger>
                        <SelectContent>
                          {contasBancarias.map(c => <SelectItem key={c.id} value={c.id}>{c.nome}</SelectItem>)}
                        </SelectContent>
                      </Select>
                    </div>
                    <div className="space-y-1.5">
                      <Label>Forma de Pagamento</Label>
                      <Select value={formaPagamento} onValueChange={setFormaPagamento}>
                        <SelectTrigger><SelectValue /></SelectTrigger>
                        <SelectContent>{pgOpts.map(o => <SelectItem key={o} value={o} className="capitalize">{o.replace('_', ' ')}</SelectItem>)}</SelectContent>
                      </Select>
                    </div>
                  </div>
                )}
              </div>
            )}
          </div>
        )}

        <div className="flex items-center gap-2 p-5 border-t border-border">
          <div className="flex-1" />
          <Button variant="outline" onClick={onClose}>Cancelar</Button>
          <Button
            onClick={handleSave}
            disabled={saving || itens.length === 0 || (tipoVenda === 'avista' && !contaBancariaId)}
            className="bg-emerald-600 hover:bg-emerald-700 text-white"
          >
            {saving ? 'Registrando...' : `Registrar Venda ${total > 0 ? '— ' + formatCurrency(total) : ''}`}
          </Button>
        </div>
      </div>
    </div>
  );
}
</file>

<file path="src/components/anamnese/AbaAnamnese.jsx">
import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { Plus, Link2, Copy, CheckCircle2, Clock, ClipboardList, Eye, ChevronDown, ChevronUp } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Label } from '@/components/ui/label';
import { format } from 'date-fns';
import { ptBR } from 'date-fns/locale';

function gerarToken() {
  return crypto.randomUUID().replace(/-/g, '').slice(0, 24);
}

function getLinkPublico(token) {
  return `${window.location.origin}/anamnese/${token}`;
}

export default function AbaAnamnese({ paciente }) {
  const [respostas, setRespostas] = useState([]);
  const [formularios, setFormularios] = useState([]);
  const [loading, setLoading] = useState(true);
  const [enviando, setEnviando] = useState(false);
  const [formularioSelecionado, setFormularioSelecionado] = useState('');
  const [copiado, setCopiado] = useState(null);
  const [expandido, setExpandido] = useState(null);

  useEffect(() => { load(); }, [paciente.id]);

  async function load() {
    const [r, f] = await Promise.all([
      base44.entities.RespostaAnamnese.filter({ paciente_id: paciente.id }, '-created_date'),
      base44.entities.FormularioAnamnese.filter({ ativo: true }),
    ]);
    setRespostas(r);
    setFormularios(f);
    setLoading(false);
  }

  async function gerarLink() {
    if (!formularioSelecionado) return alert('Selecione um formulário');
    setEnviando(true);
    const form = formularios.find(f => f.id === formularioSelecionado);
    const token = gerarToken();
    await base44.entities.RespostaAnamnese.create({
      paciente_id: paciente.id,
      paciente_nome: paciente.nome,
      formulario_id: formularioSelecionado,
      formulario_nome: form?.nome || '',
      respostas: [],
      status: 'pendente',
      token,
    });
    setEnviando(false);
    setFormularioSelecionado('');
    load();
  }

  async function copiarLink(token) {
    await navigator.clipboard.writeText(getLinkPublico(token));
    setCopiado(token);
    setTimeout(() => setCopiado(null), 2000);
  }

  if (loading) return <p className="text-sm text-muted-foreground py-4">Carregando...</p>;

  return (
    <div className="space-y-5">
      {/* Gerar novo link */}
      <div className="border border-border rounded-xl p-4 bg-muted/20 space-y-3">
        <h4 className="text-sm font-semibold">Enviar formulário de anamnese</h4>
        <div className="flex gap-2">
          <div className="flex-1">
            <Select value={formularioSelecionado} onValueChange={setFormularioSelecionado}>
              <SelectTrigger>
                <SelectValue placeholder="Selecionar formulário..." />
              </SelectTrigger>
              <SelectContent position="popper" className="z-[60]">
                {formularios.map(f => (
                  <SelectItem key={f.id} value={f.id}>{f.nome}</SelectItem>
                ))}
              </SelectContent>
            </Select>
          </div>
          <Button onClick={gerarLink} disabled={enviando || !formularioSelecionado} className="gap-1.5 shrink-0">
            <Link2 className="w-4 h-4" />
            {enviando ? 'Gerando...' : 'Gerar link'}
          </Button>
        </div>
        {formularios.length === 0 && (
          <p className="text-xs text-muted-foreground">Nenhum formulário ativo. Crie formulários na seção de Anamnese.</p>
        )}
      </div>

      {/* Lista de fichas */}
      <div className="space-y-3">
        <Label className="text-sm font-semibold">Fichas de anamnese</Label>

        {respostas.length === 0 ? (
          <div className="text-center py-10 text-muted-foreground border border-dashed border-border rounded-xl">
            <ClipboardList className="w-8 h-8 mx-auto mb-2 opacity-30" />
            <p className="text-sm">Nenhuma ficha enviada ainda.</p>
          </div>
        ) : (
          respostas.map(r => (
            <div key={r.id} className="border border-border rounded-xl overflow-hidden">
              <div className="flex items-center gap-3 p-4">
                <div className={`w-8 h-8 rounded-full flex items-center justify-center shrink-0 ${
                  r.status === 'preenchido' ? 'bg-green-100' : 'bg-amber-100'
                }`}>
                  {r.status === 'preenchido'
                    ? <CheckCircle2 className="w-4 h-4 text-green-600" />
                    : <Clock className="w-4 h-4 text-amber-600" />
                  }
                </div>
                <div className="flex-1 min-w-0">
                  <p className="font-medium text-sm truncate">{r.formulario_nome}</p>
                  <p className="text-xs text-muted-foreground">
                    {r.status === 'preenchido'
                      ? `Preenchido em ${r.data_preenchimento ? format(new Date(r.data_preenchimento), "dd/MM/yyyy 'às' HH:mm", { locale: ptBR }) : '—'}`
                      : 'Aguardando preenchimento'
                    }
                  </p>
                </div>
                <div className="flex items-center gap-1.5 shrink-0">
                  {r.status === 'pendente' && (
                    <button
                      onClick={() => copiarLink(r.token)}
                      className="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg border border-border text-xs hover:bg-muted transition-colors"
                      title="Copiar link"
                    >
                      {copiado === r.token ? <CheckCircle2 className="w-3.5 h-3.5 text-green-600" /> : <Copy className="w-3.5 h-3.5" />}
                      {copiado === r.token ? 'Copiado!' : 'Copiar link'}
                    </button>
                  )}
                  {r.status === 'preenchido' && (
                    <button
                      onClick={() => setExpandido(expandido === r.id ? null : r.id)}
                      className="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg border border-border text-xs hover:bg-muted transition-colors"
                    >
                      <Eye className="w-3.5 h-3.5" />
                      Ver respostas
                      {expandido === r.id ? <ChevronUp className="w-3 h-3" /> : <ChevronDown className="w-3 h-3" />}
                    </button>
                  )}
                </div>
              </div>

              {expandido === r.id && r.respostas?.length > 0 && (
                <div className="border-t border-border bg-muted/20 p-4 space-y-3">
                  {r.respostas.map((resp, i) => (
                    <div key={i} className="space-y-0.5">
                      <p className="text-xs font-medium text-muted-foreground">{resp.pergunta_texto}</p>
                      <p className="text-sm">{resp.resposta || <span className="text-muted-foreground italic">Não respondida</span>}</p>
                    </div>
                  ))}
                </div>
              )}
            </div>
          ))
        )}
      </div>
    </div>
  );
}
</file>

<file path="src/components/anamnese/FormularioAnamneseModal.jsx">
import { useState } from 'react';
import { base44 } from '@/api/base44Client';
import { X, Plus, Trash2, GripVertical } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';

const TIPOS = [
  { value: 'texto', label: 'Texto curto' },
  { value: 'texto_longo', label: 'Texto longo' },
  { value: 'sim_nao', label: 'Sim / Não' },
  { value: 'multipla_escolha', label: 'Múltipla escolha' },
  { value: 'numero', label: 'Número' },
];

function novaPergunta() {
  return { id: crypto.randomUUID(), texto: '', tipo: 'texto', opcoes: [], obrigatoria: false };
}

export default function FormularioAnamneseModal({ formulario, onClose, onSaved }) {
  const [nome, setNome] = useState(formulario?.nome || '');
  const [descricao, setDescricao] = useState(formulario?.descricao || '');
  const [perguntas, setPerguntas] = useState(formulario?.perguntas || []);
  const [saving, setSaving] = useState(false);

  function addPergunta() {
    setPerguntas(p => [...p, novaPergunta()]);
  }

  function updatePergunta(idx, field, value) {
    setPerguntas(p => p.map((q, i) => i === idx ? { ...q, [field]: value } : q));
  }

  function removePergunta(idx) {
    setPerguntas(p => p.filter((_, i) => i !== idx));
  }

  function addOpcao(idx) {
    setPerguntas(p => p.map((q, i) => i === idx ? { ...q, opcoes: [...(q.opcoes || []), ''] } : q));
  }

  function updateOpcao(pIdx, oIdx, value) {
    setPerguntas(p => p.map((q, i) => i === pIdx ? {
      ...q,
      opcoes: q.opcoes.map((o, j) => j === oIdx ? value : o)
    } : q));
  }

  function removeOpcao(pIdx, oIdx) {
    setPerguntas(p => p.map((q, i) => i === pIdx ? {
      ...q,
      opcoes: q.opcoes.filter((_, j) => j !== oIdx)
    } : q));
  }

  async function handleSave() {
    if (!nome.trim()) return alert('Nome é obrigatório');
    setSaving(true);
    const data = { nome, descricao, perguntas, ativo: formulario?.ativo !== false };
    if (formulario) await base44.entities.FormularioAnamnese.update(formulario.id, data);
    else await base44.entities.FormularioAnamnese.create(data);
    setSaving(false);
    onSaved();
  }

  return (
    <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
      <div className="bg-card rounded-xl shadow-xl w-full max-w-2xl flex flex-col max-h-[90vh]">
        <div className="flex items-center justify-between p-5 border-b border-border shrink-0">
          <h2 className="font-semibold">{formulario ? 'Editar Formulário' : 'Novo Formulário de Anamnese'}</h2>
          <button onClick={onClose}><X className="w-5 h-5 text-muted-foreground" /></button>
        </div>

        <div className="overflow-y-auto flex-1 p-5 space-y-5">
          <div className="space-y-3">
            <div className="space-y-1.5">
              <Label>Nome do formulário *</Label>
              <Input value={nome} onChange={e => setNome(e.target.value)} placeholder="Ex: Anamnese Inicial" />
            </div>
            <div className="space-y-1.5">
              <Label>Descrição</Label>
              <Input value={descricao} onChange={e => setDescricao(e.target.value)} placeholder="Instruções para o paciente..." />
            </div>
          </div>

          <div className="space-y-3">
            <div className="flex items-center justify-between">
              <Label className="text-sm font-semibold">Perguntas</Label>
              <Button size="sm" variant="outline" onClick={addPergunta} className="gap-1.5">
                <Plus className="w-3.5 h-3.5" /> Adicionar pergunta
              </Button>
            </div>

            {perguntas.length === 0 && (
              <p className="text-sm text-muted-foreground text-center py-6 border border-dashed border-border rounded-lg">
                Nenhuma pergunta adicionada ainda.
              </p>
            )}

            {perguntas.map((q, idx) => (
              <div key={q.id} className="border border-border rounded-lg p-4 space-y-3 bg-muted/20">
                <div className="flex items-start gap-2">
                  <GripVertical className="w-4 h-4 text-muted-foreground mt-2 shrink-0" />
                  <div className="flex-1 space-y-2">
                    <div className="flex gap-2">
                      <Input
                        className="flex-1"
                        value={q.texto}
                        onChange={e => updatePergunta(idx, 'texto', e.target.value)}
                        placeholder={`Pergunta ${idx + 1}`}
                      />
                      <Select value={q.tipo} onValueChange={v => updatePergunta(idx, 'tipo', v)}>
                        <SelectTrigger className="w-44">
                          <SelectValue />
                        </SelectTrigger>
                        <SelectContent position="popper" className="z-[70]">
                          {TIPOS.map(t => <SelectItem key={t.value} value={t.value}>{t.label}</SelectItem>)}
                        </SelectContent>
                      </Select>
                    </div>

                    {q.tipo === 'multipla_escolha' && (
                      <div className="space-y-1.5 pl-1">
                        <p className="text-xs text-muted-foreground">Opções:</p>
                        {(q.opcoes || []).map((op, oIdx) => (
                          <div key={oIdx} className="flex gap-1.5">
                            <Input
                              className="h-7 text-sm"
                              value={op}
                              onChange={e => updateOpcao(idx, oIdx, e.target.value)}
                              placeholder={`Opção ${oIdx + 1}`}
                            />
                            <button onClick={() => removeOpcao(idx, oIdx)} className="text-muted-foreground hover:text-red-500">
                              <X className="w-3.5 h-3.5" />
                            </button>
                          </div>
                        ))}
                        <button onClick={() => addOpcao(idx)} className="text-xs text-primary hover:underline">+ Adicionar opção</button>
                      </div>
                    )}

                    <label className="flex items-center gap-2 text-xs text-muted-foreground cursor-pointer">
                      <input
                        type="checkbox"
                        checked={q.obrigatoria || false}
                        onChange={e => updatePergunta(idx, 'obrigatoria', e.target.checked)}
                        className="rounded"
                      />
                      Obrigatória
                    </label>
                  </div>
                  <button onClick={() => removePergunta(idx)} className="p-1 rounded hover:bg-red-50 text-muted-foreground hover:text-red-600 shrink-0">
                    <Trash2 className="w-3.5 h-3.5" />
                  </button>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div className="flex justify-end gap-2 p-5 border-t border-border shrink-0">
          <Button variant="outline" onClick={onClose}>Cancelar</Button>
          <Button onClick={handleSave} disabled={saving}>{saving ? 'Salvando...' : 'Salvar'}</Button>
        </div>
      </div>
    </div>
  );
}
</file>

<file path="src/components/dashboard/ConsultasHoje.jsx">
import { format } from 'date-fns';
import { Badge } from '@/components/ui/badge';

const statusColor = {
  agendado: 'bg-blue-100 text-blue-700',
  confirmado: 'bg-green-100 text-green-700',
  em_atendimento: 'bg-yellow-100 text-yellow-700',
  concluido: 'bg-gray-100 text-gray-600',
  cancelado: 'bg-red-100 text-red-600',
  faltou: 'bg-orange-100 text-orange-600',
};

const statusLabel = {
  agendado: 'Agendado',
  confirmado: 'Confirmado',
  em_atendimento: 'Em Atendimento',
  concluido: 'Concluído',
  cancelado: 'Cancelado',
  faltou: 'Faltou',
};

export default function ConsultasHoje({ consultas }) {
  return (
    <div className="bg-card rounded-xl border border-border p-5">
      <h3 className="text-sm font-semibold text-foreground mb-4">Consultas de Hoje ({consultas.length})</h3>
      {consultas.length === 0 ? (
        <p className="text-sm text-muted-foreground text-center py-8">Nenhuma consulta agendada para hoje.</p>
      ) : (
        <div className="overflow-x-auto">
          <table className="w-full text-sm">
            <thead>
              <tr className="border-b border-border">
                <th className="text-left py-2 px-3 text-xs font-semibold text-muted-foreground uppercase">Horário</th>
                <th className="text-left py-2 px-3 text-xs font-semibold text-muted-foreground uppercase">Paciente</th>
                <th className="text-left py-2 px-3 text-xs font-semibold text-muted-foreground uppercase">Profissional</th>
                <th className="text-left py-2 px-3 text-xs font-semibold text-muted-foreground uppercase">Tipo</th>
                <th className="text-left py-2 px-3 text-xs font-semibold text-muted-foreground uppercase">Status</th>
              </tr>
            </thead>
            <tbody>
              {consultas.sort((a, b) => new Date(a.data_hora) - new Date(b.data_hora)).map(c => (
                <tr key={c.id} className="border-b border-border/50 hover:bg-muted/30 transition-colors">
                  <td className="py-2.5 px-3 font-mono text-xs font-semibold text-primary">{format(new Date(c.data_hora), 'HH:mm')}</td>
                  <td className="py-2.5 px-3 font-medium">{c.paciente_nome || '—'}</td>
                  <td className="py-2.5 px-3 text-muted-foreground">{c.profissional_nome || '—'}</td>
                  <td className="py-2.5 px-3 capitalize text-muted-foreground">{c.tipo || '—'}</td>
                  <td className="py-2.5 px-3">
                    <span className={`px-2 py-0.5 rounded-full text-xs font-medium ${statusColor[c.status]}`}>
                      {statusLabel[c.status] || c.status}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  );
}
</file>


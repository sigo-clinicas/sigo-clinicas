                      {arquivoGuias ? arquivoGuias.name : 'Selecionar arquivo CSV'}
                      <input type="file" accept=".csv,.txt" className="hidden" onChange={handleArquivoGuias} />
                    </label>
                    {arquivoGuias && (
                      <>
                        <Button size="sm" onClick={realizarMatch} disabled={processando} className="gap-1.5">
                          <CheckCircle className="w-4 h-4" /> {processando ? 'Processando...' : 'Realizar Match'}
                        </Button>
                        <button onClick={() => { setArquivoGuias(null); setLinhasArquivo([]); setMatchResultado(null); }} className="text-muted-foreground hover:text-red-500">
                          <X className="w-4 h-4" />
                        </button>
                      </>
                    )}
                  </div>

                  {linhasArquivo.length > 0 && !matchResultado && (
                    <div className="text-xs text-muted-foreground bg-muted/40 rounded p-3">
                      <strong>{linhasArquivo.length - 1} linhas</strong> detectadas · Colunas: {linhasArquivo[0]?.join(', ')}
                    </div>
                  )}

                  {matchResultado && (
                    <div className="space-y-3">
                      <div className="flex gap-4">
                        <span className="text-sm text-green-700 font-semibold flex items-center gap-1"><CheckCircle2 className="w-4 h-4" /> {matchResultado.matched} encontrado(s)</span>
                        <span className="text-sm text-red-600 font-semibold flex items-center gap-1"><AlertCircle className="w-4 h-4" /> {matchResultado.naoEncontrado} não encontrado(s)</span>
                      </div>
                      <div className="max-h-64 overflow-auto rounded-lg border border-border">
                        <table className="w-full text-xs">
                          <thead className="bg-muted/50 sticky top-0">
                            <tr>
                              <th className="text-left px-3 py-2 font-semibold text-muted-foreground uppercase">Nº Guia</th>
                              <th className="text-left px-3 py-2 font-semibold text-muted-foreground uppercase">Paciente</th>
                              <th className="text-right px-3 py-2 font-semibold text-muted-foreground uppercase">Valor Arquivo</th>
                              <th className="text-right px-3 py-2 font-semibold text-muted-foreground uppercase">Valor Sistema</th>
                              <th className="text-left px-3 py-2 font-semibold text-muted-foreground uppercase">Situação</th>
                            </tr>
                          </thead>
                          <tbody>
                            {matchResultado.linhas.map((l, idx) => {
                              const difValor = l.consulta && l.valor > 0 ? Math.abs(l.valor - (l.consulta.valor || 0)) > 0.01 : false;
                              return (
                                <tr key={idx} className={`border-t border-border ${l.status === 'encontrado' ? 'bg-green-50' : 'bg-red-50'}`}>
                                  <td className="px-3 py-2 font-mono">{l.guia || '—'}</td>
                                  <td className="px-3 py-2">{l.paciente || l.consulta?.paciente_nome || '—'}</td>
                                  <td className="px-3 py-2 text-right">{l.valor > 0 ? fmt(l.valor) : '—'}</td>
                                  <td className="px-3 py-2 text-right">{l.consulta ? fmt(l.consulta.valor || 0) : '—'}</td>
                                  <td className="px-3 py-2">
                                    {l.status === 'encontrado' ? (
                                      <span className={`px-1.5 py-0.5 rounded text-xs font-medium ${difValor ? 'bg-yellow-100 text-yellow-700' : 'bg-green-100 text-green-700'}`}>
                                        {difValor ? '⚠ Divergência' : '✓ OK'}
                                      </span>
                                    ) : (
                                      <span className="px-1.5 py-0.5 rounded text-xs font-medium bg-red-100 text-red-700">Não encontrado</span>
                                    )}
                                  </td>
                                </tr>
                              );
                            })}
                          </tbody>
                        </table>
                      </div>
                    </div>
                  )}
                </div>
              </div>

              {/* Lançamentos em aberto */}
              {lancamentosAbertos.length > 0 && (
                <div className="bg-card rounded-xl border border-yellow-200 overflow-hidden">
                  <div className="px-5 py-3 border-b border-yellow-200 bg-yellow-50">
                    <h3 className="font-semibold text-sm text-yellow-800 flex items-center gap-2"><AlertCircle className="w-4 h-4" /> Valores em Aberto para Fechamento</h3>
                  </div>
                  <table className="w-full text-sm">
                    <thead className="bg-muted/50">
                      <tr>
                        <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Descrição</th>
                        <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase hidden md:table-cell">Vencimento</th>
                        <th className="text-right px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Valor</th>
                        <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Status</th>
                      </tr>
                    </thead>
                    <tbody>
                      {lancamentosAbertos.map(l => (
                        <tr key={l.id} className="border-t border-border hover:bg-muted/20">
                          <td className="px-4 py-3 font-medium">{l.descricao}</td>
                          <td className="px-4 py-3 text-muted-foreground hidden md:table-cell">{l.data_vencimento ? format(new Date(l.data_vencimento), 'dd/MM/yyyy') : '—'}</td>
                          <td className="px-4 py-3 text-right font-semibold text-yellow-700">{fmt(l.valor)}</td>
                          <td className="px-4 py-3">
                            <span className={`px-2 py-0.5 rounded-full text-xs font-medium ${statusColor[l.status] || statusColor.pendente}`}>
                              {l.status?.charAt(0).toUpperCase() + l.status?.slice(1)}
                            </span>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
            </>
          )}
        </TabsContent>
      </Tabs>

      {modalOpen && (
        <ConvenioModal convenio={selecionado} onClose={() => setModalOpen(false)} onSaved={() => { setModalOpen(false); load(); }} />
      )}
    </div>
  );
}

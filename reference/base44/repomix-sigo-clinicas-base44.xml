          ) : (
            <>
              {/* Resumo */}
              <div className="grid grid-cols-4 gap-3">
                {[
                  { label: 'Saldo Inicial', value: fichaComSaldo.find(m => m.tipo === 'saldo_inicial')?.quantidade || 0, color: 'text-blue-600' },
                  { label: 'Total Entradas', value: movsFicha.filter(m => m.tipo === 'entrada').reduce((s, m) => s + m.quantidade, 0), color: 'text-green-600' },
                  { label: 'Total Saídas', value: movsFicha.filter(m => m.tipo === 'saida').reduce((s, m) => s + m.quantidade, 0), color: 'text-red-600' },
                  { label: 'Saldo Final', value: itemFicha.saldo_atual || 0, color: 'text-foreground font-bold' },
                ].map((kpi, i) => (
                  <div key={i} className="bg-card border border-border rounded-xl p-4 text-center">
                    <p className="text-xs text-muted-foreground mb-1">{kpi.label}</p>
                    <p className={`text-2xl font-semibold ${kpi.color}`}>{kpi.value} <span className="text-sm font-normal text-muted-foreground">{itemFicha.unidade || 'un'}</span></p>
                  </div>
                ))}
              </div>

              {/* Tabela ficha */}
              <div className="border border-border rounded-xl overflow-hidden">
                <table className="w-full text-sm">
                  <thead className="bg-muted/40 border-b border-border">
                    <tr>
                      <th className="text-left px-4 py-3 font-medium text-muted-foreground">Data</th>
                      <th className="text-left px-4 py-3 font-medium text-muted-foreground">Tipo</th>
                      <th className="text-right px-4 py-3 font-medium text-muted-foreground">Entrada</th>
                      <th className="text-right px-4 py-3 font-medium text-muted-foreground">Saída</th>
                      <th className="text-right px-4 py-3 font-medium text-muted-foreground">Saldo</th>
                      <th className="text-right px-4 py-3 font-medium text-muted-foreground">Valor Total</th>
                      <th className="text-left px-4 py-3 font-medium text-muted-foreground">Observação</th>
                      <th className="text-center px-4 py-3 font-medium text-muted-foreground">Ações</th>
                    </tr>
                  </thead>
                  <tbody className="divide-y divide-border">
                    {fichaComSaldo.length === 0 ? (
                      <tr><td colSpan={8} className="text-center py-10 text-muted-foreground">Nenhuma movimentação registrada</td></tr>
                    ) : fichaComSaldo.map((m, i) => (
                      <tr key={i} className="hover:bg-muted/20">
                        <td className="px-4 py-3 text-muted-foreground">{m.data ? format(parseISO(m.data), 'dd/MM/yyyy') : '—'}</td>
                        <td className="px-4 py-3">
                          <span className={`text-xs px-2 py-0.5 rounded-full font-medium ${tipoMovColor[m.tipo]}`}>
                            {tipoMovLabel[m.tipo]}
                          </span>
                        </td>
                        <td className="px-4 py-3 text-right text-green-700 font-medium">
                          {m.tipo !== 'saida' ? `+${m.quantidade}` : ''}
                        </td>
                        <td className="px-4 py-3 text-right text-red-600 font-medium">
                          {m.tipo === 'saida' ? `-${m.quantidade}` : ''}
                        </td>
                        <td className="px-4 py-3 text-right font-semibold">{m.saldo_acum}</td>
                        <td className="px-4 py-3 text-right">
                          {m.valor_total ? formatCurrency(m.valor_total) : '—'}
                          {m.lancamento_financeiro_id && (
                            <span className="ml-1.5 text-xs text-orange-600 bg-orange-50 px-1.5 py-0.5 rounded">$ pagar</span>
                          )}
                        </td>
                        <td className="px-4 py-3 text-muted-foreground text-xs">{m.observacao || m.fornecedor || '—'}</td>
                        <td className="px-4 py-3 text-center">
                          <button
                            onClick={() => setMovimentacaoEditar(m)}
                            className="p-1.5 rounded hover:bg-muted text-muted-foreground hover:text-foreground transition-colors text-xs font-medium"
                            title="Editar"
                          >
                            ✏️
                          </button>
                        </td>
                        </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </>
          )}
        </div>
      )}

      {/* Aba Relatórios */}
      {abaAtiva === 'relatorio' && (
        <RelatorioEstoque itens={itens} movimentacoes={movimentacoes} />
      )}

      {/* Modais */}
      {itemModal && (
        <ItemEstoqueModal
          item={itemModal === 'novo' ? null : itemModal}
          onClose={() => setItemModal(null)}
          onSaved={() => { setItemModal(null); load(); }}
        />
      )}
      {entradaOpen && (
        <EntradaEstoqueModal
          itensEstoque={itens}
          onClose={() => setEntradaOpen(false)}
          onSaved={() => { setEntradaOpen(false); load(); }}
        />
      )}
      {saidaOpen && (
        <SaidaEstoqueModal
          itensEstoque={itens}
          onClose={() => setSaidaOpen(false)}
          onSaved={() => { setSaidaOpen(false); load(); }}
        />
      )}
      {movimentacaoEditar && itemFicha && (
        <MovimentacaoModal
          item={itemFicha}
          movimento={movimentacaoEditar}
          onClose={() => setMovimentacaoEditar(null)}
          onSaved={() => { setMovimentacaoEditar(null); load(); }}
        />
      )}
    </div>
  );
}

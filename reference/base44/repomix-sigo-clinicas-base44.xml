              </TabsContent>
              <TabsContent value="composicao" className="p-5 m-0">
                <AbaComposicao servicoId={servico.id} />
              </TabsContent>
            </div>
          </Tabs>
        )}
        {!servico && (
          <div className="p-5 space-y-4 overflow-y-auto flex-1">
            <div className="space-y-1.5">
              <Label>Nome do Serviço *</Label>

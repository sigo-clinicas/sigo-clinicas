                  <p className="text-xs text-muted-foreground">Suba o arquivo de fechamento do convênio (CSV) para dar match com os atendimentos</p>
                </div>
                <div className="p-5 space-y-4">
                  <div className="flex items-center gap-3 flex-wrap">
                    <label className="flex items-center gap-2 cursor-pointer bg-muted hover:bg-muted/70 border border-border rounded-lg px-4 py-2 text-sm font-medium transition-colors">

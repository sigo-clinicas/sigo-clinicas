<file path="src/pages/marketing/Cupons.jsx">
import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { useAuth } from '@/lib/AuthContext';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { Plus, Trash2, Copy, CheckCircle2 } from 'lucide-react';
import { format } from 'date-fns';
import { ptBR } from 'date-fns/locale';

export default function Cupons() {
  const { currentUser } = useAuth();
  const [cuponsCriados, setCupomsCriados] = useState([]);
  const [cupomsAceitos, setCupomsAceitos] = useState([]);
  const [loading, setLoading] = useState(true);
  const [showForm, setShowForm] = useState(false);
  const [form, setForm] = useState({
    codigo: '',
    valor_desconto: '',
    tipo_desconto: 'percentual',
    descricao: '',
    validade_inicio: '',
    validade_fim: '',
    regras_uso: '',
  });
  const [saving, setSaving] = useState(false);

  useEffect(() => {
    loadData();
  }, [currentUser?.id]);

  async function loadData() {
    try {
      const cuponsData = await base44.entities.Cupom.filter({ clinica_id: currentUser?.id });
      const aceitos = cuponsData.filter(c => c.status === 'aceito');
      const criados = cuponsData.filter(c => c.status !== 'aceito');
      setCupomsCriados(criados);
      setCupomsAceitos(aceitos);
    } catch (error) {
      console.error('Erro ao carregar dados:', error);
    }
    setLoading(false);
  }

  async function handleSave() {
    if (!form.codigo.trim() || !form.valor_desconto) {
      alert('Código e valor de desconto são obrigatórios');
      return;
    }

    setSaving(true);
    try {
      await base44.entities.Cupom.create({
        codigo: form.codigo.toUpperCase().trim(),
        valor_desconto: parseFloat(form.valor_desconto),
        tipo_desconto: form.tipo_desconto,
        descricao: form.descricao,
        clinica_id: currentUser?.id,
        status: 'pendente',
        validade_inicio: form.validade_inicio,
        validade_fim: form.validade_fim,
        regras_uso: form.regras_uso,
      });
      setForm({
        codigo: '',
        valor_desconto: '',
        tipo_desconto: 'percentual',
        descricao: '',
        validade_inicio: '',
        validade_fim: '',
        regras_uso: '',
      });
      setShowForm(false);
      await loadData();
    } catch (error) {
      console.error('Erro ao salvar cupom:', error);
      alert('Erro ao salvar cupom');
    }
    setSaving(false);
  }

  async function handleDelete(id) {
    if (!confirm('Deseja deletar este cupom?')) return;
    try {
      await base44.entities.Cupom.delete(id);
      await loadData();
    } catch (error) {
      console.error('Erro ao deletar cupom:', error);
    }
  }

  function copyToClipboard(codigo) {
    navigator.clipboard.writeText(codigo);
    alert('Código copiado!');
  }

  if (loading) {
    return (
      <div className="flex items-center justify-center h-96">
        <div className="w-8 h-8 border-4 border-primary/20 border-t-primary rounded-full animate-spin" />
      </div>
    );
  }

  return (
    <div className="p-6 max-w-6xl mx-auto">
      <h1 className="text-3xl font-bold text-foreground mb-6">Cupons</h1>

      <Tabs defaultValue="cadastrar" className="w-full">
        <TabsList className="grid w-full grid-cols-2 mb-6">
          <TabsTrigger value="cadastrar">Cadastrar Cupons</TabsTrigger>
          <TabsTrigger value="aceitos">Cupons Aceitos</TabsTrigger>
        </TabsList>

        <TabsContent value="cadastrar">
          <div className="flex justify-end mb-6">
            <Button onClick={() => setShowForm(!showForm)}>
              <Plus className="w-4 h-4 mr-2" />
              Novo Cupom
            </Button>
          </div>

          {showForm && (
            <Card className="mb-6">
              <CardHeader>
                <CardTitle>Criar Novo Cupom</CardTitle>
              </CardHeader>
              <CardContent>
                <div className="grid grid-cols-2 gap-4 mb-4">
                  <div className="space-y-2">
                    <Label>Código do Cupom *</Label>
                    <Input
                      placeholder="EX: DESCONTO20"
                      value={form.codigo}
                      onChange={e => setForm({ ...form, codigo: e.target.value.toUpperCase() })}
                    />
                  </div>
                  <div className="space-y-2">
                    <Label>Valor de Desconto * (%)</Label>
                    <Input
                      type="number"
                      placeholder="20"
                      value={form.valor_desconto}
                      onChange={e => setForm({ ...form, valor_desconto: e.target.value })}
                    />
                  </div>
                  <div className="space-y-2">
                    <Label>Válido de *</Label>
                    <Input
                      type="date"
                      value={form.validade_inicio}
                      onChange={e => setForm({ ...form, validade_inicio: e.target.value })}
                    />
                  </div>
                  <div className="space-y-2">
                    <Label>Válido até *</Label>
                    <Input
                      type="date"
                      value={form.validade_fim}
                      onChange={e => setForm({ ...form, validade_fim: e.target.value })}
                    />
                  </div>
                  <div className="col-span-2 space-y-2">
                    <Label>Descrição</Label>
                    <Input
                      placeholder="Ex: Desconto especial para novos clientes"
                      value={form.descricao}
                      onChange={e => setForm({ ...form, descricao: e.target.value })}
                    />
                  </div>
                  <div className="col-span-2 space-y-2">
                    <Label>Regras de Uso</Label>
                    <Input
                      placeholder="Ex: Não cumulativo, válido apenas para primeira consulta"
                      value={form.regras_uso}
                      onChange={e => setForm({ ...form, regras_uso: e.target.value })}
                    />
                  </div>
                </div>
                <div className="flex gap-2">
                  <Button onClick={handleSave} disabled={saving}>
                    {saving ? 'Salvando...' : 'Salvar Cupom'}
                  </Button>
                  <Button variant="outline" onClick={() => setShowForm(false)}>
                    Cancelar
                  </Button>
                </div>
              </CardContent>
            </Card>
          )}

          <div className="grid gap-4">
            {cuponsCriados.length === 0 ? (
              <Card>
                <CardContent className="py-8 text-center text-muted-foreground">
                  Nenhum cupom criado ainda. Clique em "Novo Cupom" para começar.
                </CardContent>
              </Card>
            ) : (
              cuponsCriados.map(cupom => (
                <Card key={cupom.id}>
                  <CardContent className="pt-6">
                    <div className="grid grid-cols-2 md:grid-cols-3 gap-4 mb-4">
                      <div>
                        <div className="text-xs text-muted-foreground">Código</div>
                        <div className="font-bold text-lg font-mono flex items-center gap-2">
                          {cupom.codigo}
                          <button onClick={() => copyToClipboard(cupom.codigo)} className="p-1 hover:bg-muted rounded">
                            <Copy className="w-4 h-4" />
                          </button>
                        </div>
                      </div>
                      <div>
                        <div className="text-xs text-muted-foreground">Desconto</div>
                        <div className="font-bold text-lg">{cupom.valor_desconto}%</div>
                      </div>
                      <div>
                        <div className="text-xs text-muted-foreground">Status</div>
                        <div className={`font-bold text-sm ${cupom.status === 'pendente' ? 'text-yellow-600' : 'text-green-600'}`}>
                          {cupom.status === 'pendente' ? 'Pendente' : 'Ativo'}
                        </div>
                      </div>
                    </div>
                    {cupom.descricao && (
                      <div className="text-sm text-muted-foreground mb-2">{cupom.descricao}</div>
                    )}
                    {cupom.regras_uso && (
                      <div className="text-sm text-muted-foreground mb-2">
                        <strong>Regras:</strong> {cupom.regras_uso}
                      </div>
                    )}
                    {cupom.validade_inicio && cupom.validade_fim && (
                      <div className="text-xs text-muted-foreground">
                        Válido de {format(new Date(cupom.validade_inicio), 'dd/MM/yyyy', { locale: ptBR })} a {format(new Date(cupom.validade_fim), 'dd/MM/yyyy', { locale: ptBR })}
                      </div>
                    )}
                    <div className="flex gap-2 mt-4">
                      <Button variant="outline" size="sm" onClick={() => handleDelete(cupom.id)}>
                        <Trash2 className="w-4 h-4" />
                      </Button>
                    </div>
                  </CardContent>
                </Card>
              ))
            )}
          </div>
        </TabsContent>

        <TabsContent value="aceitos">
          <div className="grid gap-4">
            {cupomsAceitos.length === 0 ? (
              <Card>
                <CardContent className="py-8 text-center text-muted-foreground">
                  Nenhum cupom aceito ainda. Quando clientes utilizarem seus cupons, aparecerão aqui.
                </CardContent>
              </Card>
            ) : (
              cupomsAceitos.map(cupom => (
                <Card key={cupom.id}>
                  <CardContent className="pt-6">
                    <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
                      <div>
                        <div className="text-xs text-muted-foreground">Código</div>
                        <div className="font-bold text-lg font-mono">{cupom.codigo}</div>
                      </div>
                      <div>
                        <div className="text-xs text-muted-foreground">Cliente</div>
                        <div className="font-bold">{cupom.paciente_nome}</div>
                      </div>
                      <div>
                        <div className="text-xs text-muted-foreground">Data Aceito</div>
                        <div className="text-sm">{cupom.data_aceito ? format(new Date(cupom.data_aceito), 'dd/MM/yyyy', { locale: ptBR }) : '-'}</div>
                      </div>
                      <div className="flex items-end">
                        <CheckCircle2 className={`w-5 h-5 ${new Date(cupom.validade_fim) > new Date() ? 'text-green-600' : 'text-red-600'}`} />
                      </div>
                    </div>
                  </CardContent>
                </Card>
              ))
            )}
          </div>
        </TabsContent>
      </Tabs>
    </div>
  );
}
</file>


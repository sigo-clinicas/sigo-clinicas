<file path="src/components/prontuario/ResumoProntuario.jsx">
import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { useClinica } from '@/lib/ClinicaContext';
import { User, Stethoscope, Activity, Pill, FileText, ShoppingBag, Camera, ChevronRight, ChevronDown, ChevronUp, FolderOpen } from 'lucide-react';
import { format, differenceInYears } from 'date-fns';
import { ptBR } from 'date-fns/locale';

const ORIGEM_CORES = {
  'Instagram': 'bg-pink-100 text-pink-700',
  'Facebook': 'bg-blue-100 text-blue-700',
  'Google': 'bg-yellow-100 text-yellow-700',
  'Indicação': 'bg-green-100 text-green-700',
  'WhatsApp': 'bg-emerald-100 text-emerald-700',
  'Outros': 'bg-gray-100 text-gray-600',
};

function getOrigemCor(origem, origens) {
  const found = origens?.find(o => o.nome === origem);
  if (found?.cor) return found.cor;
  return ORIGEM_CORES[origem] || 'bg-gray-100 text-gray-600';
}

export default function ResumoProntuario({ paciente, convenio, onNavigate }) {
  const { config } = useClinica();
  const [data, setData] = useState({ evolucoes: [], avaliacoes: [], receituarios: [], anamneses: [], orcamentos: [], documentos: [] });
  const [loading, setLoading] = useState(true);
  const [dadosExpanded, setDadosExpanded] = useState(false);

  const idade = paciente.data_nascimento
    ? differenceInYears(new Date(), new Date(paciente.data_nascimento))
    : null;

  useEffect(() => {
    Promise.all([
      base44.entities.EvolucaoSessao.filter({ paciente_id: paciente.id }, '-data_hora', 10),
      base44.entities.AvaliacaoClinica.filter({ paciente_id: paciente.id }, '-data', 3),
      base44.entities.RespostaAnamnese.filter({ paciente_id: paciente.id }, '-data_preenchimento', 3),
      base44.entities.Orcamento.filter({ cliente_id: paciente.id, status: 'aprovado' }, '-created_date', 5),
      base44.entities.DocumentoConsentimento.filter({ paciente_id: paciente.id }, '-created_date', 5),
    ]).then(([ev, av, an, orc, docs]) => {
      const totalFotos = av.reduce((s, a) => s + (a.fotos_urls?.length || 0), 0)
        + ev.reduce((s, e) => s + (e.fotos_urls?.length || 0), 0);
      setData({
        evolucoes: ev,
        avaliacoes: av,
        receituarios: ev.filter(e => e.prescricao),
        anamneses: an,
        orcamentos: orc,
        documentos: docs,
        totalFotos,
      });
      setLoading(false);
    });
  }, [paciente.id]);

  if (loading) {
    return (
      <div className="flex items-center justify-center py-12">
        <div className="text-muted-foreground text-sm">Carregando resumo...</div>
      </div>
    );
  }

  return (
    <div className="space-y-6">
      {/* Card de dados pessoais com accordion */}
      <div className="bg-gradient-to-br from-primary/10 via-primary/5 to-transparent rounded-2xl border border-primary/20 overflow-hidden">
        <button
          className="w-full p-6 text-left flex items-start justify-between gap-4"
          onClick={() => setDadosExpanded(e => !e)}
        >
          <div className="space-y-2 flex-1">
            <div className="flex items-center gap-2 flex-wrap">
              <h1 className="text-2xl font-bold text-foreground">{paciente.nome}</h1>
              {paciente.origem && (
                <span className={`text-xs px-2 py-0.5 rounded-full font-medium ${getOrigemCor(paciente.origem, config.origens_pacientes)}`}>
                  {paciente.origem}
                </span>
              )}
            </div>
            <div className="flex flex-wrap gap-3 text-sm text-muted-foreground">
              {idade && <span>📅 {idade} anos</span>}
              {paciente.cpf && <span>🆔 {paciente.cpf}</span>}
              {convenio?.nome && <span>🏥 {convenio.nome}</span>}
              {paciente.telefone && <span>📱 {paciente.telefone}</span>}
            </div>
          </div>
          <div className="shrink-0 text-muted-foreground pt-1">
            {dadosExpanded ? <ChevronUp className="w-5 h-5" /> : <ChevronDown className="w-5 h-5" />}
          </div>
        </button>

        {dadosExpanded && (
          <div className="px-6 pb-6 pt-0 grid grid-cols-1 sm:grid-cols-2 gap-2 border-t border-primary/10">
            {paciente.email && <div className="text-sm text-muted-foreground">✉️ {paciente.email}</div>}
            {paciente.endereco && <div className="text-sm text-muted-foreground col-span-2">📍 {paciente.endereco}</div>}
            {paciente.sexo && <div className="text-sm text-muted-foreground capitalize">⚧ {paciente.sexo}</div>}
            {paciente.nome_mae && <div className="text-sm text-muted-foreground">👩 Mãe: {paciente.nome_mae}</div>}
            {paciente.observacoes && <div className="text-sm text-muted-foreground col-span-2">📝 {paciente.observacoes}</div>}
            {paciente.contato_emergencia_nome && (
              <div className="col-span-2 text-sm font-medium text-red-600">
                🚨 Emergência: {paciente.contato_emergencia_nome}
                {paciente.contato_emergencia_telefone && ` — ${paciente.contato_emergencia_telefone}`}
                {paciente.contato_emergencia_parentesco && ` (${paciente.contato_emergencia_parentesco})`}
              </div>
            )}
          </div>
        )}
      </div>

      {/* Cards de navegação */}
      <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
        {/* Card Dados Pessoais - primeiro */}
        <CardNavegacao
          titulo="Dados Pessoais"
          icon={User}
          cor="bg-slate-50 border-slate-200"
          contagem={1}
          conteudo={
            <div className="space-y-0.5 text-xs text-muted-foreground">
              {paciente.telefone && <div>📱 {paciente.telefone}</div>}
              {paciente.email && <div>✉️ {paciente.email}</div>}
              {paciente.endereco && <div className="truncate">📍 {paciente.endereco}</div>}
              {paciente.contato_emergencia_nome && (
                <div className="text-red-600 font-medium pt-1">
                  🚨 {paciente.contato_emergencia_nome}
                </div>
              )}
            </div>
          }
          onClick={() => onNavigate('dados')}
        />

        {/* Card Avaliação Clínica */}
        <CardNavegacao
          titulo="Avaliação Clínica"
          icon={Stethoscope}
          cor="bg-blue-50 border-blue-200"
          contagem={data.avaliacoes.length}
          conteudo={
            data.avaliacoes.length > 0 ? (
              <div className="space-y-1">
                {data.avaliacoes.slice(0, 2).map(av => (
                  <div key={av.id} className="text-xs">
                    <span className="font-medium">{format(new Date(av.data), 'dd/MM/yyyy')}</span>
                    {av.hipotese_diagnostica && (
                      <p className="text-muted-foreground truncate">{av.hipotese_diagnostica}</p>
                    )}
                  </div>
                ))}
                {data.avaliacoes.length > 2 && (
                  <p className="text-xs text-muted-foreground pt-1">+ {data.avaliacoes.length - 2} registros</p>
                )}
              </div>
            ) : (
              <p className="text-xs text-muted-foreground">Nenhuma avaliação</p>
            )
          }
          onClick={() => onNavigate('avaliacao')}
        />

        {/* Card Evolução Clínica */}
        <CardNavegacao
          titulo="Evolução Clínica"
          icon={Activity}
          cor="bg-green-50 border-green-200"
          contagem={data.evolucoes.length}
          conteudo={
            data.evolucoes.length > 0 ? (
              <div className="space-y-1">
                {data.evolucoes.slice(0, 2).map(ev => (
                  <div key={ev.id} className="text-xs">
                    <span className="font-medium">{format(new Date(ev.data_hora), 'dd/MM')}</span>
                    {ev.numero_sessao && <span className="text-muted-foreground"> • Sessão {ev.numero_sessao}</span>}
                    {ev.profissional_nome && (
                      <p className="text-muted-foreground text-xs">{ev.profissional_nome}</p>
                    )}
                  </div>
                ))}
                {data.evolucoes.length > 2 && (
                  <p className="text-xs text-muted-foreground pt-1">+ {data.evolucoes.length - 2} registros</p>
                )}
              </div>
            ) : (
              <p className="text-xs text-muted-foreground">Nenhuma evolução</p>
            )
          }
          onClick={() => onNavigate('evolucao')}
        />

        {/* Card Receituário */}
        <CardNavegacao
          titulo="Receituário"
          icon={Pill}
          cor="bg-purple-50 border-purple-200"
          contagem={data.receituarios.length}
          conteudo={
            data.receituarios.length > 0 ? (
              <div className="space-y-1">
                {data.receituarios.slice(0, 2).map(rec => (
                  <div key={rec.id} className="text-xs">
                    <span className="font-medium">{format(new Date(rec.data_hora), 'dd/MM/yyyy')}</span>
                    {rec.numero_sessao && <span className="text-muted-foreground"> • Sessão {rec.numero_sessao}</span>}
                  </div>
                ))}
                {data.receituarios.length > 2 && (
                  <p className="text-xs text-muted-foreground pt-1">+ {data.receituarios.length - 2} registros</p>
                )}
              </div>
            ) : (
              <p className="text-xs text-muted-foreground">Nenhum receituário</p>
            )
          }
          onClick={() => onNavigate('receituario')}
        />

        {/* Card Anamnese */}
        <CardNavegacao
          titulo="Anamnese"
          icon={FileText}
          cor="bg-yellow-50 border-yellow-200"
          contagem={data.anamneses.length}
          conteudo={
            data.anamneses.length > 0 ? (
              <div className="space-y-1">
                {data.anamneses.slice(0, 2).map(an => (
                  <div key={an.id} className="text-xs">
                    <span className="font-medium">{an.formulario_nome}</span>
                    <p className="text-muted-foreground text-xs">
                      {format(new Date(an.data_preenchimento), 'dd/MM/yyyy')}
                    </p>
                  </div>
                ))}
                {data.anamneses.length > 2 && (
                  <p className="text-xs text-muted-foreground pt-1">+ {data.anamneses.length - 2} registros</p>
                )}
              </div>
            ) : (
              <p className="text-xs text-muted-foreground">Nenhuma anamnese</p>
            )
          }
          onClick={() => onNavigate('anamnese')}
        />

        {/* Card Planos de Tratamento */}
        <CardNavegacao
          titulo="Planos de Tratamento"
          icon={ShoppingBag}
          cor="bg-orange-50 border-orange-200"
          contagem={data.orcamentos.length}
          conteudo={
            data.orcamentos.length > 0 ? (
              <div className="space-y-1">
                {data.orcamentos.slice(0, 2).map(orc => (
                  <div key={orc.id} className="text-xs">
                    <span className="font-medium">{format(new Date(orc.created_date), 'dd/MM/yyyy')}</span>
                    {orc.profissional_nome && (
                      <p className="text-muted-foreground">{orc.profissional_nome}</p>
                    )}
                  </div>
                ))}
                {data.orcamentos.length > 2 && (
                  <p className="text-xs text-muted-foreground pt-1">+ {data.orcamentos.length - 2} planos</p>
                )}
              </div>
            ) : (
              <p className="text-xs text-muted-foreground">Nenhum plano</p>
            )
          }
          onClick={() => onNavigate('orcamentos')}
        />

        {/* Card Documentos */}
        <CardNavegacao
          titulo="Documentos"
          icon={FolderOpen}
          cor="bg-indigo-50 border-indigo-200"
          contagem={data.documentos.length}
          conteudo={
            data.documentos.length > 0 ? (
              <div className="space-y-1">
                {data.documentos.slice(0, 2).map(doc => (
                  <div key={doc.id} className="text-xs">
                    <span className="font-medium truncate block">{doc.titulo}</span>
                    <span className={`text-xs px-1.5 py-0.5 rounded-full ${doc.status === 'assinado' ? 'bg-green-100 text-green-700' : doc.status === 'recusado' ? 'bg-red-100 text-red-700' : 'bg-yellow-100 text-yellow-700'}`}>
                      {doc.status === 'assinado' ? 'Assinado' : doc.status === 'recusado' ? 'Recusado' : 'Pendente'}
                    </span>
                  </div>
                ))}
                {data.documentos.length > 2 && <p className="text-xs text-muted-foreground pt-1">+ {data.documentos.length - 2} documento(s)</p>}
              </div>
            ) : (
              <p className="text-xs text-muted-foreground">Nenhum documento</p>
            )
          }
          onClick={() => onNavigate('documentos')}
        />

        {/* Card Galeria Fotográfica */}
        <CardNavegacao
          titulo="Galeria Fotográfica"
          icon={Camera}
          cor="bg-pink-50 border-pink-200"
          contagem={data.totalFotos || 0}
          conteudo={
            data.totalFotos > 0
              ? <p className="text-xs text-muted-foreground">{data.totalFotos} foto(s) registrada(s)</p>
              : <p className="text-xs text-muted-foreground">Nenhuma foto</p>
          }
          onClick={() => onNavigate('galeria')}
        />
      </div>
    </div>
  );
}

function CardNavegacao({ titulo, icon: Icon, cor, contagem, conteudo, onClick }) {
  return (
    <button
      onClick={onClick}
      className={`${cor} rounded-xl p-5 border transition-all hover:shadow-lg hover:scale-105 text-left space-y-3 cursor-pointer`}
    >
      <div className="flex items-start justify-between">
        <div className="flex items-center gap-2">
          <Icon className="w-5 h-5 text-foreground" />
          <h3 className="font-semibold text-sm text-foreground">{titulo}</h3>
        </div>
        <div className="flex items-center gap-1 text-muted-foreground">
          <span className="text-xs font-medium bg-white/60 px-2 py-1 rounded-full">
            {contagem}
          </span>
          <ChevronRight className="w-4 h-4 opacity-50" />
        </div>
      </div>

      <div className="text-sm text-foreground">{conteudo}</div>
    </button>
  );
}

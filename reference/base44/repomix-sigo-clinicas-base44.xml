import { useEffect, useState } from 'react';
import { base44 } from '@/api/base44Client';
import { Plus } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import ContaBancariaModal from '@/components/financeiro/ContaBancariaModal';
import CentroCustoPanel from '@/components/financeiro/CentroCustoPanel';
import ContaDetalhe from './ContaDetalhe';
import CategoriasLista from '@/components/financeiro/CategoriasLista.jsx';

const contaTipoLabel = {
  conta_corrente: 'Conta Corrente',
  cartao_credito: 'Cartão de Crédito',
  comissao: 'Conta de Comissão',
  caixa: 'Caixa',
  outro: 'Outro',
};

const fmt = v => new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v);

export default function Contas() {
  const [categorias, setCategorias] = useState([]);
  const [contas, setContas] = useState([]);
  const [loading, setLoading] = useState(true);
  const [contaDetalhe, setContaDetalhe] = useState(null);

  const [modalContaOpen, setModalContaOpen] = useState(false);
  const [contaEditando, setContaEditando] = useState(null);


  useEffect(() => { load(); }, []);

  async function load() {
    setLoading(true);
    const [cats, conts] = await Promise.all([
      base44.entities.CategoriaLancamento.list(),
      base44.entities.ContaBancaria.list(),
    ]);
    setCategorias(cats);
    setContas(conts);
    setLoading(false);
  }

  // Se há uma conta aberta no detalhe, renderiza a tela de detalhe
  if (contaDetalhe) {
    return (
      <ContaDetalhe
        conta={contaDetalhe}
        onBack={() => setContaDetalhe(null)}
        onReload={load}
      />
    );
  }

  return (
    <div className="p-6 space-y-5">
      <div>
        <h1 className="text-2xl font-semibold">Contas</h1>
        <p className="text-sm text-muted-foreground mt-0.5">Contas bancárias, categorias e conciliação</p>
      </div>

      <Tabs defaultValue="contas_bancarias" className="w-full">
        <TabsList className="grid w-full grid-cols-3">
          <TabsTrigger value="contas_bancarias">Contas Bancárias</TabsTrigger>
          <TabsTrigger value="categorias">Categorias</TabsTrigger>
          <TabsTrigger value="centros_custo">Centros de Custo</TabsTrigger>
        </TabsList>

        {/* ABA CONTAS BANCÁRIAS */}
        <TabsContent value="contas_bancarias" className="space-y-4">
          <div className="flex justify-between items-center">
            <h2 className="font-semibold">Contas Bancárias e de Caixa</h2>
            <Button onClick={() => { setContaEditando(null); setModalContaOpen(true); }} size="sm" className="gap-1">
              <Plus className="w-4 h-4" /> Adicionar
            </Button>
          </div>
          {loading ? (
            <p className="text-center py-12 text-muted-foreground">Carregando...</p>
          ) : contas.length === 0 ? (
            <p className="text-center py-12 text-muted-foreground">Nenhuma conta cadastrada</p>
          ) : (
            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
              {contas.map(conta => (
                <div
                  key={conta.id}
                  onClick={() => setContaDetalhe(conta)}
                  className="bg-card rounded-lg border border-border p-4 cursor-pointer hover:shadow-md transition-shadow space-y-3"
                >
                  <div className="flex justify-between items-start">
                    <div>
                      <h3 className="font-semibold">{conta.nome}</h3>
                      <p className="text-xs text-muted-foreground">{contaTipoLabel[conta.tipo]}</p>
                    </div>
                    <div className="flex items-center gap-2">
                      <span className={`text-xs px-2 py-1 rounded ${conta.ativo ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600'}`}>
                        {conta.ativo ? 'Ativa' : 'Inativa'}
                      </span>
                      <button
                        onClick={e => { e.stopPropagation(); setContaEditando(conta); setModalContaOpen(true); }}
                        className="text-xs text-muted-foreground hover:text-foreground px-1.5 py-0.5 rounded hover:bg-muted transition-colors"
                        title="Editar conta"
                      >
                        ✏️
                      </button>
                    </div>
                  </div>
                  {conta.banco && (
                    <p className="text-sm text-muted-foreground">{conta.banco} • Ag: {conta.agencia} • Cc: {conta.numero_conta}</p>
                  )}
                  <div className="pt-2 border-t border-border">
                    <p className="text-xs text-muted-foreground mb-1">Saldo Atual</p>
                    <p className="text-xl font-bold text-blue-600">{fmt(conta.saldo_atual || 0)}</p>
                  </div>
                </div>
              ))}
            </div>
          )}
        </TabsContent>

        {/* ABA CATEGORIAS */}
        <TabsContent value="categorias" className="space-y-4">
          <p className="text-sm text-muted-foreground">Arraste para reordenar. Clique para editar ou definir subcategorias.</p>
          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <CategoriasLista categorias={categorias} tipo="receita" onReload={load} />
            <CategoriasLista categorias={categorias} tipo="despesa" onReload={load} />
          </div>
        </TabsContent>

        {/* ABA CENTROS DE CUSTO */}
        <TabsContent value="centros_custo" className="space-y-4">
          <CentroCustoPanel />
        </TabsContent>
      </Tabs>

      {modalContaOpen && (
        <ContaBancariaModal conta={contaEditando} onClose={() => setModalContaOpen(false)} onSaved={() => { setModalContaOpen(false); load(); }} />
      )}

    </div>
  );
}
</file>


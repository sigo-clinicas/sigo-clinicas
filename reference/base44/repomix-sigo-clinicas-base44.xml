  const [assinaturas, setAssinaturas] = useState([]);
  const [loading, setLoading] = useState(true);
  const [tab, setTab] = useState('planos');
  const [modalPlano, setModalPlano] = useState({ open: false, edit: null });
  const [formPlano, setFormPlano] = useState({
    nome: '',
    descricao: '',
    preco_mensal: 0,
    limite_admin: 1,
    limite_gestor: 0,
    limite_recepcionista: 2,
    limite_profissional: 5,
    permissoes: {
      financeiro: true,
      relatorios: false,
      marketing: false,
      estoque: false,
      integracao_api: false,
      multiplas_clinicas: false,
    },
  });

  useEffect(() => {
    loadData();
  }, []);

  async function loadData() {
    try {
      const [planosData, assinaturasData] = await Promise.all([
        base44.entities.PlanoAssinatura.list(),
        base44.entities.AssinaturaClinica.list(),
      ]);
      setPlanos(planosData);
      setAssinaturas(assinaturasData);
    } catch (error) {
      console.error('Erro ao carregar dados:', error);
    }
    setLoading(false);
  }

  async function salvarPlano() {
    if (!formPlano.nome.trim() || formPlano.preco_mensal < 0) {
      alert('Preencha todos os campos obrigatórios');
      return;
    }

    try {
      if (modalPlano.edit) {
        await base44.entities.PlanoAssinatura.update(modalPlano.edit, formPlano);
      } else {
        await base44.entities.PlanoAssinatura.create(formPlano);
      }
      loadData();
      setModalPlano({ open: false, edit: null });
      setFormPlano({
        nome: '',
        descricao: '',
        preco_mensal: 0,
        limite_admin: 1,
        limite_gestor: 0,
        limite_recepcionista: 2,
        limite_profissional: 5,
        permissoes: {
          financeiro: true,
          relatorios: false,
          marketing: false,
          estoque: false,
          integracao_api: false,
          multiplas_clinicas: false,
        },
      });
    } catch (error) {
      console.error('Erro ao salvar plano:', error);
      alert('Erro ao salvar plano');
    }
  }

  async function deletarPlano(id) {
    if (confirm('Tem certeza? Clínicas com este plano não conseguirão convidar novos usuários.')) {
      try {
        await base44.entities.PlanoAssinatura.delete(id);
        loadData();
      } catch (error) {
        console.error('Erro ao deletar:', error);
      }
    }
  }

  if (loading) {
    return (
      <div className="flex items-center justify-center h-96">
        <div className="w-8 h-8 border-4 border-primary/20 border-t-primary rounded-full animate-spin" />
      </div>
    );
  }

  return (
    <div className="p-6 max-w-7xl mx-auto">
      <Tabs value={tab} onValueChange={setTab} className="w-full">
        <TabsList className="mb-6">

        <Route path="/anamnese" element={<FormulariosAnamnese />} />
        <Route path="/pacientes/perfil" element={<PacientePerfil />} />
        <Route path="/relatorios" element={<Relatorios />} />
        <Route path="/marketing/cupons" element={<MarketingCupons />} />
        <Route path="/marketing/depoimentos" element={<MarketingDepoimentos />} />
        <Route path="/marketing/campanhas" element={<MarketingCampanhas />} />
        <Route path="/configuracoes" element={<Configuracoes />} />
        <Route path="/usuarios" element={<GerenciamentoUsuarios />} />
      </Route>
      <Route path="*" element={<PageNotFound />} />
    </Routes>
  );
};

function App() {
  return (
    <AuthProvider>
      <ClinicaProvider>
      <QueryClientProvider client={queryClientInstance}>
        <Router>
          <Routes>
            {/* Rotas públicas — sem autenticação */}
            <Route path="/portal" element={<PortalAgendamento />} />
            <Route path="/anamnese/:token" element={<PreencherAnamnese />} />
            <Route path="/landing" element={<LandingPage />} />
            {/* App autenticado */}
            <Route path="/*" element={<AuthenticatedApp />} />
          </Routes>
        </Router>
        <Toaster />
      </QueryClientProvider>
      </ClinicaProvider>
    </AuthProvider>
  );
}

export default App;
</file>


<file path="src/components/prontuario/AbaGaleria.jsx">
import { useState, useEffect, useRef } from 'react';
import { base44 } from '@/api/base44Client';
import { Camera, Upload, Trash2, ZoomIn, X, Columns, Layers, Tag, Plus } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { format } from 'date-fns';

const CATEGORIAS = ['Antes', 'Depois', 'Evolução', 'Detalhe', 'Outro'];

export default function AbaGaleria({ paciente }) {
  const [fotos, setFotos] = useState([]);
  const [loading, setLoading] = useState(true);
  const [uploading, setUploading] = useState(false);
  const [modoComparacao, setModoComparacao] = useState(false);
  const [selecionadas, setSelecionadas] = useState([]);
  const [fotoAmpliada, setFotoAmpliada] = useState(null);
  const [filtroCategoria, setFiltroCategoria] = useState('Todas');
  const [editandoFoto, setEditandoFoto] = useState(null);
  const canvasRef = useRef(null);
  const [desenhando, setDesenhando] = useState(false);
  const [modoDraw, setModoDraw] = useState(false);

  useEffect(() => { load(); }, [paciente.id]);

  async function load() {
    const avs = await base44.entities.AvaliacaoClinica.filter({ paciente_id: paciente.id });
    const evs = await base44.entities.EvolucaoSessao.filter({ paciente_id: paciente.id });
    const todas = [];
    avs.forEach(av => {
      (av.fotos_urls || []).forEach(f => todas.push({ ...f, origem: 'Avaliação', data: av.data, avaliacao_id: av.id }));
    });
    evs.forEach(ev => {
      (ev.fotos_urls || []).forEach(f => todas.push({ ...f, origem: 'Evolução', data: ev.data_hora?.split('T')[0], evolucao_id: ev.id }));
    });
    // fotos extras salvas diretamente (entity GaleriaFoto não existe, usamos marcação nas avaliações)
    todas.sort((a, b) => new Date(b.data || 0) - new Date(a.data || 0));
    setFotos(todas);
    setLoading(false);
  }

  async function handleUpload(e) {
    const files = Array.from(e.target.files);
    if (!files.length) return;
    setUploading(true);
    for (const file of files) {
      const { file_url } = await base44.integrations.Core.UploadFile({ file });
      // Salva numa avaliação "galeria" especial ou cria uma
      let av = (await base44.entities.AvaliacaoClinica.filter({ paciente_id: paciente.id, queixa_principal: '__galeria__' }))[0];
      if (!av) {
        av = await base44.entities.AvaliacaoClinica.create({
          paciente_id: paciente.id,
          paciente_nome: paciente.nome,
          data: new Date().toISOString().split('T')[0],
          queixa_principal: '__galeria__',
          fotos_urls: [],
        });
      }
      const novasFotos = [...(av.fotos_urls || []), { url: file_url, descricao: '', data: new Date().toISOString().split('T')[0], categoria: 'Outro' }];
      await base44.entities.AvaliacaoClinica.update(av.id, { fotos_urls: novasFotos });
    }
    await load();
    setUploading(false);
  }

  const fotosFiltradas = filtroCategoria === 'Todas' ? fotos : fotos.filter(f => f.categoria === filtroCategoria || (!f.categoria && filtroCategoria === 'Outro'));

  function toggleSelecionada(foto) {
    setSelecionadas(prev => {
      const idx = prev.findIndex(f => f.url === foto.url);
      if (idx >= 0) return prev.filter((_, i) => i !== idx);
      if (prev.length < 2) return [...prev, foto];
      return [prev[1], foto];
    });
  }

  // Modo desenho sobre a foto ampliada
  const drawPos = useRef(null);

  function startDraw(e) {
    if (!modoDraw) return;
    e.preventDefault();
    setDesenhando(true);
    const canvas = canvasRef.current;
    const rect = canvas.getBoundingClientRect();
    const x = (e.clientX || e.touches?.[0].clientX) - rect.left;
    const y = (e.clientY || e.touches?.[0].clientY) - rect.top;
    const ctx = canvas.getContext('2d');
    ctx.beginPath();
    ctx.moveTo(x, y);
    drawPos.current = { x, y };
  }

  function onDraw(e) {
    if (!desenhando || !modoDraw) return;
    e.preventDefault();
    const canvas = canvasRef.current;
    const rect = canvas.getBoundingClientRect();
    const x = (e.clientX || e.touches?.[0].clientX) - rect.left;
    const y = (e.clientY || e.touches?.[0].clientY) - rect.top;
    const ctx = canvas.getContext('2d');
    ctx.lineWidth = 3;
    ctx.strokeStyle = '#ef4444';
    ctx.lineCap = 'round';
    ctx.lineTo(x, y);
    ctx.stroke();
  }

  function stopDraw() { setDesenhando(false); }

  if (loading) return <p className="text-sm text-muted-foreground py-4">Carregando galeria...</p>;

  return (
    <div className="space-y-4">
      {/* Barra de ações */}
      <div className="flex flex-wrap items-center gap-2 justify-between">
        <div className="flex items-center gap-2 flex-wrap">
          <span className="text-sm text-muted-foreground">{fotos.length} foto(s)</span>
          <div className="flex gap-1 flex-wrap">
            {['Todas', ...CATEGORIAS].map(cat => (
              <button
                key={cat}
                onClick={() => setFiltroCategoria(cat)}
                className={`text-xs px-2.5 py-1 rounded-full border transition-colors ${filtroCategoria === cat ? 'bg-primary text-primary-foreground border-primary' : 'border-border text-muted-foreground hover:bg-muted'}`}
              >
                {cat}
              </button>
            ))}
          </div>
        </div>
        <div className="flex items-center gap-2">
          <Button
            size="sm"
            variant={modoComparacao ? 'default' : 'outline'}
            onClick={() => { setModoComparacao(m => !m); setSelecionadas([]); }}
            className="gap-1.5"
          >
            <Columns className="w-3.5 h-3.5" />
            {modoComparacao ? 'Sair da Comparação' : 'Comparar'}
          </Button>
          <label className="cursor-pointer">
            <Button size="sm" className="gap-1.5 pointer-events-none" disabled={uploading}>
              <Upload className="w-3.5 h-3.5" />
              {uploading ? 'Enviando...' : 'Upload'}
            </Button>
            <input type="file" accept="image/*" multiple className="hidden" onChange={handleUpload} disabled={uploading} />
          </label>
        </div>
      </div>

      {/* Modo comparação lado a lado */}
      {modoComparacao && selecionadas.length === 2 && (
        <div className="border border-border rounded-xl overflow-hidden bg-black">
          <p className="text-xs text-center text-white/60 py-1">Comparação lado a lado — selecione outras fotos para alterar</p>
          <div className="grid grid-cols-2 gap-0.5">
            {selecionadas.map((f, i) => (
              <div key={i} className="relative">
                <img src={f.url} alt="" className="w-full object-cover max-h-72" />
                <div className="absolute bottom-0 left-0 right-0 bg-black/50 text-white text-xs p-1.5 text-center">
                  {f.categoria || f.origem} — {f.data ? format(new Date(f.data), 'dd/MM/yyyy') : ''}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
      {modoComparacao && selecionadas.length < 2 && (
        <div className="text-center text-sm text-muted-foreground border border-dashed border-border rounded-xl py-4">
          Selecione 2 fotos para comparar ({selecionadas.length}/2)
        </div>
      )}

      {/* Grade de fotos */}
      {fotosFiltradas.length === 0 ? (
        <div className="text-center py-12 text-muted-foreground border border-dashed border-border rounded-xl">
          <Camera className="w-10 h-10 mx-auto mb-2 opacity-30" />
          <p className="text-sm">Nenhuma foto encontrada.</p>
          <p className="text-xs mt-1">Adicione fotos via Upload ou nas Avaliações/Evoluções</p>
        </div>
      ) : (
        <div className="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2">
          {fotosFiltradas.map((foto, i) => {
            const selecionada = selecionadas.some(f => f.url === foto.url);
            return (
              <div
                key={i}
                className={`relative group cursor-pointer rounded-xl overflow-hidden border-2 transition-all ${
                  selecionada ? 'border-primary shadow-lg scale-105' : 'border-transparent hover:border-border'
                }`}
                onClick={() => modoComparacao ? toggleSelecionada(foto) : setFotoAmpliada(foto)}
              >
                <img src={foto.url} alt={foto.descricao || ''} className="w-full aspect-square object-cover" />
                {/* Badge categoria/origem */}
                <div className="absolute top-1 left-1">
                  <span className="text-xs bg-black/60 text-white px-1.5 py-0.5 rounded-full">
                    {foto.categoria || foto.origem}
                  </span>
                </div>
                {/* Data */}
                {foto.data && (
                  <div className="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-2">
                    <p className="text-white text-xs">{format(new Date(foto.data), 'dd/MM/yy')}</p>
                  </div>
                )}
                {/* Hover overlay */}
                <div className="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-all flex items-center justify-center">
                  <ZoomIn className="w-6 h-6 text-white opacity-0 group-hover:opacity-100 transition-opacity" />
                </div>
                {selecionada && (
                  <div className="absolute top-1 right-1 bg-primary rounded-full p-0.5">
                    <Layers className="w-3 h-3 text-primary-foreground" />
                  </div>
                )}
              </div>
            );
          })}
        </div>
      )}

      {/* Modal foto ampliada com desenho */}
      {fotoAmpliada && (
        <div className="fixed inset-0 z-50 bg-black/90 flex items-center justify-center p-4" onClick={() => { setFotoAmpliada(null); setModoDraw(false); }}>
          <div className="relative max-w-3xl w-full" onClick={e => e.stopPropagation()}>
            <div className="flex items-center justify-between mb-2 text-white">
              <div className="text-sm">
                {fotoAmpliada.categoria || fotoAmpliada.origem}
                {fotoAmpliada.data && ` — ${format(new Date(fotoAmpliada.data), 'dd/MM/yyyy')}`}
                {fotoAmpliada.descricao && ` — ${fotoAmpliada.descricao}`}
              </div>
              <div className="flex gap-2">
                <button
                  onClick={() => setModoDraw(m => !m)}
                  className={`text-xs px-3 py-1 rounded-lg border transition-colors ${modoDraw ? 'bg-red-500 border-red-500 text-white' : 'border-white/30 text-white hover:bg-white/10'}`}
                >
                  ✏️ {modoDraw ? 'Parar de Desenhar' : 'Marcar Área'}
                </button>
                <button onClick={() => setFotoAmpliada(null)} className="text-white/70 hover:text-white">
                  <X className="w-5 h-5" />
                </button>
              </div>
            </div>

            <div className="relative">
              <img src={fotoAmpliada.url} alt="" className="w-full rounded-xl max-h-[70vh] object-contain" id="foto-ampliada-img" />
              {modoDraw && (
                <canvas
                  ref={canvasRef}
                  className="absolute inset-0 w-full h-full rounded-xl cursor-crosshair touch-none"
                  style={{ pointerEvents: 'auto' }}
                  onMouseDown={startDraw}
                  onMouseMove={onDraw}
                  onMouseUp={stopDraw}
                  onMouseLeave={stopDraw}
                  onTouchStart={startDraw}
                  onTouchMove={onDraw}
                  onTouchEnd={stopDraw}
                  width={900}
                  height={600}
                />
              )}
            </div>
            {modoDraw && (
              <p className="text-center text-white/50 text-xs mt-2">Desenhe sobre a foto para marcar áreas de tratamento. As marcações são visuais e não são salvas.</p>
            )}
          </div>
        </div>
      )}
    </div>
  );
}

<file path="src/components/financeiro/CentroCustoPanel.jsx">
import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { Trash2, Edit2, Plus, X, Check } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';

const CORES = ['#6366f1','#8b5cf6','#ec4899','#ef4444','#f97316','#eab308','#22c55e','#14b8a6','#0ea5e9','#64748b'];

const FORM_VAZIO = { nome: '', descricao: '', cor: CORES[0] };

export default function CentroCustoPanel() {
  const [centros, setCentros] = useState([]);
  const [loading, setLoading] = useState(true);
  const [editando, setEditando] = useState(null); // null = oculto, 'novo' = novo, objeto = editar
  const [form, setForm] = useState(FORM_VAZIO);
  const [saving, setSaving] = useState(false);

  useEffect(() => { carregar(); }, []);

  async function carregar() {
    setLoading(true);
    const lista = await base44.entities.CentroCusto.list();
    setCentros(lista);
    setLoading(false);
  }

  function abrirNovo() {
    setForm(FORM_VAZIO);
    setEditando('novo');
  }

  function abrirEditar(centro) {
    setForm({ nome: centro.nome, descricao: centro.descricao || '', cor: centro.cor || CORES[0] });
    setEditando(centro);
  }

  function cancelar() {
    setEditando(null);
    setForm(FORM_VAZIO);
  }

  async function salvar() {
    if (!form.nome.trim()) return alert('Nome é obrigatório');
    setSaving(true);
    if (editando === 'novo') {
      await base44.entities.CentroCusto.create(form);
    } else {
      await base44.entities.CentroCusto.update(editando.id, form);
    }
    setSaving(false);
    setEditando(null);
    setForm(FORM_VAZIO);
    carregar();
  }

  async function deletar(id) {
    if (!confirm('Deseja excluir este centro de custo?')) return;
    await base44.entities.CentroCusto.delete(id);
    carregar();
  }

  return (
    <div className="space-y-4">
      <div className="flex justify-between items-center">
        <h2 className="font-semibold">Centros de Custo</h2>
        {editando === null && (
          <Button onClick={abrirNovo} size="sm" className="gap-1">
            <Plus className="w-4 h-4" /> Novo Centro
          </Button>
        )}
      </div>

      {/* Formulário inline */}
      {editando !== null && (
        <div className="border border-border rounded-lg p-4 space-y-3 bg-muted/30">
          <h3 className="text-sm font-medium">{editando === 'novo' ? 'Novo' : 'Editar'} Centro de Custo</h3>

          <div className="space-y-1">
            <Label className="text-xs">Nome *</Label>
            <Input
              value={form.nome}
              onChange={e => setForm({ ...form, nome: e.target.value })}
              placeholder="Ex: Administrativo, Marketing..."
              autoFocus
            />
          </div>

          <div className="space-y-1">
            <Label className="text-xs">Descrição</Label>
            <Input
              value={form.descricao}
              onChange={e => setForm({ ...form, descricao: e.target.value })}
              placeholder="Descrição opcional"
            />
          </div>

          <div className="space-y-1">
            <Label className="text-xs">Cor</Label>
            <div className="flex gap-2 flex-wrap">
              {CORES.map(cor => (
                <button
                  key={cor}
                  onClick={() => setForm({ ...form, cor })}
                  className="w-7 h-7 rounded-full border-2 transition-all flex items-center justify-center"
                  style={{
                    backgroundColor: cor,
                    borderColor: form.cor === cor ? '#000' : 'transparent',
                    transform: form.cor === cor ? 'scale(1.15)' : 'scale(1)',
                  }}
                >
                  {form.cor === cor && <Check className="w-3 h-3 text-white" />}
                </button>
              ))}
            </div>
          </div>

          <div className="flex gap-2 pt-1">
            <Button size="sm" onClick={salvar} disabled={saving} className="gap-1">
              <Check className="w-4 h-4" /> {saving ? 'Salvando...' : 'Salvar'}
            </Button>
            <Button size="sm" variant="outline" onClick={cancelar} className="gap-1">
              <X className="w-4 h-4" /> Cancelar
            </Button>
          </div>
        </div>
      )}

      {/* Lista */}
      {loading ? (
        <p className="text-sm text-muted-foreground text-center py-8">Carregando...</p>
      ) : centros.length === 0 ? (
        <p className="text-sm text-muted-foreground text-center py-8">Nenhum centro de custo cadastrado</p>
      ) : (
        <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
          {centros.map(centro => (
            <div key={centro.id} className="flex items-center gap-3 p-3 border border-border rounded-lg bg-card hover:bg-muted/30 transition-colors">
              <div className="w-4 h-4 rounded-full flex-shrink-0" style={{ backgroundColor: centro.cor || '#64748b' }} />
              <div className="flex-1 min-w-0">
                <p className="text-sm font-medium truncate">{centro.nome}</p>
                {centro.descricao && <p className="text-xs text-muted-foreground truncate">{centro.descricao}</p>}
              </div>
              <div className="flex gap-1 flex-shrink-0">
                <button onClick={() => abrirEditar(centro)} className="p-1.5 text-muted-foreground hover:text-foreground rounded">
                  <Edit2 className="w-4 h-4" />
                </button>
                <button onClick={() => deletar(centro.id)} className="p-1.5 text-destructive hover:text-destructive/80 rounded">
                  <Trash2 className="w-4 h-4" />
                </button>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

import { useEffect, useState } from 'react';
import { base44 } from '@/api/base44Client';
import { Plus, Edit2, Trash2, Shield, FileText, AlertCircle, CheckCircle2, Upload, X, CheckCircle } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import ConvenioModal from '@/components/financeiro/ConvenioModal';
import { format } from 'date-fns';

const tipoColor = {
  plano_saude: 'bg-blue-100 text-blue-700',
  particular: 'bg-gray-100 text-gray-600',
  sus: 'bg-green-100 text-green-700',
  outros: 'bg-yellow-100 text-yellow-700',
};

const statusColor = {
  pendente: 'bg-yellow-100 text-yellow-700',
  pago: 'bg-green-100 text-green-700',
  cancelado: 'bg-gray-100 text-gray-600',
  atrasado: 'bg-red-100 text-red-600',
};

const fmt = v => new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v);

export default function Convenios() {
  const [convenios, setConvenios] = useState([]);
  const [consultas, setConsultas] = useState([]);
  const [lancamentos, setLancamentos] = useState([]);
  const [modalOpen, setModalOpen] = useState(false);
  const [selecionado, setSelecionado] = useState(null);
  const [loading, setLoading] = useState(true);
  const [convenioFiltro, setConvenioFiltro] = useState('');
  const [arquivoGuias, setArquivoGuias] = useState(null);
  const [linhasArquivo, setLinhasArquivo] = useState([]);
  const [processando, setProcessando] = useState(false);
  const [matchResultado, setMatchResultado] = useState(null);

  useEffect(() => { load(); }, []);

  async function load() {
    const [c, cons, lanc] = await Promise.all([
      base44.entities.Convenio.list(),
      base44.entities.Consulta.filter({ status: 'concluido' }, '-data_hora', 500),
      base44.entities.LancamentoFinanceiro.filter({ categoria: 'convenio' }, '-data_vencimento', 300),
    ]);
    setConvenios(c);
    setConsultas(cons);
    setLancamentos(lanc);
    if (!convenioFiltro && c.length > 0) setConvenioFiltro(c[0].id);
    setLoading(false);
  }

  function handleArquivoGuias(e) {
    const file = e.target.files[0];
    if (!file) return;
    setArquivoGuias(file);
    setMatchResultado(null);
    const reader = new FileReader();
    reader.onload = (ev) => {
      const text = ev.target.result;
      // Tenta parsear como CSV simples (vírgula ou ponto-e-vírgula)
      const sep = text.includes(';') ? ';' : ',';
      const linhas = text.trim().split('\n').map(l => l.split(sep).map(c => c.replace(/^"|"$/g, '').trim()));
      setLinhasArquivo(linhas);
    };
    reader.readAsText(file, 'UTF-8');
  }

  function realizarMatch() {
    if (linhasArquivo.length < 2) return;
    setProcessando(true);
    // Tenta encontrar coluna de número de guia e valor no cabeçalho
    const cabecalho = linhasArquivo[0].map(c => c.toLowerCase());
    const idxGuia = cabecalho.findIndex(c => c.includes('guia') || c.includes('autoriza'));
    const idxValor = cabecalho.findIndex(c => c.includes('valor') || c.includes('total'));
    const idxPaciente = cabecalho.findIndex(c => c.includes('paciente') || c.includes('benefi') || c.includes('nome'));

    const guiasArquivo = linhasArquivo.slice(1).map(l => ({
      guia: idxGuia >= 0 ? l[idxGuia] : '',
      valor: idxValor >= 0 ? parseFloat(l[idxValor]?.replace(',', '.')) || 0 : 0,
      paciente: idxPaciente >= 0 ? l[idxPaciente] : '',
      _raw: l,
    }));

    // Match por número de guia com os atendimentos do convênio
    let matched = 0, naoEncontrado = 0;
    const resultado = guiasArquivo.map(g => {
      const consulta = consultasConvenio.find(c => c.numero_guia && g.guia && c.numero_guia.trim() === g.guia.trim());
      if (consulta) { matched++; return { ...g, status: 'encontrado', consulta }; }
      naoEncontrado++;
      return { ...g, status: 'nao_encontrado' };
    });

    setMatchResultado({ linhas: resultado, matched, naoEncontrado, colunas: { idxGuia, idxValor, idxPaciente } });
    setProcessando(false);
  }

  async function handleDelete(id) {
    if (!confirm('Excluir convênio?')) return;
    await base44.entities.Convenio.delete(id);
    load();
  }

  // Atendimentos do convênio selecionado
  const consultasConvenio = consultas.filter(c => c.convenio_id === convenioFiltro);
  const convenioAtual = convenios.find(c => c.id === convenioFiltro);

  // Lançamentos em aberto (pendentes) do convênio
  const lancamentosAbertos = lancamentos.filter(l => l.convenio_id === convenioFiltro && l.status !== 'pago' && l.status !== 'cancelado');
  const lancamentosPagos = lancamentos.filter(l => l.convenio_id === convenioFiltro && l.status === 'pago');

  const totalAberto = lancamentosAbertos.reduce((s, l) => s + (l.valor || 0), 0);
  const totalPago = lancamentosPagos.reduce((s, l) => s + (l.valor || 0), 0);
  const totalAtendimentos = consultasConvenio.reduce((s, c) => s + (c.valor || 0), 0);

  return (
    <div className="p-6 space-y-5">
      <div className="flex items-center justify-between">

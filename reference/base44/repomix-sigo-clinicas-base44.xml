import { useState } from 'react';
import { base44 } from '@/api/base44Client';
import { format } from 'date-fns';
import { X } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';

export default function MovimentacaoModal({ item, movimento, tipo: tipoInicial, onClose, onSaved }) {
  const [form, setForm] = useState({
    tipo: movimento?.tipo || tipoInicial || 'entrada',
    quantidade: movimento?.quantidade || '',
    preco_unitario: movimento?.preco_unitario || item?.preco_custo || '',
    data: movimento?.data || format(new Date(), 'yyyy-MM-dd'),
    fornecedor: movimento?.fornecedor || item?.fornecedor || '',
    observacao: movimento?.observacao || '',
  });
  const [saving, setSaving] = useState(false);
  const [deleting, setDeleting] = useState(false);

  function setF(k, v) { setForm(f => ({ ...f, [k]: v })); }

  const valorTotal = (Number(form.quantidade) || 0) * (Number(form.preco_unitario) || 0);

  async function handleSave() {
    if (!form.quantidade || Number(form.quantidade) <= 0) return;
    setSaving(true);

    const movData = {
      item_id: item.id,
      item_descricao: item.descricao,
      tipo: form.tipo,
      quantidade: Number(form.quantidade),
      preco_unitario: form.preco_unitario ? Number(form.preco_unitario) : undefined,
      valor_total: valorTotal || undefined,
      data: form.data,
      fornecedor: form.fornecedor,
      observacao: form.observacao,
    };

    if (movimento) {
      // Edição: desfaz o delta antigo e aplica o novo
      const deltaAntigo = movimento.tipo === 'saida' ? -movimento.quantidade : movimento.quantidade;
      const deltaNovoMov = form.tipo === 'saida' ? -Number(form.quantidade) : Number(form.quantidade);
      const novoSaldo = (item.saldo_atual || 0) - deltaAntigo + deltaNovoMov;

      // Se há lançamento financeiro, atualiza
      if (movimento.lancamento_financeiro_id) {
        await base44.entities.LancamentoFinanceiro.update(movimento.lancamento_financeiro_id, {
          tipo: form.tipo === 'entrada' ? 'despesa' : 'receita',
          valor: valorTotal || movimento.valor_total,
          data_vencimento: form.data,
          descricao: `Compra estoque: ${item.descricao} (${form.quantidade} ${item.unidade || 'un'})`,
        });
      }

      await Promise.all([
        base44.entities.MovimentacaoEstoque.update(movimento.id, movData),
        base44.entities.ItemEstoque.update(item.id, { saldo_atual: novoSaldo }),
      ]);
    } else {
      // Criação: novo movimento
      const delta = form.tipo === 'saida' ? -Number(form.quantidade) : Number(form.quantidade);
      const novoSaldo = (item.saldo_atual || 0) + delta;

      let lancamentoId = null;
      if (form.tipo === 'entrada' && valorTotal > 0) {
        const lanc = await base44.entities.LancamentoFinanceiro.create({
          tipo: 'despesa',
          descricao: `Compra estoque: ${item.descricao} (${form.quantidade} ${item.unidade || 'un'})`,
          valor: valorTotal,
          data_vencimento: form.data,
          status: 'pendente',
          categoria: 'material',
          observacoes: form.fornecedor ? `Fornecedor: ${form.fornecedor}` : undefined,
        });
        lancamentoId = lanc.id;
      }

      await Promise.all([
        base44.entities.MovimentacaoEstoque.create({ ...movData, lancamento_financeiro_id: lancamentoId }),
        base44.entities.ItemEstoque.update(item.id, { saldo_atual: novoSaldo }),
      ]);
    }

    setSaving(false);
    onSaved();
  }

  async function handleDelete() {
    if (!movimento) return;
    if (!confirm('Excluir esta movimentação e reverter o saldo?')) return;
    setDeleting(true);

    // Desfaz o delta da movimentação
    const deltaAntigo = movimento.tipo === 'saida' ? -movimento.quantidade : movimento.quantidade;
    const novoSaldo = (item.saldo_atual || 0) - deltaAntigo;

    // Se há lançamento financeiro, deleta também
    if (movimento.lancamento_financeiro_id) {
      await base44.entities.LancamentoFinanceiro.delete(movimento.lancamento_financeiro_id);
    }

    await Promise.all([
      base44.entities.MovimentacaoEstoque.delete(movimento.id),
      base44.entities.ItemEstoque.update(item.id, { saldo_atual: novoSaldo }),
    ]);

    setDeleting(false);
    onSaved();
  }

  const tipoLabel = { saldo_inicial: 'Saldo Inicial', entrada: 'Entrada', saida: 'Saída' };

  return (
    <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
      <div className="bg-card rounded-xl shadow-xl w-full max-w-md">
        <div className="flex items-center justify-between p-5 border-b border-border">
          <h2 className="text-base font-semibold">{movimento ? 'Editar' : 'Registrar'} {tipoLabel[form.tipo]}</h2>
          <button onClick={onClose}><X className="w-5 h-5 text-muted-foreground" /></button>
        </div>
        <div className="p-5 space-y-3">
          <div className="px-3 py-2 bg-muted/40 rounded-lg text-sm">
            <span className="font-medium">{item.descricao}</span>
            {item.codigo && <span className="text-muted-foreground ml-2">({item.codigo})</span>}
            <div className="text-xs text-muted-foreground mt-0.5">Saldo atual: <span className="font-semibold text-foreground">{item.saldo_atual || 0} {item.unidade || 'un'}</span></div>
          </div>

          <div className="space-y-1.5">
            <Label>Tipo de Movimentação</Label>
            <Select value={form.tipo} onValueChange={v => setF('tipo', v)}>
              <SelectTrigger><SelectValue /></SelectTrigger>
              <SelectContent>
                <SelectItem value="saldo_inicial">Saldo Inicial</SelectItem>
                <SelectItem value="entrada">Entrada (Compra)</SelectItem>
                <SelectItem value="saida">Saída (Consumo)</SelectItem>
              </SelectContent>
            </Select>
          </div>

          <div className="grid grid-cols-2 gap-3">
            <div className="space-y-1.5">
              <Label>Quantidade *</Label>
              <Input type="number" value={form.quantidade} onChange={e => setF('quantidade', e.target.value)} placeholder="0" />
            </div>
            <div className="space-y-1.5">
              <Label>Data</Label>
              <Input type="date" value={form.data} onChange={e => setF('data', e.target.value)} />
            </div>
          </div>

          {(form.tipo === 'entrada' || form.tipo === 'saldo_inicial') && (
            <div className="space-y-1.5">
              <Label>Preço Unitário (R$)</Label>
              <Input type="number" value={form.preco_unitario} onChange={e => setF('preco_unitario', e.target.value)} placeholder="0,00" />
            </div>
          )}

          {form.tipo === 'entrada' && (
            <div className="space-y-1.5">
              <Label>Fornecedor</Label>
              <Input value={form.fornecedor} onChange={e => setF('fornecedor', e.target.value)} placeholder="Nome do fornecedor" />
            </div>
          )}

          <div className="space-y-1.5">
            <Label>Observação</Label>
            <Input value={form.observacao} onChange={e => setF('observacao', e.target.value)} placeholder="Opcional" />
          </div>

          {form.tipo === 'entrada' && valorTotal > 0 && (
            <div className="flex items-center justify-between px-3 py-2.5 bg-orange-50 border border-orange-200 rounded-lg text-sm">
              <span className="text-orange-800 font-medium">Será lançado em Contas a Pagar:</span>
              <span className="font-bold text-orange-900">
                {new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(valorTotal)}
              </span>
            </div>
          )}
        </div>
        <div className="flex items-center gap-2 p-5 border-t border-border">
          {movimento && (
            <Button variant="destructive" size="sm" onClick={handleDelete} disabled={deleting}>
              {deleting ? 'Excluindo...' : 'Excluir'}
            </Button>
          )}
          <div className="flex-1" />
          <Button variant="outline" onClick={onClose}>Cancelar</Button>
          <Button onClick={handleSave} disabled={saving || !form.quantidade}>{saving ? 'Salvando...' : movimento ? 'Atualizar' : 'Registrar'}</Button>
        </div>
      </div>
    </div>
  );
}
</file>

<file path="src/components/estoque/RastreabilidadeLotes.jsx">
import { useMemo } from 'react';
import { format, parseISO, isBefore, addDays } from 'date-fns';
import { AlertTriangle, CheckCircle2, Clock } from 'lucide-react';

const categoriaLabel = {
  material_consumo: 'Material',
  medicamento: 'Medicamento',
  equipamento: 'Equipamento',
  limpeza: 'Limpeza',
  descartavel: 'Descartável',
  outros: 'Outros',
};

export default function RastreabilidadeLotes({ movimentacoes, itens }) {
  const hoje = new Date();
  const em30dias = addDays(hoje, 30);

  // Agrupa entradas que possuem lote ou validade
  const entradasRastreadas = useMemo(() => {
    return movimentacoes
      .filter(m => (m.tipo === 'entrada' || m.tipo === 'saldo_inicial') && (m.lote || m.validade))
      .sort((a, b) => (a.data || '').localeCompare(b.data || ''))
      .map(m => {
        const item = itens.find(i => i.id === m.item_id);
        let statusValidade = 'ok';
        if (m.validade) {
          const valDate = parseISO(m.validade);
          if (isBefore(valDate, hoje)) statusValidade = 'vencido';
          else if (isBefore(valDate, em30dias)) statusValidade = 'proximo';
        }
        return { ...m, item, statusValidade };
      });
  }, [movimentacoes, itens]);

  const vencidos = entradasRastreadas.filter(e => e.statusValidade === 'vencido');
  const proximos = entradasRastreadas.filter(e => e.statusValidade === 'proximo');

  return (
    <div className="space-y-5">
      {/* Alertas */}
      {(vencidos.length > 0 || proximos.length > 0) && (
        <div className="space-y-2">
          {vencidos.length > 0 && (
            <div className="flex items-center gap-2 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-800">
              <AlertTriangle className="w-4 h-4 shrink-0" />
              <strong>{vencidos.length} lote(s) VENCIDO(S)</strong> — verifique imediatamente e remova do estoque.
            </div>
          )}
          {proximos.length > 0 && (
            <div className="flex items-center gap-2 p-3 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
              <Clock className="w-4 h-4 shrink-0" />
              <strong>{proximos.length} lote(s) vencendo em até 30 dias</strong> — priorize o uso.
            </div>
          )}
        </div>
      )}

      {entradasRastreadas.length === 0 ? (
        <div className="text-center py-16 text-muted-foreground border border-dashed border-border rounded-xl">
          <AlertTriangle className="w-10 h-10 mx-auto mb-2 opacity-30" />
          <p className="text-sm">Nenhuma entrada com lote ou validade registrada.</p>
          <p className="text-xs mt-1">Informe lote e validade ao registrar entradas de medicamentos e insumos.</p>
        </div>
      ) : (
        <div className="border border-border rounded-xl overflow-hidden">
          <table className="w-full text-sm">
            <thead className="bg-muted/40 border-b border-border">
              <tr>
                <th className="text-left px-4 py-3 font-medium text-muted-foreground">Item</th>
                <th className="text-left px-4 py-3 font-medium text-muted-foreground">Cat.</th>
                <th className="text-left px-4 py-3 font-medium text-muted-foreground">Lote</th>
                <th className="text-left px-4 py-3 font-medium text-muted-foreground">Validade</th>
                <th className="text-right px-4 py-3 font-medium text-muted-foreground">Qtd Entrada</th>
                <th className="text-left px-4 py-3 font-medium text-muted-foreground">Fornecedor</th>
                <th className="text-left px-4 py-3 font-medium text-muted-foreground">Data Compra</th>
                <th className="text-center px-4 py-3 font-medium text-muted-foreground">Status</th>
              </tr>
            </thead>
            <tbody className="divide-y divide-border">
              {entradasRastreadas.map((m, idx) => (
                <tr key={idx} className={`hover:bg-muted/20 ${m.statusValidade === 'vencido' ? 'bg-red-50/40' : m.statusValidade === 'proximo' ? 'bg-yellow-50/40' : ''}`}>
                  <td className="px-4 py-3">
                    <div className="font-medium">{m.item?.descricao || m.item_descricao}</div>
                    {m.item?.codigo && <div className="text-xs text-muted-foreground">{m.item.codigo}</div>}
                  </td>
                  <td className="px-4 py-3">
                    <span className="text-xs px-2 py-0.5 rounded-full bg-secondary text-secondary-foreground">
                      {categoriaLabel[m.item?.categoria] || '—'}
                    </span>
                  </td>
                  <td className="px-4 py-3 font-mono text-xs">{m.lote || '—'}</td>
                  <td className="px-4 py-3">
                    {m.validade ? (
                      <span className={`font-medium ${m.statusValidade === 'vencido' ? 'text-red-600' : m.statusValidade === 'proximo' ? 'text-yellow-700' : 'text-foreground'}`}>
                        {format(parseISO(m.validade), 'dd/MM/yyyy')}
                      </span>
                    ) : '—'}
                  </td>
                  <td className="px-4 py-3 text-right">{m.quantidade} {m.item?.unidade || 'un'}</td>
                  <td className="px-4 py-3 text-muted-foreground text-xs">{m.fornecedor || '—'}</td>
                  <td className="px-4 py-3 text-muted-foreground text-xs">{m.data ? format(parseISO(m.data), 'dd/MM/yyyy') : '—'}</td>
                  <td className="px-4 py-3 text-center">
                    {m.statusValidade === 'vencido' ? (
                      <span className="text-xs px-2 py-0.5 rounded-full bg-red-100 text-red-700 font-medium flex items-center gap-1 justify-center">
                        <AlertTriangle className="w-3 h-3" /> Vencido
                      </span>
                    ) : m.statusValidade === 'proximo' ? (
                      <span className="text-xs px-2 py-0.5 rounded-full bg-yellow-100 text-yellow-700 font-medium flex items-center gap-1 justify-center">
                        <Clock className="w-3 h-3" /> {Math.ceil((parseISO(m.validade) - hoje) / (1000 * 60 * 60 * 24))}d
                      </span>
                    ) : (
                      <span className="text-xs px-2 py-0.5 rounded-full bg-green-100 text-green-700 font-medium flex items-center gap-1 justify-center">
                        <CheckCircle2 className="w-3 h-3" /> OK
                      </span>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  );
}

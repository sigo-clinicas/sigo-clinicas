import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { Plus, Stethoscope, Pencil, Trash2, ChevronDown, ChevronUp, Camera, X, Printer, ClipboardList } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { format } from 'date-fns';
import { ptBR } from 'date-fns/locale';
import AbaAnamnese from '@/components/anamnese/AbaAnamnese';

export default function AbaAvaliacaoClinica({ paciente }) {
  const [subTab, setSubTab] = useState('avaliacoes'); // 'avaliacoes' | 'anamnese'
  const [lista, setLista] = useState([]);
  const [anamneses, setAnamneses] = useState([]);
  const [loading, setLoading] = useState(true);
  const [editando, setEditando] = useState(null);
  const [expandido, setExpandido] = useState(null);
  const [anamneseExpandida, setAnamneseExpandida] = useState(null);

  useEffect(() => { load(); }, [paciente.id]);

  async function load() {
    setLoading(true);
    const [data, ans] = await Promise.all([
      base44.entities.AvaliacaoClinica.filter({ paciente_id: paciente.id }, '-data'),
      base44.entities.RespostaAnamnese.filter({ paciente_id: paciente.id }, '-data_preenchimento'),
    ]);
    setLista(data);
    setAnamneses(ans.filter(a => a.status === 'preenchido'));
    setLoading(false);
  }

  async function excluir(id) {
    if (!confirm('Excluir esta avaliação?')) return;
    await base44.entities.AvaliacaoClinica.delete(id);
    load();
  }

  function imprimirAvaliacao(av) {
    const win = window.open('', '_blank');
    win.document.write(`
      <html>
        <head>
          <title>Avaliação - ${paciente.nome}</title>
          <style>
            body { font-family: Arial, sans-serif; font-size: 11px; color: #000; margin: 30px; }
            h1 { font-size: 14px; margin: 0 0 2px; font-weight: bold; }
            h2 { font-size: 12px; margin: 20px 0 8px; font-weight: bold; border-bottom: 2px solid #333; padding-bottom: 4px; }
            .info { margin: 2px 0; }
            .info-label { font-weight: bold; display: inline-block; width: 140px; }
            .info-value { display: inline; }
            table { width: 100%; border-collapse: collapse; margin: 12px 0; }
            th { background: #f0f0f0; border: 1px solid #333; padding: 6px; text-align: left; font-weight: bold; font-size: 10px; }
            td { border: 1px solid #333; padding: 8px; height: 24px; }
            .assinatura-box { width: 100%; margin-top: 30px; }
            .assinatura-linha { display: inline-block; width: 30%; text-align: center; margin-right: 5%; }
            .assinatura-linha-terceira { display: inline-block; width: 30%; text-align: center; }
            .linha { border-top: 1px solid #000; padding-top: 2px; margin-top: 30px; font-size: 9px; }
            .termo { margin-top: 20px; padding: 10px; border: 1px solid #ccc; background: #f9f9f9; }
            .termo-texto { font-size: 10px; line-height: 1.4; margin-bottom: 10px; text-align: justify; }
            @media print { body { margin: 15px; } }
          </style>
        </head>
        <body>
          <h1>AVALIAÇÃO CLÍNICA</h1>
          <div class="info"><span class="info-label">Paciente:</span> <span class="info-value">${paciente.nome}</span></div>
          <div class="info"><span class="info-label">Data:</span> <span class="info-value">${format(new Date(av.data), 'dd/MM/yyyy', { locale: ptBR })}</span></div>
          <div class="info"><span class="info-label">Profissional:</span> <span class="info-value">${av.profissional_nome || ''}</span></div>

          ${av.queixa_principal ? `<h2>Queixa Principal</h2><div class="info">${av.queixa_principal}</div>` : ''}
          ${av.historia_doenca_atual ? `<h2>História da Doença Atual</h2><div class="info">${av.historia_doenca_atual}</div>` : ''}
          ${av.hipotese_diagnostica ? `<h2>Hipótese Diagnóstica</h2><div class="info">${av.hipotese_diagnostica}</div>` : ''}
          ${av.plano_terapeutico ? `<h2>Plano Terapêutico</h2><div class="info">${av.plano_terapeutico}</div>` : ''}

          <h2>5. REGISTRO DE EVOLUÇÃO E EXECUÇÃO</h2>
          <table>
            <thead>
              <tr>
                <th style="width: 12%;">Data</th>
                <th style="width: 40%;">Descrição do Procedimento/Evolução Clínica</th>
                <th style="width: 30%;">Insumos (Lote/Validade)</th>
                <th style="width: 18%;">Assinatura Prof.</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td></tr>
              <tr><td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td></tr>
              <tr><td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td></tr>
              <tr><td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td></tr>
              <tr><td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td></tr>
            </tbody>
          </table>

          <h2>6. TERMO DE CONSENTIMENTO E CIÊNCIA</h2>
          <div class="termo">
            <div class="termo-texto">
              Declaro que fui devidamente informado(a) sobre os riscos, benefícios e cuidados necessários relativos ao tratamento proposto. Autorizo a realização dos procedimentos e o registro fotográfico para fins de acompanhamento clínico.
            </div>
          </div>

          <div class="assinatura-box">
            <div class="assinatura-linha">
              <div style="height: 40px;"></div>
              <div class="linha">Assinatura do Paciente/Responsável</div>
            </div>
            <div class="assinatura-linha-terceira">
              <div style="height: 40px;"></div>
              <div class="linha">Assinatura e Carimbo do Profissional</div>
            </div>
          </div>
        </body>
      </html>
    `);
    win.document.close();
    win.focus();
    win.print();
    win.close();
  }

  if (editando !== null) {
    return (
      <FormAvaliacao
        avaliacao={editando === 'novo' ? null : editando}
        paciente={paciente}
        onSaved={() => { setEditando(null); load(); }}
        onCancel={() => setEditando(null)}
      />
    );
  }

  if (loading) return <p className="text-sm text-muted-foreground py-4">Carregando...</p>;

  return (
    <div className="space-y-4">
      {/* Sub-tabs: Avaliações | Anamnese */}
      <div className="flex gap-1 border-b border-border">
        <button
          onClick={() => setSubTab('avaliacoes')}
          className={`flex items-center gap-1.5 px-3 py-2 text-sm font-medium border-b-2 -mb-px transition-all ${subTab === 'avaliacoes' ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground'}`}
        >
          <Stethoscope className="w-3.5 h-3.5" /> Avaliações Clínicas
          {lista.length > 0 && <span className="text-xs bg-muted px-1.5 rounded-full">{lista.length}</span>}
        </button>
        <button
          onClick={() => setSubTab('anamnese')}
          className={`flex items-center gap-1.5 px-3 py-2 text-sm font-medium border-b-2 -mb-px transition-all ${subTab === 'anamnese' ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground'}`}
        >
          <ClipboardList className="w-3.5 h-3.5" /> Anamnese
          {anamneses.length > 0 && <span className="text-xs bg-yellow-100 text-yellow-700 px-1.5 rounded-full">{anamneses.length}</span>}
        </button>
      </div>

      {subTab === 'anamnese' && <AbaAnamnese paciente={paciente} />}

      {subTab === 'avaliacoes' && (
        <div className="space-y-4">
          <div className="flex items-center justify-between">
            <p className="text-sm text-muted-foreground">{lista.length} avaliação(ões)</p>
            <Button size="sm" onClick={() => setEditando('novo')} className="gap-1.5">
              <Plus className="w-3.5 h-3.5" /> Nova Avaliação
            </Button>
          </div>

          {lista.length === 0 ? (
            <div className="text-center py-10 text-muted-foreground border border-dashed border-border rounded-xl">
              <Stethoscope className="w-8 h-8 mx-auto mb-2 opacity-30" />
              <p className="text-sm">Nenhuma avaliação registrada.</p>
            </div>
          ) : (
            <div className="space-y-2">
              {lista.map(av => (
                <div key={av.id} className="bg-card border border-border rounded-xl overflow-hidden">
                  <div
                    className="p-4 flex items-center gap-3 cursor-pointer hover:bg-muted/30 transition-colors"
                    onClick={() => setExpandido(expandido === av.id ? null : av.id)}
                  >
                    <div className="flex-1 min-w-0">
                      <div className="font-medium text-sm">{format(new Date(av.data), 'dd/MM/yyyy', { locale: ptBR })}</div>
                      {av.queixa_principal && (
                        <div className="text-xs text-muted-foreground mt-0.5 truncate">Queixa: {av.queixa_principal}</div>
                      )}
                      {av.hipotese_diagnostica && (
                        <div className="text-xs text-primary mt-0.5 truncate">Diagnóstico: {av.hipotese_diagnostica}</div>
                      )}
                    </div>
                    <div className="flex items-center gap-2 shrink-0">
                      <button onClick={e => { e.stopPropagation(); imprimirAvaliacao(av); }} className="text-muted-foreground hover:text-primary p-1" title="Imprimir avaliação">
                        <Printer className="w-3.5 h-3.5" />
                      </button>
                      <button onClick={e => { e.stopPropagation(); setEditando(av); }} className="text-muted-foreground hover:text-foreground p-1">
                        <Pencil className="w-3.5 h-3.5" />
                      </button>
                      <button onClick={e => { e.stopPropagation(); excluir(av.id); }} className="text-muted-foreground hover:text-destructive p-1">
                        <Trash2 className="w-3.5 h-3.5" />
                      </button>
                      {expandido === av.id ? <ChevronUp className="w-4 h-4 text-muted-foreground" /> : <ChevronDown className="w-4 h-4 text-muted-foreground" />}
                    </div>
                  </div>

                  {expandido === av.id && (
                    <div className="border-t border-border p-4 space-y-3 bg-muted/10">
                      <div className="grid grid-cols-2 gap-4 text-sm">
                        {av.profissional_nome && <Info label="Profissional" value={av.profissional_nome} />}
                        {av.pressao_arterial && <Info label="Pressão Arterial" value={av.pressao_arterial} />}
                        {av.frequencia_cardiaca && <Info label="Freq. Cardíaca" value={av.frequencia_cardiaca} />}
                        {av.peso && <Info label="Peso" value={`${av.peso} kg`} />}
                        {av.altura && <Info label="Altura" value={`${av.altura} cm`} />}
                      </div>
                      {av.queixa_principal && <Info label="Queixa Principal" value={av.queixa_principal} full />}
                      {av.historia_doenca_atual && <Info label="História da Doença" value={av.historia_doenca_atual} full />}
                      {av.historico_familiar && <Info label="Histórico Familiar/Pessoal" value={av.historico_familiar} full />}
                      {av.revisao_sistemas && <Info label="Revisão de Sistemas" value={av.revisao_sistemas} full />}
                      {av.exame_especifico && <Info label="Exame Físico Específico" value={av.exame_especifico} full />}
                      {av.resultados_exames && <Info label="Exames Complementares" value={av.resultados_exames} full />}
                      {av.hipotese_diagnostica && <Info label="Hipótese Diagnóstica" value={av.hipotese_diagnostica} full />}
                      {av.plano_terapeutico && <Info label="Plano Terapêutico" value={av.plano_terapeutico} full />}
                      {av.fotos_urls?.length > 0 && (
                        <div>
                          <p className="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Fotos</p>
                          <div className="flex gap-2 flex-wrap">
                            {av.fotos_urls.map((f, i) => (
                              <a key={i} href={f.url} target="_blank" rel="noopener noreferrer">
                                <img src={f.url} alt={f.descricao || `Foto ${i+1}`} className="w-20 h-20 object-cover rounded-lg border border-border hover:opacity-80 transition-opacity" />
                              </a>
                            ))}
                          </div>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              ))}
            </div>
          )}
        </div>
      )}
    </div>
  );
}

function Info({ label, value, full }) {
  return (
    <div className={`space-y-0.5 ${full ? 'col-span-2' : ''}`}>
      <p className="text-xs text-muted-foreground font-medium uppercase tracking-wide">{label}</p>
      <p className="text-sm whitespace-pre-wrap">{value}</p>
    </div>
  );
}

function FormAvaliacao({ avaliacao, paciente, onSaved, onCancel }) {
  const [profissionais, setProfissionais] = useState([]);
  const [saving, setSaving] = useState(false);
  const [uploadingFoto, setUploadingFoto] = useState(false);
  const [form, setForm] = useState({
    paciente_id: paciente.id,
    paciente_nome: paciente.nome,
    profissional_id: avaliacao?.profissional_id || '',
    profissional_nome: avaliacao?.profissional_nome || '',
    data: avaliacao?.data || new Date().toISOString().split('T')[0],
    queixa_principal: avaliacao?.queixa_principal || '',
    historia_doenca_atual: avaliacao?.historia_doenca_atual || '',
    historico_familiar: avaliacao?.historico_familiar || '',
    revisao_sistemas: avaliacao?.revisao_sistemas || '',
    pressao_arterial: avaliacao?.pressao_arterial || '',
    frequencia_cardiaca: avaliacao?.frequencia_cardiaca || '',
    peso: avaliacao?.peso || '',
    altura: avaliacao?.altura || '',
    exame_especifico: avaliacao?.exame_especifico || '',
    resultados_exames: avaliacao?.resultados_exames || '',
    hipotese_diagnostica: avaliacao?.hipotese_diagnostica || '',
    plano_terapeutico: avaliacao?.plano_terapeutico || '',
    fotos_urls: avaliacao?.fotos_urls || [],
  });

  useEffect(() => {
    base44.entities.Profissional.list().then(p => setProfissionais(p.filter(x => x.ativo !== false)));
  }, []);

  function set(k, v) { setForm(f => ({ ...f, [k]: v })); }

  async function handleFoto(e) {
    const file = e.target.files[0];
    if (!file) return;
    setUploadingFoto(true);
    const { file_url } = await base44.integrations.Core.UploadFile({ file });
    setForm(f => ({ ...f, fotos_urls: [...f.fotos_urls, { url: file_url, descricao: '', data: new Date().toISOString().split('T')[0] }] }));
    setUploadingFoto(false);
  }

  function removerFoto(idx) {
    setForm(f => ({ ...f, fotos_urls: f.fotos_urls.filter((_, i) => i !== idx) }));
  }

  async function salvar() {
    if (!form.data) return alert('Data é obrigatória.');
    setSaving(true);
    if (avaliacao) await base44.entities.AvaliacaoClinica.update(avaliacao.id, form);
    else await base44.entities.AvaliacaoClinica.create(form);
    setSaving(false);
    onSaved();
  }

  return (
    <div className="space-y-5">
      <button onClick={onCancel} className="text-xs text-muted-foreground hover:text-foreground">← Voltar</button>

      {/* Cabeçalho */}
      <div className="grid grid-cols-2 gap-3">
        <div className="space-y-1">
          <Label className="text-xs">Data *</Label>
          <Input type="date" value={form.data} onChange={e => set('data', e.target.value)} />
        </div>
        <div className="space-y-1">
          <Label className="text-xs">Profissional</Label>
          <select
            className="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm"
            value={form.profissional_id}
            onChange={e => {
              const p = profissionais.find(x => x.id === e.target.value);
              set('profissional_id', e.target.value);
              set('profissional_nome', p?.nome || '');
            }}
          >
            <option value="">— Selecionar —</option>
            {profissionais.map(p => <option key={p.id} value={p.id}>{p.nome}</option>)}
          </select>
        </div>
      </div>

      {/* Sinais Vitais */}
      <Secao titulo="Sinais Vitais">
        <div className="grid grid-cols-2 gap-3">
          <Campo label="Pressão Arterial" value={form.pressao_arterial} onChange={v => set('pressao_arterial', v)} placeholder="Ex: 120/80 mmHg" />
          <Campo label="Freq. Cardíaca" value={form.frequencia_cardiaca} onChange={v => set('frequencia_cardiaca', v)} placeholder="Ex: 72 bpm" />
          <Campo label="Peso (kg)" type="number" value={form.peso} onChange={v => set('peso', v)} placeholder="Ex: 70" />
          <Campo label="Altura (cm)" type="number" value={form.altura} onChange={v => set('altura', v)} placeholder="Ex: 170" />
        </div>
      </Secao>

      {/* Anamnese */}
      <Secao titulo="Anamnese">
        <TextArea label="Queixa Principal (palavras do paciente)" value={form.queixa_principal} onChange={v => set('queixa_principal', v)} placeholder="Descreva o motivo da consulta..." />
        <TextArea label="História da Doença Atual" value={form.historia_doenca_atual} onChange={v => set('historia_doenca_atual', v)} placeholder="Como e quando os sintomas começaram..." />
        <TextArea label="Histórico Familiar / Pessoal" value={form.historico_familiar} onChange={v => set('historico_familiar', v)} placeholder="Doenças, alergias, cirurgias, vícios..." />
        <TextArea label="Revisão de Sistemas" value={form.revisao_sistemas} onChange={v => set('revisao_sistemas', v)} placeholder="Sono, apetite, digestão, etc." />
      </Secao>

      {/* Exame Físico */}
      <Secao titulo="Exame Físico">
        <TextArea label="Exame Específico" value={form.exame_especifico} onChange={v => set('exame_especifico', v)} placeholder="Estado atual da área a ser tratada..." />
        <TextArea label="Exames Complementares" value={form.resultados_exames} onChange={v => set('resultados_exames', v)} placeholder="Resultados de exames laboratoriais ou de imagem..." />
      </Secao>

      {/* Diagnóstico e Plano */}
      <Secao titulo="Diagnóstico e Plano Terapêutico">
        <TextArea label="Hipótese Diagnóstica" value={form.hipotese_diagnostica} onChange={v => set('hipotese_diagnostica', v)} placeholder="Conclusão do profissional..." />
        <TextArea label="Plano Terapêutico / Conduta" value={form.plano_terapeutico} onChange={v => set('plano_terapeutico', v)} placeholder="O que será feito, medicamentos, doses, duração..." rows={4} />
      </Secao>

      {/* Fotos */}
      <Secao titulo="Registro Fotográfico">
        <div className="flex flex-wrap gap-2">
          {form.fotos_urls.map((f, i) => (
            <div key={i} className="relative">
              <img src={f.url} alt={f.descricao || `Foto ${i+1}`} className="w-20 h-20 object-cover rounded-lg border border-border" />
              <button
                onClick={() => removerFoto(i)}
                className="absolute -top-1.5 -right-1.5 bg-destructive text-destructive-foreground rounded-full p-0.5"
              >
                <X className="w-3 h-3" />
              </button>
            </div>
          ))}
          <label className="w-20 h-20 flex flex-col items-center justify-center border-2 border-dashed border-border rounded-lg cursor-pointer hover:bg-muted/30 transition-colors text-muted-foreground">
            {uploadingFoto ? <span className="text-xs">...</span> : <><Camera className="w-5 h-5 mb-1" /><span className="text-xs">Foto</span></>}
            <input type="file" accept="image/*" className="hidden" onChange={handleFoto} disabled={uploadingFoto} />
          </label>
        </div>
      </Secao>

      <div className="flex justify-end gap-2 pt-2">
        <Button variant="outline" size="sm" onClick={onCancel}>Cancelar</Button>
        <Button size="sm" onClick={salvar} disabled={saving}>{saving ? 'Salvando...' : 'Salvar Avaliação'}</Button>
      </div>
    </div>
  );
}

function Secao({ titulo, children }) {
  return (
    <div className="border border-border rounded-xl p-4 space-y-3">
      <h3 className="text-sm font-semibold text-foreground">{titulo}</h3>
      {children}
    </div>
  );
}

function Campo({ label, value, onChange, placeholder, type = 'text' }) {
  return (
    <div className="space-y-1">
      <Label className="text-xs">{label}</Label>
      <Input type={type} value={value} onChange={e => onChange(e.target.value)} placeholder={placeholder} />
    </div>
  );
}

function TextArea({ label, value, onChange, placeholder, rows = 3 }) {
  return (
    <div className="space-y-1">
      <Label className="text-xs">{label}</Label>
      <textarea
        className="w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm resize-none focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
        style={{ minHeight: `${rows * 1.75}rem` }}
        value={value}
        onChange={e => onChange(e.target.value)}
        placeholder={placeholder}
      />
    </div>
  );
}

function NovoReceituario({ paciente, evolucao, onSaved, onCancel, onPrint }) {
  const [profissionais, setProfissionais] = useState([]);
  const [saving, setSaving] = useState(false);
  const [form, setForm] = useState({
    paciente_id: paciente.id,
    paciente_nome: paciente.nome,
    profissional_id: evolucao?.profissional_id || '',
    profissional_nome: evolucao?.profissional_nome || '',
    data_hora: evolucao?.data_hora || new Date().toISOString(),
    prescricao: evolucao?.prescricao || '',
    orientacoes_pos: evolucao?.orientacoes_pos || '',
  });

  useEffect(() => {
    base44.entities.Profissional.list().then(p => setProfissionais(p.filter(x => x.ativo !== false)));
  }, []);

  function set(k, v) { setForm(f => ({ ...f, [k]: v })); }

  async function salvar(emitir = false) {
    if (!form.prescricao.trim()) return alert('A prescrição é obrigatória.');
    setSaving(true);
    if (evolucao) {
      await base44.entities.EvolucaoSessao.update(evolucao.id, {
        prescricao: form.prescricao,
        orientacoes_pos: form.orientacoes_pos,
        profissional_id: form.profissional_id,
        profissional_nome: form.profissional_nome,
      });
    } else {
      await base44.entities.EvolucaoSessao.create({
        paciente_id: form.paciente_id,
        paciente_nome: form.paciente_nome,
        profissional_id: form.profissional_id,
        profissional_nome: form.profissional_nome,
        data_hora: form.data_hora,
        descricao_atendimento: 'Receituário Digital',
        prescricao: form.prescricao,
        orientacoes_pos: form.orientacoes_pos,
      });
    }
    setSaving(false);
    if (emitir) {
      const profissional = profissionais.find(p => p.id === form.profissional_id);
      onPrint({ ...form, data: form.data_hora }, profissional);
    }
    onSaved();
  }

  return (
    <div className="space-y-4">
      <button onClick={onCancel} className="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1">
        ← Voltar
      </button>

      <div className="flex items-center gap-2">
        <FileSignature className="w-5 h-5 text-primary" />
        <h2 className="font-semibold">Nova Receita Digital</h2>
      </div>

      <div className="flex items-start gap-3 bg-green-50 border border-green-200 rounded-xl p-3">
        <ShieldCheck className="w-4 h-4 text-green-600 shrink-0 mt-0.5" />
        <p className="text-xs text-green-800">Documento conforme Lei nº 14.063/2020. Após salvar, imprima e assine digitalmente com certificado ICP-Brasil para validade jurídica plena.</p>
      </div>

      <div className="grid grid-cols-2 gap-3">
        <div className="space-y-1">
          <Label className="text-xs">Profissional Prescritor</Label>
          <select
            className="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm"
            value={form.profissional_id}
            onChange={e => {
              const p = profissionais.find(x => x.id === e.target.value);
              set('profissional_id', e.target.value);
              set('profissional_nome', p?.nome || '');
            }}
          >
            <option value="">— Selecionar —</option>
            {profissionais.map(p => <option key={p.id} value={p.id}>{p.nome}{p.crm ? ` (CRM: ${p.crm})` : ''}</option>)}
          </select>
        </div>
        <div className="space-y-1">
          <Label className="text-xs">Data da Prescrição</Label>
          <Input
            type="datetime-local"
            value={form.data_hora ? form.data_hora.slice(0, 16) : ''}
            onChange={e => set('data_hora', e.target.value + ':00')}
          />
        </div>
      </div>

      <div className="space-y-1">
        <Label className="text-xs">Prescrição Médica *</Label>
        <textarea
          className="w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm resize-none focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring font-mono"
          style={{ minHeight: '160px' }}
          value={form.prescricao}
          onChange={e => set('prescricao', e.target.value)}
          placeholder={`Ex:\n1. Amoxicilina 500mg — 1 cápsula de 8 em 8 horas por 7 dias.\n2. Ibuprofeno 600mg — 1 comprimido de 12 em 12 horas se dor por 3 dias.\n\nUso: Oral`}
        />
      </div>

      <div className="space-y-1">
        <Label className="text-xs">Orientações ao Paciente</Label>
        <textarea
          className="w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm resize-none focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
          style={{ minHeight: '80px' }}
          value={form.orientacoes_pos}
          onChange={e => set('orientacoes_pos', e.target.value)}
          placeholder="Cuidados pós-procedimento, restrições, retorno..."
        />
      </div>

      <div className="flex justify-end gap-2 pt-2">
        <Button variant="outline" size="sm" onClick={onCancel}>Cancelar</Button>
        <Button variant="outline" size="sm" onClick={() => salvar(false)} disabled={saving}>
          {saving ? 'Salvando...' : 'Salvar Rascunho'}
        </Button>
        <Button size="sm" onClick={() => salvar(true)} disabled={saving} className="gap-1.5">
          <Printer className="w-3.5 h-3.5" />
          {saving ? 'Salvando...' : 'Salvar e Imprimir'}
        </Button>
      </div>
    </div>
  );
}

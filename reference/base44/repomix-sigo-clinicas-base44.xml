<file path="src/components/servicos/AbaComposicao.jsx">
import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { Plus, X, Trash2, Save } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';

export default function AbaComposicao({ servicoId }) {
  const [composicao, setComposicao] = useState(null);
  const [itens, setItens] = useState([]);
  const [loading, setLoading] = useState(true);
  const [markup, setMarkup] = useState(100);
  const [showAddItem, setShowAddItem] = useState(false);
  const [itensBuscados, setItensBuscados] = useState([]);
  const [itemSelecionado, setItemSelecionado] = useState('');
  const [tabelas, setTabelas] = useState([]);
  const [showSalvarTabela, setShowSalvarTabela] = useState(false);
  const [tabelaSelecionada, setTabelaSelecionada] = useState('');
  const [valorTabela, setValorTabela] = useState(0);
  const [servico, setServico] = useState(null);

  useEffect(() => {
    async function carregar() {
      setLoading(true);
      // Carrega composição existente
      const comp = await base44.entities.ComposicaoServico.filter({ servico_id: servicoId });
      if (comp.length > 0) {
        setComposicao(comp[0]);
        setItens(comp[0].itens || []);
        setMarkup(comp[0].markup_percentual || 100);
      } else {
        setComposicao({ servico_id: servicoId, itens: [] });
      }

      // Carrega itens de estoque
      const items = await base44.entities.ItemEstoque.filter({ ativo: true });
      setItensBuscados(items);

      // Carrega serviço
      const srv = await base44.entities.Servico.filter({ id: servicoId });
      if (srv.length > 0) setServico(srv[0]);

      // Carrega tabelas
      const tabs = await base44.entities.TabelaPreco.filter({ ativo: true });
      setTabelas(tabs);

      setLoading(false);
    }
    carregar();
  }, [servicoId]);

  const custoTotal = itens.reduce((sum, i) => sum + (i.valor_total || 0), 0);
  const precoVenda = custoTotal + (custoTotal * (markup / 100));

  async function adicionarItem() {
    if (!itemSelecionado) return;
    const item = itensBuscados.find(x => x.id === itemSelecionado);
    if (!item) return;

    const novoItem = {
      item_estoque_id: item.id,
      item_descricao: item.descricao,
      quantidade: 1,
      unidade: item.unidade,
      preco_unitario: item.preco_custo || 0,
      valor_total: item.preco_custo || 0,
    };
    setItens([...itens, novoItem]);
    setItemSelecionado('');
    setShowAddItem(false);
  }

  function atualizarItem(idx, field, value) {
    const newItens = [...itens];
    newItens[idx][field] = field === 'quantidade' || field === 'preco_unitario' ? Number(value) : value;
    if (field === 'quantidade' || field === 'preco_unitario') {
      newItens[idx].valor_total = newItens[idx].quantidade * newItens[idx].preco_unitario;
    }
    setItens(newItens);
  }

  function removerItem(idx) {
    setItens(itens.filter((_, i) => i !== idx));
  }

  async function salvar() {
    const dados = {
      servico_id: servicoId,
      itens,
      custo_total: custoTotal,
      markup_percentual: markup,
      preco_venda: precoVenda,
    };

    if (composicao?.id) {
      await base44.entities.ComposicaoServico.update(composicao.id, dados);
    } else {
      await base44.entities.ComposicaoServico.create(dados);
    }
    alert('Composição salva com sucesso!');
  }

  async function salvarNaTabela() {
    if (!tabelaSelecionada || !servico) return alert('Selecione uma tabela');
    
    const item = await base44.entities.ItemTabelaPreco.filter({
      tabela_id: tabelaSelecionada,
      servico_id: servicoId
    });

    if (item.length > 0) {
      await base44.entities.ItemTabelaPreco.update(item[0].id, {
        valor: valorTabela,
        tipo_valor: 'fixo'
      });
    } else {
      await base44.entities.ItemTabelaPreco.create({
        tabela_id: tabelaSelecionada,
        servico_id: servicoId,
        servico_nome: servico.nome,
        valor: valorTabela,
        tipo_valor: 'fixo'
      });
    }

    alert('Preço salvo na tabela com sucesso!');
    setShowSalvarTabela(false);
    setTabelaSelecionada('');
    setValorTabela(0);
  }

  if (loading) {
    return <div className="p-4 text-sm text-muted-foreground">Carregando...</div>;
  }

  return (
    <div className="space-y-4 p-4">
      <div className="flex items-center justify-between">
        <h3 className="font-semibold">Composição do Serviço</h3>
        <Button size="sm" onClick={() => setShowAddItem(!showAddItem)} className="gap-1.5">
          <Plus className="w-4 h-4" />
          Adicionar Item
        </Button>
      </div>

      {showAddItem && (
        <div className="border border-border rounded-lg p-3 space-y-2 bg-muted/30">
          <div className="space-y-1">
            <Label className="text-xs">Item de Estoque</Label>
            <Select value={itemSelecionado} onValueChange={setItemSelecionado}>
              <SelectTrigger>
                <SelectValue placeholder="Selecionar item" />
              </SelectTrigger>
              <SelectContent>
                {itensBuscados.map(item => (
                  <SelectItem key={item.id} value={item.id}>
                    {item.descricao} ({item.unidade})
                  </SelectItem>
                ))}
              </SelectContent>
            </Select>
          </div>
          <div className="flex gap-2">
            <Button size="sm" onClick={adicionarItem}>Adicionar</Button>
            <Button size="sm" variant="outline" onClick={() => setShowAddItem(false)}>Cancelar</Button>
          </div>
        </div>
      )}

      <div className="border border-border rounded-lg overflow-hidden">
        <table className="w-full text-sm">
          <thead className="bg-muted border-b border-border">
            <tr>
              <th className="px-3 py-2 text-left font-medium">Item</th>
              <th className="px-3 py-2 text-left font-medium w-20">Qtd</th>
              <th className="px-3 py-2 text-left font-medium w-24">Preço Unit.</th>
              <th className="px-3 py-2 text-left font-medium w-24">Total</th>
              <th className="px-3 py-2 text-center w-10"></th>
            </tr>
          </thead>
          <tbody>
            {itens.length === 0 ? (
              <tr>
                <td colSpan="5" className="px-3 py-4 text-center text-xs text-muted-foreground">
                  Nenhum item adicionado
                </td>
              </tr>
            ) : (
              itens.map((item, idx) => (
                <tr key={idx} className="border-b border-border hover:bg-muted/50">
                  <td className="px-3 py-2 text-xs">{item.item_descricao}</td>
                  <td className="px-3 py-2">
                    <Input
                      type="number"
                      value={item.quantidade}
                      onChange={e => atualizarItem(idx, 'quantidade', e.target.value)}
                      className="h-7 text-xs"
                      min="0.1"
                      step="0.1"
                    />
                  </td>
                  <td className="px-3 py-2">
                    <Input
                      type="number"
                      value={item.preco_unitario}
                      onChange={e => atualizarItem(idx, 'preco_unitario', e.target.value)}
                      className="h-7 text-xs"
                      step="0.01"
                    />
                  </td>
                  <td className="px-3 py-2 text-xs font-medium">
                    R$ {item.valor_total.toFixed(2).replace('.', ',')}
                  </td>
                  <td className="px-3 py-2 text-center">
                    <button
                      onClick={() => removerItem(idx)}
                      className="text-destructive hover:text-destructive/80"
                    >
                      <Trash2 className="w-4 h-4" />
                    </button>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>

      <div className="grid grid-cols-3 gap-3 border border-border rounded-lg p-3 bg-muted/30">
        <div>
          <p className="text-xs text-muted-foreground">Custo Total</p>
          <p className="text-sm font-semibold">R$ {custoTotal.toFixed(2).replace('.', ',')}</p>
        </div>
        <div>
          <Label className="text-xs">Markup (%)</Label>
          <Input
            type="number"
            value={markup}
            onChange={e => setMarkup(Number(e.target.value))}
            className="h-8 text-sm"
            min="0"
          />
        </div>
        <div>
          <p className="text-xs text-muted-foreground">Preço Venda</p>
          <p className="text-sm font-semibold text-primary">R$ {precoVenda.toFixed(2).replace('.', ',')}</p>
        </div>
      </div>

      <div className="flex gap-2">
        <Button onClick={salvar} className="flex-1">
          Salvar Composição
        </Button>
        <Button onClick={() => { setValorTabela(precoVenda); setShowSalvarTabela(true); }} variant="outline" className="gap-1.5">
          <Save className="w-4 h-4" />
          Salvar Preço na Tabela
        </Button>
      </div>

      {showSalvarTabela && (
        <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
          <div className="bg-card rounded-xl shadow-xl w-full max-w-sm">
            <div className="flex items-center justify-between p-5 border-b border-border">
              <h2 className="text-base font-semibold">Salvar Preço na Tabela</h2>
              <button onClick={() => setShowSalvarTabela(false)} className="text-muted-foreground hover:text-foreground"><X className="w-5 h-5" /></button>
            </div>
            <div className="p-5 space-y-4">
              <div className="space-y-1.5">
                <Label>Tabela de Preços *</Label>
                <Select value={tabelaSelecionada} onValueChange={setTabelaSelecionada}>
                  <SelectTrigger>
                    <SelectValue placeholder="Selecionar tabela" />
                  </SelectTrigger>
                  <SelectContent>
                    {tabelas.map(tab => (
                      <SelectItem key={tab.id} value={tab.id}>
                        {tab.nome}
                      </SelectItem>
                    ))}
                  </SelectContent>
                </Select>
              </div>
              <div className="space-y-1.5">
                <Label>Valor (R$)</Label>
                <Input
                  type="number"
                  value={valorTabela}
                  onChange={e => setValorTabela(Number(e.target.value))}
                  step="0.01"
                  min="0"
                  placeholder="0,00"
                />
                <p className="text-xs text-muted-foreground">Preço calculado: R$ {precoVenda.toFixed(2).replace('.', ',')}</p>
              </div>
            </div>
            <div className="flex items-center gap-2 p-5 border-t border-border">
              <div className="flex-1" />
              <Button variant="outline" onClick={() => setShowSalvarTabela(false)}>Cancelar</Button>
              <Button onClick={salvarNaTabela}>Salvar</Button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
</file>


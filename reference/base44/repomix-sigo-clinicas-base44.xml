<file path="src/components/estoque/EntradaEstoqueModal.jsx">
import { useState, useMemo } from 'react';
import { base44 } from '@/api/base44Client';
import { format } from 'date-fns';
import { X, Plus, Trash2 } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';

const fmt = v => new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v || 0);

export default function EntradaEstoqueModal({ itensEstoque, onClose, onSaved }) {
  const [data, setData] = useState(format(new Date(), 'yyyy-MM-dd'));
  const [fornecedor, setFornecedor] = useState('');
  const [observacao, setObservacao] = useState('');
  const [formaPagamento, setFormaPagamento] = useState('boleto');
  const [numeroParcelas, setNumeroParcelas] = useState(1);
  const [linhas, setLinhas] = useState([{ item_id: '', quantidade: '', preco_unitario: '', lote: '', validade: '' }]);
  const [saving, setSaving] = useState(false);
  const [centrosCusto, setCentrosCusto] = useState([]);
  const [centroCustoId, setCentroCustoId] = useState('');
  const [centroCustoNome, setCentroCustoNome] = useState('');

  useState(() => {
    base44.entities.CentroCusto.list().then(list => setCentrosCusto(list.filter(x => x.ativo !== false)));
  });

  function addLinha() {
    setLinhas(l => [...l, { item_id: '', quantidade: '', preco_unitario: '', lote: '', validade: '' }]);
  }

  function removeLinha(idx) {
    setLinhas(l => l.filter((_, i) => i !== idx));
  }

  function updateLinha(idx, key, value) {
    setLinhas(l => l.map((row, i) => {
      if (i !== idx) return row;
      const updated = { ...row, [key]: value };
      // Auto-preenche preço ao selecionar item
      if (key === 'item_id') {
        const item = itensEstoque.find(x => x.id === value);
        if (item?.preco_custo) updated.preco_unitario = String(item.preco_custo);
      }
      return updated;
    }));
  }

  const linhasValidas = linhas.filter(l => l.item_id && Number(l.quantidade) > 0);

  const totalGeral = useMemo(() => {
    return linhas.reduce((sum, l) => sum + (Number(l.quantidade) || 0) * (Number(l.preco_unitario) || 0), 0);
  }, [linhas]);

  function calcularVencimentos() {
    const parcelas = [];
    const valorParcela = totalGeral / numeroParcelas;
    for (let i = 0; i < numeroParcelas; i++) {
      const dataVenc = new Date(data);
      dataVenc.setMonth(dataVenc.getMonth() + i);
      parcelas.push({
        numero: i + 1,
        valor: i === numeroParcelas - 1 ? totalGeral - (valorParcela * i) : valorParcela,
        vencimento: format(dataVenc, 'yyyy-MM-dd'),
        pago: false
      });
    }
    return parcelas;
  }

  async function handleSave() {
    if (linhasValidas.length === 0) return;
    // Validar itens com requer_validade
    const semValidade = linhasValidas.filter(l => {
      const item = itensEstoque.find(x => x.id === l.item_id);
      return item?.requer_validade && !l.validade;
    });
    if (semValidade.length > 0) {
      const nomes = semValidade.map(l => itensEstoque.find(x => x.id === l.item_id)?.descricao).join(', ');
      alert(`Informe a data de validade para: ${nomes}`);
      return;
    }
    setSaving(true);

    // 1. Gera lançamento(s) em Contas a Pagar
    const descItens = linhasValidas.map(l => {
      const item = itensEstoque.find(x => x.id === l.item_id);
      return `${item?.descricao} (${l.quantidade})`;
    }).join(', ');

    const parcelas = calcularVencimentos();
    let lancamentoId = null;

    if (totalGeral > 0) {
      const ccNome = centroCustoId ? centroCustoNome : 'Sem Centro Definido';
      const lanc = await base44.entities.LancamentoFinanceiro.create({
        tipo: 'despesa',
        descricao: `Compra estoque${fornecedor ? ` - ${fornecedor}` : ''}: ${descItens}`,
        valor: totalGeral,
        data_vencimento: parcelas[0].vencimento,
        status: 'pendente',
        categoria: 'material',
        forma_pagamento: formaPagamento,
        venda_parcelas: parcelas,
        centro_custo_id: centroCustoId || undefined,
        centro_custo_nome: ccNome,
        observacoes: observacao || undefined,
      });
      lancamentoId = lanc.id;
    }

    // 2. Para cada linha: cria movimentação + atualiza saldo
    await Promise.all(linhasValidas.map(async (l) => {
      const item = itensEstoque.find(x => x.id === l.item_id);
      const qtd = Number(l.quantidade);
      const preco = Number(l.preco_unitario) || 0;
      const total = qtd * preco;

      await Promise.all([
        base44.entities.MovimentacaoEstoque.create({
          item_id: item.id,
          item_descricao: item.descricao,
          tipo: 'entrada',
          quantidade: qtd,
          preco_unitario: preco || undefined,
          valor_total: total || undefined,
          data,
          fornecedor: fornecedor || undefined,
          lote: l.lote || undefined,
          validade: l.validade || undefined,
          observacao: observacao || undefined,
          lancamento_financeiro_id: lancamentoId,
        }),
        base44.entities.ItemEstoque.update(item.id, { saldo_atual: (item.saldo_atual || 0) + qtd }),
      ]);
    }));

    setSaving(false);
    onSaved();
  }

  return (
    <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
      <div className="bg-card rounded-xl shadow-xl w-full max-w-2xl max-h-[90vh] flex flex-col">
        {/* Header */}
        <div className="flex items-center justify-between p-5 border-b border-border shrink-0">
          <h2 className="text-base font-semibold">Registrar Entrada de Estoque</h2>
          <button onClick={onClose}><X className="w-5 h-5 text-muted-foreground" /></button>
        </div>

        <div className="overflow-y-auto flex-1 p-5 space-y-4">
          {/* Cabeçalho da nota */}
          <div className="grid grid-cols-2 gap-3">
            <div className="space-y-1.5">
              <Label>Data *</Label>
              <Input type="date" value={data} onChange={e => setData(e.target.value)} />
            </div>
            <div className="space-y-1.5">
              <Label>Fornecedor</Label>
              <Input value={fornecedor} onChange={e => setFornecedor(e.target.value)} placeholder="Nome do fornecedor" />
            </div>
          </div>

          {/* Forma de Pagamento e Parcelas */}
          <div className="grid grid-cols-2 gap-3">
            <div className="space-y-1.5">
              <Label>Forma de Pagamento</Label>
              <Select value={formaPagamento} onValueChange={setFormaPagamento}>
                <SelectTrigger>
                  <SelectValue />
                </SelectTrigger>
                <SelectContent>
                  <SelectItem value="dinheiro">Dinheiro</SelectItem>
                  <SelectItem value="boleto">Boleto</SelectItem>
                  <SelectItem value="transferencia">Transferência</SelectItem>
                  <SelectItem value="cartao_credito">Cartão de Crédito</SelectItem>
                  <SelectItem value="cartao_debito">Cartão de Débito</SelectItem>
                </SelectContent>
              </Select>
            </div>
            <div className="space-y-1.5">
              <Label>Número de Parcelas</Label>
              <Select value={String(numeroParcelas)} onValueChange={v => setNumeroParcelas(Number(v))}>
                <SelectTrigger>
                  <SelectValue />
                </SelectTrigger>
                <SelectContent>
                  {[1, 2, 3, 4, 6, 12].map(n => (
                    <SelectItem key={n} value={String(n)}>{n}x</SelectItem>
                  ))}
                </SelectContent>
              </Select>
            </div>
          </div>

          {/* Centro de Custo */}
          <div className="space-y-1.5">
            <Label>Centro de Custo</Label>
            <Select
              value={centroCustoId || 'sem_centro'}
              onValueChange={v => {
                if (v === 'sem_centro') { setCentroCustoId(''); setCentroCustoNome(''); }
                else {
                  const cc = centrosCusto.find(x => x.id === v);
                  setCentroCustoId(v);
                  setCentroCustoNome(cc?.nome || '');
                }
              }}
            >
              <SelectTrigger><SelectValue placeholder="Sem Centro Definido" /></SelectTrigger>
              <SelectContent>
                <SelectItem value="sem_centro">Sem Centro Definido</SelectItem>
                {centrosCusto.map(cc => (
                  <SelectItem key={cc.id} value={cc.id}>{cc.nome}{cc.codigo ? ` (${cc.codigo})` : ''}</SelectItem>
                ))}
              </SelectContent>
            </Select>
          </div>

          {/* Itens */}
          <div>
            <div className="flex items-center justify-between mb-2">
              <Label>Itens da Entrada</Label>
              <Button size="sm" variant="outline" onClick={addLinha} className="gap-1 h-7 text-xs">
                <Plus className="w-3.5 h-3.5" /> Adicionar Item
              </Button>
            </div>

            <div className="border border-border rounded-lg overflow-hidden">
              <table className="w-full text-sm">
                <thead className="bg-muted/40 border-b border-border">
                  <tr>
                    <th className="text-left px-3 py-2.5 font-medium text-muted-foreground">Item</th>
                    <th className="text-right px-3 py-2.5 font-medium text-muted-foreground w-20">Qtd</th>
                    <th className="text-right px-3 py-2.5 font-medium text-muted-foreground w-24">Preço Unit.</th>
                    <th className="text-left px-3 py-2.5 font-medium text-muted-foreground w-24">Lote</th>
                    <th className="text-left px-3 py-2.5 font-medium text-muted-foreground w-28">Validade</th>
                    <th className="text-right px-3 py-2.5 font-medium text-muted-foreground w-24">Total</th>
                    <th className="w-10" />
                  </tr>
                </thead>
                <tbody className="divide-y divide-border">
                  {linhas.map((linha, idx) => {
                    const item = itensEstoque.find(x => x.id === linha.item_id);
                    const linhaTotal = (Number(linha.quantidade) || 0) * (Number(linha.preco_unitario) || 0);
                    return (
                      <tr key={idx} className="bg-card">
                        <td className="px-3 py-2">
                          <Select value={linha.item_id} onValueChange={v => updateLinha(idx, 'item_id', v)}>
                            <SelectTrigger className="h-8 text-xs">
                              <SelectValue placeholder="Selecionar item..." />
                            </SelectTrigger>
                            <SelectContent>
                              {itensEstoque.map(it => (
                                <SelectItem key={it.id} value={it.id}>
                                  {it.descricao}{it.codigo ? ` (${it.codigo})` : ''}
                                </SelectItem>
                              ))}
                            </SelectContent>
                          </Select>
                          {item && <div className="text-xs text-muted-foreground mt-0.5 pl-1">Saldo: {item.saldo_atual || 0} {item.unidade || 'un'}</div>}
                        </td>
                        <td className="px-3 py-2">
                          <Input
                            type="number"
                            className="h-8 text-xs text-right"
                            value={linha.quantidade}
                            onChange={e => updateLinha(idx, 'quantidade', e.target.value)}
                            placeholder="0"
                          />
                        </td>
                        <td className="px-3 py-2">
                          <Input
                            type="number"
                            className="h-8 text-xs text-right"
                            value={linha.preco_unitario}
                            onChange={e => updateLinha(idx, 'preco_unitario', e.target.value)}
                            placeholder="0,00"
                          />
                        </td>
                        <td className="px-3 py-2">
                          <Input
                            className="h-8 text-xs"
                            value={linha.lote}
                            onChange={e => updateLinha(idx, 'lote', e.target.value)}
                            placeholder="Nº lote"
                          />
                        </td>
                        <td className="px-3 py-2">
                          {(() => {
                            const itemSel = item;
                            const required = itemSel?.requer_validade;
                            return (
                              <Input
                                type="date"
                                className={`h-8 text-xs ${required && !linha.validade ? 'border-red-400 bg-red-50' : ''}`}
                                value={linha.validade}
                                onChange={e => updateLinha(idx, 'validade', e.target.value)}
                                title={required ? 'Obrigatório para este item' : ''}
                              />
                            );
                          })()}
                        </td>
                        <td className="px-3 py-2 text-right font-medium text-sm">
                          {linhaTotal > 0 ? fmt(linhaTotal) : '—'}
                        </td>
                        <td className="px-3 py-2 text-center">
                          {linhas.length > 1 && (
                            <button onClick={() => removeLinha(idx)} className="text-muted-foreground hover:text-destructive transition-colors">
                              <Trash2 className="w-4 h-4" />
                            </button>
                          )}
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          </div>

          <div className="space-y-1.5">
            <Label>Observação</Label>
            <Input value={observacao} onChange={e => setObservacao(e.target.value)} placeholder="Nº NF, referência, etc." />
          </div>

          {/* Parcelas Preview */}
          {numeroParcelas > 1 && totalGeral > 0 && (
            <div className="border border-border rounded-lg overflow-hidden">
              <div className="bg-muted/40 px-3 py-2.5 border-b border-border">
                <p className="text-xs font-medium text-muted-foreground">Vencimentos das Parcelas</p>
              </div>
              <div className="divide-y divide-border">
                {calcularVencimentos().map(p => (
                  <div key={p.numero} className="flex items-center justify-between px-3 py-2 text-sm">
                    <span className="text-muted-foreground">Parcela {p.numero}</span>
                    <div className="text-right">
                      <span className="font-medium">{fmt(p.valor)}</span>
                      <span className="text-xs text-muted-foreground ml-3">Vence: {new Date(p.vencimento).toLocaleDateString('pt-BR')}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* Total + aviso contas a pagar */}
          <div className="flex items-center justify-between px-4 py-3 bg-orange-50 border border-orange-200 rounded-lg">
            <div>
              <p className="text-sm font-medium text-orange-900">Total da Entrada</p>
              {totalGeral > 0 && <p className="text-xs text-orange-700 mt-0.5">{numeroParcelas} lançamento(s) em Contas a Pagar</p>}
            </div>
            <p className="text-xl font-bold text-orange-900">{fmt(totalGeral)}</p>
          </div>
        </div>

        {/* Footer */}
        <div className="flex items-center gap-2 p-5 border-t border-border shrink-0">
          <div className="flex-1" />
          <Button variant="outline" onClick={onClose}>Cancelar</Button>
          <Button onClick={handleSave} disabled={saving || linhasValidas.length === 0}>
            {saving ? 'Salvando...' : `Registrar Entrada (${linhasValidas.length} item${linhasValidas.length !== 1 ? 's' : ''})`}
          </Button>
        </div>
      </div>
    </div>
  );
}
</file>

<file path="src/components/estoque/ItemEstoqueModal.jsx">
import { useState } from 'react';
import { base44 } from '@/api/base44Client';
import { X, Trash2 } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';

const classificacoes = [
  { value: 'material_consumo', label: 'Material de Consumo' },
  { value: 'medicamento', label: 'Medicamento' },
  { value: 'equipamento', label: 'Equipamento' },
  { value: 'limpeza', label: 'Limpeza' },
  { value: 'descartavel', label: 'Descartável' },
  { value: 'produto_venda', label: 'Produto para Venda' },
  { value: 'outros', label: 'Outros' },
];

export default function ItemEstoqueModal({ item, onClose, onSaved }) {
  const [form, setForm] = useState({
    codigo: item?.codigo || '',
    descricao: item?.descricao || '',
    classificacao: item?.classificacao || item?.categoria || 'material_consumo',
    categoria: item?.categoria && !['material_consumo','medicamento','equipamento','limpeza','descartavel','outros'].includes(item.categoria) ? item.categoria : '',
    requer_validade: item?.requer_validade || false,
    unidade: item?.unidade || 'un',
    preco_custo: item?.preco_custo || '',
    preco_venda: item?.preco_venda || '',
    para_venda: item?.para_venda || false,
    estoque_minimo: item?.estoque_minimo || '',
    fornecedor: item?.fornecedor || '',
    ativo: item?.ativo !== false,
  });
  const [saving, setSaving] = useState(false);

  function setF(k, v) { setForm(f => ({ ...f, [k]: v })); }

  async function handleSave() {
    setSaving(true);
    const data = {
      ...form,
      preco_custo: form.preco_custo ? Number(form.preco_custo) : undefined,
      preco_venda: form.preco_venda ? Number(form.preco_venda) : undefined,
      estoque_minimo: form.estoque_minimo ? Number(form.estoque_minimo) : 0,
    };
    if (item) await base44.entities.ItemEstoque.update(item.id, data);
    else await base44.entities.ItemEstoque.create({ ...data, saldo_atual: 0 });
    setSaving(false);
    onSaved();
  }

  async function handleDelete() {
    if (!confirm('Excluir este item do estoque?')) return;
    await base44.entities.ItemEstoque.delete(item.id);
    onSaved();
  }

  return (
    <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
      <div className="bg-card rounded-xl shadow-xl w-full max-w-md">
        <div className="flex items-center justify-between p-5 border-b border-border">
          <h2 className="text-base font-semibold">{item ? 'Editar Item' : 'Novo Item de Estoque'}</h2>
          <button onClick={onClose}><X className="w-5 h-5 text-muted-foreground" /></button>
        </div>
        <div className="p-5 space-y-3">
          <div className="grid grid-cols-2 gap-3">
            <div className="space-y-1.5">
              <Label>Código</Label>
              <Input value={form.codigo} onChange={e => setF('codigo', e.target.value)} placeholder="Ex: MAT001" />
            </div>
            <div className="space-y-1.5">
              <Label>Unidade</Label>
              <Input value={form.unidade} onChange={e => setF('unidade', e.target.value)} placeholder="un, cx, ml..." />
            </div>
          </div>
          <div className="space-y-1.5">
            <Label>Descrição *</Label>
            <Input value={form.descricao} onChange={e => setF('descricao', e.target.value)} placeholder="Nome do produto" />
          </div>
          <div className="grid grid-cols-2 gap-3">
            <div className="space-y-1.5">
              <Label>Classificação</Label>
              <Select value={form.classificacao} onValueChange={v => setF('classificacao', v)}>
                <SelectTrigger><SelectValue /></SelectTrigger>
                <SelectContent>{classificacoes.map(c => <SelectItem key={c.value} value={c.value}>{c.label}</SelectItem>)}</SelectContent>
              </Select>
            </div>
            <div className="space-y-1.5">
              <Label>Categoria (livre)</Label>
              <Input value={form.categoria} onChange={e => setF('categoria', e.target.value)} placeholder="Ex: Botox, Fios..." />
            </div>
          </div>

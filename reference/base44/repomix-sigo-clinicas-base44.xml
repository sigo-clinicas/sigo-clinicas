<file path="src/pages/financeiro/Comissoes.jsx">
import { useEffect, useState, useMemo } from 'react';
import { base44 } from '@/api/base44Client';
import { useClinica } from '@/lib/ClinicaContext';
import { format, startOfMonth, endOfMonth, subMonths, addMonths } from 'date-fns';
import { ptBR } from 'date-fns/locale';
import { Users, ChevronLeft, ChevronRight, FileText, AlertCircle, CheckCircle2, Printer } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';

const fmt = v => new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v || 0);

const statusColor = {
  pendente: 'bg-yellow-100 text-yellow-700',
  pago: 'bg-green-100 text-green-700',
  cancelado: 'bg-gray-100 text-gray-600',
};

export default function Comissoes() {
  const { config } = useClinica();
  const baseComissao = config.base_comissao || 'por_agendamento';

  const [profissionais, setProfissionais] = useState([]);
  const [consultas, setConsultas] = useState([]);
  const [evolucoes, setEvolucoes] = useState([]);
  const [lancamentos, setLancamentos] = useState([]);
  const [loading, setLoading] = useState(true);
  const [profFiltro, setProfFiltro] = useState('');
  const [mesBase, setMesBase] = useState(new Date());
  const [gerandoLanc, setGerandoLanc] = useState(false);

  // Estado de conferência: { [itemKey]: { conferido: bool, valor: number } }
  const [conferencias, setConferencias] = useState({});

  // Filtro histórico
  const [histMes, setHistMes] = useState(format(new Date(), 'yyyy-MM'));

  useEffect(() => { load(); }, []);

  // Resetar conferências ao mudar mês ou profissional
  useEffect(() => { setConferencias({}); }, [profFiltro, mesBase]);

  async function load() {
    const [profs, cons, evols, lancs] = await Promise.all([
      base44.entities.Profissional.filter({ ativo: true }),
      base44.entities.Consulta.filter({ status: 'concluido' }, '-data_hora', 1000),
      base44.entities.EvolucaoSessao.list('-data_hora', 1000),
      base44.entities.LancamentoFinanceiro.filter({ categoria: 'salario' }, '-data_vencimento', 300),
    ]);
    setProfissionais(profs);
    setConsultas(cons);
    setEvolucoes(evols);
    setLancamentos(lancs);
    if (!profFiltro && profs.length > 0) setProfFiltro(profs[0].id);
    setLoading(false);
  }

  const mesStr = format(mesBase, 'yyyy-MM');
  const profAtual = profissionais.find(p => p.id === profFiltro);

  const atendimentosMes = useMemo(() => {
    if (!profFiltro) return [];
    if (baseComissao === 'por_evolucao') {
      return evolucoes.filter(e => e.profissional_id === profFiltro && e.data_hora?.slice(0, 7) === mesStr);
    }
    return consultas.filter(c => c.profissional_id === profFiltro && c.data_hora?.slice(0, 7) === mesStr);
  }, [profFiltro, mesStr, baseComissao, consultas, evolucoes]);

  const itensComissao = useMemo(() => {
    if (!profAtual) return [];
    return atendimentosMes.map((item, idx) => {
      const isEvolucao = baseComissao === 'por_evolucao';
      const servicoNome = isEvolucao
        ? (item.descricao_atendimento?.slice(0, 60) || 'Evolução')
        : (item.servico_nome || item.servicos?.[0]?.servico_nome || 'Consulta');
      const valorBase = item.valor || 0;
      const data = item.data_hora;
      const paciente = item.paciente_nome || '—';

      const servId = isEvolucao ? null : (item.servico_id || item.servicos?.[0]?.servico_id);
      const confComissao = profAtual.servicos_comissao?.find(sc => sc.servico_id === servId);
      let valorComissaoCalc = 0;
      if (confComissao) {
        valorComissaoCalc = confComissao.tipo_comissao === 'percentual'
          ? (valorBase * confComissao.comissao) / 100
          : confComissao.comissao;
      }

      const key = item.id || `${idx}`;
      return { key, item, servicoNome, valorBase, valorComissaoCalc, data, paciente };
    });
  }, [atendimentosMes, profAtual, baseComissao]);

  // Valor de comissão ajustado (editado pelo usuário ou calculado)
  function getConf(key) {
    return conferencias[key] || { conferido: false, valor: null };
  }

  function setConferido(key, checked) {
    setConferencias(prev => ({ ...prev, [key]: { ...getConf(key), conferido: checked } }));
  }

  function setValorConf(key, valor, valorCalc) {
    setConferencias(prev => ({ ...prev, [key]: { ...getConf(key), valor: valor === '' ? null : Number(valor), conferido: true } }));
  }

  function getValorFinal(it) {
    const conf = getConf(it.key);
    return conf.valor !== null && conf.valor !== undefined ? conf.valor : it.valorComissaoCalc;
  }

  const totalBase = itensComissao.reduce((s, i) => s + i.valorBase, 0);
  const totalComissaoCalc = itensComissao.reduce((s, i) => s + i.valorComissaoCalc, 0);
  const itensConferidos = itensComissao.filter(i => getConf(i.key).conferido);
  const totalConferido = itensConferidos.reduce((s, i) => s + getValorFinal(i), 0);

  const lancamentosMes = lancamentos.filter(l =>
    l.profissional_id === profFiltro && l.observacoes?.includes(mesStr)
  );
  const jaTemLancamento = lancamentosMes.length > 0;

  function marcarTodos(checked) {
    const update = {};
    itensComissao.forEach(it => {
      update[it.key] = { ...getConf(it.key), conferido: checked };
    });
    setConferencias(prev => ({ ...prev, ...update }));
  }

  async function gerarLancamento() {
    if (!profAtual) return;
    if (itensConferidos.length === 0) return alert('Marque pelo menos um item como conferido.');
    if (jaTemLancamento && !confirm('Já existe lançamento para este mês. Gerar outro mesmo assim?')) return;
    setGerandoLanc(true);
    const vencimento = format(endOfMonth(mesBase), 'yyyy-MM-dd');
    await base44.entities.LancamentoFinanceiro.create({
      tipo: 'despesa',
      descricao: `Comissão ${profAtual.nome} - ${format(mesBase, 'MMMM/yyyy', { locale: ptBR })}`,
      valor: totalConferido,
      data_vencimento: vencimento,
      status: 'pendente',
      categoria: 'salario',
      profissional_id: profFiltro,
      observacoes: `Comissão gerada referente a ${mesStr}. ${itensConferidos.length} atendimento(s) conferido(s).`,
    });
    setGerandoLanc(false);
    await load();
    alert('Lançamento gerado com o total dos itens conferidos!');
  }

  // Histórico agrupado por mês
  const lancProf = lancamentos.filter(l => l.profissional_id === profFiltro);
  const mesesDisponiveis = [...new Set(lancProf.map(l => l.data_vencimento?.slice(0, 7)).filter(Boolean))].sort().reverse();
  const lancHistFiltrado = histMes === 'todos' ? lancProf : lancProf.filter(l => l.data_vencimento?.slice(0, 7) === histMes);
  const totalHistFiltrado = lancHistFiltrado.reduce((s, l) => s + (l.valor || 0), 0);
  const totalHistPago = lancHistFiltrado.filter(l => l.status === 'pago').reduce((s, l) => s + (l.valor || 0), 0);
  const totalHistPendente = lancHistFiltrado.filter(l => l.status !== 'pago' && l.status !== 'cancelado').reduce((s, l) => s + (l.valor || 0), 0);

  return (
    <div className="p-6 space-y-5">
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-semibold">Fechamento de Comissões</h1>
          <p className="text-sm text-muted-foreground mt-0.5">
            Base de cálculo: <strong>{baseComissao === 'por_evolucao' ? 'Evoluções Clínicas' : 'Agendamentos Concluídos'}</strong>
            <span className="ml-2 text-xs">(configurável em Configurações → Clínica)</span>
          </p>
        </div>
      </div>

      <Tabs defaultValue="fechamento">
        <TabsList className="grid w-full grid-cols-2">
          <TabsTrigger value="fechamento">Fechamento do Mês</TabsTrigger>
          <TabsTrigger value="historico">Histórico de Lançamentos</TabsTrigger>
        </TabsList>

        {/* ABA FECHAMENTO */}
        <TabsContent value="fechamento" className="space-y-5">
          <div className="flex flex-wrap gap-3 items-center">
            <Select value={profFiltro} onValueChange={setProfFiltro}>
              <SelectTrigger className="w-64">
                <SelectValue placeholder="Selecione o profissional" />
              </SelectTrigger>
              <SelectContent>
                {profissionais.map(p => (
                  <SelectItem key={p.id} value={p.id}>{p.nome}{p.especialidade ? ` — ${p.especialidade}` : ''}</SelectItem>
                ))}
              </SelectContent>
            </Select>

            <div className="flex items-center gap-1 bg-card border border-border rounded-lg px-2">
              <button onClick={() => setMesBase(m => subMonths(m, 1))} className="p-1.5 hover:bg-muted rounded text-muted-foreground"><ChevronLeft className="w-4 h-4" /></button>
              <span className="text-sm font-medium px-2 capitalize min-w-[110px] text-center">{format(mesBase, 'MMMM yyyy', { locale: ptBR })}</span>
              <button onClick={() => setMesBase(m => addMonths(m, 1))} className="p-1.5 hover:bg-muted rounded text-muted-foreground"><ChevronRight className="w-4 h-4" /></button>
            </div>
          </div>

          {profAtual && (
            <>
              {/* KPIs */}
              <div className="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div className="bg-card rounded-xl border border-border p-4">
                  <p className="text-xs text-muted-foreground uppercase font-semibold mb-1">Atendimentos no Mês</p>
                  <p className="text-2xl font-bold">{itensComissao.length}</p>
                  <p className="text-sm text-muted-foreground">Total faturado: {fmt(totalBase)}</p>
                </div>
                <div className="bg-card rounded-xl border border-border p-4 border-l-4 border-l-blue-400">
                  <p className="text-xs text-muted-foreground uppercase font-semibold mb-1">Comissão Calculada</p>
                  <p className="text-2xl font-bold text-blue-600">{fmt(totalComissaoCalc)}</p>
                  <p className="text-sm text-muted-foreground">
                    {itensConferidos.length > 0
                      ? <span className="text-green-600 font-semibold">{itensConferidos.length} conferido(s): {fmt(totalConferido)}</span>
                      : 'Nenhum item conferido ainda'}
                  </p>
                </div>
                <div className={`bg-card rounded-xl border p-4 border-l-4 ${jaTemLancamento ? 'border-l-green-400' : 'border-l-yellow-400'}`}>
                  <div className="flex items-center gap-2 mb-1">
                    {jaTemLancamento ? <CheckCircle2 className="w-4 h-4 text-green-600" /> : <AlertCircle className="w-4 h-4 text-yellow-600" />}
                    <p className="text-xs text-muted-foreground uppercase font-semibold">Situação</p>
                  </div>
                  <p className={`text-sm font-semibold ${jaTemLancamento ? 'text-green-600' : 'text-yellow-600'}`}>
                    {jaTemLancamento ? 'Lançamento Gerado' : 'Pendente de Fechamento'}
                  </p>
                  {lancamentosMes.map(l => (
                    <p key={l.id} className="text-xs text-muted-foreground mt-0.5">
                      {fmt(l.valor)} · {l.status === 'pago' ? '✓ Pago' : 'A pagar'}
                    </p>
                  ))}
                </div>
              </div>

              {/* Tabela de atendimentos com conferência */}
              <div className="bg-card rounded-xl border border-border overflow-hidden">
                <div className="px-5 py-3 border-b border-border bg-muted/30 flex items-center justify-between">
                  <h3 className="font-semibold text-sm flex items-center gap-2">
                    <FileText className="w-4 h-4" />
                    {baseComissao === 'por_evolucao' ? 'Evoluções Clínicas Registradas' : 'Atendimentos Concluídos'}
                    {' '}— {format(mesBase, 'MMMM/yyyy', { locale: ptBR })}
                  </h3>
                  <div className="flex items-center gap-3">
                    <label className="flex items-center gap-1.5 text-xs text-muted-foreground cursor-pointer select-none">
                      <input
                        type="checkbox"
                        className="w-3.5 h-3.5 accent-primary"
                        checked={itensComissao.length > 0 && itensComissao.every(i => getConf(i.key).conferido)}
                        onChange={e => marcarTodos(e.target.checked)}
                      />
                      Marcar todos
                    </label>
                    <button onClick={() => window.print()} className="flex items-center gap-1.5 text-xs text-muted-foreground hover:text-foreground">
                      <Printer className="w-3.5 h-3.5" /> Imprimir
                    </button>
                  </div>
                </div>
                <table className="w-full text-sm">
                  <thead className="bg-muted/50">
                    <tr>
                      <th className="px-4 py-3 w-8"></th>
                      <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Data</th>
                      <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Paciente</th>
                      <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase hidden md:table-cell">Serviço</th>
                      <th className="text-right px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Valor</th>
                      <th className="text-right px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Comissão</th>
                    </tr>
                  </thead>
                  <tbody>
                    {loading ? (
                      <tr><td colSpan={6} className="text-center py-8 text-muted-foreground">Carregando...</td></tr>
                    ) : itensComissao.length === 0 ? (
                      <tr><td colSpan={6} className="text-center py-12 text-muted-foreground">
                        <Users className="w-8 h-8 mx-auto mb-2 opacity-30" />
                        Nenhum atendimento encontrado para este profissional no mês.
                      </td></tr>
                    ) : itensComissao.map((it) => {
                      const conf = getConf(it.key);
                      const valorFinal = getValorFinal(it);
                      return (
                        <tr key={it.key} className={`border-t border-border transition-colors ${conf.conferido ? 'bg-green-50/50' : 'hover:bg-muted/20'}`}>
                          <td className="px-4 py-3 text-center">
                            <input
                              type="checkbox"
                              className="w-4 h-4 accent-primary cursor-pointer"
                              checked={conf.conferido}
                              onChange={e => setConferido(it.key, e.target.checked)}
                            />
                          </td>
                          <td className="px-4 py-3 text-muted-foreground">{it.data ? format(new Date(it.data), 'dd/MM/yyyy') : '—'}</td>
                          <td className="px-4 py-3 font-medium">{it.paciente}</td>
                          <td className="px-4 py-3 text-muted-foreground hidden md:table-cell">{it.servicoNome}</td>
                          <td className="px-4 py-3 text-right font-semibold">{it.valorBase > 0 ? fmt(it.valorBase) : '—'}</td>
                          <td className="px-4 py-3 text-right">
                            <Input
                              type="number"
                              className="w-28 h-7 text-xs text-right ml-auto"
                              value={conf.valor !== null && conf.valor !== undefined ? conf.valor : it.valorComissaoCalc}
                              onChange={e => setValorConf(it.key, e.target.value, it.valorComissaoCalc)}
                              placeholder="0,00"
                            />
                          </td>
                        </tr>
                      );
                    })}
                  </tbody>
                  {itensComissao.length > 0 && (
                    <tfoot className="bg-muted/50 border-t-2 border-border">
                      <tr>
                        <td colSpan={4} className="px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">
                          Total ({itensConferidos.length}/{itensComissao.length} conferidos)
                        </td>
                        <td className="px-4 py-3 text-right font-bold">{fmt(totalBase)}</td>
                        <td className="px-4 py-3 text-right font-bold text-green-600">{fmt(totalConferido)}</td>
                      </tr>
                    </tfoot>
                  )}
                </table>
              </div>

              {itensComissao.some(i => i.valorComissaoCalc === 0 && i.valorBase > 0) && (
                <div className="flex items-start gap-2 p-3 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
                  <AlertCircle className="w-4 h-4 mt-0.5 shrink-0" />
                  <span>Alguns atendimentos não possuem comissão configurada. Configure em <strong>Configurações → Profissionais</strong>.</span>
                </div>
              )}

              <div className="flex items-center justify-between">
                <p className="text-sm text-muted-foreground">
                  {itensConferidos.length > 0
                    ? <span className="text-green-700 font-medium">{itensConferidos.length} item(ns) conferido(s) · Total a lançar: {fmt(totalConferido)}</span>
                    : 'Confira os itens antes de gerar o lançamento'}
                </p>
                <Button
                  onClick={gerarLancamento}
                  disabled={gerandoLanc || itensConferidos.length === 0}
                  className="gap-1.5"
                >
                  <CheckCircle2 className="w-4 h-4" />
                  {gerandoLanc ? 'Gerando...' : `Gerar Lançamento (${fmt(totalConferido)})`}
                </Button>
              </div>
            </>
          )}
        </TabsContent>

        {/* ABA HISTÓRICO */}
        <TabsContent value="historico" className="space-y-4">
          <div className="flex flex-wrap gap-3 items-center">
            <Select value={profFiltro} onValueChange={setProfFiltro}>
              <SelectTrigger className="w-64">
                <SelectValue placeholder="Selecione o profissional" />
              </SelectTrigger>
              <SelectContent>
                {profissionais.map(p => <SelectItem key={p.id} value={p.id}>{p.nome}</SelectItem>)}
              </SelectContent>
            </Select>

            <Select value={histMes} onValueChange={setHistMes}>
              <SelectTrigger className="w-44">
                <SelectValue placeholder="Filtrar por mês" />
              </SelectTrigger>
              <SelectContent>
                <SelectItem value="todos">Todos os meses</SelectItem>
                {mesesDisponiveis.map(m => (
                  <SelectItem key={m} value={m}>
                    {format(new Date(m + '-01'), 'MMMM yyyy', { locale: ptBR })}
                  </SelectItem>
                ))}
              </SelectContent>
            </Select>
          </div>

          {/* KPIs histórico */}
          {lancHistFiltrado.length > 0 && (
            <div className="grid grid-cols-3 gap-3">
              <div className="bg-card rounded-xl border border-border p-3">
                <p className="text-xs text-muted-foreground uppercase font-semibold">Total</p>
                <p className="text-xl font-bold text-foreground">{fmt(totalHistFiltrado)}</p>
              </div>
              <div className="bg-card rounded-xl border border-border p-3">
                <p className="text-xs text-muted-foreground uppercase font-semibold">Pago</p>
                <p className="text-xl font-bold text-green-600">{fmt(totalHistPago)}</p>
              </div>
              <div className="bg-card rounded-xl border border-border p-3">
                <p className="text-xs text-muted-foreground uppercase font-semibold">A Pagar</p>
                <p className="text-xl font-bold text-yellow-600">{fmt(totalHistPendente)}</p>
              </div>
            </div>
          )}

          <div className="bg-card rounded-xl border border-border overflow-hidden">

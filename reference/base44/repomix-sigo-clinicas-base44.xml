  { key: 'integracao_api', label: 'API e Integrações', desc: 'Acesso a APIs externas' },
  { key: 'multiplas_clinicas', label: 'Múltiplas Clínicas', desc: 'Gerenciar várias clínicas' },
];

export default function PlanoAssinaturas() {

<file path="src/pages/Orcamentos.jsx">
import { useState, useEffect, useMemo } from 'react';
import { base44 } from '@/api/base44Client';
import { Plus, FileText, Trash2, CheckCircle, Clock, XCircle, Send, LayoutGrid, DollarSign, Search } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { useClinica } from '@/lib/ClinicaContext';
import ItemOrcamentoModal from '@/components/orcamento/ItemOrcamentoModal';
import ItemEstoqueOrcamentoModal from '@/components/orcamento/ItemEstoqueOrcamentoModal';
import OrcamentoKanban from '@/components/orcamento/OrcamentoKanban';
import VendasFaturamento from '@/components/orcamento/VendasFaturamento';
import { format, startOfMonth, endOfMonth, subMonths } from 'date-fns';
import { ptBR } from 'date-fns/locale';

const STATUS_CONFIG = {
  rascunho: { label: 'Rascunho', color: 'bg-gray-100 text-gray-600', icon: FileText },
  enviado:  { label: 'Enviado',  color: 'bg-blue-100 text-blue-600', icon: Send },
  aprovado: { label: 'Aprovado', color: 'bg-green-100 text-green-600', icon: CheckCircle },
  recusado: { label: 'Recusado', color: 'bg-red-100 text-red-600', icon: XCircle },
  expirado: { label: 'Expirado', color: 'bg-yellow-100 text-yellow-700', icon: Clock },
};

function formatCurrency(v) {
  if (!v && v !== 0) return '—';
  return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v);
}

const TABS = [
  { id: 'kanban', label: 'Kanban', icon: LayoutGrid },
  { id: 'vendas', label: 'Vendas & Faturamento', icon: DollarSign },
];

// Gera lista de meses (atual e 11 anteriores)
function getMeses() {
  const now = new Date();
  const meses = [];
  for (let i = 0; i < 12; i++) {
    const d = subMonths(now, i);
    meses.push({
      value: format(d, 'yyyy-MM'),
      label: format(d, 'MMMM/yyyy', { locale: ptBR }),
    });
  }
  return meses;
}

export default function Orcamentos() {
  const { termo } = useClinica();
  const [orcamentos, setOrcamentos] = useState([]);
  const [loading, setLoading] = useState(true);
  const [showForm, setShowForm] = useState(false);
  const [editando, setEditando] = useState(null);
  const [activeTab, setActiveTab] = useState('kanban');

  // Filtros
  const [filtroCliente, setFiltroCliente] = useState('');
  const [filtroStatus, setFiltroStatus] = useState('todos');
  const [filtroMes, setFiltroMes] = useState(format(new Date(), 'yyyy-MM'));

  const meses = useMemo(() => getMeses(), []);

  useEffect(() => { carregar(); }, []);

  async function carregar() {
    setLoading(true);
    const data = await base44.entities.Orcamento.list('-created_date');
    setOrcamentos(data);
    setLoading(false);
  }

  function editar(orc) { setEditando(orc); setShowForm(true); }

  async function excluir(id) {
    if (!confirm('Excluir este orçamento?')) return;
    await base44.entities.Orcamento.delete(id);
    carregar();
  }

  // Filtra por período, cliente e status
  const orcamentosFiltrados = useMemo(() => {
    return orcamentos.filter(o => {
      // Filtro mês (por created_date)
      if (filtroMes !== 'todos') {
        const mesOrc = o.created_date ? format(new Date(o.created_date), 'yyyy-MM') : null;
        if (mesOrc !== filtroMes) return false;
      }
      // Filtro cliente
      if (filtroCliente.trim()) {
        const nome = (o.cliente_nome || '').toLowerCase();
        if (!nome.includes(filtroCliente.toLowerCase())) return false;
      }
      // Filtro status
      if (filtroStatus !== 'todos' && o.status !== filtroStatus) return false;
      return true;
    });
  }, [orcamentos, filtroMes, filtroCliente, filtroStatus]);

  // Kanban só mostra orçamentos NÃO vendidos (aprovado+venda_data vai pra Vendas)
  const orcamentosKanban = useMemo(() =>
    orcamentosFiltrados.filter(o => !(o.status === 'aprovado' && o.venda_data)),
    [orcamentosFiltrados]
  );

  if (showForm) {
    return (
      <OrcamentoForm
        orcamento={editando}
        termo={termo}
        onSaved={() => { setShowForm(false); carregar(); }}
        onCancel={() => setShowForm(false)}
      />
    );
  }

  return (
    <div className="p-6 space-y-5">
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-bold">{termo.orcamento}s</h1>
          <p className="text-sm text-muted-foreground">Gerencie e acompanhe seus {termo.orcamento.toLowerCase()}s</p>
        </div>
        <Button onClick={() => { setEditando(null); setShowForm(true); }} className="gap-2">
          <Plus className="w-4 h-4" /> Novo {termo.orcamento}
        </Button>
      </div>

      {/* Filtros */}
      <div className="flex flex-wrap gap-3 bg-muted/30 border border-border rounded-xl p-3">
        <div className="relative flex-1 min-w-40">
          <Search className="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-muted-foreground" />
          <Input
            placeholder="Buscar cliente..."
            value={filtroCliente}
            onChange={e => setFiltroCliente(e.target.value)}
            className="h-8 text-sm pl-7"
          />
        </div>
        <Select value={filtroMes} onValueChange={setFiltroMes}>
          <SelectTrigger className="h-8 text-sm w-44">
            <SelectValue placeholder="Mês" />
          </SelectTrigger>
          <SelectContent>
            <SelectItem value="todos">Todos os períodos</SelectItem>
            {meses.map(m => (
              <SelectItem key={m.value} value={m.value}>{m.label}</SelectItem>
            ))}
          </SelectContent>
        </Select>
        <Select value={filtroStatus} onValueChange={setFiltroStatus}>
          <SelectTrigger className="h-8 text-sm w-36">
            <SelectValue placeholder="Status" />
          </SelectTrigger>
          <SelectContent>
            <SelectItem value="todos">Todos os status</SelectItem>
            {Object.entries(STATUS_CONFIG).map(([k, v]) => (
              <SelectItem key={k} value={k}>{v.label}</SelectItem>
            ))}
          </SelectContent>
        </Select>
      </div>

      {/* Tabs */}
      <div className="flex border-b border-border gap-1">
        {TABS.map(t => (
          <button
            key={t.id}
            onClick={() => setActiveTab(t.id)}
            className={`flex items-center gap-2 px-5 py-2.5 text-sm font-medium border-b-2 transition-all -mb-px ${activeTab === t.id ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground'}`}
          >
            <t.icon className="w-4 h-4" />
            {t.label}
          </button>
        ))}
      </div>

      {loading ? (
        <div className="text-center py-16 text-muted-foreground">Carregando...</div>
      ) : activeTab === 'kanban' ? (
        <OrcamentoKanban
          orcamentos={orcamentosKanban}
          onEdit={editar}
          onDelete={excluir}
          onRefresh={carregar}
          termo={termo}
        />
      ) : (
        <VendasFaturamento
          orcamentos={orcamentosFiltrados}
          onEdit={editar}
          onRefresh={carregar}
        />
      )}
    </div>
  );
}

// ─── Formulário de Orçamento ─────────────────────────────────────────────────
function OrcamentoForm({ orcamento, termo, onSaved, onCancel }) {
  const [profissionais, setProfissionais] = useState([]);
  const [convenios, setConvenios] = useState([]);
  const [pacientes, setPacientes] = useState([]);
  const [servicos, setServicos] = useState([]);
  const [tabelasPreco, setTabelasPreco] = useState([]);
  const [itensTabela, setItensTabela] = useState([]);
  const [itensEstoque, setItensEstoque] = useState([]);
  const [showAddItem, setShowAddItem] = useState(false);
  const [showAddProduto, setShowAddProduto] = useState(false);
  const [saving, setSaving] = useState(false);

  const [form, setForm] = useState({
    cliente_nome: orcamento?.cliente_nome || '',
    cliente_id: orcamento?.cliente_id || '',
    cliente_telefone: orcamento?.cliente_telefone || '',
    cliente_email: orcamento?.cliente_email || '',
    profissional_id: orcamento?.profissional_id || '',
    profissional_nome: orcamento?.profissional_nome || '',
    convenio_id: orcamento?.convenio_id || '',
    convenio_nome: orcamento?.convenio_nome || '',
    status: orcamento?.status || 'rascunho',
    validade_dias: orcamento?.validade_dias || 30,
    desconto: orcamento?.desconto || 0,
    observacoes: orcamento?.observacoes || '',
    anotacoes_internas: orcamento?.anotacoes_internas || '',
    itens: orcamento?.itens || [],
    valor_total: orcamento?.valor_total || 0,
    valor_final: orcamento?.valor_final || 0,
  });

  useEffect(() => {
    Promise.all([
      base44.entities.Profissional.list(),
      base44.entities.Convenio.list(),
      base44.entities.Paciente.list('nome', 300),
      base44.entities.Servico.list(),
      base44.entities.TabelaPreco.list(),
      base44.entities.ItemTabelaPreco.list(),
      base44.entities.ItemEstoque.list(),
    ]).then(([pr, co, pa, se, tb, it, ie]) => {
      setProfissionais(pr.filter(x => x.ativo !== false));
      setConvenios(co.filter(x => x.ativo !== false));
      setPacientes(pa.filter(x => x.ativo !== false));
      setServicos(se.filter(x => x.ativo !== false));
      setTabelasPreco(tb.filter(x => x.ativo !== false));
      setItensTabela(it.filter(x => x.ativo !== false));
      setItensEstoque(ie.filter(x => x.ativo !== false));
    });
  }, []);

  function setF(k, v) { setForm(f => ({ ...f, [k]: v })); }

  function calcTotais(itens, desconto) {
    const total = itens.reduce((s, it) => s + (it.valor_total || 0), 0);
    const final = total * (1 - (Number(desconto) || 0) / 100);
    return { valor_total: total, valor_final: final };
  }

  function addItem(item) {
    setForm(f => { const itens = [...f.itens, item]; return { ...f, itens, ...calcTotais(itens, f.desconto) }; });
  }

  function removeItem(idx) {
    setForm(f => { const itens = f.itens.filter((_, i) => i !== idx); return { ...f, itens, ...calcTotais(itens, f.desconto) }; });
  }

  useEffect(() => {
    setForm(f => ({ ...f, ...calcTotais(f.itens, f.desconto) }));
  }, [form.desconto]);

  async function salvar() {
    setSaving(true);
    if (orcamento) await base44.entities.Orcamento.update(orcamento.id, form);
    else await base44.entities.Orcamento.create(form);
    setSaving(false);
    onSaved();
  }

  return (
    <div className="p-6 max-w-3xl mx-auto space-y-6">
      <div className="flex items-center gap-3">
        <button onClick={onCancel} className="text-muted-foreground hover:text-foreground text-sm">← Voltar</button>
        <h1 className="text-xl font-bold">{orcamento ? `Editar ${termo.orcamento}` : `Novo ${termo.orcamento}`}</h1>
      </div>

      {/* Dados do cliente */}
      <div className="bg-card border border-border rounded-xl p-5 space-y-4">
        <h2 className="font-semibold text-sm uppercase tracking-wide text-muted-foreground">Dados do {termo.paciente}</h2>
        <div className="space-y-3">
          <div className="space-y-1.5">
            <Label>Paciente *</Label>
            <Select value={form.cliente_id || 'avulso'} onValueChange={v => {
              if (v === 'avulso') { setF('cliente_id', ''); } 
              else {
                const p = pacientes.find(x => x.id === v);
                setF('cliente_id', v);
                setF('cliente_nome', p?.nome || '');
                setF('cliente_telefone', p?.telefone || '');
                setF('cliente_email', p?.email || '');
                setF('convenio_id', p?.convenio_id || '');
              }
            }}>
              <SelectTrigger><SelectValue placeholder="Selecionar paciente..." /></SelectTrigger>
              <SelectContent className="max-h-60">
                <SelectItem value="avulso">— Avulso (digitar nome) —</SelectItem>
                {pacientes.map(p => <SelectItem key={p.id} value={p.id}>{p.nome}</SelectItem>)}
              </SelectContent>
            </Select>
          </div>
          {!form.cliente_id && (
            <div className="space-y-1.5">
              <Label>Nome *</Label>
              <Input value={form.cliente_nome} onChange={e => setF('cliente_nome', e.target.value)} placeholder="Nome do paciente" />
            </div>
          )}
          <div className="grid grid-cols-2 gap-3">
            <div className="space-y-1.5">
              <Label>Telefone</Label>
              <Input value={form.cliente_telefone} onChange={e => setF('cliente_telefone', e.target.value)} />
            </div>
            <div className="space-y-1.5">
              <Label>E-mail</Label>
              <Input value={form.cliente_email} onChange={e => setF('cliente_email', e.target.value)} />
            </div>
          </div>
        </div>
        <div className="grid grid-cols-2 gap-3">
          <div className="space-y-1.5">
            <Label>{termo.profissional}</Label>
            <Select value={form.profissional_id || 'nenhum'} onValueChange={v => {
              const p = profissionais.find(x => x.id === v);
              setF('profissional_id', v === 'nenhum' ? '' : v);
              setF('profissional_nome', p?.nome || '');
            }}>
              <SelectTrigger><SelectValue placeholder="Selecionar" /></SelectTrigger>
              <SelectContent>
                <SelectItem value="nenhum">— Nenhum —</SelectItem>
                {profissionais.map(p => <SelectItem key={p.id} value={p.id}>{p.nome}</SelectItem>)}
              </SelectContent>
            </Select>
          </div>
          <div className="space-y-1.5">
            <Label>Convênio</Label>
            <Select value={form.convenio_id || 'nenhum'} onValueChange={v => {
              const c = convenios.find(x => x.id === v);
              setF('convenio_id', v === 'nenhum' ? '' : v);
              setF('convenio_nome', c?.nome || '');
            }}>
              <SelectTrigger><SelectValue placeholder="Particular" /></SelectTrigger>
              <SelectContent>
                <SelectItem value="nenhum">Particular</SelectItem>
                {convenios.map(c => <SelectItem key={c.id} value={c.id}>{c.nome}</SelectItem>)}
              </SelectContent>
            </Select>
          </div>
        </div>
        <div className="grid grid-cols-2 gap-3">
          <div className="space-y-1.5">
            <Label>Status</Label>
            <Select value={form.status} onValueChange={v => setF('status', v)}>
              <SelectTrigger><SelectValue /></SelectTrigger>
              <SelectContent>
                {Object.entries(STATUS_CONFIG).map(([k, v]) => (
                  <SelectItem key={k} value={k}>{v.label}</SelectItem>
                ))}
              </SelectContent>
            </Select>
          </div>
          <div className="space-y-1.5">
            <Label>Validade (dias)</Label>
            <Input type="number" value={form.validade_dias} onChange={e => setF('validade_dias', Number(e.target.value))} />
          </div>
        </div>
      </div>

      {/* Serviços */}
      <div className="bg-card border border-border rounded-xl p-5 space-y-4">
        <div className="flex items-center justify-between">
          <h2 className="font-semibold text-sm uppercase tracking-wide text-muted-foreground">Serviços e Produtos</h2>
          <div className="flex gap-2">
            <Button size="sm" onClick={() => setShowAddItem(true)} className="gap-1 bg-primary hover:bg-primary/90 text-primary-foreground">
              <Plus className="w-3.5 h-3.5" /> Serviço
            </Button>
            <Button size="sm" onClick={() => setShowAddProduto(true)} className="gap-1 bg-blue-600 hover:bg-blue-700 text-white">
              <Plus className="w-3.5 h-3.5" /> Produto
            </Button>
          </div>
        </div>

        {form.itens.length === 0 ? (
          <div className="text-center py-8 text-muted-foreground text-sm">Nenhum serviço. Clique em "Adicionar".</div>
        ) : (
          <div className="space-y-2">
            {form.itens.map((item, idx) => (
              <div key={idx} className="flex items-start gap-3 p-3 bg-muted/30 rounded-lg border border-border">
                <div className="flex-1 min-w-0">
                  <div className="flex items-center gap-2">
                    <div className="font-medium text-sm">{item.servico_nome}</div>
                    {item.is_produto_estoque && (
                      <span className="text-xs px-1.5 py-0.5 rounded bg-blue-100 text-blue-700">Produto</span>
                    )}
                  </div>
                  <div className="text-xs text-muted-foreground mt-0.5">
                    {item.quantidade}x{item.unidade ? ` ${item.unidade}` : ''} · {item.tipo_valor === 'gratuito' ? 'Gratuito' : item.tipo_valor === 'a_partir_de' ? `A partir de ${formatCurrency(item.valor_unitario)}` : formatCurrency(item.valor_unitario)}
                    {item.regioes?.length > 0 && ` · ${item.regioes.slice(0, 3).join(', ')}`}
                  </div>
                </div>
                <div className="font-semibold text-sm">{item.tipo_valor === 'gratuito' ? 'Grátis' : formatCurrency(item.valor_total)}</div>
                <button onClick={() => removeItem(idx)} className="text-muted-foreground hover:text-destructive"><Trash2 className="w-4 h-4" /></button>
              </div>
            ))}
          </div>
        )}

        {form.itens.length > 0 && (
          <div className="border-t border-border pt-3 space-y-2">
            <div className="flex items-center justify-between text-sm">
              <span className="text-muted-foreground">Subtotal</span>
              <span>{formatCurrency(form.valor_total)}</span>
            </div>
            <div className="flex items-center gap-2">
              <span className="text-sm text-muted-foreground">Desconto (%)</span>
              <Input type="number" min={0} max={100} value={form.desconto} onChange={e => setF('desconto', e.target.value)} className="w-20 h-7 text-sm" />
              <span className="text-sm text-muted-foreground ml-auto">- {formatCurrency((form.valor_total || 0) * (Number(form.desconto) || 0) / 100)}</span>
            </div>
            <div className="flex items-center justify-between font-bold">
              <span>Total Final</span>
              <span className="text-lg text-primary">{formatCurrency(form.valor_final)}</span>
            </div>
          </div>
        )}
      </div>

      {/* Observações */}
      <div className="bg-card border border-border rounded-xl p-5 space-y-3">
        <h2 className="font-semibold text-sm uppercase tracking-wide text-muted-foreground">Observações</h2>
        <textarea className="w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm resize-none h-20 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" value={form.observacoes} onChange={e => setF('observacoes', e.target.value)} placeholder="Condições, instruções..." />
        <textarea className="w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm resize-none h-16 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" value={form.anotacoes_internas} onChange={e => setF('anotacoes_internas', e.target.value)} placeholder="Anotações internas (não aparecem para o cliente)" />
      </div>

      <div className="flex justify-end gap-2 pb-6">
        <Button variant="outline" onClick={onCancel}>Cancelar</Button>
        <Button onClick={salvar} disabled={saving || !form.cliente_nome}>{saving ? 'Salvando...' : 'Salvar'}</Button>
      </div>

      {showAddItem && (
        <ItemOrcamentoModal
          servicos={servicos}
          tabelasPreco={tabelasPreco}
          itensTabela={itensTabela}
          convenioId={form.convenio_id}
          onAdd={addItem}
          onClose={() => setShowAddItem(false)}
        />
      )}
      {showAddProduto && (
        <ItemEstoqueOrcamentoModal
          itensEstoque={itensEstoque}
          onAdd={addItem}
          onClose={() => setShowAddProduto(false)}
        />
      )}
    </div>
  );
}
</file>

<file path="src/pages/PacientePerfil.jsx">
import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { ArrowLeft, User, Stethoscope, Activity, FileText, ShoppingBag, Pill, Printer, Camera } from 'lucide-react';
import { Link } from 'react-router-dom';
import { format, differenceInYears } from 'date-fns';
import AbaOrcamentos from '@/components/pacientes/AbaOrcamentos';
import AbaAvaliacaoClinica from '@/components/prontuario/AbaAvaliacaoClinica';
import AbaEvolucao from '@/components/prontuario/AbaEvolucao';
import AbaDocumentos from '@/components/prontuario/AbaDocumentos';
import AbaReceituario from '@/components/prontuario/AbaReceituario';
import AbaGaleria from '@/components/prontuario/AbaGaleria';
import ResumoProntuario from '@/components/prontuario/ResumoProntuario';
import PacienteModal from '@/components/pacientes/PacienteModal';
import { Button } from '@/components/ui/button';

const TABS = [
  { id: 'resumo', label: 'Resumo', icon: Printer },
  { id: 'avaliacao', label: 'Avaliação', icon: Stethoscope },
  { id: 'orcamentos', label: 'Planos', icon: ShoppingBag },
  { id: 'evolucao', label: 'Evolução Clínica', icon: Activity },
  { id: 'receituario', label: 'Receituário', icon: Pill },
  { id: 'galeria', label: 'Galeria', icon: Camera },
  { id: 'documentos', label: 'Documentos', icon: FileText },
  { id: 'dados', label: 'Dados Pessoais', icon: User },
];

export default function PacientePerfil() {
  const params = new URLSearchParams(window.location.search);
  const pacienteId = params.get('id');

  const [paciente, setPaciente] = useState(null);
  const [convenios, setConvenios] = useState([]);
  const [tab, setTab] = useState('resumo');
  const [loading, setLoading] = useState(true);
  const [editOpen, setEditOpen] = useState(false);

  useEffect(() => { load(); }, [pacienteId]);

  async function load() {
    if (!pacienteId) return;
    const [lista, conv] = await Promise.all([
      base44.entities.Paciente.filter({ id: pacienteId }),
      base44.entities.Convenio.list(),
    ]);
    setPaciente(lista[0] || null);
    setConvenios(conv);
    setLoading(false);
  }

  if (loading) return <div className="p-6 text-muted-foreground">Carregando...</div>;
  if (!paciente) return <div className="p-6 text-muted-foreground">Paciente não encontrado.</div>;

  const convenio = convenios.find(c => c.id === paciente.convenio_id);
  const idade = paciente.data_nascimento ? differenceInYears(new Date(), new Date(paciente.data_nascimento)) : null;

  return (
    <div className="p-4 md:p-6 space-y-5 max-w-4xl mx-auto">
      {/* Header */}
      <div className="flex items-center gap-3">
        <Link to="/pacientes" className="p-2 rounded-lg hover:bg-muted transition-colors text-muted-foreground hover:text-foreground">
          <ArrowLeft className="w-4 h-4" />
        </Link>
        <div className="flex-1 min-w-0">
          <h1 className="text-xl font-semibold truncate">{paciente.nome}</h1>
          <p className="text-sm text-muted-foreground">
            {[
              paciente.telefone,
              idade ? `${idade} anos` : null,
              convenio?.nome || 'Particular',
            ].filter(Boolean).join(' · ')}
          </p>
        </div>
        <Button variant="outline" size="sm" onClick={() => setEditOpen(true)}>Editar</Button>
      </div>

      {/* Tabs - scrollável no mobile */}
      <div className="border-b border-border overflow-x-auto">
        <div className="flex gap-1 min-w-max">
          {TABS.map(t => (
            <button
              key={t.id}
              onClick={() => setTab(t.id)}
              className={`flex items-center gap-1.5 px-3 py-2.5 text-sm font-medium border-b-2 transition-all -mb-px whitespace-nowrap ${
                tab === t.id
                  ? 'border-primary text-primary'
                  : 'border-transparent text-muted-foreground hover:text-foreground'
              }`}
            >
              <t.icon className="w-3.5 h-3.5" />
              {t.label}
            </button>
          ))}
        </div>
      </div>

      {/* Botão voltar ao resumo quando não está no resumo */}
      {tab !== 'resumo' && (
        <button
          onClick={() => setTab('resumo')}
          className="flex items-center gap-1.5 text-xs text-muted-foreground hover:text-foreground transition-colors"
        >
          <ArrowLeft className="w-3.5 h-3.5" /> Voltar ao Resumo
        </button>
      )}

      {/* Conteúdo das Abas */}
      {tab === 'resumo' && <ResumoProntuario paciente={paciente} convenio={convenio} onNavigate={setTab} />}
      {tab === 'avaliacao' && <AbaAvaliacaoClinica paciente={paciente} />}
      {tab === 'evolucao' && <AbaEvolucao paciente={paciente} />}
      {tab === 'receituario' && <AbaReceituario paciente={paciente} />}
      {tab === 'orcamentos' && <AbaOrcamentos paciente={paciente} />}
      {tab === 'galeria' && <AbaGaleria paciente={paciente} />}
      {tab === 'documentos' && <AbaDocumentos paciente={paciente} />}
      {tab === 'dados' && (
        <DadosPaciente paciente={paciente} convenio={convenio} idade={idade} />
      )}

      {editOpen && (
        <PacienteModal
          paciente={paciente}
          convenios={convenios}
          onClose={() => setEditOpen(false)}
          onSaved={() => { setEditOpen(false); load(); }}
        />
      )}
    </div>
  );
}

function DadosPaciente({ paciente, convenio, idade }) {
  const campos = [
    { label: 'CPF', value: paciente.cpf },
    { label: 'Data de Nascimento', value: paciente.data_nascimento ? `${format(new Date(paciente.data_nascimento), 'dd/MM/yyyy')} (${idade} anos)` : null },
    { label: 'Sexo', value: paciente.sexo ? paciente.sexo.charAt(0).toUpperCase() + paciente.sexo.slice(1) : null },
    { label: 'Telefone', value: paciente.telefone },
    { label: 'Email', value: paciente.email },
    { label: 'Convênio', value: convenio?.nome || 'Particular' },
    { label: 'Nº Carteirinha', value: paciente.numero_carteirinha },
    { label: 'Nome da Mãe', value: paciente.nome_mae },
    { label: 'Endereço', value: paciente.endereco, full: true },
  ].filter(c => c.value);

  const emergencia = [
    paciente.contato_emergencia_nome,
    paciente.contato_emergencia_parentesco ? `(${paciente.contato_emergencia_parentesco})` : null,
    paciente.contato_emergencia_telefone,
  ].filter(Boolean).join(' · ');

  const observacoes = paciente.observacoes;

  return (
    <div className="space-y-4">
      <div className="grid grid-cols-2 md:grid-cols-3 gap-4">
        {campos.map(({ label, value, full }) => (
          <div key={label} className={`space-y-0.5 ${full ? 'col-span-2 md:col-span-3' : ''}`}>
            <p className="text-xs text-muted-foreground font-medium uppercase tracking-wide">{label}</p>
            <p className="text-sm">{value}</p>
          </div>
        ))}
      </div>

      {emergencia && (
        <div className="border border-border rounded-xl p-4 bg-yellow-50 dark:bg-yellow-900/10">
          <p className="text-xs text-muted-foreground font-medium uppercase tracking-wide mb-1">Contato de Emergência</p>
          <p className="text-sm font-medium">{emergencia}</p>
        </div>
      )}

      {observacoes && (
        <div className="space-y-0.5">
          <p className="text-xs text-muted-foreground font-medium uppercase tracking-wide">Observações</p>
          <p className="text-sm whitespace-pre-wrap">{observacoes}</p>
        </div>
      )}
    </div>
  );
}
</file>


<file path="src/components/financeiro/PagamentoRapidoModal.jsx">
import { useState } from 'react';
import { base44 } from '@/api/base44Client';
import { X, CheckCircle } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { format } from 'date-fns';

const formasPg = ['dinheiro', 'cartao_debito', 'cartao_credito', 'pix', 'transferencia', 'boleto'];
const fmt = v => new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v || 0);

export default function PagamentoRapidoModal({ lancamento, onClose, onSaved }) {
  const isReceita = lancamento.tipo === 'receita';
  const valorJaPago = lancamento.valor_pago || (lancamento.status === 'pago' ? lancamento.valor : 0) || 0;
  const saldoAberto = lancamento.saldo_em_aberto ?? Math.max(0, (lancamento.valor || 0) - valorJaPago);

  const [valor, setValor] = useState(String(saldoAberto.toFixed(2)));
  const [data, setData] = useState(format(new Date(), 'yyyy-MM-dd'));
  const [forma, setForma] = useState(lancamento.forma_pagamento || 'pix');
  const [obs, setObs] = useState('');
  const [saving, setSaving] = useState(false);

  async function confirmar() {
    const val = Number(valor);
    if (!val || val <= 0) return alert('Informe um valor válido');
    if (val > saldoAberto + 0.01) return alert(`Valor maior que o saldo em aberto (${fmt(saldoAberto)})`);

    setSaving(true);
    const novoPagamento = { data, valor: val, forma_pagamento: forma, observacao: obs };
    const novaLista = [...(lancamento.pagamentos_parciais || []), novoPagamento];
    const novoTotal = valorJaPago + val;
    const novoSaldo = Math.max(0, (lancamento.valor || 0) - novoTotal);
    const novoStatus = novoSaldo <= 0.01 ? 'pago' : 'pago_parcial';

    await base44.entities.LancamentoFinanceiro.update(lancamento.id, {
      pagamentos_parciais: novaLista,
      valor_pago: novoTotal,
      saldo_em_aberto: novoSaldo,
      status: novoStatus,
      data_pagamento: novoSaldo <= 0.01 ? data : lancamento.data_pagamento,
    });
    setSaving(false);
    onSaved();
  }

  return (
    <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4" onClick={onClose}>
      <div className="bg-card rounded-xl shadow-xl w-full max-w-sm" onClick={e => e.stopPropagation()}>
        <div className="flex items-center justify-between px-5 py-4 border-b border-border">
          <div>
            <h2 className="font-semibold text-sm">{isReceita ? '💰 Registrar Recebimento' : '💸 Registrar Pagamento'}</h2>
            <p className="text-xs text-muted-foreground truncate max-w-[240px]">{lancamento.descricao}</p>
          </div>
          <button onClick={onClose} className="text-muted-foreground hover:text-foreground ml-2"><X className="w-4 h-4" /></button>
        </div>

        <div className="p-5 space-y-3">
          <div className="flex gap-2 text-xs">
            <span className="text-muted-foreground">Total: <strong>{fmt(lancamento.valor)}</strong></span>
            {valorJaPago > 0 && <span className="text-green-700">Já pago: <strong>{fmt(valorJaPago)}</strong></span>}
            <span className="text-orange-600 font-semibold">Aberto: {fmt(saldoAberto)}</span>
          </div>

          <div className="grid grid-cols-2 gap-3">
            <div className="space-y-1">
              <Label className="text-xs">Valor *</Label>
              <Input type="number" value={valor} onChange={e => setValor(e.target.value)} className="h-9" />
            </div>
            <div className="space-y-1">
              <Label className="text-xs">Data</Label>
              <Input type="date" value={data} onChange={e => setData(e.target.value)} className="h-9" />
            </div>
            <div className="space-y-1 col-span-2">
              <Label className="text-xs">Forma de Pagamento</Label>
              <Select value={forma} onValueChange={setForma}>
                <SelectTrigger className="h-9"><SelectValue /></SelectTrigger>
                <SelectContent>
                  {formasPg.map(f => <SelectItem key={f} value={f} className="capitalize">{f.replace(/_/g, ' ')}</SelectItem>)}
                </SelectContent>
              </Select>
            </div>
            <div className="space-y-1 col-span-2">
              <Label className="text-xs">Observação (opcional)</Label>
              <Input placeholder="Ex: parcela 1/3" value={obs} onChange={e => setObs(e.target.value)} className="h-9" />
            </div>
          </div>
        </div>

        <div className="flex gap-2 px-5 pb-5">
          <Button variant="outline" className="flex-1" onClick={onClose}>Cancelar</Button>
          <Button className="flex-1 gap-1.5" onClick={confirmar} disabled={saving}>
            <CheckCircle className="w-4 h-4" />
            {saving ? 'Salvando...' : isReceita ? 'Confirmar Recebimento' : 'Confirmar Pagamento'}
          </Button>
        </div>
      </div>
    </div>
  );
}
</file>

<file path="src/components/orcamento/ItemEstoqueOrcamentoModal.jsx">
import { useState } from 'react';
import { X } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';

export default function ItemEstoqueOrcamentoModal({ itensEstoque, onAdd, onClose }) {
  const [itemId, setItemId] = useState('');
  const [quantidade, setQuantidade] = useState(1);
  const [valorUnit, setValorUnit] = useState('');
  const [observacao, setObservacao] = useState('');

  const itensFiltrados = itensEstoque.filter(i => i.ativo !== false && (i.saldo_atual || 0) > 0);

  function handleSelectItem(id) {
    setItemId(id);
    const item = itensEstoque.find(x => x.id === id);
    if (item?.preco_custo) setValorUnit(String(item.preco_custo));
  }

  function handleAdd() {
    if (!itemId) return;
    const item = itensEstoque.find(x => x.id === itemId);
    const qtd = Number(quantidade) || 1;
    const vUnit = Number(valorUnit) || 0;
    onAdd({
      item_estoque_id: itemId,
      servico_nome: item?.descricao || '',
      servico_id: null,
      quantidade: qtd,
      valor_unitario: vUnit,
      valor_total: vUnit * qtd,
      tipo_valor: 'fixo',
      regioes: [],
      observacao,
      is_produto_estoque: true,
      unidade: item?.unidade || 'un',
    });
    onClose();
  }

  const itemSel = itensEstoque.find(x => x.id === itemId);

  return (
    <div className="fixed inset-0 bg-black/50 z-[60] flex items-center justify-center p-4">
      <div className="bg-card rounded-xl shadow-xl w-full max-w-md">
        <div className="flex items-center justify-between p-5 border-b border-border">
          <h3 className="font-semibold">Adicionar Produto do Estoque</h3>
          <button onClick={onClose}><X className="w-5 h-5 text-muted-foreground" /></button>
        </div>
        <div className="p-5 space-y-4">
          <div className="space-y-1.5">
            <Label>Produto *</Label>
            <Select value={itemId} onValueChange={handleSelectItem}>
              <SelectTrigger><SelectValue placeholder="Selecionar produto..." /></SelectTrigger>
              <SelectContent position="popper" className="z-[70]">
                {itensFiltrados.map(it => (
                  <SelectItem key={it.id} value={it.id}>
                    {it.descricao}{it.codigo ? ` (${it.codigo})` : ''} — saldo: {it.saldo_atual} {it.unidade || 'un'}
                  </SelectItem>
                ))}
              </SelectContent>
            </Select>
            {itemSel && (
              <p className="text-xs text-muted-foreground">Saldo disponível: {itemSel.saldo_atual} {itemSel.unidade || 'un'}</p>
            )}
          </div>
          <div className="grid grid-cols-2 gap-3">
            <div className="space-y-1.5">
              <Label>Quantidade</Label>
              <Input type="number" min={1} value={quantidade} onChange={e => setQuantidade(e.target.value)} />
            </div>
            <div className="space-y-1.5">
              <Label>Valor Unitário (R$)</Label>
              <Input type="number" value={valorUnit} onChange={e => setValorUnit(e.target.value)} placeholder="0,00" />
            </div>
          </div>
          <div className="space-y-1.5">
            <Label>Observação</Label>
            <Input value={observacao} onChange={e => setObservacao(e.target.value)} placeholder="Opcional" />
          </div>
          {valorUnit && quantidade && (
            <div className="flex items-center justify-between p-3 bg-muted/40 rounded-lg text-sm">
              <span className="text-muted-foreground">Total</span>
              <span className="font-bold">
                {new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format((Number(valorUnit) || 0) * (Number(quantidade) || 0))}
              </span>
            </div>
          )}
        </div>
        <div className="flex justify-end gap-2 p-5 border-t border-border">
          <Button variant="outline" onClick={onClose}>Cancelar</Button>
          <Button onClick={handleAdd} disabled={!itemId}>Adicionar</Button>
        </div>
      </div>
    </div>
  );
}

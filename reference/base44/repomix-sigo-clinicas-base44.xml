                    {c.codigo && <p className="text-xs text-muted-foreground mt-0.5">Cód: {c.codigo}</p>}
                  </div>
                  <div className="flex gap-1">
                    <button onClick={() => { setSelecionado(c); setModalOpen(true); }} className="p-1.5 rounded hover:bg-muted text-muted-foreground"><Edit2 className="w-3.5 h-3.5" /></button>
                    <button onClick={() => handleDelete(c.id)} className="p-1.5 rounded hover:bg-red-50 text-muted-foreground hover:text-red-600"><Trash2 className="w-3.5 h-3.5" /></button>
                  </div>

<file path="src/pages/admin/SalaVIP.jsx">
import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { useAuth } from '@/lib/AuthContext';
import { useClinica } from '@/lib/ClinicaContext';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { Badge } from '@/components/ui/badge';
import { Dialog, DialogContent, DialogHeader, DialogTitle } from '@/components/ui/dialog';
import { Input } from '@/components/ui/input';
import { Trash2, Check, X, Plus } from 'lucide-react';
import { format } from 'date-fns';
import { ptBR } from 'date-fns/locale';

export default function SalaVIP() {
  const { currentUser } = useAuth();
  const { config } = useClinica();
  const isAdmin = currentUser?.role === 'admin';
  const [leads, setLeads] = useState([]);
  const [salas, setSalas] = useState([]);
  const [clinicas, setClinicas] = useState([]);
  const [loading, setLoading] = useState(true);
  const [salaModal, setSalaModal] = useState({ open: false, nome: '', descricao: '', beneficios: '', quantidade_vagas: 100, clinica_id: '' });

  useEffect(() => {
    loadData();
  }, []);

  async function loadData() {
    try {
      const leadsData = await base44.entities.LeadSalaVIP.list();
      const salasData = await base44.entities.SalaVIP.list();
      const clinicasData = await base44.entities.Clinica.list();
      setLeads(leadsData);
      setSalas(salasData);
      setClinicas(clinicasData);
    } catch (error) {
      console.error('Erro ao carregar dados:', error);
    }
    setLoading(false);
  }

  async function updateLeadStatus(id, newStatus) {
    try {
      await base44.entities.LeadSalaVIP.update(id, { status: newStatus });
      await loadData();
    } catch (error) {
      console.error('Erro ao atualizar status:', error);
    }
  }

  async function deleteLead(id) {
    if (!confirm('Deseja deletar este lead?')) return;
    try {
      await base44.entities.LeadSalaVIP.delete(id);
      await loadData();
    } catch (error) {
      console.error('Erro ao deletar:', error);
    }
  }

  async function createSala() {
    if (!salaModal.nome || !salaModal.clinica_id) {
      alert('Nome e clínica são obrigatórios');
      return;
    }
    try {
      const clinicaSelecionada = clinicas.find(c => c.id === salaModal.clinica_id);
      await base44.entities.SalaVIP.create({
        nome: salaModal.nome,
        descricao: salaModal.descricao,
        beneficios: salaModal.beneficios,
        quantidade_vagas: parseInt(salaModal.quantidade_vagas),
        clinica_id: salaModal.clinica_id,
        clinica_nome: clinicaSelecionada?.nome,
        clinica_cidade: clinicaSelecionada?.cidade,
        status: 'pendente',
        ativa: false
      });
      setSalaModal({ open: false, nome: '', descricao: '', beneficios: '', quantidade_vagas: 100, clinica_id: '' });
      await loadData();
    } catch (error) {
      console.error('Erro ao criar sala:', error);
      alert('Erro ao criar sala');
    }
  }

  async function updateSalaStatus(id, newStatus) {
    try {
      await base44.entities.SalaVIP.update(id, { status: newStatus, ativa: newStatus === 'aprovada' });
      await loadData();
    } catch (error) {
      console.error('Erro ao atualizar status:', error);
    }
  }

  async function deleteSala(id) {
    if (!confirm('Deseja deletar esta sala VIP?')) return;
    try {
      await base44.entities.SalaVIP.delete(id);
      await loadData();
    } catch (error) {
      console.error('Erro ao deletar:', error);
    }
  }

  if (loading) {
    return (
      <div className="flex items-center justify-center h-96">
        <div className="w-8 h-8 border-4 border-primary/20 border-t-primary rounded-full animate-spin" />
      </div>
    );
  }

  const statusColors = {
    novo: 'bg-blue-100 text-blue-800',
    contatado: 'bg-yellow-100 text-yellow-800',
    aprovado: 'bg-green-100 text-green-800',
    recusado: 'bg-red-100 text-red-800',
    pendente: 'bg-yellow-100 text-yellow-800',
    aprovada: 'bg-green-100 text-green-800',
    rejeitada: 'bg-red-100 text-red-800'
  };

  return (
    <div className="p-6 max-w-7xl mx-auto">
      <h1 className="text-3xl font-bold text-foreground mb-6">Sala VIP</h1>

      <Tabs defaultValue="leads" className="w-full">
        <div className="flex justify-between items-center mb-6">
          <TabsList className="grid w-full grid-cols-2 w-auto">
            <TabsTrigger value="leads">Leads ({leads.length})</TabsTrigger>
            <TabsTrigger value="salas">Salas VIP ({salas.length})</TabsTrigger>
          </TabsList>
          <Button onClick={() => setSalaModal({ ...salaModal, open: true })} className="gap-2">
            <Plus className="w-4 h-4" />
            Criar Sala VIP
          </Button>
        </div>

        <TabsContent value="leads">
          <div className="grid gap-4">
            {leads.length === 0 ? (
              <Card>
                <CardContent className="py-8 text-center text-muted-foreground">
                  Nenhum lead de Sala VIP ainda.
                </CardContent>
              </Card>
            ) : (
              leads.map(lead => (
                <Card key={lead.id}>
                  <CardContent className="pt-6">
                    <div className="flex justify-between items-start mb-4">
                      <div className="flex-1">
                        <h3 className="font-bold text-lg">{lead.nome}</h3>
                        <p className="text-sm text-muted-foreground">{lead.telefone}</p>
                        {lead.email && <p className="text-sm text-muted-foreground">{lead.email}</p>}
                      </div>
                      <Badge className={statusColors[lead.status] || 'bg-gray-100 text-gray-800'}>
                        {lead.status}
                      </Badge>
                    </div>

                    <div className="grid grid-cols-2 gap-4 mb-4 text-sm">
                      <div>
                        <div className="text-xs text-muted-foreground">Clínica</div>
                        <div className="font-semibold">{lead.clinica_nome}</div>
                        <div className="text-xs text-muted-foreground">{lead.clinica_cidade}</div>
                      </div>
                      <div>
                        <div className="text-xs text-muted-foreground">Sala VIP</div>
                        <div className="font-semibold">{lead.sala_vip_nome}</div>
                      </div>
                    </div>

                    <div className="text-xs text-muted-foreground mb-4">
                      Interesse em: {format(new Date(lead.data_interesse), 'dd/MM/yyyy HH:mm', { locale: ptBR })}
                    </div>

                    <div className="flex gap-2">
                      <Button
                        size="sm"
                        variant="outline"
                        onClick={() => updateLeadStatus(lead.id, 'aprovado')}
                        disabled={lead.status === 'aprovado'}
                      >
                        <Check className="w-4 h-4 mr-2" />
                        Aprovar
                      </Button>
                      <Button
                        size="sm"
                        variant="outline"
                        onClick={() => updateLeadStatus(lead.id, 'recusado')}
                        disabled={lead.status === 'recusado'}
                      >
                        <X className="w-4 h-4 mr-2" />
                        Recusar
                      </Button>
                      <Button
                        size="sm"
                        variant="outline"
                        onClick={() => deleteLead(lead.id)}
                      >
                        <Trash2 className="w-4 h-4" />
                      </Button>
                    </div>
                  </CardContent>
                </Card>
              ))
            )}
          </div>
        </TabsContent>

        <TabsContent value="salas">
          <div className="grid gap-4">
            {salas.length === 0 ? (
              <Card>
                <CardContent className="py-8 text-center text-muted-foreground">
                  Nenhuma sala VIP criada ainda.
                </CardContent>
              </Card>
            ) : (
              salas.map(sala => (
                <Card key={sala.id}>
                  <CardContent className="pt-6">
                    <div className="flex justify-between items-start mb-4">
                      <div>
                        <h3 className="font-bold text-lg">{sala.nome}</h3>
                        <p className="text-sm text-muted-foreground">{sala.clinica_nome}</p>
                      </div>
                      <Badge className={statusColors[sala.status] || 'bg-gray-100 text-gray-800'}>
                        {sala.status?.charAt(0).toUpperCase() + sala.status?.slice(1)}
                      </Badge>
                    </div>

                    {sala.descricao && (
                      <p className="text-sm text-muted-foreground mb-3">{sala.descricao}</p>
                    )}

                    {sala.beneficios && (
                      <div className="text-sm mb-3">
                        <div className="text-xs text-muted-foreground mb-1">Benefícios:</div>
                        <p className="text-sm">{sala.beneficios}</p>
                      </div>
                    )}

                    <div className="grid grid-cols-3 gap-4 text-sm mb-4">
                      <div>
                        <div className="text-xs text-muted-foreground">Vagas Totais</div>
                        <div className="font-semibold">{sala.quantidade_vagas}</div>
                      </div>
                      <div>
                        <div className="text-xs text-muted-foreground">Membros Atuais</div>
                        <div className="font-semibold">{sala.quantidade_membros || 0}</div>
                      </div>
                      <div>
                        <div className="text-xs text-muted-foreground">Vagas Livres</div>
                        <div className="font-semibold">{(sala.quantidade_vagas || 0) - (sala.quantidade_membros || 0)}</div>
                      </div>
                    </div>

                    {isAdmin && sala.status === 'pendente' && (
                      <div className="flex gap-2">
                        <Button
                          size="sm"
                          variant="outline"
                          onClick={() => updateSalaStatus(sala.id, 'aprovada')}
                        >
                          <Check className="w-4 h-4 mr-2" />
                          Aprovar
                        </Button>
                        <Button
                          size="sm"
                          variant="outline"
                          onClick={() => updateSalaStatus(sala.id, 'rejeitada')}
                        >
                          <X className="w-4 h-4 mr-2" />
                          Rejeitar
                        </Button>
                        <Button
                          size="sm"
                          variant="outline"
                          onClick={() => deleteSala(sala.id)}
                        >
                          <Trash2 className="w-4 h-4" />
                        </Button>
                      </div>
                    )}
                  </CardContent>
                </Card>
              ))
            )}
          </div>
        </TabsContent>
      </Tabs>

      {/* Modal Criar Sala VIP */}
      <Dialog open={salaModal.open} onOpenChange={(open) => setSalaModal({ ...salaModal, open })}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>Criar Sala VIP</DialogTitle>
          </DialogHeader>
          <div className="space-y-4">
            <div>
              <label className="block text-sm font-medium mb-2">Clínica *</label>
              <select
                value={salaModal.clinica_id}
                onChange={(e) => setSalaModal({ ...salaModal, clinica_id: e.target.value })}
                className="w-full p-2 border rounded-md"
                required
              >
                <option value="">Selecione uma clínica</option>
                {clinicas.map(c => (
                  <option key={c.id} value={c.id}>{c.nome}</option>
                ))}
              </select>
            </div>
            <div>
              <label className="block text-sm font-medium mb-2">Nome da Sala VIP *</label>
              <Input
                placeholder="Ex: VIP Botox"
                value={salaModal.nome}
                onChange={(e) => setSalaModal({ ...salaModal, nome: e.target.value })}
              />
            </div>
            <div>
              <label className="block text-sm font-medium mb-2">Descrição</label>
              <Input
                placeholder="Descrição breve"
                value={salaModal.descricao}
                onChange={(e) => setSalaModal({ ...salaModal, descricao: e.target.value })}
              />
            </div>
            <div>
              <label className="block text-sm font-medium mb-2">Benefícios</label>
              <Input
                placeholder="Ex: 20% desconto, atendimento VIP"
                value={salaModal.beneficios}
                onChange={(e) => setSalaModal({ ...salaModal, beneficios: e.target.value })}
              />
            </div>
            <div>
              <label className="block text-sm font-medium mb-2">Quantidade de Vagas</label>
              <Input
                type="number"
                value={salaModal.quantidade_vagas}
                onChange={(e) => setSalaModal({ ...salaModal, quantidade_vagas: e.target.value })}
                min="1"
              />
            </div>
            <div className="flex gap-3 pt-4">
              <Button
                type="button"
                variant="outline"
                className="flex-1"
                onClick={() => setSalaModal({ ...salaModal, open: false })}
              >
                Cancelar
              </Button>
              <Button type="button" className="flex-1" onClick={createSala}>
                Criar Sala VIP
              </Button>
            </div>
          </div>
        </DialogContent>
      </Dialog>
    </div>
  );
}
</file>


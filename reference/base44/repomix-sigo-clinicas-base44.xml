import { useEffect, useState } from 'react';
import { base44 } from '@/api/base44Client';
import { Plus, Edit2, Trash2, Clock, DollarSign, List, ChevronDown, ChevronRight, Package, Zap } from 'lucide-react';
import { Button } from '@/components/ui/button';
import ServicoModal from '@/components/servicos/ServicoModal';
import TabelaPrecoModal from '@/components/servicos/TabelaPrecoModal';
import AbaComposicao from '@/components/servicos/AbaComposicao';

function formatValor(item) {
  if (item.tipo_valor === 'gratuito') return <span className="text-green-600 font-medium">Gratuito</span>;
  const v = `R$ ${Number(item.valor || 0).toFixed(2).replace('.', ',')}`;
  if (item.tipo_valor === 'a_partir_de') return <span className="text-muted-foreground">A partir de <span className="text-foreground font-medium">{v}</span></span>;
  return <span className="font-medium">{v}</span>;
}

function TabelaCard({ tabela, itens, onEdit }) {
  const [open, setOpen] = useState(true);
  return (
    <div className="bg-card rounded-xl border border-border overflow-hidden">
      <div className="flex items-center justify-between px-5 py-4 cursor-pointer select-none" onClick={() => setOpen(o => !o)}>
        <div className="flex items-center gap-3">
          {open ? <ChevronDown className="w-4 h-4 text-muted-foreground" /> : <ChevronRight className="w-4 h-4 text-muted-foreground" />}
          <div>
            <h3 className="font-semibold text-sm">{tabela.nome}</h3>
            <p className="text-xs text-muted-foreground mt-0.5">
              {tabela.convenio_nome || 'Particular'} · {itens.length} serviço(s)
              {tabela.descricao && ` · ${tabela.descricao}`}
            </p>
          </div>
        </div>
        <div className="flex items-center gap-2">
          {tabela.ativo === false && <span className="text-xs text-red-500 font-medium">● Inativo</span>}
          <button
            onClick={e => { e.stopPropagation(); onEdit(tabela); }}
            className="p-1.5 rounded hover:bg-muted text-muted-foreground"
          >
            <Edit2 className="w-3.5 h-3.5" />
          </button>
        </div>
      </div>
      {open && (
        itens.length === 0 ? (
          <div className="px-5 pb-4 text-sm text-muted-foreground italic">Nenhum serviço nesta tabela.</div>
        ) : (
          <table className="w-full text-sm border-t border-border">
            <thead className="bg-muted/40">
              <tr>
                <th className="text-left px-5 py-2.5 text-xs font-medium text-muted-foreground">Serviço</th>
                <th className="text-right px-5 py-2.5 text-xs font-medium text-muted-foreground">Valor</th>
              </tr>
            </thead>
            <tbody>
              {itens.map(item => (
                <tr key={item.id} className="border-t border-border/50 hover:bg-muted/20 transition-colors">
                  <td className="px-5 py-2.5">{item.servico_nome}</td>
                  <td className="px-5 py-2.5 text-right">{formatValor(item)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        )
      )}
    </div>
  );
}

export default function Servicos() {
  const [servicos, setServicos] = useState([]);
  const [tabelas, setTabelas] = useState([]);
  const [itensTabela, setItensTabela] = useState([]);
  const [convenios, setConvenios] = useState([]);
  const [loading, setLoading] = useState(true);
  const [tab, setTab] = useState('servicos');
  const [expandMarketing, setExpandMarketing] = useState(true);

  const [servicoModal, setServicoModal] = useState(false);
  const [servicoSel, setServicoSel] = useState(null);
  const [tabelaModal, setTabelaModal] = useState(false);
  const [tabelaSel, setTabelaSel] = useState(null);

  useEffect(() => { load(); }, []);

  async function load() {
    const [s, t, it, c] = await Promise.all([
      base44.entities.Servico.list(),
      base44.entities.TabelaPreco.list(),
      base44.entities.ItemTabelaPreco.list(),
      base44.entities.Convenio.list(),
    ]);
    setServicos(s);
    setTabelas(t);
    setItensTabela(it);
    setConvenios(c);
    setLoading(false);
  }

  async function deleteServico(id) {
    if (!confirm('Excluir este serviço?')) return;
    await base44.entities.Servico.delete(id);
    load();
  }

  return (
    <div className="flex gap-6">
      {/* Sidebar */}
      <div className="w-48 pt-6">
        <div className="space-y-1">
          <button
            onClick={() => setExpandMarketing(!expandMarketing)}
            className="w-full flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-muted transition-colors text-sm font-medium"
          >
            {expandMarketing ? <ChevronDown className="w-4 h-4" /> : <ChevronRight className="w-4 h-4" />}
            <Zap className="w-4 h-4" />
            Marketing
          </button>
          {expandMarketing && (
            <div className="pl-6 space-y-1">
              <button className="w-full text-left px-3 py-1.5 rounded-lg hover:bg-muted transition-colors text-sm text-foreground font-medium">
                Portal Público
              </button>
              <button disabled className="w-full text-left px-3 py-1.5 rounded-lg hover:bg-muted transition-colors text-sm text-muted-foreground opacity-50 cursor-not-allowed">
                Comunicação (fazer depois)
              </button>
              <button disabled className="w-full text-left px-3 py-1.5 rounded-lg hover:bg-muted transition-colors text-sm text-muted-foreground opacity-50 cursor-not-allowed">
                Campanhas (fazer depois)
              </button>
            </div>
          )}
        </div>
      </div>

      {/* Main content */}
      <div className="flex-1 p-6 space-y-5">
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-semibold">Serviços e Tabelas de Preços</h1>
          <p className="text-sm text-muted-foreground mt-0.5">Gerencie serviços e tabelas de repasse por convênio</p>
        </div>
        <Button
          onClick={() => {
            if (tab === 'servicos') { setServicoSel(null); setServicoModal(true); }
            else { setTabelaSel(null); setTabelaModal(true); }
          }}
          className="gap-1.5"
        >
          <Plus className="w-4 h-4" />
          {tab === 'servicos' ? 'Novo Serviço' : 'Nova Tabela'}
        </Button>
      </div>

      {/* Tabs */}
       <div className="flex gap-1 bg-muted p-1 rounded-lg w-fit">
         <button
           onClick={() => setTab('servicos')}
           className={`px-4 py-1.5 rounded-md text-sm font-medium transition-all ${tab === 'servicos' ? 'bg-card shadow text-foreground' : 'text-muted-foreground hover:text-foreground'}`}
         >
           <span className="flex items-center gap-1.5"><List className="w-3.5 h-3.5" /> Serviços</span>
         </button>
         <button
           onClick={() => setTab('tabela')}
           className={`px-4 py-1.5 rounded-md text-sm font-medium transition-all ${tab === 'tabela' ? 'bg-card shadow text-foreground' : 'text-muted-foreground hover:text-foreground'}`}
         >
           <span className="flex items-center gap-1.5"><DollarSign className="w-3.5 h-3.5" /> Tabelas de Preços</span>
         </button>

       </div>

      {loading ? (
        <p className="text-muted-foreground py-12 text-center">Carregando...</p>
      ) : tab === 'servicos' ? (
        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {servicos.length === 0 ? (
            <div className="col-span-3 text-center py-16 text-muted-foreground">
              <List className="w-12 h-12 mx-auto mb-3 opacity-30" />
              <p>Nenhum serviço cadastrado.</p>
            </div>
          ) : servicos.map(s => (
            <div key={s.id} className="bg-card rounded-xl border border-border p-5">
              <div className="flex items-start justify-between mb-2">
                <div>
                  <h3 className="font-semibold text-sm">{s.nome}</h3>
                  {s.codigo && <p className="text-xs text-muted-foreground mt-0.5">Cód: {s.codigo}</p>}
                </div>
                <div className="flex gap-1">
                  <button onClick={() => { setServicoSel(s); setServicoModal(true); }} className="p-1.5 rounded hover:bg-muted text-muted-foreground"><Edit2 className="w-3.5 h-3.5" /></button>
                  <button onClick={() => deleteServico(s.id)} className="p-1.5 rounded hover:bg-red-50 text-muted-foreground hover:text-red-600"><Trash2 className="w-3.5 h-3.5" /></button>
                </div>
              </div>
              <div className="flex items-center gap-3 flex-wrap">
                <span className="flex items-center gap-1 text-xs text-muted-foreground">
                  <Clock className="w-3 h-3" /> {s.duracao_minutos} min
                </span>
                {s.especialidade && <span className="text-xs bg-secondary text-secondary-foreground px-2 py-0.5 rounded-full">{s.especialidade}</span>}
                {s.ativo === false && <span className="text-xs text-red-500 font-medium">● Inativo</span>}
              </div>
              {s.observacoes && <p className="text-xs text-muted-foreground mt-2 border-t border-border pt-2">{s.observacoes}</p>}
            </div>
          ))}
        </div>
      ) : tab === 'tabela' ? (
        <div className="space-y-4">
          {tabelas.length === 0 ? (
            <div className="text-center py-16 text-muted-foreground">
              <DollarSign className="w-12 h-12 mx-auto mb-3 opacity-30" />
              <p>Nenhuma tabela cadastrada.</p>
            </div>
          ) : tabelas.map(t => (
            <TabelaCard
              key={t.id}
              tabela={t}
              itens={itensTabela.filter(it => it.tabela_id === t.id)}
              onEdit={tab => { setTabelaSel(tab); setTabelaModal(true); }}
            />
          ))}
        </div>
      ) : null}

      {servicoModal && (
        <ServicoModal
          servico={servicoSel}
          onClose={() => setServicoModal(false)}
          onSaved={() => { setServicoModal(false); load(); }}
        />
      )}
      {tabelaModal && (
        <TabelaPrecoModal
          tabela={tabelaSel}
          servicos={servicos}
          convenios={convenios}
          onClose={() => setTabelaModal(false)}
          onSaved={() => { setTabelaModal(false); load(); }}
        />
      )}

      </div>
      </div>
      );
      }

const PERMISSOES_DISPONIVEIS = [
  { key: 'financeiro', label: 'Módulo Financeiro', desc: 'Cobrança, fluxo de caixa, contas' },
  { key: 'relatorios', label: 'Relatórios Gerenciais', desc: 'Dashboard e relatórios avançados' },

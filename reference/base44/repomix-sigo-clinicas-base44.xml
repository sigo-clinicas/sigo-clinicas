<file path="src/components/pacientes/AbaOrcamentos.jsx">
import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { Plus, FileText, Trash2, CheckCircle, Clock, XCircle, Send, ChevronDown, ChevronRight } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { useClinica } from '@/lib/ClinicaContext';
import { format } from 'date-fns';
import { ptBR } from 'date-fns/locale';
import ItemOrcamentoModal from '@/components/orcamento/ItemOrcamentoModal';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';

const STATUS_CONFIG = {
  rascunho: { label: 'Rascunho', color: 'bg-gray-100 text-gray-600', icon: FileText },
  enviado:  { label: 'Enviado',  color: 'bg-blue-100 text-blue-600', icon: Send },
  aprovado: { label: 'Aprovado', color: 'bg-green-100 text-green-600', icon: CheckCircle },
  recusado: { label: 'Recusado', color: 'bg-red-100 text-red-600', icon: XCircle },
  expirado: { label: 'Expirado', color: 'bg-yellow-100 text-yellow-700', icon: Clock },
};

function formatCurrency(v) {
  if (!v && v !== 0) return '—';
  return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v);
}

export default function AbaOrcamentos({ paciente }) {
  const { termo } = useClinica();
  const [orcamentos, setOrcamentos] = useState([]);
  const [consultas, setConsultas] = useState([]);
  const [loading, setLoading] = useState(true);
  const [editando, setEditando] = useState(null); // null = lista, objeto = form
  const [expandidoId, setExpandidoId] = useState(null);

  useEffect(() => { load(); }, [paciente.id]);

  async function load() {
    setLoading(true);
    const [data, cons] = await Promise.all([
      base44.entities.Orcamento.filter({ cliente_nome: paciente.nome }, '-created_date'),
      base44.entities.Consulta.filter({ paciente_id: paciente.id }),
    ]);
    setOrcamentos(data);
    setConsultas(cons);
    setLoading(false);
  }

  async function excluir(id) {
    if (!confirm(`Excluir este ${termo.orcamento}?`)) return;
    await base44.entities.Orcamento.delete(id);
    load();
  }

  // Monta mapa: orcamento_id + item_idx -> consulta mais recente
  const consultaMap = {};
  consultas.forEach(c => {
    const servicos = c.servicos?.length ? c.servicos : (c.orcamento_id ? [{ orcamento_id: c.orcamento_id, orcamento_item_idx: c.orcamento_item_idx }] : []);
    servicos.forEach(s => {
      if (s.orcamento_id) {
        const key = `${s.orcamento_id}-${s.orcamento_item_idx ?? 0}`;
        if (!consultaMap[key] || new Date(c.data_hora) > new Date(consultaMap[key].data_hora)) {
          consultaMap[key] = c;
        }
      }
    });
  });

  if (editando !== null) {
    return (
      <OrcamentoForm
        orcamento={editando === 'novo' ? null : editando}
        paciente={paciente}
        termo={termo}
        onSaved={() => { setEditando(null); load(); }}
        onCancel={() => setEditando(null)}
      />
    );
  }

  if (loading) return <p className="text-sm text-muted-foreground py-4">Carregando...</p>;

  return (
    <div className="space-y-4">
      <div className="flex items-center justify-between">
        <p className="text-sm text-muted-foreground">{orcamentos.length} {termo.orcamento.toLowerCase()}(s)</p>
        <Button size="sm" onClick={() => setEditando('novo')} className="gap-1.5">
          <Plus className="w-3.5 h-3.5" /> Novo {termo.orcamento}
        </Button>
      </div>

      {orcamentos.length === 0 ? (
        <div className="text-center py-10 text-muted-foreground border border-dashed border-border rounded-xl">
          <FileText className="w-8 h-8 mx-auto mb-2 opacity-30" />
          <p className="text-sm">Nenhum {termo.orcamento.toLowerCase()} criado ainda.</p>
        </div>
      ) : (
        <div className="space-y-2">
          {orcamentos.map(orc => {
            const sc = STATUS_CONFIG[orc.status] || STATUS_CONFIG.rascunho;
            const Icon = sc.icon;
            return (
              <div
                key={orc.id}
                className="bg-card border border-border rounded-xl overflow-hidden hover:shadow-sm transition-shadow"
              >
                {/* Cabeçalho do orçamento */}
                <div className="p-4 flex items-center gap-3 cursor-pointer" onClick={() => setEditando(orc)}>
                  <div className="flex-1 min-w-0">
                    <div className="flex items-center gap-2 flex-wrap">
                      <span className="font-medium text-sm">{orc.itens?.length || 0} serviço(s)</span>
                      <span className={`inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded-full font-medium ${sc.color}`}>
                        <Icon className="w-3 h-3" />{sc.label}
                      </span>
                    </div>
                    <div className="text-xs text-muted-foreground mt-0.5">
                      {orc.profissional_nome && `${orc.profissional_nome} · `}
                      {orc.created_date && format(new Date(orc.created_date), "dd/MM/yyyy", { locale: ptBR })}
                    </div>
                  </div>
                  <div className="text-right shrink-0">
                    <div className="font-semibold text-sm">{formatCurrency(orc.valor_final ?? orc.valor_total)}</div>
                    {orc.desconto > 0 && <div className="text-xs text-muted-foreground">{orc.desconto}% desc.</div>}
                  </div>
                  <button className="text-muted-foreground hover:text-destructive p-1 shrink-0" onClick={e => { e.stopPropagation(); excluir(orc.id); }}>
                    <Trash2 className="w-3.5 h-3.5" />
                  </button>
                </div>

                {/* Toggle de itens */}
                {orc.itens?.length > 0 && (
                  <>
                    <button
                      className="w-full border-t border-border px-4 py-1.5 flex items-center gap-1.5 text-xs text-muted-foreground hover:bg-muted/20 transition-colors"
                      onClick={e => { e.stopPropagation(); setExpandidoId(expandidoId === orc.id ? null : orc.id); }}
                    >
                      {expandidoId === orc.id
                        ? <ChevronDown className="w-3.5 h-3.5" />
                        : <ChevronRight className="w-3.5 h-3.5" />}
                      {orc.itens.length} serviço(s) — clique para {expandidoId === orc.id ? 'ocultar' : 'ver agendamentos'}
                    </button>

                    {expandidoId === orc.id && (
                      <div className="bg-muted/10 divide-y divide-border">
                        {orc.itens.map((item, idx) => {
                          const key = `${orc.id}-${idx}`;
                          const consulta = consultaMap[key];
                          const STATUS_CONSULTA = {
                            agendado: { label: 'Agendado', color: 'bg-blue-100 text-blue-700' },
                            confirmado: { label: 'Confirmado', color: 'bg-cyan-100 text-cyan-700' },
                            em_atendimento: { label: 'Em atendimento', color: 'bg-yellow-100 text-yellow-700' },
                            concluido: { label: 'Concluído', color: 'bg-green-100 text-green-700' },
                            cancelado: { label: 'Cancelado', color: 'bg-red-100 text-red-700' },
                            faltou: { label: 'Faltou', color: 'bg-orange-100 text-orange-700' },
                          };
                          const cSc = consulta ? (STATUS_CONSULTA[consulta.status] || { label: consulta.status, color: 'bg-gray-100 text-gray-600' }) : null;
                          return (
                            <div key={idx} className="px-4 py-2 flex items-center gap-2">
                              <div className="flex-1 min-w-0">
                                <span className="text-sm">{item.servico_nome}</span>
                                {item.quantidade > 1 && <span className="text-xs text-muted-foreground ml-1">×{item.quantidade}</span>}
                              </div>
                              {consulta ? (
                                <div className="flex items-center gap-1.5 shrink-0">
                                  <span className="text-xs text-muted-foreground">{format(new Date(consulta.data_hora), "dd/MM/yyyy", { locale: ptBR })}</span>
                                  <span className={`text-xs px-1.5 py-0.5 rounded-full font-medium ${cSc.color}`}>{cSc.label}</span>
                                </div>
                              ) : (
                                <span className="text-xs text-muted-foreground italic shrink-0">Não agendado</span>
                              )}
                            </div>
                          );
                        })}
                      </div>
                    )}
                  </>
                )}
              </div>
            );
          })}
        </div>
      )}
    </div>
  );
}

function OrcamentoForm({ orcamento, paciente, termo, onSaved, onCancel }) {
  const [profissionais, setProfissionais] = useState([]);
  const [convenios, setConvenios] = useState([]);
  const [servicos, setServicos] = useState([]);
  const [tabelasPreco, setTabelasPreco] = useState([]);
  const [itensTabela, setItensTabela] = useState([]);
  const [showAddItem, setShowAddItem] = useState(false);
  const [saving, setSaving] = useState(false);

  const [form, setForm] = useState({
    cliente_nome: orcamento?.cliente_nome || paciente.nome,
    cliente_telefone: orcamento?.cliente_telefone || paciente.telefone || '',
    cliente_email: orcamento?.cliente_email || paciente.email || '',
    profissional_id: orcamento?.profissional_id || '',
    profissional_nome: orcamento?.profissional_nome || '',
    convenio_id: orcamento?.convenio_id || paciente.convenio_id || '',
    convenio_nome: orcamento?.convenio_nome || '',
    status: orcamento?.status || 'rascunho',
    validade_dias: orcamento?.validade_dias || 30,
    desconto: orcamento?.desconto || 0,
    observacoes: orcamento?.observacoes || '',
    anotacoes_internas: orcamento?.anotacoes_internas || '',
    itens: orcamento?.itens || [],
    valor_total: orcamento?.valor_total || 0,
    valor_final: orcamento?.valor_final || 0,
  });

  useEffect(() => {
    Promise.all([
      base44.entities.Profissional.list(),
      base44.entities.Convenio.list(),
      base44.entities.Servico.list(),
      base44.entities.TabelaPreco.list(),
      base44.entities.ItemTabelaPreco.list(),
    ]).then(([pr, co, se, tb, it]) => {
      setProfissionais(pr.filter(x => x.ativo !== false));
      setConvenios(co.filter(x => x.ativo !== false));
      setServicos(se.filter(x => x.ativo !== false));
      setTabelasPreco(tb.filter(x => x.ativo !== false));
      setItensTabela(it.filter(x => x.ativo !== false));
    });
  }, []);

  function setF(k, v) { setForm(f => ({ ...f, [k]: v })); }

  function calcTotais(itens, desconto) {
    const total = itens.reduce((s, it) => s + (it.valor_total || 0), 0);
    const final = total * (1 - (Number(desconto) || 0) / 100);
    return { valor_total: total, valor_final: final };
  }

  function addItem(item) {
    setForm(f => {
      const itens = [...f.itens, item];
      return { ...f, itens, ...calcTotais(itens, f.desconto) };
    });
  }

  function removeItem(idx) {
    setForm(f => {
      const itens = f.itens.filter((_, i) => i !== idx);
      return { ...f, itens, ...calcTotais(itens, f.desconto) };
    });
  }

  useEffect(() => {
    setForm(f => ({ ...f, ...calcTotais(f.itens, f.desconto) }));
  }, [form.desconto]);

  async function salvar() {
    setSaving(true);
    if (orcamento) await base44.entities.Orcamento.update(orcamento.id, form);
    else await base44.entities.Orcamento.create(form);
    setSaving(false);
    onSaved();
  }

  return (
    <div className="space-y-4">
      <button onClick={onCancel} className="text-xs text-muted-foreground hover:text-foreground">← Voltar</button>

      {/* Profissional + Convênio + Status */}
      <div className="grid grid-cols-2 gap-3">
        <div className="space-y-1">
          <Label className="text-xs">{termo.profissional}</Label>
          <Select value={form.profissional_id || 'nenhum'} onValueChange={v => {
            const p = profissionais.find(x => x.id === v);
            setF('profissional_id', v === 'nenhum' ? '' : v);
            setF('profissional_nome', p?.nome || '');
          }}>
            <SelectTrigger className="h-8 text-sm"><SelectValue placeholder="Selecionar" /></SelectTrigger>
            <SelectContent className="z-[200]">
              <SelectItem value="nenhum">— Nenhum —</SelectItem>
              {profissionais.map(p => <SelectItem key={p.id} value={p.id}>{p.nome}</SelectItem>)}
            </SelectContent>
          </Select>
        </div>
        <div className="space-y-1">
          <Label className="text-xs">Status</Label>
          <Select value={form.status} onValueChange={v => setF('status', v)}>
            <SelectTrigger className="h-8 text-sm"><SelectValue /></SelectTrigger>
            <SelectContent className="z-[200]">
              {Object.entries(STATUS_CONFIG).map(([k, v]) => (
                <SelectItem key={k} value={k}>{v.label}</SelectItem>
              ))}
            </SelectContent>
          </Select>
        </div>
      </div>

      {/* Serviços */}
      <div className="border border-border rounded-xl p-4 space-y-3">
        <div className="flex items-center justify-between">
          <h3 className="text-sm font-semibold">Serviços</h3>
          <Button size="sm" variant="outline" onClick={() => setShowAddItem(true)} className="gap-1 h-7 text-xs">
            <Plus className="w-3 h-3" /> Adicionar
          </Button>
        </div>

        {form.itens.length === 0 ? (
          <p className="text-xs text-muted-foreground text-center py-4">Nenhum serviço. Clique em "Adicionar".</p>
        ) : (
          <div className="space-y-2">
            {form.itens.map((item, idx) => (
              <div key={idx} className="flex items-start gap-2 p-2 bg-muted/30 rounded-lg border border-border">
                <div className="flex-1 min-w-0">
                  <div className="font-medium text-sm">{item.servico_nome}</div>
                  <div className="text-xs text-muted-foreground">
                    {item.quantidade}x · {item.tipo_valor === 'gratuito' ? 'Gratuito' : formatCurrency(item.valor_unitario)}
                  </div>
                </div>
                <div className="text-right shrink-0 text-sm font-semibold">{item.tipo_valor === 'gratuito' ? 'Grátis' : formatCurrency(item.valor_total)}</div>
                <button onClick={() => removeItem(idx)} className="text-muted-foreground hover:text-destructive">
                  <Trash2 className="w-3.5 h-3.5" />
                </button>
              </div>
            ))}

            <div className="border-t border-border pt-2 space-y-1.5">
              <div className="flex items-center gap-2 text-sm">
                <span className="text-muted-foreground flex-1">Subtotal</span>
                <span>{formatCurrency(form.valor_total)}</span>
              </div>
              <div className="flex items-center gap-2 text-sm">
                <span className="text-muted-foreground">Desconto (%)</span>
                <Input type="number" min={0} max={100} value={form.desconto} onChange={e => setF('desconto', e.target.value)} className="w-16 h-7 text-sm" />
                <span className="ml-auto text-muted-foreground text-xs">- {formatCurrency((form.valor_total || 0) * (Number(form.desconto) || 0) / 100)}</span>
              </div>
              <div className="flex items-center justify-between font-bold text-sm">
                <span>Total Final</span>
                <span className="text-primary">{formatCurrency(form.valor_final)}</span>
              </div>
            </div>
          </div>
        )}
      </div>

      {/* Observações */}
      <div className="space-y-1">
        <Label className="text-xs">Observações</Label>
        <textarea
          className="w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm resize-none h-16 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
          value={form.observacoes}
          onChange={e => setF('observacoes', e.target.value)}
          placeholder="Condições, instruções..."
        />
      </div>

      <div className="flex justify-end gap-2">
        <Button variant="outline" size="sm" onClick={onCancel}>Cancelar</Button>
        <Button size="sm" onClick={salvar} disabled={saving}>
          {saving ? 'Salvando...' : 'Salvar'}
        </Button>
      </div>

      {showAddItem && (
        <ItemOrcamentoModal
          servicos={servicos}
          tabelasPreco={tabelasPreco}
          itensTabela={itensTabela}
          convenioId={form.convenio_id}
          onAdd={addItem}
          onClose={() => setShowAddItem(false)}
        />
      )}
    </div>
  );
}
</file>

<file path="src/components/pacientes/PacienteModal.jsx">
import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { useClinica } from '@/lib/ClinicaContext';
import { X, Send, Link, CheckCircle } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';

function gerarToken() {
  return Math.random().toString(36).substring(2) + Date.now().toString(36);
}

function getLinkAnamnese(token) {
  return `${window.location.origin}/anamnese/${token}`;
}

export default function PacienteModal({ paciente, convenios, onClose, onSaved }) {
  const { config } = useClinica();
  const origens = config.origens_pacientes || [];
  const [form, setForm] = useState({
    nome: paciente?.nome || '',
    cpf: paciente?.cpf || '',
    data_nascimento: paciente?.data_nascimento || '',
    telefone: paciente?.telefone || '',
    email: paciente?.email || '',
    endereco: paciente?.endereco || '',
    sexo: paciente?.sexo || '',
    convenio_id: paciente?.convenio_id || '',
    numero_carteirinha: paciente?.numero_carteirinha || '',
    nome_mae: paciente?.nome_mae || '',
    contato_emergencia_nome: paciente?.contato_emergencia_nome || '',
    contato_emergencia_telefone: paciente?.contato_emergencia_telefone || '',
    contato_emergencia_parentesco: paciente?.contato_emergencia_parentesco || '',
    observacoes: paciente?.observacoes || '',
    origem: paciente?.origem || '',
    ativo: paciente?.ativo !== false,
  });
  const [saving, setSaving] = useState(false);
  const [savedPaciente, setSavedPaciente] = useState(paciente || null);

  // Anamnese
  const [formularios, setFormularios] = useState([]);
  const [formularioSel, setFormularioSel] = useState('');
  const [linkGerado, setLinkGerado] = useState('');
  const [linkCopiado, setLinkCopiado] = useState(false);
  const [enviandoLink, setEnviandoLink] = useState(false);

  useEffect(() => {
    base44.entities.FormularioAnamnese.list().then(fs => setFormularios(fs.filter(f => f.ativo !== false)));
  }, []);

  function set(k, v) { setForm(f => ({ ...f, [k]: v })); }

  async function handleSave() {
    if (!form.nome.trim()) return alert('Nome é obrigatório');
    setSaving(true);
    let resultado;
    if (paciente) {
      resultado = await base44.entities.Paciente.update(paciente.id, form);
      setSavedPaciente({ ...paciente, ...form });
    } else {
      resultado = await base44.entities.Paciente.create(form);
      setSavedPaciente(resultado);
    }
    setSaving(false);
    onSaved(resultado);
  }

  async function gerarLink() {
    if (!formularioSel) return;
    if (!savedPaciente?.id) return alert('Salve o paciente primeiro.');
    setEnviandoLink(true);
    const token = gerarToken();
    const formulario = formularios.find(f => f.id === formularioSel);
    await base44.entities.RespostaAnamnese.create({
      paciente_id: savedPaciente.id,
      paciente_nome: savedPaciente.nome || form.nome,
      formulario_id: formularioSel,
      formulario_nome: formulario?.nome || '',
      token,
      status: 'pendente',
      respostas: [],
    });
    const link = getLinkAnamnese(token);
    setLinkGerado(link);
    setEnviandoLink(false);
  }

  async function copiarLink() {
    if (!linkGerado) return;
    await navigator.clipboard.writeText(linkGerado);
    setLinkCopiado(true);
    setTimeout(() => setLinkCopiado(false), 2000);
  }

  return (
    <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
      <div className="bg-card rounded-xl shadow-xl w-full max-w-lg max-h-[90vh] overflow-y-auto">
        <div className="flex items-center justify-between p-5 border-b border-border">
          <h2 className="text-base font-semibold">{paciente ? 'Editar Paciente' : 'Novo Paciente'}</h2>
          <button onClick={onClose} className="text-muted-foreground hover:text-foreground"><X className="w-5 h-5" /></button>
        </div>

        <div className="p-5 space-y-4">
          <div className="grid grid-cols-2 gap-3">
            <div className="col-span-2 space-y-1.5">
              <Label>Nome completo *</Label>
              <Input value={form.nome} onChange={e => set('nome', e.target.value)} placeholder="Nome do paciente" />
            </div>
            <div className="space-y-1.5">
              <Label>CPF</Label>
              <Input value={form.cpf} onChange={e => set('cpf', e.target.value)} placeholder="000.000.000-00" />
            </div>
            <div className="space-y-1.5">
              <Label>Data de Nascimento</Label>
              <Input type="date" value={form.data_nascimento} onChange={e => set('data_nascimento', e.target.value)} />
            </div>
            <div className="space-y-1.5">
              <Label>Telefone</Label>
              <Input value={form.telefone} onChange={e => set('telefone', e.target.value)} placeholder="(00) 00000-0000" />
            </div>
            <div className="space-y-1.5">
              <Label>Email</Label>
              <Input type="email" value={form.email} onChange={e => set('email', e.target.value)} placeholder="email@exemplo.com" />
            </div>
            <div className="col-span-2 space-y-1.5">
              <Label>Endereço</Label>
              <Input value={form.endereco} onChange={e => set('endereco', e.target.value)} placeholder="Rua, número, bairro..." />
            </div>
            <div className="space-y-1.5">
              <Label>Sexo</Label>
              <Select value={form.sexo || 'nao_informado'} onValueChange={v => set('sexo', v === 'nao_informado' ? '' : v)}>
                <SelectTrigger><SelectValue placeholder="Selecionar" /></SelectTrigger>
                <SelectContent>
                  <SelectItem value="nao_informado">Não informado</SelectItem>
                  <SelectItem value="masculino">Masculino</SelectItem>
                  <SelectItem value="feminino">Feminino</SelectItem>
                  <SelectItem value="outro">Outro</SelectItem>
                </SelectContent>
              </Select>
            </div>
            <div className="space-y-1.5">
              <Label>Status</Label>
              <Select value={form.ativo ? 'ativo' : 'inativo'} onValueChange={v => set('ativo', v === 'ativo')}>
                <SelectTrigger><SelectValue /></SelectTrigger>
                <SelectContent>
                  <SelectItem value="ativo">Ativo</SelectItem>
                  <SelectItem value="inativo">Inativo</SelectItem>
                </SelectContent>
              </Select>
            </div>
            <div className="space-y-1.5">
              <Label>Convênio</Label>
              <Select value={form.convenio_id || 'particular'} onValueChange={v => set('convenio_id', v === 'particular' ? '' : v)}>
                <SelectTrigger><SelectValue placeholder="Particular" /></SelectTrigger>
                <SelectContent>
                  <SelectItem value="particular">Particular</SelectItem>
                  {convenios.map(c => <SelectItem key={c.id} value={c.id}>{c.nome}</SelectItem>)}
                </SelectContent>
              </Select>
            </div>
            <div className="space-y-1.5">
              <Label>Nº Carteirinha</Label>
              <Input value={form.numero_carteirinha} onChange={e => set('numero_carteirinha', e.target.value)} />
            </div>
            <div className="col-span-2 space-y-1.5">
              <Label>Nome da Mãe</Label>
              <Input value={form.nome_mae} onChange={e => set('nome_mae', e.target.value)} placeholder="Nome completo da mãe" />
            </div>
          </div>

          {/* Contato de Emergência */}
          <div className="border border-border rounded-xl p-4 space-y-3 bg-muted/20">
            <p className="text-sm font-medium">Contato de Emergência</p>
            <div className="grid grid-cols-2 gap-3">
              <div className="col-span-2 space-y-1.5">
                <Label className="text-xs">Nome</Label>
                <Input value={form.contato_emergencia_nome} onChange={e => set('contato_emergencia_nome', e.target.value)} placeholder="Nome do contato" />
              </div>
              <div className="space-y-1.5">
                <Label className="text-xs">Telefone</Label>
                <Input value={form.contato_emergencia_telefone} onChange={e => set('contato_emergencia_telefone', e.target.value)} placeholder="(00) 00000-0000" />
              </div>
              <div className="space-y-1.5">
                <Label className="text-xs">Parentesco</Label>
                <Input value={form.contato_emergencia_parentesco} onChange={e => set('contato_emergencia_parentesco', e.target.value)} placeholder="Ex: Mãe, Cônjuge..." />
              </div>
            </div>
          </div>

          {origens.length > 0 && (
            <div className="space-y-1.5">
              <Label>Origem</Label>
              <Select value={form.origem || 'nenhuma'} onValueChange={v => set('origem', v === 'nenhuma' ? '' : v)}>
                <SelectTrigger><SelectValue placeholder="Como chegou até nós?" /></SelectTrigger>
                <SelectContent>
                  <SelectItem value="nenhuma">Não informado</SelectItem>
                  {origens.map(o => <SelectItem key={o.nome} value={o.nome}>{o.nome}</SelectItem>)}
                </SelectContent>
              </Select>
            </div>
          )}

          <div className="space-y-1.5">
            <Label>Observações</Label>
            <Input value={form.observacoes} onChange={e => set('observacoes', e.target.value)} placeholder="Alergias, histórico, observações..." />
          </div>

          {/* Seção de Anamnese — só aparece se o paciente já foi salvo ou está editando */}
          {(savedPaciente?.id) && formularios.length > 0 && (
            <div className="border border-border rounded-xl p-4 space-y-3 bg-muted/20">
              <div className="flex items-center gap-2">
                <Send className="w-4 h-4 text-primary" />
                <p className="text-sm font-medium">Enviar link de anamnese</p>
              </div>
              <div className="flex gap-2">
                <Select value={formularioSel} onValueChange={v => { setFormularioSel(v); setLinkGerado(''); }}>
                  <SelectTrigger className="flex-1">
                    <SelectValue placeholder="Selecionar formulário..." />
                  </SelectTrigger>
                  <SelectContent>
                    {formularios.map(f => <SelectItem key={f.id} value={f.id}>{f.nome}</SelectItem>)}
                  </SelectContent>
                </Select>
                <Button
                  variant="outline"
                  size="sm"
                  disabled={!formularioSel || enviandoLink}
                  onClick={gerarLink}
                  className="shrink-0"
                >
                  <Link className="w-3.5 h-3.5" />
                  {enviandoLink ? '...' : 'Gerar'}
                </Button>
              </div>

              {linkGerado && (
                <div className="space-y-2">
                  <div className="flex items-center gap-2 bg-background border border-border rounded-lg px-3 py-2">
                    <span className="text-xs text-muted-foreground truncate flex-1">{linkGerado}</span>
                    <button
                      onClick={copiarLink}
                      className="shrink-0 text-xs font-medium text-primary hover:underline flex items-center gap-1"
                    >
                      {linkCopiado ? <><CheckCircle className="w-3.5 h-3.5 text-green-500" /> Copiado!</> : 'Copiar'}
                    </button>
                  </div>
                  <p className="text-xs text-muted-foreground">Envie este link para o paciente preencher a anamnese.</p>
                </div>
              )}
            </div>
          )}
        </div>

        <div className="flex justify-end gap-2 p-5 border-t border-border">
          <Button variant="outline" onClick={onClose}>Fechar</Button>
          <Button onClick={handleSave} disabled={saving}>{saving ? 'Salvando...' : 'Salvar'}</Button>
        </div>
      </div>
    </div>
  );
}
</file>

<file path="src/components/pacientes/PacientePerfilModal.jsx">
import { useState } from 'react';
import { X, User, Receipt, HeartPulse, Edit2 } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { format } from 'date-fns';
import { useClinica } from '@/lib/ClinicaContext';
import AbaAnamnesePaciente from './AbaAnamnesePaciente';
import AbaOrcamentos from './AbaOrcamentos';
import PacienteModal from './PacienteModal';

export default function PacientePerfilModal({ paciente, convenios, onClose, onSaved }) {
  const clinicaCtx = useClinica();
  const config = clinicaCtx?.config || {};
  const [tab, setTab] = useState('dados');
  const [editOpen, setEditOpen] = useState(false);

  const tipoClinica = config.tipo || 'medica';

  // Nome da aba do meio varia por tipo de clínica
  const labelAba = tipoClinica === 'odontologica' ? 'Plano de Tratamento'
    : tipoClinica === 'estetica' ? 'Procedimentos'
    : 'Orçamentos';

  const TABS = [
    { id: 'dados',     label: 'Dados',     icon: User },
    { id: 'orcamento', label: labelAba,    icon: Receipt },
    { id: 'anamnese',  label: 'Anamnese',  icon: HeartPulse },
  ];

  const convenio = convenios.find(c => c.id === paciente.convenio_id);

  const campos = [
    { label: 'CPF', value: paciente.cpf },
    { label: 'Data de Nascimento', value: paciente.data_nascimento ? format(new Date(paciente.data_nascimento), 'dd/MM/yyyy') : null },
    { label: 'Sexo', value: paciente.sexo ? paciente.sexo.charAt(0).toUpperCase() + paciente.sexo.slice(1) : null },
    { label: 'Telefone', value: paciente.telefone },
    { label: 'Email', value: paciente.email },
    { label: 'Convênio', value: convenio?.nome || 'Particular' },
    { label: 'Nº Carteirinha', value: paciente.numero_carteirinha },
    { label: 'Endereço', value: paciente.endereco },
    { label: 'Observações', value: paciente.observacoes },
  ].filter(c => c.value);

  return (
    <>
      <div className="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50">
        <div className="bg-background rounded-2xl shadow-2xl w-full max-w-4xl max-h-[92vh] flex flex-col overflow-hidden">

          {/* Header */}
          <div className="flex items-center gap-3 px-6 py-4 border-b border-border shrink-0">
            <div className="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold shrink-0">
              {paciente.nome?.[0]?.toUpperCase()}
            </div>
            <div className="flex-1 min-w-0">
              <h2 className="font-semibold text-base truncate">{paciente.nome}</h2>
              <p className="text-xs text-muted-foreground truncate">{paciente.telefone || paciente.email || 'Sem contato cadastrado'}</p>
            </div>
            <Button variant="outline" size="sm" onClick={() => setEditOpen(true)} className="gap-1.5 shrink-0">
              <Edit2 className="w-3.5 h-3.5" /> Editar
            </Button>
            <button onClick={onClose} className="p-1.5 rounded-lg hover:bg-muted text-muted-foreground transition-colors">
              <X className="w-4 h-4" />
            </button>
          </div>

          {/* Tabs */}
          <div className="border-b border-border shrink-0">
            <div className="flex px-6 gap-1">
              {TABS.map(t => (
                <button
                  key={t.id}
                  onClick={() => setTab(t.id)}
                  className={`flex items-center gap-2 px-4 py-2.5 text-sm font-medium border-b-2 transition-all -mb-px ${
                    tab === t.id
                      ? 'border-primary text-primary'
                      : 'border-transparent text-muted-foreground hover:text-foreground'
                  }`}
                >
                  <t.icon className="w-4 h-4" />
                  {t.label}
                </button>
              ))}
            </div>
          </div>

          {/* Content */}
          <div className="flex-1 overflow-y-auto p-6">
            {tab === 'dados' && (
              <div className="grid grid-cols-2 gap-4">
                {campos.map(({ label, value }) => (
                  <div key={label} className={`space-y-0.5 ${label === 'Endereço' || label === 'Observações' ? 'col-span-2' : ''}`}>
                    <p className="text-xs text-muted-foreground font-medium uppercase tracking-wide">{label}</p>
                    <p className="text-sm">{value}</p>
                  </div>
                ))}
                {campos.length === 0 && (
                  <p className="col-span-2 text-sm text-muted-foreground text-center py-6">Nenhum dado cadastrado além do nome.</p>
                )}
              </div>
            )}

            {tab === 'orcamento' && <AbaOrcamentos paciente={paciente} />}

            {tab === 'anamnese' && <AbaAnamnesePaciente paciente={paciente} />}
          </div>
        </div>
      </div>

      {editOpen && (
        <PacienteModal
          paciente={paciente}
          convenios={convenios}
          onClose={() => setEditOpen(false)}
          onSaved={() => { setEditOpen(false); onSaved?.(); }}
        />
      )}
    </>
  );
}
</file>

<file path="src/components/profissionais/ProfissionalModal.jsx">
import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { X, Plus, Trash2 } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';

const DIAS = [{ id: 1, label: 'Seg' }, { id: 2, label: 'Ter' }, { id: 3, label: 'Qua' }, { id: 4, label: 'Qui' }, { id: 5, label: 'Sex' }, { id: 6, label: 'Sáb' }, { id: 0, label: 'Dom' }];
const CORES = ['#1E3A5F', '#2563EB', '#7C3AED', '#059669', '#DC2626', '#D97706', '#0891B2', '#BE185D'];
const TABS = [{ id: 'dados', label: 'Dados' }, { id: 'servicos', label: 'Serviços & Comissões' }];

export default function ProfissionalModal({ profissional, convenios, onClose, onSaved }) {
  const [tab, setTab] = useState('dados');
  const [servicos, setServicos] = useState([]);
  const [form, setForm] = useState({
    nome: profissional?.nome || '',
    especialidade: profissional?.especialidade || '',
    crm: profissional?.crm || '',
    telefone: profissional?.telefone || '',
    email: profissional?.email || '',
    cor: profissional?.cor || '#1E3A5F',
    horario_inicio: profissional?.horario_inicio || '08:00',
    horario_fim: profissional?.horario_fim || '18:00',
    dias_atendimento: profissional?.dias_atendimento || [1, 2, 3, 4, 5],
    convenios_aceitos: profissional?.convenios_aceitos || [],
    servicos_comissao: profissional?.servicos_comissao || [],
    ativo: profissional?.ativo !== false,
  });
  const [saving, setSaving] = useState(false);

  useEffect(() => {
    base44.entities.Servico.list().then(s => setServicos(s.filter(x => x.ativo !== false)));
  }, []);

  function set(k, v) { setForm(f => ({ ...f, [k]: v })); }

  function toggleDia(id) {
    setForm(f => ({
      ...f,
      dias_atendimento: f.dias_atendimento.includes(id)
        ? f.dias_atendimento.filter(d => d !== id)
        : [...f.dias_atendimento, id]
    }));
  }

  // Serviços/Comissões
  const servicosNaoVinculados = servicos.filter(s => !form.servicos_comissao.find(sc => sc.servico_id === s.id));

  function adicionarServico(servicoId) {
    const s = servicos.find(x => x.id === servicoId);
    if (!s) return;
    set('servicos_comissao', [...form.servicos_comissao, {
      servico_id: s.id,
      servico_nome: s.nome,
      tipo_comissao: 'percentual',
      comissao: 0,
    }]);
  }

  function removerServico(idx) {
    set('servicos_comissao', form.servicos_comissao.filter((_, i) => i !== idx));
  }

  function updateServico(idx, field, value) {
    const updated = form.servicos_comissao.map((sc, i) => i === idx ? { ...sc, [field]: value } : sc);
    set('servicos_comissao', updated);
  }

  async function handleSave() {
    if (!form.nome.trim()) return alert('Nome é obrigatório');
    setSaving(true);
    if (profissional) await base44.entities.Profissional.update(profissional.id, form);
    else await base44.entities.Profissional.create(form);
    setSaving(false);
    onSaved();
  }

  return (
    <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
      <div className="bg-card rounded-xl shadow-xl w-full max-w-2xl max-h-[90vh] flex flex-col overflow-hidden">
        <div className="flex items-center justify-between p-5 border-b border-border shrink-0">

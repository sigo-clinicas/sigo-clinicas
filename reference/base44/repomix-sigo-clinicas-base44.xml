<file path="src/components/financeiro/FecharContaModal.jsx">
import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { X, Check } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Label } from '@/components/ui/label';
import { Input } from '@/components/ui/input';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';

const pgOpts = ['dinheiro', 'cartao_debito', 'cartao_credito', 'pix', 'transferencia', 'boleto'];

export default function FecharContaModal({ lancamento, contas, onClose, onSaved }) {
  const [contas_bancarias, setContasBancarias] = useState([]);
  const [saving, setSaving] = useState(false);
  const [form, setForm] = useState({
    valor_pago: lancamento?.saldo_em_aberto || lancamento?.valor || '',
    conta_id: '',
    forma_pagamento: 'dinheiro',
    observacao: '',
  });

  useEffect(() => {
    base44.entities.ContaBancaria.list().then(c => {
      setContasBancarias(c.filter(x => x.ativo !== false));
      if (c.length > 0) setForm(f => ({ ...f, conta_id: c[0].id }));
    });
  }, []);

  async function handleSave() {
    if (!form.conta_id) return alert('Selecione uma conta.');
    if (!form.valor_pago || Number(form.valor_pago) <= 0) return alert('Valor deve ser maior que zero.');
    
    setSaving(true);
    const valorPago = Number(form.valor_pago);
    const novoSaldo = (lancamento?.saldo_em_aberto || 0) - valorPago;
    
    // Atualiza lançamento
    await base44.entities.LancamentoFinanceiro.update(lancamento.id, {
      valor_pago: (lancamento?.valor_pago || 0) + valorPago,
      saldo_em_aberto: Math.max(0, novoSaldo),
      status: novoSaldo <= 0 ? 'pago' : 'pago_parcial',
      forma_pagamento: form.forma_pagamento,
    });

    // Registra movimentação na conta
    if (lancamento.tipo === 'receita') {
      await base44.entities.MovimentacaoConta.create({
        conta_id: form.conta_id,
        conta_nome: contas_bancarias.find(c => c.id === form.conta_id)?.nome || '',
        lancamento_financeiro_id: lancamento.id,
        tipo: 'entrada',
        descricao: `Recebimento: ${lancamento.descricao}`,
        valor: valorPago,
        data: new Date().toISOString().split('T')[0],
        observacao: form.observacao || '',
      });
    }

    setSaving(false);
    onSaved();
  }

  return (
    <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
      <div className="bg-card rounded-xl shadow-xl w-full max-w-sm">
        <div className="flex items-center justify-between p-5 border-b border-border">
          <h2 className="text-base font-semibold">Fechar Conta</h2>
          <button onClick={onClose} className="text-muted-foreground hover:text-foreground">
            <X className="w-5 h-5" />
          </button>
        </div>

        <div className="p-5 space-y-4">
          <div className="space-y-1">
            <p className="text-xs text-muted-foreground font-medium uppercase">Lançamento</p>
            <p className="text-sm font-medium">{lancamento?.descricao}</p>
          </div>

          <div className="space-y-1">
            <Label className="text-xs">Valor a Receber</Label>
            <div className="flex h-9 items-center px-3 rounded-md border border-input bg-muted/30 text-sm font-medium">
              R$ {Number(lancamento?.saldo_em_aberto || 0).toFixed(2).replace('.', ',')}
            </div>
          </div>

          <div className="space-y-1">
            <Label className="text-xs">Valor Pago *</Label>
            <Input
              type="number"
              value={form.valor_pago}
              onChange={e => setForm(f => ({ ...f, valor_pago: e.target.value }))}
              placeholder="0,00"
              max={lancamento?.saldo_em_aberto || 0}
            />
          </div>

          <div className="space-y-1">
            <Label className="text-xs">Conta a Receber *</Label>
            <Select value={form.conta_id} onValueChange={v => setForm(f => ({ ...f, conta_id: v }))}>
              <SelectTrigger>
                <SelectValue placeholder="Selecionar conta" />
              </SelectTrigger>
              <SelectContent>
                {contas_bancarias.map(c => (
                  <SelectItem key={c.id} value={c.id}>
                    {c.nome}
                  </SelectItem>
                ))}
              </SelectContent>
            </Select>
          </div>

          <div className="space-y-1">
            <Label className="text-xs">Forma de Pagamento</Label>
            <Select value={form.forma_pagamento} onValueChange={v => setForm(f => ({ ...f, forma_pagamento: v }))}>
              <SelectTrigger>
                <SelectValue />
              </SelectTrigger>
              <SelectContent>
                {pgOpts.map(o => (
                  <SelectItem key={o} value={o} className="capitalize">
                    {o.replace('_', ' ')}
                  </SelectItem>
                ))}
              </SelectContent>
            </Select>
          </div>

          <div className="space-y-1">
            <Label className="text-xs">Observação</Label>
            <Input
              value={form.observacao}
              onChange={e => setForm(f => ({ ...f, observacao: e.target.value }))}
              placeholder="Opcional"
            />
          </div>
        </div>

        <div className="flex items-center gap-2 p-5 border-t border-border">
          <div className="flex-1" />
          <Button variant="outline" onClick={onClose}>Cancelar</Button>
          <Button onClick={handleSave} disabled={saving} className="gap-1.5">
            <Check className="w-4 h-4" />
            {saving ? 'Salvando...' : 'Confirmar'}
          </Button>
        </div>
      </div>
    </div>
  );
}

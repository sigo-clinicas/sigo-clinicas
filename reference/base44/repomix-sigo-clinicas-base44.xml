function SolicitarModal({ open, onClose, clinicas, profissionais }) {
  const [form, setForm] = useState({ paciente_nome: '', clinica_id: '', clinica_nome: '', profissional_id: '', profissional_nome: '' });

  const handleClinica = (id) => {
    const c = clinicas.find(x => x.id === id);
    setForm(f => ({ ...f, clinica_id: id, clinica_nome: c?.nome || '' }));
  };

  const handleSolicitar = async () => {
    if (!form.paciente_nome) return;
    const token = Math.random().toString(36).slice(2);
    await base44.entities.Depoimento.create({
      ...form,
      texto: '',
      status: 'pendente',
      origem: 'solicitado',
      link_solicitacao: `${window.location.origin}/depoimento/${token}`,
    });
    onClose();
  };

  return (
    <Dialog open={open} onOpenChange={onClose}>
      <DialogContent className="max-w-md">
        <DialogHeader>
          <DialogTitle className="flex items-center gap-2">
            <Send className="w-5 h-5" /> Solicitar Avaliação
          </DialogTitle>
        </DialogHeader>
        <div className="space-y-4 pt-2">

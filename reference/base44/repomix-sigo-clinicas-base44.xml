<file path="src/components/estoque/SaidaEstoqueModal.jsx">
import { useState } from 'react';
import { base44 } from '@/api/base44Client';
import { format } from 'date-fns';
import { X, Plus, Trash2 } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';

export default function SaidaEstoqueModal({ itensEstoque, onClose, onSaved }) {
  const [data, setData] = useState(format(new Date(), 'yyyy-MM-dd'));
  const [observacao, setObservacao] = useState('');
  const [linhas, setLinhas] = useState([{ item_id: '', quantidade: '' }]);
  const [saving, setSaving] = useState(false);

  function addLinha() {
    setLinhas(l => [...l, { item_id: '', quantidade: '' }]);
  }

  function removeLinha(idx) {
    setLinhas(l => l.filter((_, i) => i !== idx));
  }

  function updateLinha(idx, key, value) {
    setLinhas(l => l.map((row, i) => i === idx ? { ...row, [key]: value } : row));
  }

  const linhasValidas = linhas.filter(l => l.item_id && Number(l.quantidade) > 0);

  // Verifica se alguma linha tem saldo insuficiente
  const erros = linhas.map(l => {
    if (!l.item_id || !l.quantidade) return null;
    const item = itensEstoque.find(x => x.id === l.item_id);
    const qtd = Number(l.quantidade);
    if (item && qtd > (item.saldo_atual || 0)) return `Saldo insuficiente (disponível: ${item.saldo_atual || 0})`;
    return null;
  });

  const temErro = erros.some(Boolean);

  async function handleSave() {
    if (linhasValidas.length === 0 || temErro) return;
    setSaving(true);

    await Promise.all(linhasValidas.map(async (l) => {
      const item = itensEstoque.find(x => x.id === l.item_id);
      const qtd = Number(l.quantidade);

      await Promise.all([
        base44.entities.MovimentacaoEstoque.create({
          item_id: item.id,
          item_descricao: item.descricao,
          tipo: 'saida',
          quantidade: qtd,
          data,
          observacao: observacao || undefined,
        }),
        base44.entities.ItemEstoque.update(item.id, { saldo_atual: (item.saldo_atual || 0) - qtd }),
      ]);
    }));

    setSaving(false);
    onSaved();
  }

  return (
    <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
      <div className="bg-card rounded-xl shadow-xl w-full max-w-xl max-h-[90vh] flex flex-col">
        {/* Header */}
        <div className="flex items-center justify-between p-5 border-b border-border shrink-0">
          <h2 className="text-base font-semibold">Registrar Saída de Estoque</h2>
          <button onClick={onClose}><X className="w-5 h-5 text-muted-foreground" /></button>
        </div>

        <div className="overflow-y-auto flex-1 p-5 space-y-4">
          <div className="space-y-1.5">
            <Label>Data *</Label>
            <Input type="date" value={data} onChange={e => setData(e.target.value)} className="w-40" />
          </div>

          {/* Itens */}
          <div>
            <div className="flex items-center justify-between mb-2">
              <Label>Itens da Saída</Label>
              <Button size="sm" variant="outline" onClick={addLinha} className="gap-1 h-7 text-xs">
                <Plus className="w-3.5 h-3.5" /> Adicionar Item
              </Button>
            </div>

            <div className="border border-border rounded-lg overflow-hidden">
              <table className="w-full text-sm">
                <thead className="bg-muted/40 border-b border-border">
                  <tr>
                    <th className="text-left px-3 py-2.5 font-medium text-muted-foreground">Item</th>
                    <th className="text-right px-3 py-2.5 font-medium text-muted-foreground w-28">Quantidade</th>
                    <th className="w-10" />
                  </tr>
                </thead>
                <tbody className="divide-y divide-border">
                  {linhas.map((linha, idx) => {
                    const item = itensEstoque.find(x => x.id === linha.item_id);
                    return (
                      <tr key={idx} className="bg-card">
                        <td className="px-3 py-2">
                          <Select value={linha.item_id} onValueChange={v => updateLinha(idx, 'item_id', v)}>
                            <SelectTrigger className="h-8 text-xs">
                              <SelectValue placeholder="Selecionar item..." />
                            </SelectTrigger>
                            <SelectContent>
                              {itensEstoque.map(it => (
                                <SelectItem key={it.id} value={it.id}>
                                  {it.descricao}{it.codigo ? ` (${it.codigo})` : ''}
                                </SelectItem>
                              ))}
                            </SelectContent>
                          </Select>
                          {item && (
                            <div className="text-xs mt-0.5 pl-1">
                              <span className="text-muted-foreground">Saldo: </span>
                              <span className={item.saldo_atual <= 0 ? 'text-destructive font-medium' : 'text-foreground'}>
                                {item.saldo_atual || 0} {item.unidade || 'un'}
                              </span>
                            </div>
                          )}
                          {erros[idx] && <p className="text-xs text-destructive mt-0.5 pl-1">{erros[idx]}</p>}
                        </td>
                        <td className="px-3 py-2">
                          <Input
                            type="number"
                            className="h-8 text-xs text-right"
                            value={linha.quantidade}
                            onChange={e => updateLinha(idx, 'quantidade', e.target.value)}
                            placeholder="0"
                          />
                        </td>
                        <td className="px-3 py-2 text-center">
                          {linhas.length > 1 && (
                            <button onClick={() => removeLinha(idx)} className="text-muted-foreground hover:text-destructive transition-colors">
                              <Trash2 className="w-4 h-4" />
                            </button>
                          )}
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          </div>

          <div className="space-y-1.5">
            <Label>Observação / Motivo</Label>
            <Input value={observacao} onChange={e => setObservacao(e.target.value)} placeholder="Ex: uso em procedimento, descarte, etc." />
          </div>
        </div>

        {/* Footer */}
        <div className="flex items-center gap-2 p-5 border-t border-border shrink-0">
          <div className="flex-1" />
          <Button variant="outline" onClick={onClose}>Cancelar</Button>
          <Button
            onClick={handleSave}
            disabled={saving || linhasValidas.length === 0 || temErro}
            variant="destructive"
          >
            {saving ? 'Salvando...' : `Registrar Saída (${linhasValidas.length} item${linhasValidas.length !== 1 ? 's' : ''})`}
          </Button>
        </div>
      </div>
    </div>
  );
}
</file>

<file path="src/components/financeiro/CategoriaModal.jsx">
import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';

export default function CategoriaModal({ categoria, onClose, onSaved, todasCategorias = [] }) {
  const [form, setForm] = useState({
    nome: '',
    tipo: 'receita',
    descricao: '',
    pai_id: '',
    ativo: true,
  });
  const [loading, setLoading] = useState(false);

  useEffect(() => {
    if (categoria) {
      setForm({
        nome: categoria.nome || '',
        tipo: categoria.tipo || 'receita',
        descricao: categoria.descricao || '',
        pai_id: categoria.pai_id || '',
        ativo: categoria.ativo !== false,
      });
    }
  }, [categoria]);

  // Candidatos a pai: mesmo tipo, não é a própria categoria, e não é filha dela (evitar ciclo)
  const candidatosPai = todasCategorias.filter(c =>
    c.tipo === form.tipo &&
    c.id !== categoria?.id &&
    !c.pai_id // só categorias raiz podem ser pai
  );

  async function handleSave() {
    if (!form.nome.trim()) return alert('Nome é obrigatório');
    setLoading(true);
    const data = {
      ...form,
      pai_id: form.pai_id || null,
      pai_nome: form.pai_id ? (todasCategorias.find(c => c.id === form.pai_id)?.nome || '') : '',
    };
    if (categoria?.id) {
      await base44.entities.CategoriaLancamento.update(categoria.id, data);
    } else {
      await base44.entities.CategoriaLancamento.create(data);
    }
    setLoading(false);
    onSaved();
  }

  async function handleDelete() {
    if (!categoria?.id || !confirm('Deseja excluir esta categoria?')) return;
    setLoading(true);
    await base44.entities.CategoriaLancamento.delete(categoria.id);
    setLoading(false);
    onSaved();
  }

  return (
    <div className="fixed inset-0 bg-black/50 flex items-center justify-center z-50">
      <div className="bg-card rounded-xl shadow-lg max-w-md w-full mx-4 p-6 space-y-4">
        <h2 className="text-xl font-semibold">{categoria?.id ? 'Editar Categoria' : 'Nova Categoria'}</h2>

        <div>
          <label className="text-sm font-medium mb-1 block">Nome *</label>
          <Input
            value={form.nome}
            onChange={e => setForm({ ...form, nome: e.target.value })}
            placeholder="Ex: Consultas, Aluguel, Insumos..."
          />
        </div>

        <div>
          <label className="text-sm font-medium mb-1 block">Tipo *</label>
          <Select value={form.tipo} onValueChange={tipo => setForm({ ...form, tipo, pai_id: '' })}>
            <SelectTrigger><SelectValue /></SelectTrigger>
            <SelectContent>
              <SelectItem value="receita">Receita</SelectItem>
              <SelectItem value="despesa">Despesa</SelectItem>
            </SelectContent>
          </Select>
        </div>

        <div>
          <label className="text-sm font-medium mb-1 block">Categoria Pai (opcional)</label>
          <Select value={form.pai_id || 'nenhuma'} onValueChange={v => setForm({ ...form, pai_id: v === 'nenhuma' ? '' : v })}>
            <SelectTrigger>
              <SelectValue placeholder="Nenhuma (categoria raiz)" />
            </SelectTrigger>
            <SelectContent>
              <SelectItem value="nenhuma">— Nenhuma (categoria raiz) —</SelectItem>
              {candidatosPai.map(c => (
                <SelectItem key={c.id} value={c.id}>{c.nome}</SelectItem>
              ))}
            </SelectContent>
          </Select>
          {form.pai_id && (
            <p className="text-xs text-muted-foreground mt-1">Esta será uma subcategoria de "{todasCategorias.find(c => c.id === form.pai_id)?.nome}"</p>
          )}
        </div>

        <div>
          <label className="text-sm font-medium mb-1 block">Descrição</label>
          <Input
            value={form.descricao}
            onChange={e => setForm({ ...form, descricao: e.target.value })}
            placeholder="Descrição da categoria..."
          />
        </div>

        <div className="flex items-center gap-2">
          <input
            type="checkbox"
            id="ativo"
            checked={form.ativo}
            onChange={e => setForm({ ...form, ativo: e.target.checked })}
            className="rounded"
          />
          <label htmlFor="ativo" className="text-sm">Ativo</label>
        </div>

        <div className="flex gap-2 pt-2">
          {categoria?.id && (
            <Button variant="destructive" onClick={handleDelete} disabled={loading} className="flex-1">
              Excluir
            </Button>
          )}
          <Button variant="outline" onClick={onClose} className="flex-1">Cancelar</Button>
          <Button onClick={handleSave} disabled={loading} className="flex-1">Salvar</Button>
        </div>
      </div>
    </div>
  );
}
</file>

<file path="src/components/financeiro/CategoriasLista.jsx">
import { useState } from 'react';
import { DragDropContext, Droppable, Draggable } from '@hello-pangea/dnd';
import { base44 } from '@/api/base44Client';
import { GripVertical, ChevronRight, ChevronDown, Plus } from 'lucide-react';
import { Button } from '@/components/ui/button';
import CategoriaModal from './CategoriaModal';

function CategoriaItem({ cat, allCats, depth = 0, onEdit, tipo }) {
  const [expanded, setExpanded] = useState(true);
  const filhos = allCats.filter(c => c.pai_id === cat.id).sort((a, b) => (a.ordem ?? 0) - (b.ordem ?? 0));
  const hasFilhos = filhos.length > 0;
  const corStatus = tipo === 'receita'
    ? (cat.ativo ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500')
    : (cat.ativo ? 'bg-red-100 text-red-700' : 'bg-gray-100 text-gray-500');

  return (
    <div>
      <div
        className="flex items-center gap-2 px-2 py-2 rounded hover:bg-muted/50 cursor-pointer"
        style={{ paddingLeft: `${8 + depth * 20}px` }}
        onClick={() => onEdit(cat)}
      >
        <button
          onClick={e => { e.stopPropagation(); setExpanded(v => !v); }}
          className={`w-4 h-4 shrink-0 text-muted-foreground ${!hasFilhos ? 'invisible' : ''}`}
        >
          {expanded ? <ChevronDown className="w-3.5 h-3.5" /> : <ChevronRight className="w-3.5 h-3.5" />}
        </button>
        <div className="flex-1 min-w-0">
          <div className="flex items-center gap-2">
            <p className={`font-medium text-sm ${depth > 0 ? 'text-muted-foreground' : ''}`}>{cat.nome}</p>
            {depth > 0 && <span className="text-xs text-muted-foreground/60 italic">subcategoria</span>}
          </div>
          {cat.descricao && <p className="text-xs text-muted-foreground truncate">{cat.descricao}</p>}
        </div>
        <span className={`text-xs px-2 py-0.5 rounded shrink-0 ${corStatus}`}>
          {cat.ativo ? 'Ativo' : 'Inativo'}
        </span>
      </div>
      {hasFilhos && expanded && (
        <div className="border-l-2 border-muted ml-5">
          {filhos.map(filho => (
            <CategoriaItem key={filho.id} cat={filho} allCats={allCats} depth={depth + 1} onEdit={onEdit} tipo={tipo} />
          ))}
        </div>
      )}
    </div>
  );
}

export default function CategoriasLista({ categorias, tipo, onReload }) {
  const [modal, setModal] = useState(false);
  const [catEditando, setCatEditando] = useState(null);

  const raizes = categorias
    .filter(c => c.tipo === tipo && !c.pai_id)
    .sort((a, b) => (a.ordem ?? 0) - (b.ordem ?? 0));

  const titulo = tipo === 'receita' ? 'Categorias de Receita' : 'Categorias de Despesa';
  const cor = tipo === 'receita' ? 'text-green-700' : 'text-red-700';

  async function onDragEnd(result) {
    if (!result.destination || result.source.index === result.destination.index) return;
    const reordenados = Array.from(raizes);
    const [moved] = reordenados.splice(result.source.index, 1);
    reordenados.splice(result.destination.index, 0, moved);
    await Promise.all(
      reordenados.map((cat, idx) =>
        base44.entities.CategoriaLancamento.update(cat.id, { ordem: idx })
      )
    );
    onReload();
  }

  return (
    <div className="bg-card rounded-lg border border-border p-4 space-y-3">
      <div className="flex items-center justify-between">
        <h3 className={`font-semibold ${cor}`}>{titulo}</h3>
        <Button size="sm" variant="ghost" className="gap-1 h-7 text-xs" onClick={() => { setCatEditando(null); setModal(true); }}>
          <Plus className="w-3.5 h-3.5" /> Adicionar
        </Button>
      </div>

      {raizes.length === 0 ? (
        <p className="text-sm text-muted-foreground py-4 text-center">Nenhuma cadastrada</p>
      ) : (
        <DragDropContext onDragEnd={onDragEnd}>
          <Droppable droppableId={`cat-${tipo}`}>
            {(provided) => (
              <ul ref={provided.innerRef} {...provided.droppableProps} className="space-y-0.5">
                {raizes.map((cat, idx) => (
                  <Draggable key={cat.id} draggableId={cat.id} index={idx}>
                    {(drag, snapshot) => (
                      <li
                        ref={drag.innerRef}
                        {...drag.draggableProps}
                        className={`rounded border transition-shadow ${snapshot.isDragging ? 'shadow-lg bg-accent/30 border-primary/30' : 'border-transparent'}`}
                      >
                        <div className="flex items-start gap-1">
                          <div
                            {...drag.dragHandleProps}
                            className="mt-2.5 p-1 text-muted-foreground/40 hover:text-muted-foreground cursor-grab active:cursor-grabbing shrink-0"
                            onClick={e => e.stopPropagation()}
                          >
                            <GripVertical className="w-4 h-4" />
                          </div>
                          <div className="flex-1 min-w-0">
                            <CategoriaItem
                              cat={cat}
                              allCats={categorias.filter(c => c.tipo === tipo)}
                              depth={0}
                              onEdit={c => { setCatEditando(c); setModal(true); }}
                              tipo={tipo}
                            />
                          </div>
                        </div>
                      </li>
                    )}
                  </Draggable>
                ))}
                {provided.placeholder}
              </ul>
            )}
          </Droppable>
        </DragDropContext>
      )}

      {modal && (
        <CategoriaModal
          categoria={catEditando || { tipo }}
          todasCategorias={categorias}
          onClose={() => setModal(false)}
          onSaved={() => { setModal(false); onReload(); }}
        />
      )}
    </div>
  );
}
</file>

<file path="src/components/financeiro/CentroCustoModal.jsx">
import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { X, Trash2, Edit2 } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';

const CORES = ['#6366f1','#8b5cf6','#ec4899','#ef4444','#f97316','#eab308','#22c55e','#14b8a6','#0ea5e9','#64748b'];

export default function CentroCustoModal({ onClose, onSaved }) {
  const [centros, setCentros] = useState([]);
  const [editando, setEditando] = useState(null);
  const [form, setForm] = useState({ nome: '', descricao: '', cor: CORES[0] });
  const [loading, setLoading] = useState(true);

  useEffect(() => { carregarCentros(); }, []);

  async function carregarCentros() {
    setLoading(true);
    const lista = await base44.entities.CentroCusto.list();
    setCentros(lista);
    setLoading(false);
  }

  async function salvar() {
    if (!form.nome.trim()) return alert('Nome é obrigatório');
    if (editando) {
      await base44.entities.CentroCusto.update(editando.id, form);
    } else {
      await base44.entities.CentroCusto.create(form);
    }
    resetar();
    carregarCentros();
  }

  async function deletar(id) {
    if (!confirm('Deseja deletar este centro de custo?')) return;
    await base44.entities.CentroCusto.delete(id);
    carregarCentros();
  }

  function editar(centro) {
    setEditando(centro);
    setForm({ nome: centro.nome, descricao: centro.descricao || '', cor: centro.cor || CORES[0] });
  }

  function resetar() {
    setEditando(null);
    setForm({ nome: '', descricao: '', cor: CORES[0] });
  }

  return (
    <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
      <div className="bg-card rounded-xl shadow-xl w-full max-w-lg max-h-[90vh] overflow-y-auto">
        <div className="flex items-center justify-between p-5 border-b border-border">
          <h2 className="text-base font-semibold">Centros de Custo</h2>
          <button onClick={onClose} className="text-muted-foreground hover:text-foreground">
            <X className="w-5 h-5" />
          </button>
        </div>

        <div className="p-5 space-y-4">
          {/* Formulário */}
          <div className="border border-border rounded-lg p-4 space-y-3 bg-muted/30">
            <h3 className="text-sm font-medium">{editando ? 'Editar' : 'Novo'} Centro de Custo</h3>

            <div className="space-y-1">
              <Label className="text-xs">Nome *</Label>
              <Input
                value={form.nome}
                onChange={e => setForm({ ...form, nome: e.target.value })}
                placeholder="Ex: Administrativo, Marketing, Operacional"
              />
            </div>

            <div className="space-y-1">
              <Label className="text-xs">Descrição</Label>
              <Input
                value={form.descricao}
                onChange={e => setForm({ ...form, descricao: e.target.value })}
                placeholder="Descrição adicional"
              />
            </div>

            <div className="space-y-1">
              <Label className="text-xs">Cor</Label>
              <div className="flex gap-2 flex-wrap">
                {CORES.map(cor => (
                  <button
                    key={cor}
                    onClick={() => setForm({ ...form, cor })}
                    className="w-7 h-7 rounded-full border-2 transition-all"
                    style={{
                      backgroundColor: cor,
                      borderColor: form.cor === cor ? '#000' : 'transparent',
                      transform: form.cor === cor ? 'scale(1.2)' : 'scale(1)',
                    }}
                  />
                ))}
              </div>
            </div>

            <div className="flex gap-2 pt-1">
              <Button size="sm" onClick={salvar} className="flex-1">
                {editando ? 'Atualizar' : 'Criar'}
              </Button>
              {editando && (
                <Button size="sm" variant="outline" onClick={resetar}>
                  Cancelar
                </Button>
              )}
            </div>
          </div>

          {/* Lista */}
          {loading ? (
            <div className="text-xs text-muted-foreground text-center py-4">Carregando...</div>
          ) : centros.length === 0 ? (
            <div className="text-xs text-muted-foreground text-center py-4">Nenhum centro de custo cadastrado</div>
          ) : (
            <div className="space-y-2">
              {centros.map(centro => (
                <div key={centro.id} className="flex items-center gap-3 p-3 border border-border rounded-lg hover:bg-muted/50">
                  <div
                    className="w-4 h-4 rounded-full flex-shrink-0"
                    style={{ backgroundColor: centro.cor || '#64748b' }}
                  />
                  <div className="flex-1">
                    <p className="text-sm font-medium">{centro.nome}</p>
                    {centro.descricao && <p className="text-xs text-muted-foreground">{centro.descricao}</p>}
                  </div>
                  <div className="flex gap-1">
                    <button onClick={() => editar(centro)} className="p-1.5 text-muted-foreground hover:text-foreground">
                      <Edit2 className="w-4 h-4" />
                    </button>
                    <button onClick={() => deletar(centro.id)} className="p-1.5 text-destructive hover:text-destructive/80">
                      <Trash2 className="w-4 h-4" />
                    </button>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>

        <div className="flex justify-end p-5 border-t border-border">
          <Button variant="outline" onClick={onClose}>Fechar</Button>
        </div>
      </div>
    </div>
  );
}

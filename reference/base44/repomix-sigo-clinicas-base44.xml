import { useEffect, useState } from 'react';
import { base44 } from '@/api/base44Client';
import { format } from 'date-fns';
import { Search } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';

const contaTipoLabel = {
  conta_corrente: 'Conta Corrente',
  cartao_credito: 'Cartão de Crédito',
  comissao: 'Conta de Comissão',
  caixa: 'Caixa',
  outro: 'Outro'
};

export default function Conciliacao() {
  const [contas, setContas] = useState([]);
  const [movimentacoes, setMovimentacoes] = useState([]);
  const [contaSelecionada, setContaSelecionada] = useState('');
  const [busca, setBusca] = useState('');
  const [loading, setLoading] = useState(true);

  useEffect(() => { load(); }, []);

  async function load() {
    setLoading(true);
    const [conts, movs] = await Promise.all([
      base44.entities.ContaBancaria.list('-updated_date'),
      base44.entities.MovimentacaoConta.list('-data', 500)
    ]);
    setContas(conts.filter(c => c.ativo));
    setMovimentacoes(movs);
    if (!contaSelecionada && conts.length > 0) {
      setContaSelecionada(conts[0].id);
    }
    setLoading(false);
  }

  const contaAtual = contas.find(c => c.id === contaSelecionada);
  const movsFiltradas = movimentacoes.filter(m => {
    const contaOk = m.conta_id === contaSelecionada;
    const buscaOk = !busca || m.descricao?.toLowerCase().includes(busca.toLowerCase());
    return contaOk && buscaOk;
  }).sort((a, b) => new Date(b.data) - new Date(a.data));

  const fmt = v => new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v);

  return (
    <div className="p-6 space-y-5">
      <div>
        <h1 className="text-2xl font-semibold">Conciliação Bancária</h1>
        <p className="text-sm text-muted-foreground mt-0.5">Acompanhe entradas e saídas por conta</p>
      </div>

      <div className="flex flex-wrap gap-3">
        <Select value={contaSelecionada} onValueChange={setContaSelecionada}>
          <SelectTrigger className="w-64">
            <SelectValue />
          </SelectTrigger>
          <SelectContent>
            {contas.map(c => (
              <SelectItem key={c.id} value={c.id}>
                {c.nome} • {fmt(c.saldo_atual || 0)}
              </SelectItem>
            ))}
          </SelectContent>
        </Select>
        <div className="relative flex-1 min-w-[200px]">
          <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground" />
          <Input 
            className="pl-9" 
            placeholder="Buscar..." 
            value={busca} 
            onChange={e => setBusca(e.target.value)} 
          />
        </div>
      </div>

      {contaAtual && (
        <div className="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div className="bg-card rounded-lg border border-border p-4">
            <p className="text-xs text-muted-foreground uppercase font-semibold mb-1">Tipo</p>
            <p className="text-lg font-semibold">{contaTipoLabel[contaAtual.tipo]}</p>
          </div>
          <div className="bg-card rounded-lg border border-border p-4">
            <p className="text-xs text-muted-foreground uppercase font-semibold mb-1">Saldo Inicial</p>
            <p className="text-lg font-semibold text-blue-600">{fmt(contaAtual.saldo_inicial || 0)}</p>
          </div>
          <div className="bg-card rounded-lg border border-border p-4">
            <p className="text-xs text-muted-foreground uppercase font-semibold mb-1">Saldo Atual</p>
            <p className={`text-lg font-bold ${(contaAtual.saldo_atual || 0) >= 0 ? 'text-green-600' : 'text-red-600'}`}>
              {fmt(contaAtual.saldo_atual || 0)}
            </p>
          </div>
        </div>
      )}

      <div className="bg-card rounded-xl border border-border overflow-hidden">
        <table className="w-full text-sm">
          <thead className="bg-muted/50">
            <tr>
              <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Data</th>
              <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Descrição</th>
              <th className="text-right px-4 py-3 text-xs font-semibold text-muted-foreground uppercase">Valor</th>
              <th className="text-right px-4 py-3 text-xs font-semibold text-muted-foreground uppercase hidden md:table-cell">Saldo</th>
              <th className="text-left px-4 py-3 text-xs font-semibold text-muted-foreground uppercase hidden md:table-cell">Obs.</th>
            </tr>
          </thead>
          <tbody>
            {loading ? (
              <tr><td colSpan={5} className="text-center py-12 text-muted-foreground">Carregando...</td></tr>
            ) : movsFiltradas.length === 0 ? (
              <tr><td colSpan={5} className="text-center py-12 text-muted-foreground">Nenhuma movimentação encontrada</td></tr>
            ) : movsFiltradas.map((mov, idx) => (
              <tr key={mov.id} className="border-t border-border hover:bg-muted/20">
                <td className="px-4 py-3">{format(new Date(mov.data), 'dd/MM/yyyy')}</td>
                <td className="px-4 py-3 font-medium">{mov.descricao}</td>
                <td className={`px-4 py-3 text-right font-semibold ${mov.tipo === 'entrada' ? 'text-green-700' : 'text-red-600'}`}>
                  {mov.tipo === 'entrada' ? '+' : '-'}{fmt(mov.valor)}
                </td>
                <td className="px-4 py-3 text-right font-semibold hidden md:table-cell">{fmt(mov.saldo_posterior || 0)}</td>
                <td className="px-4 py-3 text-muted-foreground text-xs hidden md:table-cell">{mov.observacao || '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div className="bg-blue-50 border border-blue-200 rounded-lg p-4">
        <p className="text-sm text-blue-900">
          <strong>Informação:</strong> As movimentações são registradas automaticamente quando você cadastra lançamentos financeiros vinculados a uma conta bancária.
        </p>
      </div>
    </div>
  );
}

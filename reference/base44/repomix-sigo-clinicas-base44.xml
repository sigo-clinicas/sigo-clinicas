import { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { Plus, Edit2, Trash2, ClipboardList, ToggleLeft, ToggleRight, Link2, Copy, CheckCircle2 } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import FormularioAnamneseModal from '@/components/anamnese/FormularioAnamneseModal';

function gerarToken() {
  return crypto.randomUUID().replace(/-/g, '').slice(0, 24);
}

function getLinkPublico(token) {
  return `${window.location.origin}/anamnese/${token}`;
}

export default function FormulariosAnamnese() {
  const [formularios, setFormularios] = useState([]);
  const [pacientes, setPacientes] = useState([]);
  const [loading, setLoading] = useState(true);
  const [modalOpen, setModalOpen] = useState(false);
  const [selecionado, setSelecionado] = useState(null);

  // Para gerar link
  const [formularioSel, setFormularioSel] = useState('');
  const [pacienteSel, setPacienteSel] = useState('');
  const [enviando, setEnviando] = useState(false);
  const [linkGerado, setLinkGerado] = useState('');
  const [copiado, setCopiado] = useState(false);

  useEffect(() => { load(); }, []);

  async function load() {
    const [f, p] = await Promise.all([
      base44.entities.FormularioAnamnese.list('-created_date'),
      base44.entities.Paciente.list('nome', 300),
    ]);
    setFormularios(f);
    setPacientes(p.filter(x => x.ativo !== false));
    setLoading(false);
  }

  async function handleDelete(id) {
    if (!confirm('Excluir formulário?')) return;
    await base44.entities.FormularioAnamnese.delete(id);
    load();
  }

  async function toggleAtivo(f) {
    await base44.entities.FormularioAnamnese.update(f.id, { ativo: !f.ativo });
    load();
  }

  async function gerarLink() {
    if (!formularioSel) return alert('Selecione um formulário');
    if (!pacienteSel) return alert('Selecione um paciente');
    setEnviando(true);
    const form = formularios.find(f => f.id === formularioSel);
    const pac = pacientes.find(p => p.id === pacienteSel);
    const token = gerarToken();
    await base44.entities.RespostaAnamnese.create({
      paciente_id: pacienteSel,
      paciente_nome: pac?.nome || '',
      formulario_id: formularioSel,
      formulario_nome: form?.nome || '',
      respostas: [],
      status: 'pendente',
      token,
    });
    const link = getLinkPublico(token);
    setLinkGerado(link);
    setEnviando(false);
  }

  async function copiarLink() {
    await navigator.clipboard.writeText(linkGerado);
    setCopiado(true);
    setTimeout(() => setCopiado(false), 2000);
  }

  function novoLink() {
    setLinkGerado('');
    setFormularioSel('');
    setPacienteSel('');
  }

  return (
    <div className="p-6 space-y-6">
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-semibold">Formulários de Anamnese</h1>
          <p className="text-sm text-muted-foreground mt-0.5">Crie questionários e envie links para pacientes</p>
        </div>
        <Button onClick={() => { setSelecionado(null); setModalOpen(true); }} className="gap-1.5">
          <Plus className="w-4 h-4" /> Novo Formulário
        </Button>
      </div>

      {/* Seção Gerar Link */}
      <div className="bg-card border border-border rounded-xl p-5 space-y-4">
        <h2 className="text-sm font-semibold flex items-center gap-2">
          <Link2 className="w-4 h-4 text-primary" />
          Enviar formulário para paciente
        </h2>

        {linkGerado ? (
          <div className="space-y-3">
            <p className="text-sm text-muted-foreground">Link gerado com sucesso! Copie e envie ao paciente:</p>
            <div className="flex gap-2">
              <div className="flex-1 bg-muted rounded-lg px-3 py-2 text-xs text-foreground break-all font-mono border border-border">
                {linkGerado}
              </div>
              <Button onClick={copiarLink} variant={copiado ? 'default' : 'outline'} size="sm" className="gap-1.5 shrink-0">
                {copiado ? <CheckCircle2 className="w-3.5 h-3.5" /> : <Copy className="w-3.5 h-3.5" />}
                {copiado ? 'Copiado!' : 'Copiar'}
              </Button>
            </div>
            <button onClick={novoLink} className="text-xs text-primary hover:underline">Gerar outro link</button>
          </div>
        ) : (
          <div className="grid grid-cols-1 sm:grid-cols-3 gap-3 items-end">
            <div className="space-y-1.5">
              <label className="text-xs font-medium text-muted-foreground">Paciente</label>
              <Select value={pacienteSel} onValueChange={setPacienteSel}>
                <SelectTrigger>
                  <SelectValue placeholder="Selecionar paciente..." />
                </SelectTrigger>
                <SelectContent className="max-h-60">
                  {pacientes.map(p => (
                    <SelectItem key={p.id} value={p.id}>{p.nome}</SelectItem>
                  ))}
                </SelectContent>
              </Select>
            </div>
            <div className="space-y-1.5">
              <label className="text-xs font-medium text-muted-foreground">Formulário</label>
              <Select value={formularioSel} onValueChange={setFormularioSel}>
                <SelectTrigger>
                  <SelectValue placeholder="Selecionar formulário..." />
                </SelectTrigger>
                <SelectContent>
                  {formularios.filter(f => f.ativo).map(f => (
                    <SelectItem key={f.id} value={f.id}>{f.nome}</SelectItem>
                  ))}
                </SelectContent>
              </Select>
            </div>
            <Button onClick={gerarLink} disabled={enviando || !formularioSel || !pacienteSel} className="gap-1.5">
              <Link2 className="w-4 h-4" />
              {enviando ? 'Gerando...' : 'Gerar link'}
            </Button>
          </div>
        )}
      </div>

      {/* Lista de Formulários */}
      {loading ? (
        <p className="text-muted-foreground">Carregando...</p>
      ) : formularios.length === 0 ? (
        <div className="text-center py-20 text-muted-foreground">
          <ClipboardList className="w-12 h-12 mx-auto mb-3 opacity-30" />
          <p>Nenhum formulário criado ainda.</p>
        </div>
      ) : (
        <div className="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {formularios.map(f => (
            <div key={f.id} className="bg-card border border-border rounded-xl p-5 space-y-3">
              <div className="flex items-start justify-between gap-2">
                <div className="flex-1 min-w-0">
                  <h3 className="font-semibold truncate">{f.nome}</h3>
                  {f.descricao && <p className="text-sm text-muted-foreground mt-0.5 line-clamp-2">{f.descricao}</p>}
                </div>
                <span className={`px-2 py-0.5 rounded-full text-xs font-medium shrink-0 ${f.ativo ? 'bg-green-100 text-green-700' : 'bg-muted text-muted-foreground'}`}>
                  {f.ativo ? 'Ativo' : 'Inativo'}
                </span>
              </div>
              <p className="text-xs text-muted-foreground">{(f.perguntas || []).length} pergunta(s)</p>
              <div className="flex items-center gap-2 pt-1 border-t border-border">
                <Button size="sm" variant="ghost" className="gap-1.5 flex-1" onClick={() => { setSelecionado(f); setModalOpen(true); }}>
                  <Edit2 className="w-3.5 h-3.5" /> Editar
                </Button>
                <button onClick={() => toggleAtivo(f)} className="p-1.5 rounded hover:bg-muted text-muted-foreground transition-colors" title={f.ativo ? 'Desativar' : 'Ativar'}>
                  {f.ativo ? <ToggleRight className="w-4 h-4 text-green-600" /> : <ToggleLeft className="w-4 h-4" />}
                </button>
                <button onClick={() => handleDelete(f.id)} className="p-1.5 rounded hover:bg-red-50 text-muted-foreground hover:text-red-600 transition-colors">
                  <Trash2 className="w-3.5 h-3.5" />
                </button>
              </div>
            </div>
          ))}
        </div>
      )}

      {modalOpen && (
        <FormularioAnamneseModal
          formulario={selecionado}
          onClose={() => setModalOpen(false)}
          onSaved={() => { setModalOpen(false); load(); }}
        />
      )}
    </div>
  );
}

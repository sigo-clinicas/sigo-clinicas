<file path="base44/functions/anamnesePublica/entry.ts">
import { createClientFromRequest } from 'npm:@base44/sdk@0.8.25';

Deno.serve(async (req) => {
  try {
    const base44 = createClientFromRequest(req);
    const body = await req.json();
    const { action, token, respostas } = body;

    if (action === 'get') {
      // Buscar a ficha pelo token (acesso público via service role)
      const lista = await base44.asServiceRole.entities.RespostaAnamnese.filter({ token });
      if (!lista || lista.length === 0) {
        return Response.json({ error: 'not_found' }, { status: 404 });
      }
      const r = lista[0];

      // Buscar o formulário
      const forms = await base44.asServiceRole.entities.FormularioAnamnese.filter({ id: r.formulario_id });
      return Response.json({ resposta: r, formulario: forms[0] || null });

    } else if (action === 'submit') {
      // Salvar respostas (acesso público via service role)
      const lista = await base44.asServiceRole.entities.RespostaAnamnese.filter({ token });
      if (!lista || lista.length === 0) {
        return Response.json({ error: 'not_found' }, { status: 404 });
      }
      const r = lista[0];
      if (r.status === 'preenchido') {
        return Response.json({ error: 'already_filled' }, { status: 400 });
      }
      await base44.asServiceRole.entities.RespostaAnamnese.update(r.id, {
        respostas,
        status: 'preenchido',
        data_preenchimento: new Date().toISOString(),
      });
      return Response.json({ ok: true });

    } else {
      return Response.json({ error: 'invalid_action' }, { status: 400 });
    }
  } catch (error) {
    return Response.json({ error: error.message }, { status: 500 });
  }
});
</file>


# =============================================================================
# Sigo Clínicas — variáveis de ambiente (copie para .env.local e preencha)
# NUNCA commitar .env*; produção usa Vercel/Supabase secrets.
# =============================================================================

# Projeto Supabase (região sa-east-1). Local dev: valores do `supabase start`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SOMENTE servidor (Server Actions/Route Handlers/Edge Functions).
# Jamais prefixar com NEXT_PUBLIC_. Jamais usar no browser.
SUPABASE_SERVICE_ROLE_KEY=

# E-mail transacional (Resend) — agendamento, senha, anamnese
RESEND_API_KEY=

# --- Supabase CLI (tooling de deploy — NÃO é lido pelo app em runtime) ---
# Ref do projeto remoto (Sigo Clínicas em sa-east-1). Fixo, não é segredo.
SUPABASE_PROJECT_REF=xbnveoshbqtekctzwnur
# Senha do banco do projeto remoto: Dashboard > Project Settings > Database >
# "Database password". Usada por `supabase link` / `supabase db push`.
# É segredo — só no ambiente/tooling do servidor, NUNCA no browser.
SUPABASE_DB_PASSWORD=

# Usado pelos testes de policy RLS (tests/rls) contra o Supabase local
SUPABASE_TEST_URL=http://127.0.0.1:54321
SUPABASE_TEST_ANON_KEY=
SUPABASE_TEST_SERVICE_ROLE_KEY=

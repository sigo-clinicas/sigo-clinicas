# =============================================================================
# Sigo Clínicas — variáveis de ambiente (copie para .env.local e preencha)
# NUNCA commitar .env*; produção usa Vercel/Supabase secrets.
# =============================================================================
#
# PRECEDÊNCIA (Next carrega ".env.local" DEPOIS de ".env" → .env.local VENCE):
#   • .env         → aponta para PRODUÇÃO (https://xbnveoshbqtekctzwnur.supabase.co)
#   • .env.local   → override para o Supabase LOCAL (http://127.0.0.1:54321),
#                    usado só por quem roda `supabase start` (precisa de Docker).
#
# Alternar o alvo do `npm run dev` (ambos os arquivos são git-ignored):
#   → usar PRODUÇÃO:  renomeie/remova o .env.local (ex.: `.env.local` → `.env.local.off`)
#                     para o .env (prod) valer. NÃO deixe o .env.local apontando
#                     p/ 127.0.0.1 se o stack local não estiver de pé (dá
#                     ECONNREFUSED / "fetch failed" no login e nas páginas).
#   → usar LOCAL:     restaure o .env.local (127.0.0.1:54321 + anon local) e rode
#                     `supabase start` antes.

# Projeto Supabase (região sa-east-1). Local dev: valores do `supabase start`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SOMENTE servidor (Server Actions/Route Handlers/Edge Functions).
# Jamais prefixar com NEXT_PUBLIC_. Jamais usar no browser.
SUPABASE_SERVICE_ROLE_KEY=

# E-mail transacional (Resend) — agendamento, senha, anamnese
RESEND_API_KEY=

# --- Hardening Fase 1 (S4-6) — CORS dos endpoints públicos ---
# Origens liberadas p/ /api/publico/* (agendamento, lead). CSV: sem espaço.
# Produção: "https://app.sigoclinicas.com,https://sigoclinicas.com".
# VAZIO = dev (reflete a origem). NUNCA usar "*".
PUBLIC_ALLOWED_ORIGINS=
# Idem para a Edge Function de anamnese (secret do Supabase, não do Next):
# `supabase secrets set ANAMNESE_ALLOWED_ORIGINS="https://app.sigoclinicas.com"`.

# --- Supabase CLI (tooling de deploy — NÃO é lido pelo app em runtime) ---
# Ref do projeto remoto (Sigo Clínicas em sa-east-1). Fixo, não é segredo.
SUPABASE_PROJECT_REF=xbnveoshbqtekctzwnur
# Senha do banco do projeto remoto: Dashboard > Project Settings > Database >
# "Database password". Usada por `supabase link` / `supabase db push`.
# É segredo — só no ambiente/tooling do servidor, NUNCA no browser.
SUPABASE_DB_PASSWORD=

# Usado pelos testes de policy RLS (tests/rls) contra o Supabase local
SUPABASE_TEST_URL=http://127.0.0.1:54321
SUPABASE_TEST_ANON_KEY=
SUPABASE_TEST_SERVICE_ROLE_KEY=
